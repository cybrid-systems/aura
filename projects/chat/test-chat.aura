;; === test-chat.aura — chat 功能测试 ===
;; 注意: send/recv 需要 --serve 模式
;; 本测试只验证包装函数逻辑，不触发送/收原语

(define passed 0)
(define failed 0)

(define (assert-equal actual expected msg)
  (if (equal? actual expected)
      (begin
        (set! passed (+ passed 1))
        (display "[PASS] ") (display msg) (newline))
      (begin
        (set! failed (+ failed 1))
        (display "[FAIL] ") (display msg)
        (display " — expected: ") (display expected)
        (display ", got: ") (display actual)
        (newline))))

(display "=== chat.aura tests ===") (newline)

;; chat.aura 通过 pipe 或 (load) 预加载，此处不再重复 load

;; start
(assert-equal (chat-start "alice") "OK" "chat-start returns OK")
(assert-equal *chat-nick* "alice" "chat-nick set correctly")

;; send without nick
(set! *chat-nick* #f)
(assert-equal (chat-send "bob" "hi") #f "chat-send without nick returns #f")
(set! *chat-nick* "alice")

(newline)
(display "=== Results: ") (display passed) (display " passed, ")
(display failed) (display " failed") (newline)
