;; === test-kv.aura — kv 存储 V2 测试（含 TTL） ===
;; 用法: (load "projects/kv/kv.aura") (load "projects/kv/test-kv.aura")
;;   或: cat kv.aura test-kv.aura | ./build/aura

(define passed 0)
(define failed 0)

(define (assert-equal actual expected msg)
  (if (equal? actual expected)
      (begin
        (set! passed (+ passed 1))
        (display "[PASS] ") (display msg) (newline))
      (begin
        (set! failed (+ failed 1))
        (display "[FAIL] ") (display msg)
        (display " — expected: ") (display expected)
        (display ", got: ") (display actual)
        (newline))))

(display "=== kv.aura V2 tests (with TTL) ===") (newline)

;; ── 基础操作 ──
(assert-equal (kv-set "name" "Aura") "OK" "kv-set returns OK")
(assert-equal (kv-get "name") "Aura" "kv-get returns stored value")
(assert-equal (kv-get "nonexistent") (void) "kv-get missing key returns void")
(assert-equal (kv-exists? "name") #t "kv-exists? existing key")
(assert-equal (kv-exists? "nope") #f "kv-exists? missing key")
(assert-equal (kv-del "name") "OK" "kv-del returns OK")
(assert-equal (kv-exists? "name") #f "kv-exists? after del")
(assert-equal (kv-get "name") (void) "kv-get after del returns void")

;; ── Incr ──
(assert-equal (kv-incr "counter") 1 "kv-incr starts at 1")
(assert-equal (kv-incr "counter") 2 "kv-incr increments to 2")
(assert-equal (kv-incr "counter") 3 "kv-incr increments to 3")
(assert-equal (kv-get "counter") 3 "kv-get after incr")
(kv-set "str" "hello")
(assert-equal (kv-incr "str") "ERR wrong type" "kv-incr on non-int returns error")
(kv-del "str")

;; ── String values ──
(assert-equal (kv-set "x" "hello") "OK" "kv-set string value")
(assert-equal (kv-get "x") "hello" "kv-get string value")

;; ── Flush ──
(assert-equal (kv-flush) "OK" "kv-flush returns OK")
(assert-equal (kv-length) 0 "kv-length after flush is 0")
(assert-equal (kv-exists? "counter") #f "kv-exists? after flush")

;; ── TTL Tests ──

;; TTL 非过期键
(kv-set "persistent" "stays")
(assert-equal (kv-ttl "persistent") -1 "kv-ttl of key without TTL is -1")
(assert-equal (kv-get "persistent") "stays" "kv-get on key with no TTL")

;; TTL 正常键（30 秒）
(kv-set-with-ttl "temp" "will-disappear" 30)
(assert-equal (kv-get "temp") "will-disappear" "kv-set-with-ttl stores value")
(assert-equal (kv-exists? "temp") #t "kv-exists? with TTL returns true (not expired)")
(assert-equal (kv-ttl "temp") 30 "kv-ttl of 30s key is 30")
(assert-equal (kv-persist "temp") "OK" "kv-persist removes TTL")
(assert-equal (kv-ttl "temp") -1 "kv-ttl after persist is -1")

;; TTL 过期键（0 秒 = 立即过期）
(kv-set-with-ttl "insta" "gone" 0)
(assert-equal (kv-get "insta") (void) "kv-get of expired key returns void")
(assert-equal (kv-exists? "insta") #f "kv-exists? of expired key is false")

;; TTL 过期后 incr 应从 1 开始
(kv-set-with-ttl "counter2" 999 0)
(assert-equal (kv-incr "counter2") 1 "kv-incr on expired key starts at 1")

;; kv-set 清理旧 TTL：过期后重新 set 再去 incr
(kv-set-with-ttl "c" 0 0)  ;; 立即过期
(kv-set "c" 10)            ;; kv-set 会清理旧 TTL
(assert-equal (kv-incr "c") 11 "kv-set after expiry clears TTL, incr works")

;; kv-expire 设置 TTL
(kv-set "e" "val")
(assert-equal (kv-expire "e" 60) "OK" "kv-expire sets TTL on existing key")
(assert-equal (kv-ttl "e") 60 "kv-ttl after kv-expire")

;; kv-expire 不存在的键
(assert-equal (kv-expire "no-such-key" 60) "ERR no such key" "kv-expire on missing key")

;; kv-persist 不存在的键
(assert-equal (kv-persist "no-such-key") "ERR no such key" "kv-persist on missing key")

;; kv-exists? after expire set
(assert-equal (kv-exists? "e") #t "kv-exists? after kv-expire")

;; kv-ttl 不存在的键 = -2
(assert-equal (kv-ttl "no-such-key") -2 "kv-ttl of missing key is -2")

;; kv-ttl 过期键 = -2
(kv-set-with-ttl "dead" "gone" 0)
(assert-equal (kv-ttl "dead") -2 "kv-ttl of expired key is -2")

;; kv-keys 排除过期键（member 现用 equal? 比较，字符串内容正确匹配）
(kv-set "keep" "stay")
(kv-set-with-ttl "expire-soon" "bye" 0)  ;; 立即过期
(assert-equal (not (not (member "keep" (kv-keys)))) #t "kv-keys includes unexpired key")
(assert-equal (not (not (member "expire-soon" (kv-keys)))) #f "kv-keys excludes expired key")
(assert-equal (not (not (member "dead" (kv-keys)))) #f "kv-keys excludes expired key (dead)")

;; kv-length 不计过期键
(assert-equal (> (kv-length) 0) #t "kv-length > 0 (at least 'keep' and 'e')")

;; 清理
(kv-flush)

(newline)
(display "=== Results: ") (display passed) (display " passed, ")
(display failed) (display " failed") (newline)
