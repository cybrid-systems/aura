  (tui:cell 10 6 "*" 16711680 0 0)
  (tui:cell 1 0 "S" 65280 0 1)
  (tui:cell 2 0 "n" 65280 0 1)
  (tui:cell 3 0 "a" 65280 0 1)
  (tui:cell 4 0 "k" 65280 0 1)
  (tui:cell 5 0 "e" 65280 0 1)
  (tui:present)
  (tui:shutdown)
  #t)

(snake-demo)
