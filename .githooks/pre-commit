#!/usr/bin/env bash
#
# Aura pre-commit hook — clang-format (C++) + ruff (Python) + docs regen.
#
# Why plan B (auto-fix + check) instead of plan A (check-only)?
#   - Today #637-#644 (6 issues) shipped with clang-format drift because the
#     commit gate never caught it. Auto-fix at commit time eliminates the
#     friction entirely.
#   - Pure whitespace/indent reflow — no semantic risk. `git restore <file>`
#     can always revert if a specific file is unhappy.
#   - The final --dry-run --Werror at the end is the same gate CI runs
#     (`workflows/ci.yml`), so local + CI behavior are identical.
#
# 2026-07-07 update: also run `ruff check --fix` and `ruff format` on staged
# Python files. The CI gate's `./build.py lint` was failing because the
# pre-commit hook only caught C++; Python lint drift slipped through. Same
# auto-fix + final-check pattern as clang-format below.
#
# 2026-07-07 (later) update: also run `./build.py docs` to regenerate
# `docs/generated/*.md` files. The CI gate's docs check was failing
# because adding/removing primitives didn't trigger docs regen. The
# generated files live in the repo, so any commit that adds a primitive
# (src/compiler/evaluator_primitives_*.cpp changes) MUST update
# docs/generated/primitives.md. Auto-fix regenerates + re-stages.
#
# 2026-07-17 (Issue #1572): when tests/*.cpp is staged (add/mod/delete),
# regenerate docs/generated/test-registry.json via gen_test_registry.py
# and re-stage it. CI's gate → check_test_coverage already --checks the
# registry; without auto-regen, every new test_issue_* left a stale
# catalog and a red gate. Same auto-fix + --check pattern as docs.
#
# Flow:
#   1. Collect staged C++ files matching the same filter CI uses
#      (src|tests) + (\.(cpp|ixx|hh|h)$).
#   2. Collect staged Python files (\.py$).
#   3. Run `clang-format -i` on C++ files (auto-fix).
#   4. Run `ruff check --fix --unsafe-fixes` + `ruff format` on Python
#      files (auto-fix). Matches `./build.py lint --fix`.
#   5. If src/ changed (likely added/removed/renamed primitives),
#      run `./build.py docs` to regen docs/generated/*.md, then
#      `git add` any modified generated files.
#   6. After the docs regen + re-stage, run `gen_docs.py --check` to
#      verify the working tree + index are now consistent with source.
#      If they're not, FAIL the commit. (Past #739/#740 slipped past
#      regen + re-stage into commits — --check catches that case.)
#   7. If tests/*.cpp staged (incl. deletes), regen test-registry.json
#      + git add, then gen_test_registry.py --check.
#   8. `git add` the modified C++/Python/generated files so the formatted
#      content is what gets committed (no separate "format" noise commit).
#   9. Final `clang-format --dry-run -Werror` and `ruff check` +
#      `ruff format --check` — belt-and-suspenders so the commit message
#      is honest even if auto-fix ever diverges from --check.
#
# Exit codes:
#   0 — all staged files clean (or no matching files staged)
#   1 — clang-format / ruff / build.py missing OR final check failed

set -euo pipefail

ROOT=$(git rev-parse --show-toplevel)

# Collect staged C++ files using the same filter the CI gate uses
# (`.github/workflows/ci.yml` line 64-66).
cpp_files=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(cpp|ixx|hh|h)$' \
    | grep -E '^(src|tests)/' \
    || true)

# Collect staged Python files.
py_files=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.py$' \
    || true)

# Collect staged files under src/ — triggers docs regen since
# primitive registration lives in src/compiler/evaluator_primitives_*.cpp.
src_files=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^src/' \
    || true)

# Collect staged test files — triggers the test-includes linter
# (Issue #1484) since bare `#include "X.h"` patterns only matter for
# test files (production includes use the subdir prefixes by convention).
test_files=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^tests/.*\.cpp$' \
    || true)

# Registry catalog tracks tests/test_*.cpp add/mod/delete (Issue #1572).
# Include D so removing a test drops it from test-registry.json.
test_registry_files=$(git diff --cached --name-only --diff-filter=ACMRD \
    | grep -E '^tests/.*\.cpp$' \
    || true)

# ── C++ (clang-format) ─────────────────────────────────────────────
if [ -n "$cpp_files" ]; then
    # Defensive: ensure clang-format is on PATH.
    if ! command -v clang-format >/dev/null 2>&1; then
        echo "❌ pre-commit: clang-format not found on PATH" >&2
        echo "   install clang-format (CI uses clang-format 22.1.7 from llvm.org)" >&2
        exit 1
    fi

    echo "pre-commit: clang-format -i on $(echo "$cpp_files" | wc -l) staged C++ file(s)..."
    echo "$cpp_files" | xargs clang-format -i

    # Re-stage so formatted content lands in this commit (same as ruff path).
    echo "$cpp_files" | xargs git add

    echo "pre-commit: clang-format --dry-run -Werror (staged files)..."
    echo "$cpp_files" | xargs clang-format --dry-run -Werror

    # Full-tree check — matches CI gate. Staged-only -i misses drift in
    # files that were not part of this commit (root cause of past CI reds).
    echo "pre-commit: clang-format full-tree --dry-run -Werror..."
    all_cpp=$(find "$ROOT/src" "$ROOT/tests" \
        \( -name '*.cpp' -o -name '*.ixx' -o -name '*.hh' -o -name '*.h' \) \
        2>/dev/null || true)
    if [ -n "$all_cpp" ]; then
        echo "$all_cpp" | xargs clang-format --dry-run -Werror
    fi
    echo "pre-commit: clang-format clean ✓"
fi

# ── Python (ruff check + format) ────────────────────────────────────
if [ -n "$py_files" ]; then
    # Defensive: ensure ruff is on PATH.
    if ! command -v ruff >/dev/null 2>&1; then
        echo "❌ pre-commit: ruff not found on PATH" >&2
        echo "   pip install ruff (matches CI requirements-dev.txt)" >&2
        exit 1
    fi

    # Step 1: ruff check --fix --unsafe-fixes (matches build.py lint --fix).
    # Restricted to the staged files only (don't re-lint the whole repo at
    # every commit — too slow).
    echo "pre-commit: ruff check --fix on $(echo "$py_files" | wc -l) staged Python file(s)..."
    echo "$py_files" | xargs ruff check --fix --unsafe-fixes

    # Step 2: ruff format (auto-format).
    echo "pre-commit: ruff format on $(echo "$py_files" | wc -l) staged Python file(s)..."
    echo "$py_files" | xargs ruff format

    # Step 3: re-stage so the fixed content lands in this commit.
    echo "$py_files" | xargs git add

    # Step 4: final check (matches CI `./build.py lint`).
    echo "pre-commit: ruff check (final check)..."
    echo "$py_files" | xargs ruff check
    echo "pre-commit: ruff format --check (final check)..."
    echo "$py_files" | xargs ruff format --check
    echo "pre-commit: ruff clean ✓"
fi

# ── Docs regen (docs/generated/*.md) ───────────────────────────────
# Triggered when src/ has staged changes (primitive registration
# lives there). The regen is fast (~2s) and matches the CI gate's
# `./build.py docs` check exactly. Skip if no src/ changes.
if [ -n "$src_files" ]; then
    if ! command -v python3 >/dev/null 2>&1; then
        echo "❌ pre-commit: python3 not found on PATH" >&2
        exit 1
    fi

    echo "pre-commit: regenerating docs (src/ has staged changes)..."
    if ! python3 "$ROOT/build.py" docs > /tmp/docs_regen.log 2>&1; then
        echo "❌ pre-commit: ./build.py docs failed. See /tmp/docs_regen.log" >&2
        cat /tmp/docs_regen.log >&2
        exit 1
    fi

    # Re-stage any docs/generated/ files that were updated.
    docs_changed=$(git diff --name-only docs/generated/ || true)
    if [ -n "$docs_changed" ]; then
        echo "pre-commit: re-staging updated docs ($(echo "$docs_changed" | wc -l) file(s))..."
        echo "$docs_changed" | xargs git add
    fi
    echo "pre-commit: docs regen clean ✓"

    # Belt-and-suspenders verify: after regen + re-stage, run
    # gen_docs.py --check and FAIL the commit if docs are still
    # stale. This catches edge cases that slipped past regen +
    # re-stage on past commits (see history for #739 / #740
    # where committed docs lagged source by 2 primitives despite
    # the hook firing — likely --no-verify was used or the index
    # already had a stale snapshot). Without this, CI's
    # `./build.py gate → docs --check` is the only safety net
    # and the bad commit is already in history by then.
    if ! python3 "$ROOT/scripts/gen_docs.py" --check > /tmp/docs_check.log 2>&1; then
        echo "❌ pre-commit: docs still stale after regen (gen_docs.py --check failed)" >&2
        cat /tmp/docs_check.log >&2
        echo "   Hint: run ./build.py docs manually, then git add docs/generated/" >&2
        exit 1
    fi
    echo "pre-commit: docs verify (--check) clean ✓"
fi

# ── Test includes linter (Issue #1484) ─────────────────────────────
# Lints tests/*.cpp for bare `#include "X.h"` patterns where the header
# lives under src/compiler/ or src/core/ but the include doesn't use the
# subdir prefix. Runs as a final gate (parallel to the docs regen +
# verify pattern above). Skip if no tests/ changes. Discovered during
# #1459 close-verify (9 broken files on main were fixed at commit
# 313c530d); this linter prevents future regressions.
if [ -n "$test_files" ]; then
    if ! command -v python3 >/dev/null 2>&1; then
        echo "❌ pre-commit: python3 not found on PATH" >&2
        exit 1
    fi

    echo "pre-commit: running test includes linter (tests/ has staged changes)..."
    if ! python3 "$ROOT/scripts/check_test_includes.py" > /tmp/test_includes_check.log 2>&1; then
        echo "❌ pre-commit: test includes linter failed. See /tmp/test_includes_check.log" >&2
        cat /tmp/test_includes_check.log >&2
        echo "   Hint: run python3 scripts/check_test_includes.py to see which include is broken." >&2
        exit 1
    fi
    echo "pre-commit: test includes linter clean ✓"
fi

# ── Test registry regen (Issue #1572) ──────────────────────────────
# When tests/*.cpp is staged (add/mod/rename/delete), regenerate the
# lightweight TestRegistry catalog so docs/generated/test-registry.json
# stays in sync with source. Without this, every new test_issue_* left
# a stale registry and failed `./build.py gate` (check_test_coverage).
# Pattern mirrors docs regen: write → git add → --check verify.
if [ -n "$test_registry_files" ]; then
    if ! command -v python3 >/dev/null 2>&1; then
        echo "❌ pre-commit: python3 not found on PATH" >&2
        exit 1
    fi

    echo "pre-commit: regenerating test-registry (tests/ has staged changes)..."
    if ! python3 "$ROOT/scripts/gen_test_registry.py" > /tmp/test_registry_regen.log 2>&1; then
        echo "❌ pre-commit: gen_test_registry.py failed. See /tmp/test_registry_regen.log" >&2
        cat /tmp/test_registry_regen.log >&2
        exit 1
    fi
    cat /tmp/test_registry_regen.log

    registry_path="docs/generated/test-registry.json"
    if [ -f "$ROOT/$registry_path" ]; then
        # Always re-stage so the regenerated content is in this commit
        # (even if git status is quiet — covers first-time adds).
        git add "$ROOT/$registry_path"
        echo "pre-commit: staged $registry_path"
    fi
    echo "pre-commit: test-registry regen clean ✓"

    if ! python3 "$ROOT/scripts/gen_test_registry.py" --check > /tmp/test_registry_check.log 2>&1; then
        echo "❌ pre-commit: test-registry still stale after regen (--check failed)" >&2
        cat /tmp/test_registry_check.log >&2
        echo "   Hint: run python3 scripts/gen_test_registry.py && git add $registry_path" >&2
        exit 1
    fi
    echo "pre-commit: test-registry verify (--check) clean ✓"
fi

# ── Aura philosophy guard: no docs/design/ in commits ─────────────
# Per Anqi 2026-07-19 directive — aura philosophy, AI-agent-developed
# repo, no per-issue plan docs in docs/design/. This guard prevents
# local commits from shipping docs/design/* files. The external
# mergebot is the source of docs/design/* re-additions on origin/main;
# this guard catches them at commit time so future agents don't
# propagate them. The CI workflow (`.github/workflows/ci.yml`) has the
# same guard for mergebot pushes that bypass this hook.
design_files=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^docs/design/' \
    || true)
if [ -n "$design_files" ]; then
    echo "❌ pre-commit: docs/design/ files staged — aura philosophy forbids per-issue plan docs" >&2
    echo "   Staged design files:" >&2
    echo "$design_files" | sed 's/^/     /' >&2
    echo "   Hint: git rm -rf --cached docs/design/ && rm -rf docs/design/" >&2
    exit 1
fi
echo "pre-commit: docs/design/ guard clean ✓"

# If neither C++ nor Python staged, exit 0 (nothing to format).
exit 0