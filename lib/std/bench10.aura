(define t107 (list "edsl-optimize-fitness" "synthesize:optimize with benchmark-driven fitness scores" (list "pair") "" (list "--- Benchmark-driven fitness ---" "(set-code \"(define (inc x) (+ x 1))\")" "(synthesize:optimize \"inc\" :population 3 :generations 1)")))
(define t108 (list "edsl-optimize-multiarg" "synthesize:optimize on multi-arg function" (list "pair") "" (list "--- Multi-arg optimize ---" "(set-code \"(define (add x y) (+ x y))\")" "(synthesize:optimize \"add\" :population 3 :generations 1)")))
(define t109 (list "edsl-pipeline-basic" "Use synthesize:pipeline with template and set-code steps" (list "Complete") "" (list "(require \"std/pipeline\" all:)" "(set-code \"(begin)\")" "(synthesize:register-template \"add\" \"(define (add-{n} x y) (+ x y))\" \"n\")" "(synthesize:pipeline \"test\" (synthesize:fill \"add\" \"nums\"))" "(display \"Pipeline complete\")")))
(define t110 (list "edsl-query" "Use set-code + (current-source) to load and display code" (list "g") "" (list "--- EDSL set-code + current-source ---" ";; set-code loads code into workspace" "(set-code \"(define (g x) (* x 2))\")" ";; current-source returns source code string" "(display (current-source))")))
