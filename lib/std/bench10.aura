(define t112 (list "edsl-rule-basic" "Use rule:define and rule:apply-all to normalize code" (list "rule") "" (list "(require \"std/rule\" all:)" "(rule:define 'tr :pattern \"(+ 1 1)\" :replace \"2\")" "(display (rule:list))")))
(define t113 (list "edsl-rule" "Use rule:define and rule:apply-all" (list "rule") "" (list "--- Rule normalize ---" "(require \"std/rule\" all:)" "(rule:define 'test-rule :pattern \"(+ 1 1)\" :replace \"2\")" "(display (rule:apply-all))")))
(define t114 (list "edsl-set-code" "Use set-code to define a function, then query:find to verify it's loaded" (list "Define") "" (list "--- EDSL set-code + query ---" ";; Step 1: Load code into AST" "(set-code \"(define (f x) (+ x 1))\")" ";; Step 2: Query the AST to verify" "(display (query:node-type \"Define\"))")))
(define t115 (list "edsl-snapshot-multi" "Take multiple snapshots and verify they persist" (list "v2") "" (list "(set-code \"(define x 1)\")" "(ast:snapshot 'v1)" "(set-code \"(define x 2)\")" "(ast:snapshot 'v2)" "(ast:list-snapshots)")))
(define t116 (list "edsl-snapshot" "Use ast:snapshot then mutate then ast:restore to revert changes" (list "g") "" (list "--- EDSL snapshot/restore ---" "(set-code \"(define (g x) (* x 2))\")" "(define sid (ast:snapshot \"before\"))" "(mutate:rebind \"g\" \"(lambda (x) (+ x 1))\" \"test\")" "(ast:restore sid)" "(display (car (query:def-use \"g\")))")))
(define t117 (list "edsl-splice-wrap" "Use mutate:splice and mutate:wrap for structural AST editing" (list "insert") "" (list "--- Higher-order AST transforms ---" "(set-code \"(begin (display 1) (display 3))\")" "(mutate:splice 0 1 \"(display 2)\" \"insert\")" "(display (current-source))")))
(define t118 (list "edsl-summary" "Use ast:summary and compile:status to inspect workspace state" (list "total") "" (list "--- EDSL summary/status ---" "(set-code \"(define (g x) (+ x 1))\")" "(display (ast:summary))")))
(define t119 (list "edsl-synthesize-pipeline" "Use synthesize:pipeline to chain multiple steps" (list "Complete") "" (list "--- Pipeline strategy ---" "(require \"std/pipeline\" all:)" "(set-code \"(begin)\")" "(synthesize:register-template \"add\"" "\"(define (add-{name} x y) (+ x y))\" \"name\")" "(synthesize:pipeline \"test\"" "(synthesize:fill \"add\" \"nums\"))" "(display \"Pipeline complete\")")))
(define t120 (list "edsl-synthesize-template" "Use synthesize:register-template and synthesize:fill" (list "handle") "" (list "--- Template strategy ---" "(set-code \"(begin)\")" "(synthesize:register-template \"handler\"" "\"(define (handle-{name} req) (display req))\" \"name\")" "(synthesize:fill \"handler\" \"test\")" "(display (current-source))")))
(define t121 (list "edsl-workspace-cow" "Create child workspace, switch, and verify COW isolation" (list "iso") "" (list "(set-code \"(define x 1)\")" "(define ws (workspace:create 'test))" "(workspace:switch ws)" "(set-code \"(define y 2)\")" "(workspace:switch 0)" "(display (car (car (query:def-use 'x))))")))
(define t122 (list "edsl-workspace" "Use workspace:create, switch, and merge to isolate changes" (list "ws") "" (list "--- Workspace layering ---" "(set-code \"(define (g x) (+ x 1))\")" "(define ws (workspace:create \"sandbox\"))" "(workspace:switch ws)" "(mutate:rebind \"g\" \"(lambda (x) (* x 2))\" \"mutate\")" "(workspace:switch 0)" "(workspace:merge ws)" "(display (car (query:def-use \"g\")))")))
