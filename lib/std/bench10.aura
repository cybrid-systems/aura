(define t92 (list "is-anagram" "Write (anagram? a b) that checks if two strings are anagrams using hash, test with \"listen\" and \"silent\"" (list "#t") "std/iter" (list "--- WORKING Aura anagram check ---" "(require std/hash all:)" "(for-each (lambda (c) (hash-set! h c (+ 1 (if (hash-has-key? h c) (hash-ref h c) 0)))) (string->list s))" "h))" "(and (= (hash-length a) (hash-length b))" "(if (null? keys) #t" "(and (hash-has-key? b (car keys))" "(= (hash-ref a (car keys)) (hash-ref b (car keys)))" "(loop (cdr keys))))))))" "(display (anagram? \"listen\" \"silent\"))")))
(define t93 (list "string-reverse" "Write (str-rev s) that reverses a string using list->string and string->list" (list "!dlroW olleH") "std/list" (list "--- WORKING Aura string reverse ---" "(list->string (reverse (string->list s))))" "(display (str-rev \"Hello World!\"))" "--- NOTE ---" "reverse is in std/list, load with (require std/list all:)")))
(define t94 (list "string-split-join" "Use std/string to split \"a,b,c\" by \",\" then join with \"-\"" (list "a-b-c") "std/string" (list "--- WORKING Aura string split/join ---" "(require std/string all:)" "(display (string-join (string-split \"a,b,c\" \",\") \"-\"))")))
(define t95 (list "edsl-colony" "Use colony:search to find a working local mutation when output is wrong" (list "42") "ant" (list "--- EDSL colony search ---" ";; Use set-code + colony:search to find a fix" "(set-code \"(define (foo) (* 6 7))\")" ";; colony:search tries local mutations automatically" "(colony:search \"foo\" \"(lambda () (* 6 7))\")" "(display (foo))")))
(define t96 (list "edsl-defuse-cross" "Use query:def-use to trace cross-scope variable references" (list "outer") "" (list "(set-code \"(define outer 42)(define (f n) (+ outer n))\")" "(display (car (query:def-use 'outer)))")))
(define t97 (list "edsl-defuse-multi" "Use query:def-use with multiple functions in workspace" (list "2") "" (list "(set-code \"(define (f x) (+ x 1))(define (g y) (* y 2))\")" "(display (+ (length (car (query:def-use 'f)))(length (car (query:def-use 'g)))))")))
(define t98 (list "edsl-defuse" "Use set-code + query:def-use to find a function's definition and use points" (list "g") "" (list "--- EDSL def-use analysis ---" ";; set-code loads code into workspace" "(set-code \"(define (g x) (+ x 1))\")" ";; query:def-use returns ((def-node-id ...) . (use-node-id ...))" "(display (car (query:def-use \"g\")))")))
(define t99 (list "edsl-evolve" "Use synthesize:optimize for genetic optimization" (list "pair") "" (list "--- Genetic optimize ---" "(set-code \"(define (g x) (+ x 100))\")" "(display (synthesize:optimize \"g\" :population 3 :generations 1))")))
(define t100 (list "edsl-find-pattern" "Use set-code to load code, then query the AST using query:node-type" (list "Define") "edsl" (list "--- EDSL set-code + query:node-type ---" ";; Load code into workspace (set-code takes a STRING argument)" "(set-code \"(define (double x) (* x 2))\")" ";; Query the AST for Define nodes" "(display (query:node-type \"Define\"))")))
(define t101 (list "edsl-intend-basic" "Use intend to generate code with generator/verifier cycle" (list "intend") "" (list "(define (gen g) '(define (f x) (+ x 1)))" "(define (ver code) '#t)" "(intend 'test gen ver)" "(display 'intend-complete)")))
(define t102 (list "edsl-messaging" "Use my-id, session-active?, and mailbox-count" (list "session") "" (list "--- Inter-agent messaging ---" "(display (my-id))" "(display (session-active? \"default\"))" "(display (mailbox-count))")))
(define t103 (list "edsl-mutate-chain" "Use set-code + mutate:rebind to change a function's behavior, then eval-current" (list "42") "edsl" (list "--- EDSL set-code + mutate:rebind + eval-current ---" ";; Step 1: Load a function" "(set-code \"(define (f) (* 6 7))\")" ";; Step 2: Rebind to a simpler body" "(mutate:rebind \"f\" \"(lambda () 42)\")" ";; Step 3: Evaluate the current workspace" "(display (f))")))
(define t104 (list "edsl-mutate" "Use set-code + mutate:rebind to modify a function definition" (list "3") "" (list "--- EDSL set-code + mutate ---" ";; Step 1: Load initial code" "(set-code \"(define (h x) (+ x 1))\")" ";; Step 2: Rebind to change body to (+ x 2)" "(mutate:rebind \"h\" \"(lambda (x) (+ x 2))\")" ";; Step 3: Evaluate to see the result" "(display (h 1))")))
(define t105 (list "edsl-mutation-rollback" "EDSL mutation with rollback — apply mutation, then query to verify" (list "20") "" (list )))
