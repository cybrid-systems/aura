(define t36 (list "merge-sort" "Write merge sort using std/list" (list "1" "2" "3" "4" "5") "std/list" (list "--- CRITICAL: END with (display ...) ---" "Aura outputs #<procedure> when you JUST define a function." "You MUST call it with (display ...) to see the result!" "--- WORKING Aura merge sort ---" "(require std/list all:)" "(define (merge a b)" "(cond" "((null? a) b)" "((null? b) a)" "((< (car a) (car b)) (cons (car a) (merge (cdr a) b)))" "(else (cons (car b) (merge a (cdr b))))))" "(define (merge-sort lst)" "(let ((mid (quotient (length lst) 2)))" "(if (or (null? lst) (null? (cdr lst))) lst" "(merge (merge-sort (take mid lst)) (merge-sort (drop mid lst))))))" "(display (merge-sort (list 3 1 4 1 5 9 2 6)))")))
