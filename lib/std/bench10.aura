(define t11 (list "word-freq" "Write word frequency counter using hash" (list "hello" "world" "hash") "std/string" (list "--- WORKING Aura word frequency ---" "CRITICAL: Aura hash API uses DIFFERENT names than Scheme/Racket!" "hash-set! (not hash-set), hash-ref (same), hash-has-key? (not has-key?)," "hash-keys (not hash-map), make-hash (not make-hash)" "(require std/string all:)" "(if (null? ws) h" "(if (hash-has-key? h w)" "(loop (cdr ws) (hash-set! h w (+ (hash-ref h w) 1)))" "(loop (cdr ws) (hash-set! h w 1))))))))" "; (display <hash>) shows <hash[N]>, NOT keys!" "; MUST use hash-keys to show words:" "(display (hash-keys (word-freq \"hello world hello\")))")))
