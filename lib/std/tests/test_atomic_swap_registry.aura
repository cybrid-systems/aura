; lib/std/tests/test_atomic_swap_registry.aura — Issue #1380
; Returns #t when multi-binding registry + drain works.

(require "std/atomic-swap" all:)

(define (test-atomic-swap-registry)
  (let* ((r0 (make-registry))
         (b-a (make-binding "a" 0 "A0"))
         (b-b (make-binding "b" 0 "B0"))
         (r1 (registry-put (registry-put r0 b-a) b-b))
         (ids (registry-ids r1))
         (pend0 (pending-swaps r1))
         (b-a2 (swap-binding! b-a 2 "A2"))
         (b-b2 (swap-binding! b-b 3 "B3"))
         (r2 (registry-put (registry-put r1 b-a2) b-b2))
         (pend1 (pending-swaps r2))
         (dr (drain-pending-swaps! r2))
         (r3 (car dr))
         (any (cdr dr))
         (a3 (registry-ref r3 "a"))
         (b3 (registry-ref r3 "b"))
         (pend2 (pending-swaps r3))
         (dr2 (sync-registry! r3))
         (any2 (cdr dr2))
         (st (atomic-swap:stats r3)))
    (and (= (length ids) 2)
         (= (length pend0) 0)
         (= (length pend1) 2)
         any
         (= (binding-target-version a3) 2)
         (equal? (binding-artifact-id a3) "A2")
         (= (binding-target-version b3) 3)
         (equal? (binding-artifact-id b3) "B3")
         (= (length pend2) 0)
         (not any2)
         (= (car st) 0)
         (= (car (cdr st)) 2))))

(test-atomic-swap-registry)
