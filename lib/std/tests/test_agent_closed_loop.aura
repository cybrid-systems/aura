; lib/std/tests/test_agent_closed_loop.aura — Issue #1460
; Offline multi-round EDSL closed-loop: query + atomic-batch + decision metrics.
; Returns #t when all checks pass.

(require "std/agent" all:)

(agent:loop-stats-reset!)

; AC2: decision metrics contract shape
(define m0 (agent:decision-metrics))
(define metrics-ok
  (and (hash? m0)
       (= (hash-ref m0 "schema") 1461)
       (string? (hash-ref m0 "recommendation"))))

; AC1/AC4: single closed-loop round
(define r1
  (agent:closed-loop-once
    :source "(define (f x) (+ x 1))"
    :rebind "f" "(lambda (x) (* x 2))"
    :summary "test-r1"))
(define ok1 (and (pair? r1) (equal? (car (car r1)) ":ok") (cdr (car r1))))
(define f-ok (= (f 21) 42))

; Multi-round via auto-grow
(agent:loop-stats-reset!)
(define ag
  (auto-grow "triple"
    :source "(define (g x) (+ x 1))"
    :rebind "g" "(lambda (x) (* x 3))"
    :max-tries 3))
(define g-ok (and (eq? ag #t) (= (g 7) 21)))

; Loop telemetry: query + atomic-batch + metrics
(define st (agent:loop-stats))
(define touched
  (and (> (hash-ref st "query-calls" 0) 0)
       (> (hash-ref st "atomic-batch-calls" 0) 0)
       (> (hash-ref st "metrics-calls" 0) 0)))

; edsl-fix path
(edsl-fix "quad" "(define (h x) (+ x 1))"
           :rebind "h" "(lambda (x) (* x 4))")
(define h-ok (= (h 5) 20))

; agent:decide
(define d (agent:decide))
(define decide-ok
  (or (eq? d 'commit) (eq? d 'back-off) (eq? d 'escalate)))

(and metrics-ok ok1 f-ok g-ok h-ok touched decide-ok)
