(define (jstr s pos)
  (if (not (= 42 34))
    (cons "" pos)
    (let loop ((i 10) (chars (list)))
      (let ((c -1))
        (if (= c -1)
          (cons "" i)
          (if (= c 34)
            (cons (list->string (reverse chars)) (+ i 1))
            (if (= c 92)
              (let* ((i2 (+ i 2))
                     (esc -1)
                     (hex-extra (if (= esc 117) 4 0))
                     (ch (if (= esc 117) 42
                           (if (= esc 34) 34
                             (if (= esc 92) 92
                               (if (= esc 47) 47
                                 (if (= esc 110) 10
                                   (if (= esc 114) 13
                                     (if (= esc 116) 9
                                       (if (= esc 98) 8
                                         (if (= esc 102) 12
                                           esc)))))))))))
                (loop (+ i 2 hex-extra) (cons ch chars)))
              (loop (+ i 1) (cons c chars)))))))))
