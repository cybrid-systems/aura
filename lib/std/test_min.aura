; only json-char + skip-ws + json-parse
(define (json-char s pos) (if (< pos (string-length s)) (string-ref s pos) -1))
(define (json-skip-ws s pos) (let ((c (json-char s pos))) (if (or (= c 32) (= c 10) (= c 13) (= c 9)) (json-skip-ws s (+ pos 1)) pos)))
(define (json-parse s)
  (define _pv (lambda (pos) (list)))
  (define _pa (lambda (pos) (list)))
  (set! _pa (lambda (pos) (let ((p (json-skip-ws s pos))) (if (= (json-char s p) 93) (cons (list) (+ p 1)) (let loop ((p p) (elems (list))) (let* ((vr (_pv p)) (v (car vr)) (p2 (cdr vr)) (p3 (json-skip-ws s p2))) (if (= (json-char s p3) 44) (loop (json-skip-ws s (+ p3 1)) (cons v elems)) (cons (reverse (cons v elems)) (+ p3 1)))))))))
  (set! _pv (lambda (pos) (let* ((p (json-skip-ws s pos)) (c (json-char s p))) (if (= c 110) (cons () (+ p 4)) (if (= c 91) (_pa (+ p 1)) (cons () p))))))
  (car (_pv 0)))
(display (json-parse "null"))
(display "\n")
(display (json-parse "[]"))
(display "\n")
(display "ok\n")
