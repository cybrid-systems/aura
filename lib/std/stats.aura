; ── (stats:get name) → invoke the named stats primitive ──────
(define (stats:get name)
  (cond
    ((equal? name "all")
      ; Bundle every registered stats primitive into a
      ; structured list of (name . value) pairs.
      (map (lambda (n) (cons n (eval n))) stats-registry))
    ((member? name stats-registry)
      (eval name))
    (else
      ; Unknown name — surface a structured diagnostic.
      (list 'unknown-stats-name name))))

; ── (stats:list) → list of every registered stats primitive ──
(define (stats:list) stats-registry)

; ── (stats:contains? name) → bool ──
(define (stats:contains? name)
  (member? name stats-registry))

; ── (stats:count) → number of registered stats primitives ──
(define (stats:count) (length stats-registry))

; ── (stats:prefix "query:") → list of stats matching prefix ──
(define (stats:prefix p)
  (filter (lambda (n) (string-contains? n p)) stats-registry))

; ── (stats:filter pred) → list of stats matching pred ──
(define (stats:filter pred)
  (filter pred stats-registry))

; ── Helper: string-contains? (Aura lacks this in stdlib) ──
(define (string-contains? s sub)
  (let ((n (string-length s)) (m (string-length sub)))
    (cond
      ((> m n) #f)
      ((= m 0) #t)
      (else
        (let loop ((i 0))
          (cond
            ((> (+ i m) n) #f)
            ((string=? (substring s i (+ i m)) sub) #t)
            (else (loop (+ i 1))))))))