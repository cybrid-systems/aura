; Aura standard observability / stats module
; Import with: (require std/stats all:)
; Or:        (import "std/stats")
;
; Issue #560: uniform wrapper around the 56 *-stats primitives
; scattered across `query:*-stats` and `compile:*-stats` namespaces.
; This module provides a single uniform interface:
;
;   (stats:get "query:envframe-dualpath-stats")  ; direct lookup
;   (stats:get "all")                            ; every counter
;   (stats:list)                                 ; enumerate names
;   (stats:contains? "query:envframe-dualpath-stats")
;   (stats:count)                                ; # registered stats
;
; The underlying primitives remain (no removal this cycle —
; tracked as future follow-up under the Issue #560 migration
; plan). The wrapper just routes by string name.

(export get list contains? count prefix filter)

; ── Master registry (manually maintained for P0) ────────────────
; New stats primitives added to the engine should be appended
; here AND in the underlying evaluator_primitives_*.cpp file.
; The (stats:list) primitive returns the live engine count
; for verification; this list is the source of truth for the
; stdlib layer.

(define stats-registry
  (list
    ; ── Issue #543 — EnvFrame dual-path ──
