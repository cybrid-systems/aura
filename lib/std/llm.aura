; Aura std/llm — LLM 交互模块
;
; Generator 和 Fixer 直接从 Python 接收 JSON-escape 后的字符串。
; 不执行递归字符处理（避免 C++ 栈溢出）。

(define aura-llm-call
  (lambda (body)
    (let ((key (getenv "LLM_API_KEY")))
      (if (or (not key) (= (string-length key) 0)) ""
        (http-post "https://api.deepseek.com/v1/chat/completions" body key)))))

(define aura-verify
  (lambda (code)
    (if (set-code code)
      (begin (typecheck-current)
        (let ((r (eval-current)))
          (if (error? r) (string-append "err:" (type-of r)) "#t")))
      "bad-code")))
