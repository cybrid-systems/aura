; json-char
(define (json-char s pos)
  (if (< pos (string-length s)) (string-ref s pos) -1))
; json-skip-ws
(define (json-skip-ws s pos)
  (let ((c (json-char s pos)))
    (if (or (= c 32) (= c 10) (= c 13) (= c 9))
      (json-skip-ws s (+ pos 1)) pos)))
; json-parse-hex
(define (json-parse-hex s pos)
  (define (hd c)
    (if (and (>= c 48) (<= c 57)) (- c 48)
      (if (and (>= c 65) (<= c 70)) (- c 55)
        (if (and (>= c 97) (<= c 102)) (- c 87) 0))))
  (+ (* (hd (string-ref s pos)) 4096)
     (* (hd (string-ref s (+ pos 1))) 256)
     (* (hd (string-ref s (+ pos 2))) 16)
     (hd (string-ref s (+ pos 3)))))
; json-decode-esc
(define (json-decode-esc esc s pos)
  (if (= esc 117) (json-parse-hex s pos)
    (if (= esc 34) 34 (if (= esc 92) 92 (if (= esc 47) 47
      (if (= esc 110) 10 (if (= esc 114) 13 (if (= esc 116) 9
        (if (= esc 98) 8 (if (= esc 102) 12 esc))))))))))
; json-parse-string-internal
(define (json-parse-string-internal s pos)
  (if (= (json-char s pos) 34)
    (let loop ((i (+ pos 1)) (chars (list)))
      (let ((c (json-char s i)))
        (if (= c -1) (cons "" i)
          (if (= c 34) (cons (list->string (reverse chars)) (+ i 1))
            (if (= c 92)
              (let* ((i2 (+ i 2)) (esc (json-char s (+ i 1)))
                     (hex-extra (if (= esc 117) 4 0))
                     (ch (json-decode-esc esc s (+ i 2))))
                (loop (+ i 2 hex-extra) (cons ch chars)))
              (loop (+ i 1) (cons c chars)))))))
    (cons "" pos)))
; json-take-digits
(define (json-take-digits s p)
  (if (and (< p (string-length s)) (>= (string-ref s p) 48) (<= (string-ref s p) 57))
    (json-take-digits s (+ p 1)) p))
; json-parse-number
(define (json-parse-number s pos)
  (let* ((p0 pos) (p1 (if (= (string-ref s pos) 45) (+ pos 1) pos))
         (p2 (json-take-digits s p1))
         (p3 (if (and (< p2 (string-length s)) (= (string-ref s p2) 46))
               (let ((p3a (+ p2 1)))
                 (let ((end (json-take-digits s p3a)))
                   (if (> end p3a) end p2))) p2))
         (p4 (if (and (< p3 (string-length s))
                      (or (= (string-ref s p3) 101) (= (string-ref s p3) 69)))
               (let* ((start (+ p3 1))
                      (after-sign (if (and (< start (string-length s))
                                           (or (= (string-ref s start) 43) (= (string-ref s start) 45)))
                                    (+ start 1) start))
                      (end (json-take-digits s after-sign)))
                 (if (> end after-sign) end p3)) p3)))
    (cons (string->number (substring s p0 p4)) p4)))
; json-build-hash
(define (json-build-hash keys vals)
  (let ((h (hash)))
    (let build ((ks keys) (vs vals))
      (if (null? ks) h
        (begin (hash-set! h (car ks) (car vs))
               (build (cdr ks) (cdr vs)))))))
; json-parse
(define (json-parse s)
  (define _pv (lambda (pos) (list)))
  (define _pa (lambda (pos) (list)))
  (define _po (lambda (pos) (list)))
  (set! _pa (lambda (pos)
    (let ((p (json-skip-ws s pos)))
      (if (= (json-char s p) 93) (cons (list) (+ p 1))
        (let loop ((p p) (elems (list)))
          (let* ((vr (_pv p)) (v (car vr)) (p2 (cdr vr)) (p3 (json-skip-ws s p2)))
            (if (= (json-char s p3) 44)
              (loop (json-skip-ws s (+ p3 1)) (cons v elems))
              (cons (reverse (cons v elems)) (+ p3 1)))))))))
  (set! _po (lambda (pos)
    (let ((p (json-skip-ws s pos)))
      (if (= (json-char s p) 125) (cons (hash) (+ p 1))
        (let loop ((p p) (keys (list)) (vals (list)))
          (let* ((kr (json-parse-string-internal s p))
                 (k (car kr)) (p2 (cdr kr)) (p3 (json-skip-ws s p2)))
            (if (not (= (json-char s p3) 58))
              (cons (json-build-hash (reverse keys) (reverse vals)) p3)
              (let* ((p4 (json-skip-ws s (+ p3 1)))
                     (vr (_pv p4)) (v (car vr)) (p5 (cdr vr)) (p6 (json-skip-ws s p5)))
                (if (= (json-char s p6) 44)
                  (loop (json-skip-ws s (+ p6 1))
                    (cons k keys) (cons v vals))
                  (cons (json-build-hash (reverse (cons k keys))
                                         (reverse (cons v vals)))
                        (+ p6 1)))))))))))
  (set! _pv (lambda (pos)
    (let* ((p (json-skip-ws s pos)) (c (json-char s p)))
      (if (= c 110) (cons () (+ p 4))
        (if (= c 116) (cons #t (+ p 4))
          (if (= c 102) (cons #f (+ p 5))
            (if (= c 34) (json-parse-string-internal s p)
              (if (or (and (>= c 48) (<= c 57)) (= c 45))
                (json-parse-number s p)
                (if (= c 91) (_pa (+ p 1))
                  (if (= c 123) (_po (+ p 1)) (cons () p)))))))))))
  (car (_pv 0)))
; json-stringify
(define (json-stringify v)
  (define (ec c)
    (if (= c 34) "\\\"" (if (= c 92) "\\\\" (if (= c 10) "\\n" (if (= c 13) "\\r"
      (if (= c 9) "\\t" (if (= c 8) "\\b" (if (= c 12) "\\f" (list->string (list c))))))))))
  (define (ea chars) (if (null? chars) "" (string-append (ec (car chars)) (ea (cdr chars)))))
  (define (je s) (ea (string->list s)))
  (define (ai lst)
    (if (null? lst) "" (string-append (json-stringify (car lst))
      (if (null? (cdr lst)) "" (string-append "," (ai (cdr lst)))))))
  (define (oi ks vs)
    (if (null? ks) "" (string-append "\"" (je (car ks)) "\":" (json-stringify (car vs))
      (if (null? (cdr ks)) "" (string-append "," (oi (cdr ks) (cdr vs)))))))
  (if (null? v) "null"
    (if (boolean? v) (if v "true" "false")
      (if (integer? v) (number->string v)
        (if (float? v) (number->string v)
          (if (string? v) (string-append "\"" (je v) "\"")
            (if (pair? v) (string-append "[" (ai v) "]")
              (if (hash? v) (string-append "{" (oi (hash-keys v) (hash-values v)) "}")
                "null"))))))))

; ── Tests ─────────────────────────────────────────────────────
(display "=== Tests ===\n")
(display "null: ") (display (json-parse "null")) (display "\n")
(display "bool: ") (display (json-parse "true")) (display " ") (display (json-parse "false")) (display "\n")
(display "int: ") (display (json-parse "42")) (display " ") (display (json-parse "-17")) (display "\n")
(display "float: ") (display (json-parse "3.14")) (display " ") (display (json-parse "-2.5e3")) (display "\n")
(display "str: ") (display (json-parse "\"hello\"")) (display "\n")
(display "arr: ") (display (json-parse "[1, 2, 3]")) (display "\n")
(display "obj: ") (display (json-parse "{\"a\":1,\"b\":2}")) (display "\n")
(display "nest: ") (display (json-parse "[[1,2],[3,4]]")) (display "\n")
(display "strfy: ") (display (json-stringify 42)) (display " ") (display (json-stringify "hi")) (display "\n")
(display "strfy arr: ") (display (json-stringify (list 1 "two" #t))) (display "\n")
(display "ok\n")
