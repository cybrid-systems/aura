; lib/std/synthesize-v2.aura -- Synthesize Pipeline v2
;
(require std/list all:)
(require std/json all:)
(require std/llm all:)
(require std/adaptive all:)

(export synthesize:test-driven synthesize:debug synthesize:project
        synthesize:run-tests synthesize:eval-test)

; ── string-trim ──
(define (string-trim str)
  (let ((n (string-length str)))
    (let lp ((i 0))
      (if (or (>= i n) (> (string-ref str i) 32))
        (let rp ((j (- n 1)))
          (if (or (< j i) (> (string-ref str j) 32))
            (substring str i (+ j 1))
            (rp (- j 1))))
        (lp (+ i 1))))))

; ── eval-test ──
(define (synthesize:eval-test code test-code expected)
  (set-code code)
  (eval-current)
  (set-code test-code)
  (let ((actual (eval-current-output)))
    (let ((trimmed (string-trim actual)))
      (if (string=? trimmed (string-trim expected))
        (list #t actual "")
        (list #f actual (string-append "expected: '" expected "', got: '" trimmed "'"))))))

; ── run-tests ──
(define (synthesize:run-tests code tests)
  (let ((passed 0) (total (length tests)) (failures '()))
    (for-each
      (lambda (test)
        (let* ((tc (list-ref test 0)) (ex (list-ref test 1))
               (r (synthesize:eval-test code tc ex)))
          (if (car r) (set! passed (+ passed 1))
            (set! failures (cons (list tc (list-ref r 1) (list-ref r 2)) failures)))))
      tests)
    (list passed total (reverse failures))))

; ── build-diagnostic ──
(define (build-diagnostic goal-name code passed total failures)
  (let ((diag ""))
    (set! diag (string-append diag "=== Code: ===\n" code "\n"))
    (set! diag (string-append diag "=== Test Results: " (number->string passed)
                               "/" (number->string total) " passed ===\n"))
    (if (null? failures)
      (set! diag (string-append diag "All tests passed!\n"))
      (begin
        (set! diag (string-append diag "\nFailures:\n"))
        (for-each (lambda (f)
          (set! diag (string-append diag "  Test: (" goal-name " " (list-ref f 0) ")\n"))
          (set! diag (string-append diag "    " (list-ref f 2) "\n"))) failures)
        (if (pair? failures)
          (let* ((ff (car failures)))
            (set! diag (string-append diag "\nFirst failure analysis:\n"))
            (set! diag (string-append diag "  Actual: " (list-ref ff 1) "\n"))
            (set! diag (string-append diag "  " (list-ref ff 2) "\n"))))))
    diag))

; ── build-llm-prompt ──
(define (build-llm-prompt goal-name code feedback model)
  (let* ((sys "You are an expert Aura Lisp programmer. Write ONLY valid Aura Lisp code.\n\
Rules:\n\
- Use (define (name args...) body) for function definitions\n\
- Use (if cond then else) for conditionals\n\
- CRITICAL: Wrap the code in ```lisp ... ``` markers.\n")
         (usr (string-append "Goal: " goal-name "\n\n"
           (if (string=? code "") "" (string-append "Current code:\n" code "\n\n"))
           (if (string=? feedback "") "" (string-append "Feedback:\n" feedback "\n\n"))
           "Generate a correct Aura Lisp implementation:\n"
           "(define (" goal-name " args...) body)\nWrap in ```lisp code ```."))
         (msgs (list (hash "role" "system" "content" sys)
                    (hash "role" "user" "content" usr)))
         (body (json-encode (hash "model" model "messages" msgs "temperature" 0.3))))
    body))

; ── call-llm ──
(define (call-llm goal-name code feedback model)
  (let* ((p (build-llm-prompt goal-name code feedback model))
         (raw (aura-llm-call p))
         (parsed (json-parse raw))
         (choices (hash-ref parsed "choices"))
         (first (if (pair? choices) (car choices) (hash)))
         (msg (hash-ref first "message"))
         (content (if (hash? msg) (hash-ref msg "content") "")))
    content))

; ── extract-code ──
(define (extract-code response)
  (let ((l (string-index response "```lisp" 0)))
    (if (> l -1)
      (let* ((s (+ l 8)) (e (string-index response "```" s)))
        (if (> e -1) (string-trim (substring response s e))
          (let ((d (string-index response "(define " 0)))
            (if (> d -1) (substring response d (string-length response)) response))))
      (let ((m (string-index response "```" 0)))
        (if (> m -1)
          (let* ((s (+ m 3)) (e (string-index response "```" s)))
            (if (> e -1) (string-trim (substring response s e)) response))
          (let ((d (string-index response "(define " 0)))
            (if (> d -1) (substring response d (string-length response)) response)))))))

; ── try-attempt ──
(define (try-attempt goal-name code tests max-a model
                     attempt-num best-code best-score)
  (let* ((sn (ast:snapshot "synth-v2"))
         (tr (synthesize:run-tests code tests))
         (p (list-ref tr 0)) (t (list-ref tr 1)) (fl (list-ref tr 2))
         (score (* 100 (/ p (max t 1))))
         (is-b (or (= best-score -1) (> score best-score)))
         (nb (if is-b code best-code))
         (ns (if is-b score best-score)))
    (ast:restore sn)
    (if (= p t) (list #t code (list p t fl))
      (if (>= attempt-num max-a) (list #f code ns)
        (let* ((fb (build-diagnostic goal-name code p t fl))
               (llm (if (string=? model "") "" (call-llm goal-name code fb model)))
               (nc (if (string=? model "") "" (extract-code llm)))
               (uc (if (string=? (string-trim nc) "") code nc)))
          (try-attempt goal-name uc tests max-a model
                      (+ attempt-num 1) nb ns))))))

; ── synthesize:test-driven ──
(define (synthesize:test-driven name . args)
  (let* ((goal (if (pair? args) (if (eq? (car args) :goal) (if (pair? (cdr args)) (cadr args) "") "") ""))
         (tests (if (pair? args) (if (eq? (car args) :tests) (if (pair? (cdr args)) (cadr args) '()) '()) '()))
         (code  (if (pair? args) (if (eq? (car args) :code) (if (pair? (cdr args)) (cadr args) "") "") ""))
         (max-a (if (pair? args) (if (eq? (car args) :max-attempts) (if (pair? (cdr args)) (cadr args) 5) 5) 5))
         (model (if (pair? args) (if (eq? (car args) :model) (if (pair? (cdr args)) (cadr args) "deepseek-chat") "deepseek-chat") "deepseek-chat"))
         (args2 (if (pair? (cddr args)) (cddr args) '()))
         (goal (if (pair? args2) (if (eq? (car args2) :goal) (if (pair? (cdr args2)) (cadr args2) goal) goal) goal))
         (tests (if (pair? args2) (if (eq? (car args2) :tests) (if (pair? (cdr args2)) (cadr args2) tests) tests) tests))
         (code (if (pair? args2) (if (eq? (car args2) :code) (if (pair? (cdr args2)) (cadr args2) code) code) code))
         (max-a (if (pair? args2) (if (eq? (car args2) :max-attempts) (if (pair? (cdr args2)) (cadr args2) max-a) max-a) max-a))
         (model (if (pair? args2) (if (eq? (car args2) :model) (if (pair? (cdr args2)) (cadr args2) model) model) model))
         (args3 (if (pair? (cddr args2)) (cddr args2) '()))
         (goal (if (pair? args3) (if (eq? (car args3) :goal) (if (pair? (cdr args3)) (cadr args3) goal) goal) goal))
         (tests (if (pair? args3) (if (eq? (car args3) :tests) (if (pair? (cdr args3)) (cadr args3) tests) tests) tests))
         (code (if (pair? args3) (if (eq? (car args3) :code) (if (pair? (cdr args3)) (cadr args3) code) code) code))
         (max-a (if (pair? args3) (if (eq? (car args3) :max-attempts) (if (pair? (cdr args3)) (cadr args3) max-a) max-a) max-a))
         (model (if (pair? args3) (if (eq? (car args3) :model) (if (pair? (cdr args3)) (cadr args3) model) model) model))
         (bad (or (null? tests) (not (pair? tests)))))
    (if bad (list #f code (list 0 0 '()))
      (try-attempt goal code tests max-a model 1 code -1))))

; ── synthesize:debug ──
(define (synthesize:debug . args)
  (let* ((code (if (pair? args) (if (eq? (car args) :code) (if (pair? (cdr args)) (cadr args) "") "") ""))
         (tests (if (pair? args) (if (eq? (car args) :tests) (if (pair? (cdr args)) (cadr args) '()) '()) '()))
         (max-a 3) (model "deepseek-chat")
         (args2 (if (pair? (cddr args)) (cddr args) '()))
         (tests (if (pair? args2) (if (eq? (car args2) :tests) (if (pair? (cdr args2)) (cadr args2) tests) tests) tests))
         (max-a (if (pair? args2) (if (eq? (car args2) :max-attempts) (if (pair? (cdr args2)) (cadr args2) max-a) max-a) max-a))
         (model (if (pair? args2) (if (eq? (car args2) :model) (if (pair? (cdr args2)) (cadr args2) model) model) model)))
    (if (string=? code "") (list #f "" '())
      (synthesize:test-driven "debug-fn" :goal "Fix the code" :tests tests :code code
        :max-attempts max-a :model model))))

; ── synthesize:project ──
(define (synthesize:project name . args)
  (let* ((files (if (pair? args) (if (eq? (car args) :files) (if (pair? (cdr args)) (cadr args) '()) '()) '()))
         (tests (if (pair? args) (if (eq? (car args) :tests) (if (pair? (cdr args)) (cadr args) '()) '()) '()))
         (max-a (if (pair? args) (if (eq? (car args) :max-attempts) (if (pair? (cdr args)) (cadr args) 3) 3) 3))
         (model (if (pair? args) (if (eq? (car args) :model) (if (pair? (cdr args)) (cadr args) "deepseek-chat") "deepseek-chat") "deepseek-chat"))
         (args2 (if (pair? (cddr args)) (cddr args) '()))
         (files (if (pair? args2) (if (eq? (car args2) :files) (if (pair? (cdr args2)) (cadr args2) files) files) files))
         (tests (if (pair? args2) (if (eq? (car args2) :tests) (if (pair? (cdr args2)) (cadr args2) tests) tests) tests))
         (max-a (if (pair? args2) (if (eq? (car args2) :max-attempts) (if (pair? (cdr args2)) (cadr args2) max-a) max-a) max-a))
         (model (if (pair? args2) (if (eq? (car args2) :model) (if (pair? (cdr args2)) (cadr args2) model) model) model)))
    (if (or (null? files) (not (pair? files))) (list #f "no files")
      (let* ((root (workspace:current)) (ws-ids '()) (file-rs '()) (all-ok #t))
        (for-each (lambda (fs)
          (let* ((fn (list-ref fs 0)) (fg (if (> (length fs) 2) (list-ref fs 2) ""))
                 (wid (workspace:create fn)))
            (set! ws-ids (cons wid ws-ids))
            (workspace:switch wid)
            (let* ((r (synthesize:test-driven fn :goal (string-append "Implement " fn ": " fg)
                       :code "" :tests (list) :max-attempts max-a :model model))
                   (ok (car r)) (fc (cadr r)))
              (when (not ok) (set! all-ok #f))
              (set! file-rs (cons (list fn ok fc) file-rs))
              (workspace:switch root)))) files)
        (set! file-rs (reverse file-rs))
        (if (and all-ok (pair? tests))
          (let* ((ac (string-join (map (lambda (r) (list-ref r 2)) file-rs) "\n"))
                 (tr (synthesize:run-tests ac tests))
                 (p (list-ref tr 0)) (t (list-ref tr 1)) (fl (list-ref tr 2)))
            (if (= p t) (list #t (list file-rs (list p t fl)))
              (list #f (list file-rs (list p t fl)))))
          (if all-ok (list #t (list file-rs "no-integ-tests"))
            (list #f (list file-rs "some-files-failed"))))))))
