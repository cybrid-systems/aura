; lib/std/INDEX.aura — Stdlib discoverability index (Issue #565)
;
; Import with: (import "std/INDEX")
; Or:        (require "std/INDEX" all:)
;
; The PRIMARY discovery surface for AI Agents. Lists every
; stdlib module with a one-line description + an example call.
; The full doc catalog is at docs/generated/stdlib-index.md
; (auto-generated by build.py docs), but the agent-facing
; surface is this INDEX.

(export stdlib:list stdlib:help stdlib:examples
        stdlib:by-prefix stdlib:by-tag)

; The master registry of stdlib modules. Each entry is
; (name . (description . example-call)). Order = discoverable
; order (high-level Agent helpers first, low-level primitives
; last). This list is the canonical source of truth for the
; stdlib catalog; build.py docs reads it for the generated
; stdlib-index.md.
(define stdlib-registry
  (list
    ; ── High-level Agent modules (Issue #559-#564 demotions) ──
    (list "stats"
      (list "Query + observability stats unified layer (56 *-stats primitives)"
            "(stats:get \"query:envframe-dualpath-stats\")"))
    (list "synthesize"
      (list "Synthesize namespace stdlib wrappers (LLM template registration)"
            "(synthesize:list-templates)"))
    (list "query"
      (list "High-level query: namespace Agent API"
            "(query:list-categories)"))
    (list "ast"
      (list "AST helpers: formatted summary, validate, version"
            "(ast:summary-formatted)"))
    (list "workspace"
      (list "Workspace helpers: snapshot, rollback, memory"
            "(ws:snapshot-current)"))
    (list "core"
      (list "High-level core builtin wrappers (any/all/zip-with/etc.)"
            "(core:any (lambda (x) (> x 0)) (list -1 2 -3))"))
    ; ── Adaptive + agent helpers ──
    (list "adaptive"
      (list "Adaptive API discovery + diagnostics"
            "(get-api-ref stdlib-list)"))
    (list "agent"
      (list "EDSL closed-loop auto-grow + decision-metrics (#1460)"
            "(auto-grow \"task\" :source \"(define (f x) x)\" :rebind \"f\" \"(lambda (x) (* x 2))\")"))
    (list "algorithm"
      (list "Algorithm utilities (sort, group, partition)"
            "(partition (lambda (x) (> x 0)) (list -1 2 -3))"))
    (list "capability"
      (list "Capability discovery"
            "(capability:list)"))
    (list "combinators"
      (list "Higher-order combinators"
            "(combinator:compose f g)"))
    (list "data"
      (list "Structured data utilities"
            "(data:make-hash)"))
    (list "rule"
      (list "Rule engine helpers"
            "(rule:define)"))
    (list "edsl"
      (list "EDSL syntax macros"
            "(syntax-rules)"))
    ; ── Pipeline + agent ──
    (list "pipeline"
      (list "Synthesize pipeline v2 (test-driven, debug)"
            "(synthesize:run-tests code tests)"))
    (list "orchestrator"
      (list "Agent orchestrator (multi-agent, spawn)"
            "(orchestrator:spawn)"))
    ; ── Collection + data ──
    (list "list"
      (list "List utilities (map, filter, foldl, list-sort) [perf-tier:hot #923/#928]"
            "(sort (list 3 1 2))"))
    (list "vector"
      (list "Vector utilities"
            "(vector:make 1 2 3)"))
    (list "hash"
      (list "Hash utilities"
            "(hash:set 'k 'v)"))
    (list "json"
      (list "JSON utilities"
            "(json:stringify (cons 'a 1))"))
    (list "string"
      (list "String utilities"
            "(string:length \"hello\")"))
    ; ── TUI (Issues #1334–#1358) ──
    (list "tui/canvas"
      (list "TUI canvas: colors, draw-text/rect, buffer-backed make-canvas"
            "(require \"std/tui/canvas\" all:)"))
    (list "tui/sprite"
      (list "TUI sprites + cyber cat frames"
            "(require \"std/tui/sprite\" all:)"))
    (list "tui/input"
      (list "TUI input poll + arrow/WASD helpers"
            "(require \"std/tui/input\" all:)"))
    (list "tui/run"
      (list "TUI run/game-loop + raw-mode session"
            "(require \"std/tui/run\" all:)"))
    (list "tui/scene"
      (list "TUI scene graph (list of sprite/text/char objects)"
            "(require \"std/tui/scene\" all:)"))
    (list "tui/anim"
      (list "TUI animation timeline (frames + fps ticks)"
            "(require \"std/tui/anim\" all:)"))
    ; ── Atomic resource swap (Issue #1380) ──
    (list "atomic-swap"
      (list "Bind resource→artifact; queue swap, drain at sync boundary"
            "(require \"std/atomic-swap\" all:)"))
    ; ── Workspace persistence (Issue #1381) ──
    (list "persist"
      (list "Save/load workspace + AOT meta + mutation log (AURASOUL binary)"
            "(require \"std/persist\" all:)"))
    ; ── AOT hot-update (Issue #1370) ──
    (list "hot-update"
      (list "AOT hot-reload + region + health (high-level Agent API)"
            "(require \"std/hot-update\" all:)"))
    (list "hot-update/reload"
      (list "AOT reload strategies (manual, threshold, composite)"
            "(require \"std/hot-update/reload\" all:)"))
    (list "hot-update/region"
      (list "Multi-agent region isolation helpers"
            "(require \"std/hot-update/region\" all:)"))
    (list "hot-update/monitor"
      (list "Hot-update health monitor poll helpers"
            "(require \"std/hot-update/monitor\" all:)"))
    ; ── IO / system ──
    (list "fs"
      (list "Filesystem helpers"
            "(fs:read \"/tmp/foo.txt\")"))
    (list "path"
      (list "Path manipulation"
            "(path:join \"a\" \"b\")"))
    (list "time"
      (list "Time helpers"
            "(time:now)"))
    ; ── Engine primitives discoverability (#1552) ──
    (list "primitives"
      (list "Engine PrimRegistrar registry (fiber/mutate/query hot paths) + Agent discovery (#1552)"
            "(require \"std/primitives\" all:)(primitives:help)"))
    ; ── Helpers ──
    ; Issue #981: removed duplicate "hash" entry (first entry under
    ; Collection + data is canonical: "(hash:set 'k 'v)").
    (list "INDEX"
      (list "This discoverability index"
            "(stdlib:list)"))))
; ── (stdlib:list) — returns list of all module names
(define (stdlib:list)
  (map car stdlib-registry))

; ── (stdlib:help name) — returns the help alist for a module
;     Returns '("not-found" name) if name is unknown.
(define (stdlib:help name)
  (let loop ((rest stdlib-registry))
    (cond
      ((null? rest) (list "not-found" name))
      ((string=? name (car (car rest)))
       (car (cdr (car rest))))
      (else (loop (cdr rest))))))

; ── (stdlib:examples) — returns list of (name . example-call) pairs
(define (stdlib:examples)
  (let helper ((rest stdlib-registry) (acc (list)))
    (cond
      ((null? rest) (reverse acc))
      (else
        (let* ((entry (car rest))
               (name (car entry))
               (data (car (cdr entry)))
               (example (car (cdr (cdr data)))))
          (helper (cdr rest) (cons (list name example) acc)))))))

; ── (stdlib:by-prefix prefix) — returns modules whose name starts with prefix
(define (stdlib:by-prefix prefix)
  (let helper ((rest stdlib-registry) (acc (list)))
    (cond
      ((null? rest) (reverse acc))
      ((string=? "" prefix)
       (helper (cdr rest) (cons (car (car rest)) acc)))
      (else
        (let* ((name (car (car rest)))
               (match? (if (>= (string-length name) (string-length prefix))
                       (string=? (substring name 0 (string-length prefix)) prefix)
                       #f)))
          (helper (cdr rest)
                  (if match? (cons name acc) acc)))))))

; ── (stdlib:by-tag tag) — returns modules whose help text contains tag
(define (stdlib:by-tag tag)
  (let helper ((rest stdlib-registry) (acc (list)))
    (cond
      ((null? rest) (reverse acc))
      (else
        (let* ((entry (car rest))
               (name (car entry))
               (help (car (car (cdr entry)))))
          (helper (cdr rest)
                  (if (string-contains? (string?-> help) tag)
                    (cons name acc)
                    acc)))))))

; Helper: string-contains? for the stdlib layer (used by by-tag).
(define (string-contains? str sub)
  (cond
    ((= (string-length sub) 0) #t)
    ((> (string-length sub) (string-length str)) #f)
    (else
      (let loop ((i 0))
        (cond
          ((> (+ i (string-length sub)) (string-length str)) #f)
          ((string=? (substring str i (+ i (string-length sub))) sub) #t)
          (else (loop (+ i 1)))))))

; Helper: convert any to string (used by by-tag for help text).
(define (string?-> v)
  (cond
    ((string? v) v)
    ((number? v) (number->string v))
    ((symbol? v) (symbol->string v))
    ((boolean? v) (if v "true" "false"))
    (else "...")))