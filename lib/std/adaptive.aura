; lib/std/adaptive.aura -- adaptive intend decision module
;
; Returns lists, not hashes (avoids cross-module hash mutation bug).
; Uses cond, not if (avoids cross-module if-in-begin bug).
(export string-index string-contains? string-trim measure-distance structured-diagnosis pid:analyze get-api-ref get-full-api-ref)

; == Primitives ==

(define string-index
  (lambda (text substr start)
    (let ((n (string-length text))
          (m (string-length substr)))
      (let loop ((i start))
        (if (> i (- n m)) -1
            (if (string=? (substring text i (+ i m)) substr) i
                (loop (+ i 1))))))))

(define string-contains?
  (lambda (text substr)
    (not (= (string-index text substr 0) -1))))

(define string-downcase
  (lambda (str)
    (list->string
      (map (lambda (c)
             (if (and (>= c 65) (<= c 90)) (+ c 32) c))
           (string->list str)))))

(define string-trim
  (lambda (str)
    (let ((n (string-length str)))
      (let lp ((i 0))
        (if (or (>= i n) (> (string-ref str i) 32))
            (let rp ((j (- n 1)))
              (if (or (< j i) (> (string-ref str j) 32))
                  (substring str i (+ j 1))
                  (rp (- j 1))))
            (lp (+ i 1)))))))

(define count-matches
  (lambda (output keys)
    (if (null? keys) 0
        (+ (if (string-contains? output (car keys)) 1 0)
           (count-matches output (cdr keys))))))

; == measure-distance ==
; Returns (list phase-string ratio-number diagnosis-string)

(define measure-distance
  (lambda (rc output expected-list)
    (let ((trimmed (string-trim output))
          (n-expected (length expected-list))
          (lower-out (string-downcase output))
          (lower-exp (map (lambda (kw) (string-downcase kw)) expected-list))
          (m (count-matches (string-downcase output)
                            (map (lambda (kw) (string-downcase kw)) expected-list))))
      (let ((ratio (/ m (max n-expected 1))))
        (cond
          ((not (= rc 0))
           (list "coarse" 0.0 "compile error: code did not compile or run"))
          ((or (string=? trimmed "") (string=? trimmed "()"))
           (list "coarse" 0.0 "empty output: did you forget (display ...)?"))
          ((= n-expected 0)
           (list "putt" 1.0 ""))
          ((>= ratio 0.85)
           (list "putt" ratio ""))
          ((= ratio 0.0)
           (list "fine" ratio "no expected keywords found in output"))
          (#t
           (list "fine" ratio
                 (string-append "partial match (ratio: " (number->string ratio) ")"))))))))

; == structured-diagnosis ==

(define find-missing
  (lambda (output expected-list)
    (if (null? expected-list) ()
        (let ((kw (car expected-list)))
          (if (string-contains? output kw)
              (find-missing output (cdr expected-list))
              (cons kw (find-missing output (cdr expected-list))))))))

(define structured-diagnosis
  (lambda (output expected-list)
    (let ((d (measure-distance 0 output expected-list))
          (missing (find-missing output expected-list)))
      (string-append
        "=== Diagnosis ===\n"
        "Phase: " (car d) "\n"
        "Ratio: " (number->string (car (cdr d))) "\n"
        (if (null? missing) ""
            (let ((first (car missing)))
          (string-append
            "Missing in output: " first
            (let join ((rest (cdr missing)) (acc ""))
              (if (null? rest) acc
                  (join (cdr rest) (string-append acc ", " (car rest)))))
            "\n")))
        (if (string-contains? output "<hash")
            (string-append
              "WARNING: (display <hash>) shows reference, not content.\n"
              "Use (hash-keys ...) or (hash-values ...) to extract.\n")
            "")
        (let ((diag (car (cdr (cdr d)))))
          (if (string=? diag "") "" (string-append "Note: " diag "\n")))))))

; == API Reference ==

(define aura-pitfalls
  "=== Aura Common Pitfalls ===\n\1. (display <hash>) shows <hash[N]>, NOT the content.\n\   Use (hash-keys h) or (hash-values h) or (hash->alist h).\n\2. (display 42) prints 42. To show multiple values, call (display) each.\n\3. Strings use double quotes: \"hello\". Single quotes are NOT string delimiters.\n\4. (if cond expr) returns () when cond is false (no else clause).\n\5. Booleans: #t and #f, NOT true/false.\n\6. Lists display inline: (display '(1 2 3)) shows (1 2 3).\n\7. Functions are not hoisted: define BEFORE use.\n\
   When i*i == n, the number has a divisor and is NOT prime.\n\
8. modulo: use (modulo n i) to get remainder. (mod n i) does NOT exist.\n\
   Available: modulo, remainder. NOT: mod.\n\
9. USE (display ...) at the end of your program!\n\
   If you only (define (f x) ...) without calling it, the output\n\
   will be \"#<procedure>\" and the TEST WILL FAIL.\n\
10. c-func creates a callable function, you still need to CALL it.\n\
   Correct: (define sqrt-fn (c-func \"sqrt\" \"m\" double double))\n\
           (display (sqrt-fn 25.0))\n\
   WRONG:  (c-func \"sqrt\" \"m\" double double)  ; returns procedure, never called\n")

(define (api-for-module mod)
  (string-append
    (cond
      ((string=? mod "core")
       "=== Core Aura Primitives (always available, no require) ===\n(c-func lib-id \"name\" \"(ArgType) -> RetType\") -> procedure\n   Creates a callable function from a C shared library.\n   lib-id: -1 (RTLD_DEFAULT, no c-load needed) or result of c-load.\n   Valid types: Int, Float, String, Opaque, Void\n   Example: (define sqrt-fn (c-func -1 \"sqrt\" \"(Float) -> Float\"))\n           (display (sqrt-fn 25.0))  ; MUST call the result!\n   WRONG:  (display (c-func -1 \"sqrt\" \"(Float) -> Float\"))\n           ; This shows #<procedure>, doesn't call the function!\n(c-load \"lib.so\") -> int  Load shared library, returns handle\n\n(: x Type val)  Type annotation: bind x with type Type and value val\n(: x Type)      Type annotation: declare type (no value binding)\nType values: Int, Float, String, Bool, List, (-> A B), (Pair A B), Any\n\n=== EDSL / Reflection Primitives ===\n(set-code \"src\")           -> void  Replace workspace code\n(eval-current)               -> bool  Evaluate current workspace\n(ast:snapshot tag)           -> int   Snapshot ID for rollback\n(ast:restore sid)            -> bool  Roll back to snapshot\n(ast:list-snapshots)         -> list  Active snapshot list\n(ast:print)                  -> void  Print AST (debug)\n(ast:print-node id)          -> void  Print single AST node\n\n(query:find pattern)         -> list  Find AST nodes by pattern\n(query:pattern pattern-str)  -> list  Find nodes matching pattern string\n(query:def-use var-name)     -> list  Def-use chain for variable\n(query:code)                 -> str   Get current code\n\n(mutate:rebind node-id val reason) -> bool  Replace node value\n   Examples:\n   (mutate:rebind 14 \"(lambda (x) (* x x))\" \"make square\")\n(mutate:replace-value start end new-val msg) -> bool  Range replacement\n\n(synthesize:optimize template) -> str  Optimize template against benchmarks\n(synthesize:register-template name template) -> void  Register template\n(synthesize:list-templates)    -> list  List registered templates\n(synthesize:fill name args...) -> str  Fill template with args\n(synthesize:define name sig ...) -> void  Define new template\n\n(ast:defs)                   -> list  Top-level definitions\n(ast:nodes)                  -> list  All AST node IDs\n\n=== M4 Linear Types ===\n(m4-move x)                  -> y     Linear move (x consumed)\n(m4-borrow x)                -> y     Linear borrow (x still owned)\n(define-linear x val)        -> void  Define linear variable\n(m4-return! x)               -> void  Return linear value to pool\n")
      ((string=? mod "std/hash")
       "=== std/hash ===\n(hash key val ...)      -> <hash[N]>  Create hash\n(hash-ref hash key)     -> value | ()  Lookup key\n(hash-set! hash key v)  -> void  Mutate hash (BUG across modules)\n(hash-keys hash)        -> list  Get all keys\n(hash-values hash)      -> list  Get all values\n(hash-length hash)      -> int   Number of entries\n(hash->alist hash)      -> alist  Convert to association list\n(hash-for-each hash fn)  -> void  Apply fn(key,value) to each entry\n")
      ((string=? mod "std/list")
       "=== std/list ===\n(filter pred lst)       -> list  pred: element -> bool\n(map fn lst)            -> list\n(foldl fn init lst)     -> any   (accumulator, element) -> any\n(for-each fn lst)       -> void  Side effect only\n(range start end)       -> list  [start, end)\n(append a b)            -> list  Concatenate\n(reverse lst)           -> list\n(length lst)            -> int\n(list-ref lst i)        -> any   0-based index\n(flatten lst)           -> list  Flatten nested lists\n(zip a b)               -> list  Pair elements from two lists\n(take lst n)            -> list  First n elements\n(drop lst n)            -> list  Drop first n elements\n(sort lst)              -> list  Ascending sort (numbers)\n(member x lst)          -> list | #f  Find element\n(frequencies lst)       -> hash  Count occurrences\n")
      ((string=? mod "std/iter")
       "=== std/iter ===\n(iterator lst)            -> iter  Create iterator from list\n(iter-next iter)          -> val | ()  Get next element\n(iter-collect iter)       -> list  Collect remaining elements\n(first lst)               -> any   Safe car (returns () on empty)\n(rest lst)                -> list  Safe cdr (returns () on empty)\n(last lst)                -> any   Last element\n(take-while pred lst)     -> list\n(drop-while pred lst)     -> list\n(map fn lst)              -> list\n(filter pred lst)         -> list\n(foldl fn init lst)       -> any\n(foldr fn init lst)       -> any\n(flatten lst)             -> list\n(interleave sep lsts)     -> list\n(split-at n lst)          -> list\n(group-by keyfn lst)      -> list\n(partition pred lst)      -> (list list)\n")
      ((string=? mod "std/json")
       "=== std/json ===\n(json-encode value)       -> string  Serialize to JSON\n(json-parse json-str)     -> value  Parse JSON string\n")
      ((string=? mod "std/llm")
       "=== std/llm ===\n(aura-llm-call json-body) -> string  Call LLM and return response\n")
      ((string=? mod "std/socket")
       "=== std/socket ===\n(tcp-connect host port)   -> socket | error  Open TCP connection\n(tcp-send socket data)    -> bool  Send data\n(tcp-recv socket maxlen)  -> string  Receive data\n(tcp-close socket)        -> void  Close connection\n")
      ((string=? mod "std/string")
       "=== std/string (require \"std/string\" all:) ===\n(string-split str delim)  -> list  Split string\n(string-join lst sep)     -> string  Join strings\n(string-pad str len)      -> string  Pad with spaces\n(string-reverse str)      -> string\n(string-downcase str)     -> string\n(string-upcase str)       -> string\n(string-trim str)         -> string  Strip whitespace\n(string-contains? str sub) -> bool  Check substring\n")
      ((string=? mod "std/math")
       "=== std/math (require \"std/math\" all:) ===\n(square x)                -> num\n(sqrt x)                  -> num\n(sin x)                   -> num\n(cos x)                   -> num\n(tan x)                   -> num\n(abs x)                   -> num\n(floor x)                 -> int\n(ceil x)                  -> int\n(round x)                 -> int\n(log x)                   -> num  Natural log\n(exp x)                   -> num  e^x\n")
      ((string=? mod "std/vector-math")
       "=== std/vector-math (require \"std/vector-math\" all:) ===\n(vec2 x y)                -> vec2  Create 2D vector\n(vec3 x y z)              -> vec3  Create 3D vector\n(vec-add a b)             -> vec   Element-wise add\n(vec-sub a b)             -> vec   Element-wise sub\n(vec-scale v s)           -> vec   Scale by scalar\n(vec-dot a b)             -> num   Dot product\n(vec-cross a b)           -> vec   Cross product\n(vec-length v)            -> num   Magnitude\n(vec-normalize v)         -> vec   Unit vector\n")
      ((string=? mod "std/rule")
       "=== std/rule (require \"std/rule\" all:) ===\n(rule:define name :pattern \"p\" :replace \"r\" ...) -> name\n   Keywords: :pattern (required), :replace (required), :condition, :description,\n             :enabled (default #t), :scope (:workspace or file)\n(rule:apply name)         -> int  Apply single rule\n(rule:apply-all)          -> int  Apply all enabled rules\n(rule:list)               -> list  List registered rules\n(rule:list-violations)    -> list  Audit mode\n(rule:remove name)        -> name  Remove rule\n(rule:enable/disable name) -> #t | #f  Toggle rule\n(rule:status name)        -> list | #f  Rule details\n")
      ((string=? mod "std/pipeline")
       "=== std/pipeline (require \"std/pipeline\" all:) ===\n(synthesize:pipeline \"name\" steps...) -> bool  Run pipeline\n   Each step can be: (synthesize:fill \"tmpl\" args...) or (synthesize:define ...)\n   Returns #t on success, rolls back AST on failure.\n")
      ((string=? mod "std/agent")
       "=== std/agent (require \"std/agent\" all:) ===\n(my-id)                   -> str     Current session ID\n(session-active? id)   -> bool    Check if session exists\n(mailbox-count)        -> int     Messages in mailbox\n(send target msg)      -> bool    Send message to agent\n(recv)                 -> msg | () Receive message (non-blocking)\n(recv-timeout sec)     -> msg | () Receive with timeout\n")
      ((string=? mod "std/ant")
       "=== std/ant (require \"std/ant\" all:) ===\n(pheromone:init)           -> void  Initialize pheromone system\n(pheromone:update k v)    -> void  Update pheromone trail\n(pheromone:rank)          -> list  Ranked pheromone trails\n(pheromone:score k)       -> num   Score for key\n(colony:search expected limit) -> (#t output msg) | (#f \"...\")\n   Locally mutate workspace and test against expected output.\n")
      ((string=? mod "std/maybe")
       "=== std/maybe (require \"std/maybe\" all:) ===\n(make-some val)          -> (some val)  Wrapper for Maybe values\n(make-none)              -> (none)  Nothing wrapper\n(maybe? x)               -> bool   Check if Maybe value\n(from-maybe default mb)  -> val    Unwrap or default\n")
      ((string=? mod "std/data")
       "=== std/data (require \"std/data\" all:) ===\n(define-type name ctor1 ctor2 ...) -> void  Define algebraic data type\n   Example: (define-type Tree (leaf val) (node left right))\n           creates constructors: (leaf val), (node left right)\n           Type dispatch: (match expr (leaf v) ... (node l r) ...)\n(match expr (ctor vars) body (ctor vars) body ...) -> value\n   Pattern match on ADT constructors.\n(type-of val)             -> symbol | #f  Get type of value\n")
      (#t (string-append "=== " mod " === (no detailed reference)\n")))))

(define (get-api-ref stdlib-list)
  (let loop ((libs stdlib-list) (result (api-for-module "core")))
    (if (null? libs) (string-append aura-pitfalls result)
        (loop (cdr libs) (string-append result (api-for-module (car libs)))))))

(define (get-full-api-ref)
  (let* ((all-mods (list "core" "std/hash" "std/list" "std/iter" "std/json"
                         "std/llm" "std/socket" "std/string" "std/math"
                         "std/vector-math" "std/rule" "std/pipeline"
                         "std/agent" "std/ant" "std/maybe" "std/data"))
         (ref (get-api-ref all-mods)))
    ref))
(define pid:analyze
  (lambda (output expected-list)
    (let* ((d (measure-distance 0 output expected-list))
           (phase (list-ref d 0))
           (ratio (list-ref d 1))
           (diag (list-ref d 2))
           (fb (list)))
      ;; Collect feedback lines
      (set! fb (cons (string-append "=== " (if (or (= (string-index output "unbound" 0) 0)
                                                    (= (string-index output "parse" 0) 0)
                                                    (= (string-index output "type error" 0) 0))
                                               "COMPILE ERROR" "OUTPUT MISMATCH")
                                 " ===") fb))
      (set! fb (cons (string-append "Phase: " phase " (ratio: " (number->string ratio) ")") fb))
      (set! fb (cons (string-append "Expected to contain: ") fb))
      (set! fb (cons (string-append "Actual output: " output) fb))
      ;; Check for common issues
      (if (string=? (string-trim output) "")
          (set! fb (cons "- Output is empty. Did you forget (display ...)?" fb)))
      (if (string-contains? output "<hash")
          (set! fb (cons "- display <hash> shows reference, not content. Use hash-keys/hash-values." fb)))
      (if (= (string-index output "unbound" 0) 0)
          (set! fb (cons "- The variable used doesn't exist. Check available primitives." fb)))
      (if (= (string-index output "parse error" 0) 0)
          (set! fb (cons "- Syntax error: check parentheses and string escaping." fb)))
      (list phase ratio diag (string-join (reverse fb) "\n")))))
