; lib/std/adaptive.aura -- adaptive intend decision module
;
; Returns lists, not hashes (avoids cross-module hash mutation bug).
; Uses cond, not if (avoids cross-module if-in-begin bug).
(export string-index string-contains? string-trim measure-distance structured-diagnosis pid:analyze get-api-ref get-full-api-ref)

; == Primitives ==

(define string-index
  (lambda (text substr start)
    (let ((n (string-length text))
          (m (string-length substr)))
      (let loop ((i start))
        (if (> i (- n m)) -1
            (if (string=? (substring text i (+ i m)) substr) i
                (loop (+ i 1))))))))

(define string-contains?
  (lambda (text substr)
    (not (= (string-index text substr 0) -1))))

(define string-downcase
  (lambda (str)
    (list->string
      (map (lambda (c)
             (if (and (>= c 65) (<= c 90)) (+ c 32) c))
           (string->list str)))))

(define string-trim
  (lambda (str)
    (let ((n (string-length str)))
      (let lp ((i 0))
        (if (or (>= i n) (> (string-ref str i) 32))
            (let rp ((j (- n 1)))
              (if (or (< j i) (> (string-ref str j) 32))
                  (substring str i (+ j 1))
                  (rp (- j 1))))
            (lp (+ i 1)))))))

(define count-matches
  (lambda (output keys)
    (if (null? keys) 0
        (+ (if (string-contains? output (car keys)) 1 0)
           (count-matches output (cdr keys))))))

; == measure-distance ==
; Returns (list phase-string ratio-number diagnosis-string)

(define measure-distance
  (lambda (rc output expected-list)
    (let ((trimmed (string-trim output))
          (n-expected (length expected-list))
          (lower-out (string-downcase output))
          (lower-exp (map (lambda (kw) (string-downcase kw)) expected-list))
          (m (count-matches (string-downcase output)
                            (map (lambda (kw) (string-downcase kw)) expected-list))))
      (let ((ratio (/ m (max n-expected 1))))
        (cond
          ((not (= rc 0))
           (list "coarse" 0.0 "compile error: code did not compile or run"))
          ((or (string=? trimmed "") (string=? trimmed "()"))
           (list "coarse" 0.0 "empty output: did you forget (display ...)?"))
          ((= n-expected 0)
           (list "putt" 1.0 ""))
          ((>= ratio 0.85)
           (list "putt" ratio ""))
          ((= ratio 0.0)
           (list "fine" ratio "no expected keywords found in output"))
          (#t
           (list "fine" ratio
                 (string-append "partial match (ratio: " (number->string ratio) ")"))))))))

; == structured-diagnosis ==

(define find-missing
  (lambda (output expected-list)
    (if (null? expected-list) ()
        (let ((kw (car expected-list)))
          (if (string-contains? output kw)
              (find-missing output (cdr expected-list))
              (cons kw (find-missing output (cdr expected-list))))))))

(define structured-diagnosis
  (lambda (output expected-list)
    (let ((d (measure-distance 0 output expected-list))
          (missing (find-missing output expected-list)))
      (string-append
        "=== Diagnosis ===\n"
        "Phase: " (car d) "\n"
        "Ratio: " (number->string (car (cdr d))) "\n"
        (if (null? missing) ""
            (let ((first (car missing)))
          (string-append
            "Missing in output: " first
            (let join ((rest (cdr missing)) (acc ""))
              (if (null? rest) acc
                  (join (cdr rest) (string-append acc ", " (car rest)))))
            "\n")))
        (if (string-contains? output "<hash")
            (string-append
              "WARNING: (display <hash>) shows reference, not content.\n"
              "Use (hash-keys ...) or (hash-values ...) to extract.\n")
            "")
        (let ((diag (car (cdr (cdr d)))))
          (if (string=? diag "") "" (string-append "Note: " diag "\n")))))))

; == API Reference ==

(define aura-pitfalls
  "=== Aura Common Pitfalls ===\n\1. (display <hash>) shows <hash[N]>, NOT the content.\n\   Use (hash-keys h) or (hash-values h) or (hash->alist h).\n\2. (display 42) prints 42. To show multiple values, call (display) each.\n\3. Strings use double quotes: \"hello\". Single quotes are NOT string delimiters.\n\4. (if cond expr) returns () when cond is false (no else clause).\n\5. Booleans: #t and #f, NOT true/false.\n\6. Lists display inline: (display '(1 2 3)) shows (1 2 3).\n\7. Functions are not hoisted: define BEFORE use.\n\
   When i*i == n, the number has a divisor and is NOT prime.\n\
8. modulo: use (modulo n i) to get remainder. (mod n i) does NOT exist.\n\
   Available: modulo, remainder. NOT: mod.\n\
9. USE (display ...) at the end of your program!\n\
   If you only (define (f x) ...) without calling it, the output\n\
   will be \"#<procedure>\" and the TEST WILL FAIL.\n\
10. c-func creates a callable function, you still need to CALL it.\n\
   Correct: (define sqrt-fn (c-func \"sqrt\" \"m\" double double))\n\
           (display (sqrt-fn 25.0))\n\
   WRONG:  (c-func \"sqrt\" \"m\" double double)  ; returns procedure, never called\n")

(define api-for-module
  (lambda (mod)
    (cond
      ((string=? mod "core")
       "=== Core Aura Primitives (always available, no require) ===\n\
\(c-func lib-id \"name\" \"(ArgType) -> RetType\") -> procedure\n\
   Creates a callable function from a C shared library.\n\
   lib-id: -1 (RTLD_DEFAULT, no c-load needed) or result of c-load.\n\
   Valid types: Int, Float, String, Opaque, Void\n\
   Example: (define sqrt-fn (c-func -1 \"sqrt\" \"(Float) -> Float\"))\n\
           (display (sqrt-fn 25.0))  ; MUST call the result!\n\
   WRONG:  (display (c-func -1 \"sqrt\" \"(Float) -> Float\"))\n\
           ; This shows #<procedure>, doesn't call the function!\n\
(c-load \"lib.so\") -> int  Load shared library, returns handle\n\
\
(: x Type val)  Type annotation: bind x with type Type and value val\
(: x Type)      Type annotation: declare type (no value binding)\
Type values: Int, Float, String, Bool, List, (-> A B), (Pair A B), Any\
\
=== EDSL / Reflection Primitives ===\
(set-code \"src\")           -> void  Replace workspace code\
(eval-current)               -> bool  Evaluate current workspace\
(ast:snapshot tag)           -> int   Snapshot ID for rollback\
(ast:restore sid)            -> bool  Roll back to snapshot\
(ast:list-snapshots)         -> list  Active snapshot list\
(ast:print)                  -> void  Print AST (debug)\
(ast:print-node id)          -> void  Print single AST node\
\
(query:find pattern)         -> list  Find AST nodes by pattern\
(query:pattern pattern-str)  -> list  Find nodes matching pattern string\
(query:def-use var-name)     -> list  Def-use chain for variable\
(query:code)                 -> str   Get current code\
\
(mutate:rebind node-id val reason) -> bool  Replace node value\
   Examples:\
   (mutate:rebind 14 \"(lambda (x) (* x x))\" \"make square\")\
(mutate:replace-value start end new-val msg) -> bool  Range replace\
\
(synthesize:optimize template) -> str  Optimize template against benchmarks\
(synthesize:register-template name template) -> void  Register template\
(synthesize:list-templates)    -> list  List registered templates\
(synthesize:fill name args...) -> str  Fill template with args\
(synthesize:define name sig ...) -> void  Define new template\
\
(ast:defs)                   -> list  Top-level definitions\
(ast:nodes)                  -> list  All AST node IDs\
\
=== M4 Linear Types ===\
(m4-move x)                  -> y     Linear move (x consumed)\
(m4-borrow x)                -> y     Linear borrow (x still valid)\
(define-linear x val)        -> void  Define linear variable\
(m4-return! x)               -> void  Return linear value to scope\
")
      ((string=? mod "std/hash")
       "=== std/hash ===\n\(hash key val ...)      -> <hash[N]>  Create hash\n\(hash-ref hash key)     -> value | ()  Lookup key\n\(hash-set! hash key v)  -> void  Mutate hash (BUG across modules)\n\(hash-keys hash)        -> list  Get all keys\n\(hash-values hash)      -> list  Get all values\n\(hash-length hash)      -> int   Number of entries\n\(hash->alist hash)      -> alist  Convert to association list\n\(hash-for-each hash fn)  -> void  Apply fn(key,value) to each entry\n")
      ((string=? mod "std/list")
       "=== std/list ===\n\(filter pred lst)       -> list  pred: element -> bool\n\(map fn lst)            -> list\n\(foldl fn init lst)     -> any   (accumulator, element) -> any\n\(for-each fn lst)       -> void  Side effect only\n\(range start end)       -> list  [start, end)\n\(append a b)            -> list  Concatenate\n\(reverse lst)           -> list\n\(length lst)            -> int\n\(list-ref lst i)        -> any   0-based index\n\(flatten lst)           -> list  Flatten nested lists\n\(zip a b)               -> list  Pair elements from two lists\n\(take lst n)            -> list  First n elements\n\(drop lst n)            -> list  Drop first n elements\n\(sort lst)              -> list  Ascending sort (numbers)\n\(member x lst)          -> list | #f  Find element\n\(frequencies lst)       -> hash  Count occurrences\n")
      ((string=? mod "std/iter")
       "=== std/iter ===\n\(iterator lst)            -> iter  Create iterator\n\(iterator-next! iter)     -> element | ()  Mutates iter\n\(iterator-empty? iter)    -> bool\n\(iterate fn init n)       -> any  Apply fn n times\n")
      ((string=? mod "std/json")
       "=== std/json ===\n\(json-encode value)       -> string  Serialize Aura value to JSON\n\(json-parse json-str)     -> value   Parse JSON string to Aura value\n\(json-get-string js f)    -> string  Extract string field from JSON\n")
      ((string=? mod "std/llm")
       "=== std/llm ===\n\(aura-llm-call json-body) -> string  Call LLM API\n\(aura-verify code)         -> \"#t\" | error-string  Verify code compiles+eval\n")
      ((string=? mod "std/socket")
       "=== std/socket ===\n\(tcp-connect host port)   -> socket | ()  TCP connect to host:port\n\(tcp-send socket data)    -> void  Send data\n\(tcp-recv socket)         -> string  Receive response\n\(tcp-close socket)        -> void  Close connection\n\HTTP response format: \"HTTP/1.1 200 OK\\n...\"\n\Parse status line to extract code (200) and message (OK).\n")
      ((string=? mod "std/string")
       "=== std/string (require \"std/string\" all:) ===\n\(string-split s sep)        -> list  Split by char\n\(string-split-words s)      -> list  Split by whitespace\n\(string-join strs sep)       -> str   Join with separator\n\(string-trim s)              -> str   Trim whitespace\n\(string-upcase s)            -> str   Uppercase (ASCII)\n\(string-downcase s)          -> str   Lowercase (ASCII)\n\(string-contains? hs ndl)    -> bool  Substring check\n\(string-prefix? s pfx)       -> bool  Prefix check\n\(string-suffix? s sfx)       -> bool  Suffix check\n\(string-replace s old new)   -> str   Replace all\n\(string-reverse s)           -> str   Reverse\n\(string-repeat s n)          -> str   Repeat n times\n\(string->chars s)            -> list  Char codes list\n\(chars->string cs)           -> str   From char codes\n\(string-take s n)            -> str   First n chars\n\(string-drop s n)            -> str   Drop n chars\n\(string-pad-left s w)        -> str   Pad left\n\(string-pad-right s w)       -> str   Pad right\n")
      ((string=? mod "std/math")
       "=== std/math (require \"std/math\" all:) ===\n\(square x)               -> square of x\n\(cube x)                 -> cube of x\n\(clamp x lo hi)          -> clamped value\n\(avg a b)                -> average of two numbers\n\(mean lst)               -> arithmetic mean\n\(median lst)             -> median\n\(gcd a b)                -> greatest common divisor\n\(lcm a b)                -> least common multiple\n\(prime? n)               -> primality test\n\(fibonacci n)            -> nth Fibonacci\n\(factorial n)            -> n!\n\(nCr n r)                -> combinations\n\(nPr n r)                -> permutations\n\(variance lst)           -> variance\n\(stddev lst)             -> standard deviation\n\(pi) (e) (phi) (tau)     -> math constants\n\(degrees->radians d)     -> convert\n\(radians->degrees r)     -> convert\n\(expt b n)               -> b^n\n\(sum lst)                -> sum of list\n\(product lst)            -> product of list\n\(range lst)              -> max - min\n\(normalize lst)          -> normalize to [0,1]\n\(percentile lst p)       -> p-th percentile\n")
      ((string=? mod "std/vector-math")
       "=== std/vector-math (require \"std/vector-math\" all:) ===\n\(vec:range start end)     -> vector  [start, end)\n\(vec:map f v)             -> vector  Element-wise map\n\(vec:zip f a b)           -> vector  Pairwise operation\n\(vec:fold f init v)       -> any     Fold over vector\n\(vec:sum v)               -> number  Sum elements\n\(vec:dot a b)             -> number  Dot product\n\(vec:norm v)              -> number  L2 norm\n\(vec:normalize v)         -> vector  Unit vector\n\(vec:scale v s)           -> vector  Scale by scalar\n\(vec:add / vec:sub / vec:mul / vec:div) -> element-wise ops\n\(vec:argmin / vec:argmax) -> int     Index of min/max\n\(vec:mean v)              -> number  Arithmetic mean\n\(vec:slice v s e)         -> vector  Slice\n\(vec:concat a b)          -> vector  Concatenate\n\(mat:identity n)          -> matrix  Identity\n\(mat:ref m r c)           -> number  Matrix element\n\(mat:transpose m)         -> matrix  Transpose\n\(mat:mul a b)             -> matrix  Matrix multiply\n\(mat:shape m)             -> vector  (rows cols)\n\(vec->list v)             -> list    Convert\n\(list->vec lst)           -> vector  Convert\n")
      ((string=? mod "std/rule")
       "=== std/rule (require \"std/rule\" all:) ===\n\(rule:define name :pattern \"pattern\" :replace \"replacement\" ...) -> name\n\   Keywords: :pattern (required), :replace (required), :condition, :description,\
\             :enabled (default #t), :scope (:workspace or function name)\
\(rule:apply name)         -> int  Apply single rule\
\(rule:apply-all)          -> int  Apply all enabled rules\
\(rule:list)               -> list  List registered rules\
\(rule:list-violations)    -> list  Audit mode\
\(rule:remove name)        -> name  Remove rule\
\(rule:enable/disable name) -> #t | #f  Toggle rule\
\(rule:status name)        -> list | #f  Rule details\
")
      ((string=? mod "std/pipeline")
       "=== std/pipeline (require \"std/pipeline\" all:) ===\n\(synthesize:pipeline \"name\" steps...) -> bool  Run pipeline\
\   Each step can be: (synthesize:fill \"tmpl\" args...) or (synthesize:define ...)\
\   Returns #t on success, rolls back AST on failure.\
")
      ((string=? mod "std/agent")
       "=== std/agent (require \"std/agent\" all:) ===\n\(my-id)                -> string  Agent's own session ID\
\(session-active? id)   -> bool    Check if session exists\
\(mailbox-count)        -> int     Messages in mailbox\
\(send target msg)      -> bool    Send message to agent\
\(recv)                 -> msg | () Receive message (non-blocking)\
\(recv-timeout sec)     -> msg | () Receive with timeout\
")
      ((string=? mod "std/ant")
       "=== std/ant (require \"std/ant\" all:) ===\n\(pheromone:init)          -> void  Initialize pheromone table\
\(pheromone:update k v)    -> void  Update pheromone trail\
\(pheromone:rank)          -> list  Ranked pheromone trails\
\(pheromone:score k)       -> num   Score for key\
\(colony:search expected limit) -> (#t output msg) | (#f \"\" msg)\
\   Locally mutate workspace and test against expected output.\
")
      ((string=? mod "std/maybe")
       "=== std/maybe (require \"std/maybe\" all:) ===\n\(make-some val)          -> (some val)  Wrapper for Maybe values\
\(make-none)              -> (none)  Nothing wrapper\
\(maybe? x)               -> bool   Check if Maybe value\
\(from-maybe default mb)  -> val    Unwrap or default\
")
      ((string=? mod "std/data")
       "=== std/data (require \"std/data\" all:) ===\n\(define-type name ctor1 ctor2 ...) -> void  Define algebraic data type\
\   Example: (define-type Tree (leaf val) (node left right))\
           creates constructors: (leaf val), (node left right)\
           Type dispatch: (match expr (leaf v) ... (node l r) ...)\
\(match expr (ctor vars) body (ctor vars) body ...) -> value\
\   Pattern match on ADT constructors.\
\(type-of val)             -> symbol | #f  Get type of value\
")
      ((#t (string-append "=== " mod " === (no detailed reference)\n")))))

;; Always include core primitives plus any requested modules
(define aura-core-ref
  (lambda ()
    (api-for-module "core")))

(define get-api-ref
  (lambda (stdlib-list)
    (let loop ((libs stdlib-list) (result (aura-core-ref)))
      (if (null? libs) (string-append aura-pitfalls result)
          (loop (cdr libs) (string-append result (api-for-module (car libs))))))))

;; Convenience: get full API ref for all commonly used modules at once
(define get-full-api-ref
  (lambda ()
    (let ((all-mods (list "core" "std/hash" "std/list" "std/iter" "std/json"
                          "std/llm" "std/socket" "std/string" "std/math"
                          "std/vector-math" "std/rule" "std/pipeline"
                          "std/agent" "std/ant" "std/maybe" "std/data")))
      (get-api-ref all-mods))))

(define pid:analyze
  (lambda (output expected-list)
    (let* ((d (measure-distance 0 output expected-list))
           (phase (list-ref d 0))
           (ratio (list-ref d 1))
           (diag (list-ref d 2))
           (fb (list)))
      ;; Collect feedback lines
      (set! fb (cons (string-append "=== " (if (or (= (string-index output "unbound" 0) 0)
                                                    (= (string-index output "parse" 0) 0)
                                                    (= (string-index output "type error" 0) 0))
                                               "COMPILE ERROR" "OUTPUT MISMATCH")
                                 " ===") fb))
      (set! fb (cons (string-append "Phase: " phase " (ratio: " (number->string ratio) ")") fb))
      (set! fb (cons (string-append "Expected to contain: ") fb))
      (set! fb (cons (string-append "Actual output: " output) fb))
      ;; Check for common issues
      (if (string=? (string-trim output) "")
          (set! fb (cons "- Output is empty. Did you forget (display ...)?" fb)))
      (if (string-contains? output "<hash")
          (set! fb (cons "- display <hash> shows reference, not content. Use hash-keys/hash-values." fb)))
      (if (= (string-index output "unbound" 0) 0)
          (set! fb (cons "- The variable used doesn't exist. Check available primitives." fb)))
      (if (= (string-index output "parse error" 0) 0)
          (set! fb (cons "- Syntax error: check parentheses and string escaping." fb)))
      (list phase ratio diag (string-join (reverse fb) "\n")))))
