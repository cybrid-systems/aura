; ── lib/std/bench.aura — Aura Native EDSL Benchmark ───
;
; Uses std/extract for code extraction (list-based, no string-index needed).
; Uses built-in check-success primitive (C++, false-positive guard).
; Prompt building uses std/prompt for consistency with Python runner.
;
(require "std/synthesize-v2" "std/list" "std/json" "std/fs" "std/ant" "std/extract" all:)

(export all-tasks task-count run-rounds aggregate)
(export print-report run-one)

; ── Load tasks from JSON ──
(define all-tasks
  (let* ((raw (read-file "lib/std/bench-tasks.json"))
         (parsed (json-parse raw)))
    parsed))
(define (task-count) (length all-tasks))

; ── Runner ──
(define (run-one task model max-a)
  ; Extract task fields
  (define name (list-ref task 0))
  (define goal (list-ref task 1))
  (define expects (list-ref task 2))
  (define depend (list-ref task 3))
  (define hints-list (list-ref task 4))
  (define hints-str (if (null? hints-list) ""
                      (let loop ((h hints-list) (acc ""))
                        (if (null? h) acc
                          (loop (cdr h) (string-append acc (car h) "\n"))))))
  (define expected-str (trim-str (list-ref expects 0)))

  ; Build system prompt using std/extract's trim-str (safe, no string-index)
  (define sys (string-append "You are Aura Lisp. Write valid code ending with (display ...).\n"
    "CRITICAL: (display (your-function args)) — if you only (define (f x) ...)"
    " the output will be '#<procedure>' and the TEST WILL FAIL!\n"
    (if (string=? hints-str "") "" (string-append "\n=== TASK HINTS ===\n" hints-str "\n"))))

  ; ── Generator: (lambda (goal) → code-string) ──
  (define (generator g)
    (let* ((usr (string-append "Goal: " g))
           (msgs (list (hash "role" "system" "content" sys)
                      (hash "role" "user" "content" usr)))
           (body (json-encode (hash "model" model "messages" msgs "temperature" 0.3)))
           (raw (aura-llm-call body))
           (parsed (json-parse raw))
           (choices (hash-ref parsed "choices"))
           (first (if (pair? choices) (car choices) (hash)))
           (msg (hash-ref first "message"))
           (content (if (hash? msg) (hash-ref msg "content") "")))
      ; Use std/extract's extract-code (list-based, no string-index dependency)
      (extract-code content)))

  ; ── Verifier: (lambda (code) → "#t" | error-string) ──
  ; Uses the built-in check-success C++ primitive (false-positive guard, structured error detection).
  ; NOTE: Do NOT define a local (check-success ...) — that would shadow the built-in.
  (define (verifier code)
    (let* ((full-code (string-append
               (if (string=? depend "") "" (string-append "(require \"" depend "\" all:)"))
               code))
           (actual (begin (set-code full-code) (eval-current-output)))
           (actual-str actual))
      (if (check-success actual-str expects)
        "#t"
        (string-append "expected: " expected-str " got: " actual-str))))

  ; ── Fixer: self-healing fallback chain ──
  ; 1. diagnose + apply-fix (zero cost, no LLM)
  ; 2. ant colony (local mutations, no LLM)
  ; 3. LLM (last resort)
  (define (fixer code err g)
    ; Step 0: Try diagnose + apply-fix (zero cost, known patterns)
    (let* ((diag (try (diagnose err) (catch (e) #f)))
           (fixed (if (and diag (pair? diag))
                    (apply-fix code diag)
                    #f)))
      (if (and (string? fixed) (not (string=? fixed code)))
        (begin
          (display "[SELF-HEAL via apply-fix] ")
          (display (car diag))
          (newline)
          fixed)
        ; Step 1: Try colony search (still no LLM)
        (let* ((colony-result (try (colony:search expected-str 20)
                                  (catch (e) #f))))
          (if colony-result
            (begin
              (display "[SELF-HEAL via ant colony]")
              (newline)
              (current-source))
            ; Step 2: Colony failed — fall back to LLM
            (let* ((usr (string-append "Your code:\n```lisp\n" code "\n```\nError: " err "\n\nGoal: " g))
                   (msgs (list (hash "role" "system" "content" sys)
                              (hash "role" "user" "content" usr)))
                   (body (json-encode (hash "model" model "messages" msgs "temperature" 0.3)))
                   (raw (aura-llm-call body))
                   (parsed (json-parse raw))
                   (choices (hash-ref parsed "choices"))
                   (first (if (pair? choices) (car choices) (hash)))
                   (msg (hash-ref first "message"))
                   (content (if (hash? msg) (hash-ref msg "content") "")))
              (extract-code content)))))))

  ; ── intend controller ──
  (define result (intend goal generator verifier fixer max-a))
  (if (string? result)
    (if (string=? (substring result 0 10) "#(status:")
      (list #t name)  ; intend succeeded
      (list #f name))
    (list #f name)))

; ── Rounds ──
(define (run-rounds tasks model max-a rounds)
  (define (loop r results)
    (if (>= r rounds) results
      (begin
        (newline)
        (display "=== Round ")
        (display (+ r 1))
        (display "/")
        (display rounds)
        (display " ===")
        (newline)
        (define rd '())
        (let iter ((tl tasks))
          (if (pair? tl)
            (let* ((task (car tl))
                   (name (list-ref task 0))
                   (result (run-one task model max-a))
                   (ok (car result)))
              (newline)
              (display name)
              (display " ")
              (if ok (display "OK") (display "FAIL"))
              (set! rd (cons result rd))
              (iter (cdr tl)))
            '()))
        (loop (+ r 1) (append results (list (reverse rd)))))))
  (loop 0 '()))

; ── Aggregate & Report ──
(define (aggregate tasks round-results)
  (define total (length tasks))
  (define rounds (if (pair? round-results) (length round-results) 0))
  
  (define (count-task ti)
    (let count-ri ((ri 0) (pc 0) (fc 0))
      (if (< ri rounds)
        (let* ((round (list-ref round-results ri))
               (tr (if (< ti (length round)) (list-ref round ti) (list #f "")))
               (ok (list-ref tr 0)))
          (if ok
            (count-ri (+ ri 1) (+ pc 1) fc)
            (count-ri (+ ri 1) pc (+ fc 1))))
        (list pc fc))))
  
  (define (iter ti all-p all-f stats)
    (if (< ti total)
      (let* ((pf (count-task ti))
             (pc (list-ref pf 0))
             (fc (list-ref pf 1))
             (name (list-ref (list-ref tasks ti) 0)))
        (iter (+ ti 1) (+ all-p pc) (+ all-f fc)
              (append stats (list (list name pc fc rounds)))))
      (list total all-p all-f stats)))
  
  (iter 0 0 0 '()))

(define (print-report tasks results)
  (display "print-report called\n")
  (let* ((agg (aggregate tasks results))
         (total (list-ref agg 0))
         (pass (list-ref agg 1))
         (fail (list-ref agg 2))
         (stats (list-ref agg 3))
         (rounds (if (null? results) 0 (length results))))
    (newline)
    (newline)
    (display "=== Benchmark Results ===")
    (newline)
    (display "Tasks: ")
    (display total)
    (display "  Rounds: ")
    (display rounds)
    (newline)
    (display "Passed: ")
    (display pass)
    (display "  Failed: ")
    (display fail)
    (newline)
    (if (> (+ pass fail) 0)
      (begin
        (display "Rate: ")
        (display (number->string (quotient (* pass 100) (+ pass fail))))
        (display "%")
        (newline)))
    (newline)
    (display "Task                    Pass/Fail  Rate")
    (newline)
    (display "------------------------------------------")
    (newline)
    (let iter ((si 0))
      (if (< si (length stats))
        (let* ((s (list-ref stats si))
               (name (list-ref s 0))
               (p (list-ref s 1))
               (f (list-ref s 2))
               (r (list-ref s 3))
               (rate-str (if (> r 0) (number->string (quotient (* p 100) r)) "0")))
          (display name)
          (display "  ")
          (display p)
          (display "/")
          (display f)
          (display "  ")
          (display rate-str)
          (display "%")
          (newline)
          (iter (+ si 1)))
        '()))
    agg))
