; ── lib/std/bench.aura — Aura Native EDSL Benchmark ───
;
; Uses built-in `intend` C++ primitive for phase-aware retry.
; Fixes vs the broken original:
;   - Removed check-success stub (shadowed C++ built-in, infinite loop)
;   - Uses std/extract for code extraction (original used unbound string-index)
;   - Requires std/adaptive for string-index/string-trim/pid:analyze
;   - 135 tasks load correctly from bench-tasks.json
;
(require "std/synthesize-v2" all:)
(require "std/list" all:)
(require "std/json" all:)
(require "std/fs" all:)
(require "std/ant" all:)
(require "std/extract" all:)
(require "std/adaptive" all:)

(export all-tasks task-count run-rounds aggregate)
(export print-report run-one run-parallel)

; ── Load tasks from JSON ──
(define all-tasks
  (let* ((raw (read-file "lib/std/bench-tasks.json"))
         (parsed (json-parse raw)))
    parsed))
(define (task-count) (length all-tasks))

; ── Runner via built-in `intend` C++ primitive ──
(define (run-one task model max-a)
  (define name (list-ref task 0))
  (define goal (list-ref task 1))
  (define expects (list-ref task 2))
  (define depend (list-ref task 3))
  (define hints-list (list-ref task 4))
  (define hints-str (if (null? hints-list) ""
                      (let loop ((h hints-list) (acc ""))
                        (if (null? h) acc
                          (loop (cdr h) (string-append acc (car h) "\n"))))))
  (define expected-str (list-ref expects 0))  ; keep as-is, built-in check-success handles it

  ; System prompt (same as Python runner's build_sys_prompt identity section)
  (define sys (string-append "You are Aura Lisp. Write valid code ending with (display ...).\n"
    "CRITICAL: (display (your-function args)) — if you only (define (f x) ...)"
    " the output will be '#<procedure>' and the TEST WILL FAIL!\n"
    (if (string=? hints-str "") "" (string-append "\n=== TASK HINTS ===\n" hints-str "\n"))))

  ; ── Generator: (lambda (goal) → code-string) ──
  (define (generator g)
    (let* ((usr (string-append "Goal: " g))
           (msgs (list (hash "role" "system" "content" sys)
                      (hash "role" "user" "content" usr)))
           (body (json-encode (hash "model" model "messages" msgs "temperature" 0.3)))
           (raw (aura-llm-call body))
           (parsed (json-parse raw))
           (choices (hash-ref parsed "choices"))
           (first (if (pair? choices) (car choices) (hash)))
           (msg (hash-ref first "message"))
           (content (if (hash? msg) (hash-ref msg "content") "")))
      (extract-code content)))

  ; ── Verifier: (lambda (code) → "#t" | error-string) ──
  ; Uses the built-in C++ check-success (false-positive guard, structured error detection).
  ; DO NOT define a local (check-success ...) — that would shadow the built-in.
  (define (verifier code)
    (let* ((full-code (string-append
               (if (string=? depend "") "" (string-append "(require \"" depend "\" all:)"))
               code))
           (actual (begin (set-code full-code) (eval-current-output)))
           (actual-str actual))
      (if (check-success actual-str expects)
        "#t"
        (string-append "expected: " expected-str " got: " actual-str))))

  ; ── Fixer: self-healing fallback chain ──
  ; 1. ant colony (local mutations, no LLM)
  ; 2. LLM with correction (last resort)
  (define (fixer code err goal-str)
    ; Step 1: Try ant colony search (zero LLM cost, fine/putt phase mutations)
    (let* ((colony-result (try (colony:search expected-str 5)
                              (catch (e) #f))))
      (if colony-result
        (begin
          (display "[SELF-HEAL via ant colony]")
          (newline)
          (current-source))
        ; Step 2: Colony failed — fall back to LLM with correction
        (let* ((usr (string-append "Your code:\n```lisp\n" code "\n```\nError: " err "\n\nGoal: " goal-str))
               (msgs (list (hash "role" "system" "content" sys)
                          (hash "role" "user" "content" usr)))
               (body (json-encode (hash "model" model "messages" msgs "temperature" 0.3)))
               (raw (aura-llm-call body))
               (parsed (json-parse raw))
               (choices (hash-ref parsed "choices"))
               (first (if (pair? choices) (car choices) (hash)))
               (msg (hash-ref first "message"))
               (content (if (hash? msg) (hash-ref msg "content") "")))
          (extract-code content)))))

  ; ── intend controller (C++ built-in, phase-aware retry loop) ──
  (define result (intend goal generator verifier fixer max-a))
  (if (string? result)
    ; intend returns "#(status:\"ok\" ...)" on success, or a plain error string
    ; Check if it contains "status:\"ok\""
    (if (not (= (string-index result "status:\"ok\"" 0) -1))
      (list #t name)
      (list #f name))
    (list #f name)))

; ── Rounds ──
(define (run-rounds tasks model max-a rounds)
  (define (loop r results)
    (if (>= r rounds) results
      (begin
        (newline)
        (display "=== Round ")
        (display (+ r 1))
        (display "/")
        (display rounds)
        (display " ===")
        (newline)
        (define rd '())
        (let iter ((tl tasks))
          (if (pair? tl)
            (let* ((task (car tl))
                   (name (list-ref task 0))
                   (result (run-one task model max-a))
                   (ok (car result)))
              (newline)
              (display name)
              (display " ")
              (if ok (display "OK") (display "FAIL"))
              (set! rd (cons result rd))
              (iter (cdr tl)))
            '()))
        (loop (+ r 1) (append results (list (reverse rd)))))))
  (loop 0 '()))

; ── Aggregate & Report ──
(define (aggregate tasks round-results)
  (define total (length tasks))
  (define rounds (if (pair? round-results) (length round-results) 0))
  (define (count-task ti)
    (let count-ri ((ri 0) (pc 0) (fc 0))
      (if (< ri rounds)
        (let* ((round (list-ref round-results ri))
               (tr (if (< ti (length round)) (list-ref round ti) (list #f "")))
               (ok (list-ref tr 0)))
          (if ok
            (count-ri (+ ri 1) (+ pc 1) fc)
            (count-ri (+ ri 1) pc (+ fc 1))))
        (list pc fc))))
  (define (iter ti all-p all-f stats)
    (if (< ti total)
      (let* ((pf (count-task ti))
             (pc (list-ref pf 0))
             (fc (list-ref pf 1))
             (name (list-ref (list-ref tasks ti) 0)))
        (iter (+ ti 1) (+ all-p pc) (+ all-f fc)
              (append stats (list (list name pc fc rounds)))))
      (list total all-p all-f stats)))
  (iter 0 0 0 '()))

(define (print-report tasks results)
  (display "print-report called\n")
  (let* ((agg (aggregate tasks results))
         (total (list-ref agg 0))
         (pass (list-ref agg 1))
         (fail (list-ref agg 2))
         (stats (list-ref agg 3))
         (rounds (if (null? results) 0 (length results))))
    (newline)
    (newline)
    (display "=== Benchmark Results ===")
    (newline)
    (display "Tasks: ")
    (display total)
    (display "  Rounds: ")
    (display rounds)
    (newline)
    (display "Passed: ")
    (display pass)
    (display "  Failed: ")
    (display fail)
    (newline)
    (if (> (+ pass fail) 0)
      (begin
        (display "Rate: ")
        (display (number->string (quotient (* pass 100) (+ pass fail))))
        (display "%")
        (newline)))
    (newline)
    (display "Task                    Pass/Fail  Rate")
    (newline)
    (display "------------------------------------------")
    (newline)
    (let iter ((si 0))
      (if (< si (length stats))
        (let* ((s (list-ref stats si))
               (name (list-ref s 0))
               (p (list-ref s 1))
               (f (list-ref s 2))
               (r (list-ref s 3))
               (rate-str (if (> r 0) (number->string (quotient (* p 100) r)) "0")))
          (display name)
          (display "  ")
          (display p)
          (display "/")
          (display f)
          (display "  ")
          (display rate-str)
          (display "%")
          (newline)
          (iter (+ si 1)))
        '()))
    agg))

; ── Parallel execution (fiber-based, serve-async mode only) ──
; Uses fiber:spawn to create real fibers for parallel task execution.
; Each fiber takes a partition of tasks, runs them sequentially, and
; sends results back to the main fiber via send/recv.
; Falls back to sequential if fiber:spawn is not available (stdin mode).
;
(define (run-parallel tasks model max-a rounds n-workers)
  ; Probe: does fiber:spawn return a fiber ID (integer > 0)?
  ; If not (returns #t/#f/void), we're in stdin mode.
  (define probe (fiber:spawn (lambda () #t)))
  (if (not (and (integer? probe) (> probe 0)))
    (begin
      (display "[parallel] fiber:spawn not available, falling back to sequential\n")
      (run-rounds tasks model max-a rounds))
    (let* ((n (length tasks))
           ; Partition tasks among workers
           (psize (max 1 (quotient n n-workers)))
           (partitions (let loop ((rem tasks) (acc '()))
                         (if (null? rem) (reverse acc)
                           (let ((piece (take rem psize))
                                 (rest (drop rem psize)))
                             (loop rest (cons piece acc))))))
           (nparts (length partitions))
           ; Shared result vector (one slot per partition)
           (results (make-vector nparts '())))
      (display "[parallel] ")(display (number->string nparts))(display " workers, ")
      (display (number->string n))(display " tasks\n")
      (newline)
      
      ; Launch worker fibers
      (let spawn ((i 0))
        (if (< i nparts)
          (let ((my-idx i)
                (my-tasks (list-ref partitions i)))
            (fiber:spawn
              (lambda ()
                (let iter ((tl my-tasks) (acc '()))
                  (if (pair? tl)
                    (let* ((task (car tl))
                           (name (list-ref task 0))
                           (result (run-one task model max-a))
                           (ok (car result)))
                      (display name)
                      (display " ")
                      (if ok (display "OK") (display "FAIL"))
                      (newline)
                      (iter (cdr tl) (cons result acc)))
                    ; Done — store results and signal main fiber
                    (begin
                      (vector-set! results my-idx (reverse acc))
                      (send "default" "done")))))
            (spawn (+ i 1)))
          #f))
      
      ; Workers report results as they go (via display in run-one).
      ; Main fiber does NOT wait — workers run in background and
      ; exit when done. Session fiber checks stdin_eof and exits.
      ; The scheduler keeps running until all fibers are done.
      
      (newline)
      (display "[parallel] workers launched, see per-task output above\n")
      ; Return nil (workers handle their own output)
      '())))

; Helper: take first n elements
(define take
  (lambda (lst n)
    (if (or (null? lst) (= n 0)) '()
      (cons (car lst) (take (cdr lst) (- n 1))))))

; Helper: drop first n elements
(define drop
  (lambda (lst n)
    (if (or (null? lst) (= n 0)) lst
      (drop (cdr lst) (- n 1)))))
