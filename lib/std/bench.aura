; ── bench.aura — Aura Native EDSL Benchmark ───
(require "std/synthesize-v2" "std/list" "std/json" "std/fs" all:)

; ── API reference for LLM system prompt ──
(define api-ref-str ; Static API reference (equivalent to get-full-api-ref but
                    ; avoids module closure issues with aura-core-ref)
  "=== Core Aura Primitives (always available, no require) ===
(c-func lib-id \"name\" \"(ArgType) -> RetType\") -> procedure
(: x Type val)  Type annotation: bind x with type Type and value val
(: x Type)      Type annotation: declare type (no value binding)
Type values: Int, Float, String, Bool, List, (-> A B), (Pair A B), Any

=== std/list (no require) ===
(filter pred lst)       -> list
(map fn lst)            -> list
(foldl fn init lst)     -> any
(for-each fn lst)       -> void
(range start end)       -> list  [start, end)
(append a b)            -> list
(reverse lst)           -> list
(length lst)            -> int
(list-ref lst i)        -> any   0-based
(flatten lst)           -> list
(zip a b)               -> list
(take lst n)            -> list
(drop lst n)            -> list
(sort lst)              -> list   Ascending sort (numbers)
(member x lst)          -> list | #f
(frequencies lst)       -> hash   Count occurrences

=== std/string (require \"std/string\" all:) ===
(string-split s sep)     -> list
(string-join strs sep)   -> str
(string-trim s)          -> str
(string-upcase s)        -> str
(string-contains? h n)   -> bool
(string-replace s o n)   -> str
(string-reverse s)       -> str
(string->chars s)        -> list
(chars->string cs)       -> str
(string-take s n)        -> str
(string-drop s n)        -> str

=== std/hash (require \"std/hash\" all:) ===
(hash key val ...)       -> hash
(hash-ref h k)           -> value | ()
(hash-set! h k v)        -> void
(hash-keys h)            -> list
(hash-values h)          -> list
(hash-length h)          -> int
(hash->alist h)          -> list

=== std/json (require \"std/json\" all:) ===
(json-encode value)      -> string
(json-parse json-str)    -> value

=== std/llm (require \"std/llm\" all:) ===
(aura-llm-call body)     -> string

=== std/math (require \"std/math\" all:) ===
(square x) (cube x) (clamp x lo hi) (avg a b)
(mean lst) (median lst) (gcd a b) (lcm a b)
(prime? n) (fibonacci n) (factorial n)
(nCr n r) (nPr n r) (pi) (e)

=== EDSL / Reflection Primitives ===
(set-code \"src\")          -> void
(eval-current)               -> bool
(ast:snapshot tag)           -> int
(ast:restore sid)            -> bool
(ast:print)                  -> void
(query:find pattern)         -> list
(query:def-use var-name)     -> list
(mutate:rebind node-id val reason) -> bool
(synthesize:optimize tmpl)   -> str
(synthesize:test-driven goal expected stdin hints) -> bool
")

; ── extract-code from LLM response ──
(define (extract-code response)
  (let ((l (string-index response "```lisp" 0)))
    (if (> l -1)
      (let* ((s (+ l 8)) (e (string-index response "```" s)))
        (if (> e -1) (string-trim (substring response s e))
          (let ((d (string-index response "(define " 0)))
            (if (> d -1) (substring response d (string-length response)) response))))
      (let ((m (string-index response "```" 0)))
        (if (> m -1)
          (let* ((s (+ m 3)) (e (string-index response "```" s)))
            (if (> e -1) (string-trim (substring response s e)) response))
          (let ((d (string-index response "(define " 0)))
            (if (> d -1) (substring response d (string-length response)) response)))))))

(export all-tasks task-count run-rounds aggregate)
(export print-report)

; ── Load tasks from JSON ──
(define all-tasks
  (let* ((raw (read-file "lib/std/bench-tasks.json"))
         (parsed (json-parse raw)))
    parsed))
(define (task-count) (length all-tasks))

; ── Runner ──
(define (run-one task model max-a)
  (let* ((name (list-ref task 0))
         (goal (list-ref task 1))
         (expects (list-ref task 2))
         (depend (list-ref task 3))
         (hints-list (list-ref task 4))
         (hints-str (if (null? hints-list) ""
                      (let loop ((h hints-list) (acc ""))
                        (if (null? h) acc
                          (loop (cdr h) (string-append acc (car h) "\n"))))))
         ; Build system prompt — must avoid any quote issues
         (sys (string-append "You are an expert Aura Lisp programmer. Write a complete program ending with (display ...). The output must match exactly.\nRules:\n- (define ...) for functions, then (display (my-func args...))\n- (require std/name all:) for stdlib\n- Wrap code in ```lisp ... ``` markers.\n\n" api-ref-str))
         (usr (string-append "Goal: " goal
           (if (string=? hints-str "") "" (string-append "\n\nHINTS:\n" hints-str))))
         (msgs (list (hash "role" "system" "content" sys)
                    (hash "role" "user" "content" usr)))
         (body (json-encode (hash "model" model "messages" msgs "temperature" 0.3)))
         (raw (aura-llm-call body))
         (parsed (json-parse raw))
         (choices (hash-ref parsed "choices"))
         (first (if (pair? choices) (car choices) (hash)))
         (msg (hash-ref first "message"))
         (content (if (hash? msg) (hash-ref msg "content") ""))
         (llm-code (extract-code content))
         (full-code (string-append
           (if (string=? depend "") "" (string-append "(require \"" depend "\" all:)"))
           (if (string=? llm-code "") ";" llm-code)))
         (actual (if (string=? llm-code "") ""
                   (begin (set-code full-code) (eval-current-output))))
         (expected-str (string-trim (list-ref expects 0)))
         (actual-str (string-trim actual))
         (ok (string=? actual-str expected-str)))
    (list ok name)))

(define (run-rounds tasks model max-a rounds)
  (define (loop r results)
    (if (>= r rounds) results
      (begin
        (newline)
        (display "=== Round ")
        (display (+ r 1))
        (display "/")
        (display rounds)
        (display " ===")
        (newline)
        ; Collect results using cons (O(n) per round)
        (define rd '())
        (let iter ((tl tasks))
          (if (pair? tl)
            (let* ((task (car tl))
                   (name (list-ref task 0))
                   (result (run-one task model max-a))
                   (ok (car result)))
              (newline)
              (display name)
              (display " ")
              (if ok (display "OK") (display "FAIL"))
              (set! rd (cons result rd))
              (iter (cdr tl)))
            '()))
        ; Reverse rd to maintain task order, append to results
        (loop (+ r 1) (append results (list (reverse rd)))))))
  (loop 0 '()))

(define (aggregate tasks round-results)
  (define total (length tasks))
  (define rounds (if (pair? round-results) (length round-results) 0))
  
  ; Count one task's passes/fails across all rounds
  (define (count-task ti)
    (let count-ri ((ri 0) (pc 0) (fc 0))
      (if (< ri rounds)
        (let* ((round (list-ref round-results ri))
               (tr (if (< ti (length round)) (list-ref round ti) (list #f "")))
               (ok (list-ref tr 0)))
          (if ok
            (count-ri (+ ri 1) (+ pc 1) fc)
            (count-ri (+ ri 1) pc (+ fc 1))))
        (list pc fc))))
  
  ; Iterate tasks, threading accumulators
  (define (iter ti all-p all-f stats)
    (if (< ti total)
      (let* ((pf (count-task ti))
             (pc (list-ref pf 0))
             (fc (list-ref pf 1))
             (name (list-ref (list-ref tasks ti) 0)))
        (iter (+ ti 1) (+ all-p pc) (+ all-f fc)
              (append stats (list (list name pc fc rounds)))))
      (list total all-p all-f stats)))
  
  (iter 0 0 0 '()))
(define (print-report tasks results)
  (display "print-report called\n")
  (let* ((agg (aggregate tasks results))
         (total (list-ref agg 0))
         (pass (list-ref agg 1))
         (fail (list-ref agg 2))
         (stats (list-ref agg 3))
         (rounds (if (null? results) 0 (length results))))
    (newline)
    (newline)
    (display "=== Benchmark Results ===")
    (newline)
    (display "Tasks: ")
    (display total)
    (display "  Rounds: ")
    (display rounds)
    (newline)
    (display "Passed: ")
    (display pass)
    (display "  Failed: ")
    (display fail)
    (newline)
    (if (> (+ pass fail) 0)
      (begin
        (display "Rate: ")
        (display (number->string (quotient (* pass 100) (+ pass fail))))
        (display "%")
        (newline)))
    (newline)
    (display "Task                    Pass/Fail  Rate")
    (newline)
    (display "------------------------------------------")
    (newline)
    (let iter ((si 0))
      (if (< si (length stats))
        (let* ((s (list-ref stats si))
               (name (list-ref s 0))
               (p (list-ref s 1))
               (f (list-ref s 2))
               (r (list-ref s 3))
               (rate-str (if (> r 0) (number->string (quotient (* p 100) r)) "0")))
          (display name)
          (display "  ")
          (display p)
          (display "/")
          (display f)
          (display "  ")
          (display rate-str)
          (display "%")
          (newline)
          (iter (+ si 1)))
        '()))
    agg))
