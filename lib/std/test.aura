; Aura Testing Framework
;
; Usage:
;   (test-suite "name"
;     (check expr)
;     (check= expected actual))
;
; Check and check= are built-in primitives that return #t on success
; or <error> on failure. Use with try/catch for graceful error handling.
;
; Example:
;   (test-suite "math"
;     (check= 4 (square 2))
;     (check= 9 (square 3)))
;
;   (run-tests)  → prints summary

; test-suite macro: registers a named test suite
(defmacro test-suite (name . body)
  (let ((collect-name (string-append "test:" name)))
    `(begin
       (define ,collect-name
         (list ',name
               (map (lambda (expr)
                      (list (try expr
                              (catch (e)
                                (list 'failed e)))
                            expr))
                    (list ,@body))))
       ,collect-name)))
