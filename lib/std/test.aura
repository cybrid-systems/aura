; Aura Testing Framework
;
; Usage:
;   (test-suite "name"
;     (check expr)
;     (check= expected actual))
;
; Check and check= are built-in primitives that return 1 on success
; or <error> on failure.
;
;   (run-tests)  → evaluate and print summary

; test-suite macro: stores check forms as quoted data for run-tests.
; (run-tests) evaluates each stored form one by one.
; Format: ("name" form1 form2 ...) as flat pair chain.
(defmacro (test-suite name . body)
  (let ((collect-name (string-append "test:" name)))
    (list 'begin
      (list 'define collect-name
        (list 'cons name (list 'quote body)))
      collect-name)))
