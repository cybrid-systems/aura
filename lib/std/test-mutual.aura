(define (jchar s pos)
  (if (< pos (string-length s))
    (string-ref s pos)
    -1))
(define (jskip s pos)
  (let ((c (jchar s pos)))
    (if (or (= c 32) (= c 10) (= c 13) (= c 9))
      (jskip s (+ pos 1))
      pos)))

(define (myparse s)
  (define (td p)
    (if (and (< p (string-length s))
             (>= (string-ref s p) 48)
             (<= (string-ref s p) 57))
      (td (+ p 1)) p))
  (define _pv (lambda (s pos) (list)))
  
  (set! _pv (lambda (s pos)
    (let* ((p (jskip s pos)) (c (jchar s p)))
      (if (or (and (>= c 48) (<= c 57)) (= c 45))
        (let* ((p0 p)
               (p1 (if (= c 45) (+ p 1) p))
               (p2 (td p1))
               (p3 (if (and (< p2 (string-length s))
                            (= (string-ref s p2) 46))
                     (let* ((a (+ p2 1))
                            (b (td a)))
                       (if (> b a) b p2)) p2))
               (p4 (if (and (< p3 (string-length s))
                            (or (= (string-ref s p3) 101)
                                (= (string-ref s p3) 69)))
                     (let* ((a (+ p3 1))
                            (b (if (and (< a (string-length s))
                                        (or (= (string-ref s a) 43)
                                            (= (string-ref s a) 45)))
                                  (+ a 1) a))
                            (c (td b)))
                       (if (> c b) c p3)) p3)))
          (cons 42 p4))
        (cons () p)))))
  
  (_pv s 0))

(display "loaded\n")
