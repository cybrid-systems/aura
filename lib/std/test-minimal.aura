; Top-level helpers for number parsing
(define (take-digits s p)
  (if (and (< p (string-length s))
           (>= (string-ref s p) 48)
           (<= (string-ref s p) 57))
    (take-digits s (+ p 1))
    p))

(define (parse-number s pos)
  (let* ((p0 pos)
         (p1 (if (= (string-ref s pos) 45) (+ pos 1) pos))
         (p2 (take-digits s p1))
         (p3 (if (and (< p2 (string-length s)) (= (string-ref s p2) 46))
               (let ((p3a (+ p2 1)))
                 (let ((end (take-digits s p3a)))
                   (if (> end p3a) end p2)))
               p2))
         (p4 (if (and (< p3 (string-length s))
                      (or (= (string-ref s p3) 101) (= (string-ref s p3) 69)))
               (let* ((start (+ p3 1))
                      (after-sign (if (and (< start (string-length s))
                                           (or (= (string-ref s start) 43) (= (string-ref s start) 45)))
                                    (+ start 1) start))
                      (end (take-digits s after-sign)))
                 (if (> end after-sign) end p3))
               p3)))
    (cons (string->number (substring s p0 p4)) p4)))

; json-parse uses forward-declare + set! for mutual recursion
(define (json-parse s)
  (define _char (json-char s 0))
  (define _skip (json-skip-ws s 0))
  (define _hex (json-parse-hex s 0))
  (define _str (json-parse-string-internal s 0))

  ; Forward declarations
  (define pval (lambda (pos) (list)))
  (define parr (lambda (pos) (list)))
  (define pobj (lambda (pos) (list)))

  (set! parr
    (lambda (pos)
      (let ((p (json-skip-ws s pos)))
        (if (= (json-char s p) 93)
          (cons (list) (+ p 1))
          (let loop ((p p) (elems (list)))
            (let* ((vr (pval p))
                   (v (car vr))
                   (p2 (cdr vr))
                   (p3 (json-skip-ws s p2)))
              (if (= (json-char s p3) 44)
                (loop (json-skip-ws s (+ p3 1)) (cons v elems))
                (cons (reverse (cons v elems)) (+ p3 1)))))))))

  (set! pobj
    (lambda (pos)
      (define (bh ks vs)
        (let ((h (hash)))
          (let build ((ks2 ks) (vs2 vs))
            (if (null? ks2) h
              (begin (hash-set! h (car ks2) (car vs2))
                     (build (cdr ks2) (cdr vs2)))))))
      (let ((p (json-skip-ws s pos)))
        (if (= (json-char s p) 125)
          (cons (hash) (+ p 1))
          (let loop ((p p) (keys (list)) (vals (list)))
            (let* ((kr (json-parse-string-internal s p))
                   (k (car kr))
                   (p2 (cdr kr))
                   (p3 (json-skip-ws s p2)))
              (if (not (= (json-char s p3) 58))
                (cons (bh (reverse keys) (reverse vals)) p3)
                (let* ((p4 (json-skip-ws s (+ p3 1)))
                       (vr (pval p4))
                       (v (car vr))
                       (p5 (cdr vr))
                       (p6 (json-skip-ws s p5)))
                  (if (= (json-char s p6) 44)
                    (loop (json-skip-ws s (+ p6 1))
                      (cons k keys) (cons v vals))
                    (cons (bh (reverse (cons k keys))
                              (reverse (cons v vals)))
                          (+ p6 1)))))))))))

  (set! pval
    (lambda (pos)
      (let* ((p (json-skip-ws s pos))
             (c (json-char s p)))
        (if (= c 110) (cons () (+ p 4))
          (if (= c 116) (cons #t (+ p 4))
            (if (= c 102) (cons #f (+ p 5))
              (if (= c 34) (json-parse-string-internal s p)
                (if (or (and (>= c 48) (<= c 57)) (= c 45))
                  (parse-number s p)
                  (if (= c 91) (parr (+ p 1))
                    (if (= c 123) (pobj (+ p 1))
                      (cons () p)))))))))))

  (car (pval 0)))

(display "loaded\n")
