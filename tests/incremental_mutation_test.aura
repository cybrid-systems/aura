; tests/incremental_mutation_test.aura — Issue #238 stress test
;
; Verifies acceptance criteria from the issue body:
;   - 100+ consecutive mutations: no consistency errors
;   - Re-lower scope is bounded (cascade_scope when mutating shared = 9,
;     when mutating f0..f7 = 1)
;   - dep_graph_ edges + per-block dirty bitmask cooperate
;
; Observability counters are facade-only after #1450 — use (stats:get …).

(set-code "
(define (shared x) (+ x 1))
(define (f0 x) (shared (+ x 0)))
(define (f1 x) (shared (+ x 1)))
(define (f2 x) (shared (+ x 2)))
(define (f3 x) (shared (+ x 3)))
(define (f4 x) (shared (+ x 4)))
(define (f5 x) (shared (+ x 5)))
(define (f6 x) (shared (+ x 6)))
(define (f7 x) (shared (+ x 7)))
")
(eval-current)

(display "baseline-cache-size: ") (display (stats:get "compile:cache-size")) (newline)
(display "baseline-dirty-count: ") (display (stats:get "compile:dirty-count")) (newline)

;; All helpers as let-bindings (not set-code defines) so the
;; lambda body's `mutate:rebind` lookup path works correctly.
(let ((total-cycles 100)
      (cycle-target
        (lambda (i)
          (if (= 0 (mod i 9))
              "shared"
              (string-append "f" (number->string (- (mod i 9) 1))))))
      (run-one
        (lambda (i)
          (let ((target (cycle-target i)) (new-val (+ i 100)))
            (let ((body (string-append "(lambda (x) (+ x " (number->string new-val) "))")))
              (mutate:rebind target body "summary")))))
      (run-all
        (lambda (i mismatches)
          (if (>= i total-cycles)
              (begin
                (display "mutations-completed: ") (display total-cycles) (newline)
                (display "mismatches: ") (display mismatches) (newline)
                mismatches)
              (run-all (+ i 1) mismatches)))))

  ;; Phase 3: warmup re-eval (no mutation) - should preserve dirty=0
  (let ((pre-dirty (stats:get "compile:dirty-count")))
    (eval-current)
    (let ((post-dirty (stats:get "compile:dirty-count")))
      (display "warmup-no-mut-preserves-dirty: ")
      (display (if (= pre-dirty post-dirty) #t #f))
      (newline)))

  ;; Phase 4: run 100 mutation cycles
  (display "starting-cycles...") (newline)
  (run-all 0 0)
  (newline)

  ;; Phase 5: verify final cache state
  (display "final-cache-size: ") (display (stats:get "compile:cache-size")) (newline)
  (display "final-dirty-count: ") (display (stats:get "compile:dirty-count")) (newline)
  (display "dep-edges: ") (display (stats:get "compile:dep-edges")) (newline)

  ;; Phase 6: hit-rate proxy — (eval-current) without mutation
  ;; should not increase dirty-count.
  (let ((pre-dirty (stats:get "compile:dirty-count")))
    (eval-current)
    (let ((post-dirty (stats:get "compile:dirty-count")))
      (display "no-mut-preserves-dirty: ")
      (display (if (= pre-dirty post-dirty) #t #f))
      (newline)))

  (display "test-complete") (newline))
