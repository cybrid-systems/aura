; tests/benchmark_self_evolution.aura — Issue #1463 Phase 1 stub:
; Self-Evolution Closed-Loop Reliability Suite (multi-round
; atomic mutate + observe + decide).
;
; Import with: (import "tests/benchmark-self-evolution")
;
; Status: foundation-only. Single scenario (happy-path improvement)
; shipped today; 4 other scenarios + decision-metrics are deferred
; to #1463.1+ until the closed-loop rewrite + Agent Decision
; Metrics contract land.
;
; Design notes (do NOT remove when extending):
;
; 1. The benchmark FRAMEWORK (this file) is intentionally minimal —
;    just a run-self-evolution-bench function that takes a scenario
;    name + max-rounds and returns a summary. The scenarios
;    themselves are defined as small driver procs so future scenarios
;    can be added without touching the framework.
;
; 2. Metrics returned are placeholders today (zeros + a "scenario
;    completed" flag). When Decision Metrics contract lands, each
;    metric slot will read from the contract's exposed counters
;    instead of returning zeros. This is AC #3 in the issue body.
;
; 3. The benchmark does NOT replace tests/benchmark.py (the existing
;    single-shot EDSL task benchmark) — it complements it per
;    AC #6 of #1463. CI integration (AC #4) is a follow-up.

(require std/json)
(require std/agent)

;; ── Public API ───────────────────────────────────────────────────
;;
;; run-self-evolution-bench : scenario-name : max-rounds → summary
;;
;; scenario-name : symbol — one of :happy-path / :panic / :rollback /
;;                           :long-mutation / :steal. Today only
;;                           :happy-path is implemented.
;; max-rounds   : int — upper bound on loop iterations before
;;                        declaring the scenario as failed.
;;
;; Returns a JSON summary:
;;   { "scenario": "happy-path",
;;     "rounds_run": <int>,
;;     "success": <bool>,
;;     "metrics": { "loop_success_rate": 0.0,
;;                  "decision_accuracy": 0.0,
;;                  "rounds_to_success": 0,
;;                  "invariant_violations": 0 } }
;;
;; The metrics block is populated with zeros today — the agent-decision
;; counters are not yet exposed (follow-up #1463.1 wires Decision
;; Metrics contract). When the counters land, this function will
;; read them via the contract API.

(export run-self-evolution-bench
        list-scenarios
        self-evolution-bench-version)

(define self-evolution-bench-version "0.1.0-stub")

(define (list-scenarios)
  ;; Source of truth for which scenarios exist today.
  (list :happy-path))

(define (run-scenario-happy-path max-rounds)
  ;; AC #2 partial: happy-path scenario. Drives `auto-grow` for
  ;; `max-rounds` iterations against an empty program and counts
  ;; how many rounds it takes for auto-grow to report "no more
  ;; improvements" (i.e. the closed loop converged).
  ;;
  ;; The actual decision-quality verification (AC #3) is deferred
  ;; until Decision Metrics contract lands — for now we just count
  ;; iterations and report a heuristic success.
  (let loop ((rounds 0)
             (converged? #f))
    (cond
      ((>= rounds max-rounds)
       (make-summary :happy-path rounds #f))
      (converged?
       (make-summary :happy-path rounds #t))
      (else
       ;; Drive the closed loop one round. auto-grow returns void
       ;; when there's nothing more to do; otherwise it returns
       ;; the new program state.
       (let ((result (auto-grow)))
         (loop (+ rounds 1)
               (void? result)))))))

(define (make-summary scenario rounds success?)
  (json-string->jobject
    (format-json
      { "scenario": scenario
        "rounds_run": rounds
        "success": success?
        "metrics": { "loop_success_rate": (if success? 1.0 0.0)
                     "decision_accuracy": 0.0
                     "rounds_to_success": (if success? rounds 0)
                     "invariant_violations": 0 } })))

(define (run-self-evolution-bench scenario-name max-rounds)
  (cond
    ((eq? scenario-name :happy-path)
     (run-scenario-happy-path max-rounds))
    (else
     ;; Unknown scenario — return an error-shaped summary so the
     ;; caller can distinguish "scenario not implemented" from
     ;; "scenario ran and failed".
     (json-string->jobject
       (format-json
         { "scenario": scenario-name
           "rounds_run": 0
           "success": #f
           "error": "scenario-not-implemented" })))))

;; ── Driver entry point (for future tests/benchmark runner) ────
;;
;; Today this file is loaded via (import "tests/benchmark-self-evolution")
;; and driven by test_issue_1463.cpp. A future CI driver (#1463.4)
;; would invoke (run-self-evolution-bench :happy-path 50) and parse
;; the JSON summary against pass/fail thresholds.