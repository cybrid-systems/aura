; tests/self_bench.aura — Aura Self-Hosted EDSL Benchmark
;
; Replaces Python's benchmark intend loop with synthesize:test-driven.
; Run as: LLM_API_KEY="xxx" ./build/aura < tests/self_bench.aura
;
; Or with model: LLM_MODEL="grok-4.3" LLM_API_KEY="xxx" ./build/aura < tests/self_bench.aura

(require "std/synthesize-v2" all:)
(require "std/test" all:)
(require std/list std/json all:)

(define model (try (getenv "LLM_MODEL") (catch "deepseek-chat")))
(define max-a 3)

(display "=== Aura Self-Hosted EDSL Benchmark ===\n")
(display "Model: ")(display model)(newline)
(display "Max attempts: ")(display max-a)(newline)
(newline)

;; Define tasks inline: (name goal code tests)
(define tasks
  (list
    (list "arith-basic" "Implement (+ 2 3)" ""
          (list (list "(display (+ 2 3))" "5")))
    (list "lambda-simple" "Implement (lambda (x) (+ x 1))" ""
          (list (list "(display ((lambda (x) (+ x 1)) 5))" "6")))
    (list "add" "Define add: (define (add x y) (+ x y))" ""
          (list (list "(display (add 2 3))" "5")))))

(define total (length tasks))
(define passed 0)

(for-each
  (lambda (task)
    (let* ((name (list-ref task 0))
           (goal (list-ref task 1))
           (code (list-ref task 2))
           (tests (list-ref task 3)))
      (display "  [")(display name)(display "] ")
      (let* ((result (synthesize:test-driven name
                      :goal goal :code code :tests tests
                      :max-attempts max-a :model model))
             (ok (car result)))
        (if ok
          (begin (set! passed (+ passed 1))
                 (display "✅\n"))
          (display "❌\n")))))
  tasks)

(display "\n=== Results: ")(display passed)(display "/")(display total)
(newline)
