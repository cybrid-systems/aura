;; tests/commercial_readiness_io_json_persist.aura
;;
;; Sixth-pass audit: file I/O, JSON, and workspace persistence
;; primitives. These are critical for Agent deployment — an Agent
;; needs to load/save code (persist), read/write files (I/O), and
;; round-trip structured data (JSON).
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_io_json_persist.aura

(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display "  expected=") (display expected)
        (display "  actual=") (display actual)
        (newline))))

;; ═════════════════════════════════════════════════════════════════════════
;; JSON — round-trip structured data (issue #1135 et al)
;; ═════════════════════════════════════════════════════════════════════════
(require "std/json")
(expect "json-parse-int" (json-parse "42") 42)
(expect "json-parse-string" (json-parse "\"hello\"") "hello")
(expect "json-parse-list" (car (json-parse "[1, 2, 3]")) 1)
(expect "json-stringify-int" (json-stringify 42) "42")
(expect "json-stringify-list" (json-stringify (list 1 2 3)) "[1,2,3]")

;; ═════════════════════════════════════════════════════════════════════════
;; File I/O — primitives for reading/writing files
;; ═════════════════════════════════════════════════════════════════════════
;; Use /tmp which is always writable. Note the file path must NOT
;; already exist for the write test (or we may want to compare).
(expect "file-write-then-read"
  (begin
    (with-output-to-file "/tmp/aura_io_test.txt"
      (lambda () (display "hello aura")))
    (with-input-from-file "/tmp/aura_io_test.txt"
      (lambda () (read-line))))
  "hello aura")

;; ═════════════════════════════════════════════════════════════════════════
;; Workspace persistence — save/load Aura code
;; ═════════════════════════════════════════════════════════════════════════
;; Workspace snapshot / checkpoint APIs (issue #511 / #513 family).
;; Pin the names before testing semantics.
(expect "workspace-snapshot-exists"
  (procedure? workspace-snapshot)
  #t)

;; ═════════════════════════════════════════════════════════════════════════
;; Process primitives — issue #1460 / #1504 family
;; ═════════════════════════════════════════════════════════════════════════
(expect "current-time-int?"
  (integer? (current-time))
  #t)

;; ═════════════════════════════════════════════════════════════════════════
;; End marker
;; ═════════════════════════════════════════════════════════════════════════
(display "DONE")
(newline)