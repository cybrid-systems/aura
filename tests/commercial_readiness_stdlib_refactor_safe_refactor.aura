;; tests/commercial_readiness_stdlib_refactor_safe_refactor.aura
;;
;; Seventh-pass audit: EDSL refactor + safe-refactor primitives.
;; Both modules build on query/mutate EDSL primitives with try/catch
;; defensive patterns. Per Anqi 16:30 原语最小化原则, any bugs surfaced
;; here are stdlib composition fixes (not engine primitive gaps).
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_stdlib_refactor_safe_refactor.aura
;;
;; Scope notes:
;;   - refactor:extract-function is documented as a stub (returns string
;;     template, does not actually extract). Tested for contract stability
;;     only, NOT for AST mutation semantics.
;;   - refactor:inline-function is documented to rename callers with
;;     "-inlined" suffix, NOT to substitute call bodies. Tested for the
;;     documented rename behavior only.

;; ═════════════════════════════════════════════════════════════════════════
;; Custom inline check framework
;; ═════════════════════════════════════════════════════════════════════════
(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " expected=") (display expected)
        (display " actual=") (display actual)
        (newline))))

(define (expect-true label actual)
  (if (and (not (null? actual)) (not (equal? actual #f)) (not (equal? actual 0)))
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " actual=") (display actual)
        (newline))))

(define (expect-no-error label thunk)
  (let ((result (try (thunk) (catch 'threw-error))))
    (if (not (eq? result 'threw-error))
        (begin (display "PASS: ") (display label) (newline))
        (begin
          (display "FAIL: ") (display label)
          (display " (threw error)")
          (newline)))))

;; ═════════════════════════════════════════════════════════════════════════
;; std/refactor — no-workspace contract (run BEFORE safe-refactor mutates
;; workspace state via set-code in tests below)
;; ═════════════════════════════════════════════════════════════════════════
(require "std/refactor")

;; ── refactor: API surface stability ──
(expect-no-error "rf-exports-callable"
  (lambda ()
    (expect-true "rf-rename-var-is-procedure" (procedure? refactor:rename-var))
    (expect-true "rf-extract-function-is-procedure" (procedure? refactor:extract-function))
    (expect-true "rf-inline-function-is-procedure" (procedure? refactor:inline-function))))

;; ── refactor:rename-var — no workspace must return #f (contract) ──
;; Without a current code set, query:node-type returns the
;; (no-workspace no workspace AST loaded) sentinel. After the d3be89db fix
;; (now in HEAD), refactor:ids? detects this sentinel (car is symbol, not
;; number) and returns #f instead of walking it as a list of IDs.
(expect "rf-rename-var-no-workspace-returns-false"
  (refactor:rename-var "x" "y") #f)
(expect "rf-rename-var-empty-old-no-ws"
  (refactor:rename-var "" "") #f)
(expect "rf-inline-function-no-workspace-returns-false"
  (refactor:inline-function "nonexistent-xyz") #f)

;; ── refactor:extract-function — documented stub contract ──
;; Per comment, currently a stub returning string template.
;; Should NOT crash on edge cases.
(expect-no-error "rf-extract-empty-ids"
  (lambda ()
    (let ((r (refactor:extract-function '() "newfn")))
      (display "  extract-empty-ids result type: ")
      (display (cond ((string? r) "string") ((null? r) "null") ((eq? r #f) "false") (else "other")))
      (newline))))

(expect-no-error "rf-extract-empty-fn-name"
  (lambda ()
    (let ((r (refactor:extract-function '(1 2 3) "")))
      (display "  extract-empty-name result type: ")
      (display (cond ((string? r) "string") ((null? r) "null") ((eq? r #f) "false") (else "other")))
      (newline))))

;; ═════════════════════════════════════════════════════════════════════════
;; std/safe-refactor — snapshot/rollback + verification-gated refactor
;; ═════════════════════════════════════════════════════════════════════════
(require "std/safe-refactor")

;; ── safe-refactor:with-snapshot — happy path ──
(expect-no-error "sr-with-snapshot-returns-result"
  (lambda ()
    (let ((r (safe-refactor:with-snapshot "test-snap-happy"
              (lambda () 42))))
      (expect "sr-with-snapshot-value" r 42))))

;; thunk returning 'fail triggers explicit-fail rollback
(expect-no-error "sr-with-snapshot-fail-rollback"
  (lambda ()
    (let ((r (safe-refactor:with-snapshot "test-snap-fail"
              (lambda () 'fail))))
      (expect "sr-with-snapshot-fail-value" r (list 'rolled-back "explicit-fail")))))

;; thunk that throws triggers error-raised rollback
(expect-no-error "sr-with-snapshot-throw-rollback"
  (lambda ()
    (let ((r (safe-refactor:with-snapshot "test-snap-throw"
              (lambda () (error "boom")))))
      (expect "sr-with-snapshot-throw-value" r (list 'rolled-back "error-raised")))))

;; nested with-snapshot
(expect-no-error "sr-with-snapshot-nested"
  (lambda ()
    (let ((r (safe-refactor:with-snapshot "outer"
              (lambda ()
                (safe-refactor:with-snapshot "inner"
                  (lambda () 'inner-result))))))
      (expect "sr-with-snapshot-nested-result" r 'inner-result))))

;; ── safe-refactor:check-and-apply — verification gates ──
;; pre-verify false → rejected
(expect-no-error "sr-check-apply-pre-verify-false"
  (lambda ()
    (let ((r (safe-refactor:check-and-apply
              (lambda () #f)
              (lambda () #t)
              (lambda () 'applied-result))))
      (expect "sr-check-apply-pre-reject" r (list 'rejected "pre-verify-failed")))))

;; pre-verify true, post-verify true, apply returns value → applied
(expect-no-error "sr-check-apply-success"
  (lambda ()
    (let ((r (safe-refactor:check-and-apply
              (lambda () #t)
              (lambda () #t)
              (lambda () 'ok-value))))
      (expect "sr-check-apply-success-result" r (list 'applied 'ok-value)))))

;; pre-verify true, apply throws → error
(expect-no-error "sr-check-apply-throw"
  (lambda ()
    (let ((r (safe-refactor:check-and-apply
              (lambda () #t)
              (lambda () #t)
              (lambda () (error "apply boom")))))
      (expect "sr-check-apply-throw-result" r (list 'error "apply-error-raised")))))

;; pre-verify true, apply ok, post-verify false → rolled-back
(expect-no-error "sr-check-apply-post-verify-false"
  (lambda ()
    (let ((r (safe-refactor:check-and-apply
              (lambda () #t)
              (lambda () #f)
              (lambda () 'ok-value))))
      (expect "sr-check-apply-post-reject" r (list 'rolled-back "post-verify-failed")))))

;; ── safe-refactor:replace-fn — atomic replacement + typecheck gate ──
;; empty source → rejected
(expect-no-error "sr-replace-fn-empty-source"
  (lambda ()
    (let ((r (safe-refactor:replace-fn "foo" "(define (foo x) (* x 2))")))
      ;; Could be either rejected "empty-source-or-body" or rejected "typecheck-failed"
      ;; depending on whether current-source returns empty in this context
      (display "  status: ") (display r) (newline))))

;; empty body → rejected
(expect-no-error "sr-replace-fn-empty-body"
  (lambda ()
    (let ((r (safe-refactor:replace-fn "foo" "")))
      (display "  status: ") (display r) (newline))))

;; Both empty → rejected "empty-source-or-body"
(expect-no-error "sr-replace-fn-both-empty"
  (lambda ()
    (let ((r (safe-refactor:replace-fn "" "")))
      (display "  status: ") (display r) (newline))))

;; ── safe-refactor:rollback — last-snapshot restore ──
(expect-no-error "sr-rollback-no-snapshots"
  (lambda ()
    ;; If there are no safe-refactor snapshots, returns #f
    (let ((r (safe-refactor:rollback)))
      (display "  rollback-no-snap result: ") (display r) (newline))))

;; ── safe-refactor API surface stability ──
;; exports should be present and callable
(expect-no-error "sr-exports-callable"
  (lambda ()
    (expect-true "sr-with-snapshot-is-procedure" (procedure? safe-refactor:with-snapshot))
    (expect-true "sr-check-and-apply-is-procedure" (procedure? safe-refactor:check-and-apply))
    (expect-true "sr-replace-fn-is-procedure" (procedure? safe-refactor:replace-fn))
    (expect-true "sr-rollback-is-procedure" (procedure? safe-refactor:rollback))))

;; ═════════════════════════════════════════════════════════════════════════
;; std/refactor — workspace-state tests (run AFTER safe-refactor has set
;; code via set-code). At this point workspace exists, so rename-var
;; processes real IDs and returns a count.
;; ═════════════════════════════════════════════════════════════════════════
;; ── refactor:inline-function — no matching function / no callers ──
(expect-no-error "rf-inline-no-match"
  (lambda ()
    (let ((r (refactor:inline-function "nonexistent-function-xyz")))
      (display "  inline-no-match: ") (display r) (newline))))

;; ═════════════════════════════════════════════════════════════════════════
;; Cross-module smoke: safe-refactor composes with refactor primitives
;; ═════════════════════════════════════════════════════════════════════════
(expect-no-error "x-module-smoke-safe-then-rename"
  (lambda ()
    (let ((result (safe-refactor:with-snapshot "composite-smoke"
                   (lambda ()
                     (let ((rv (refactor:rename-var "a" "b")))
                       (list 'rename rv))))))
      (display "  composite: ") (display result) (newline))))

;; ═════════════════════════════════════════════════════════════════════════
;; Summary
;; ═════════════════════════════════════════════════════════════════════════
(display "\n=== refactor + safe-refactor audit done ===\n")
