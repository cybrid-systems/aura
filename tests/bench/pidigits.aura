; ── pidigits (Aura, unrolled) — Computer Language Benchmarks Game ──
; Gibbons unbounded spigot (Mr Ledrug's C port) via GMP FFI. N=27.
; Unrolled to 112 top-level ops. Generated by scripts/gen_pidigits.py.

; WHY UNROLLED — Aura's FFI closures (c-func) cannot be invoked from
; inside a user closure (lambda / while-body / named-let body): the FFI
; dispatch is silently skipped at that call site, so a while/named-let
; loop calling GMP does not execute. FFI DOES work from top-level inline
; begin/if. So this file pre-simulates the algorithm in Python, records
; each next_term / emit / eliminate step, and emits the exact top-level
; GMP call sequence. Every GMP call is a real GMP call at runtime; only
; the loop control flow is pre-unrolled. Output is byte-identical to the
; reference (10 digits/line, tab, :count; trailing-space padding + :count
; on the last partial line).

; NOTE on Aura integer limits: this port REQUIRES GMP (arbitrary precision)
; because the algorithm's num/den/acc grow without bound — Aura's native
; integers are int64 fixnums and overflow silently. GMP is loaded via the
; c-load/c-func FFI; libgmp must be present (Homebrew: /opt/homebrew/lib).

(begin
  (define libgmp (c-load "/opt/homebrew/lib/libgmp.dylib"))
  (define SZ 256)
  (define mpz-init (c-func libgmp "__gmpz_init" 1 1))
  (define mpz-init-set-ui (c-func libgmp "__gmpz_init_set_ui" 1 1 1))
  (define mpz-mul-ui (c-func libgmp "__gmpz_mul_ui" 1 1 1 1))
  (define mpz-add (c-func libgmp "__gmpz_add" 1 1 1 1))
  (define mpz-tdiv-q (c-func libgmp "__gmpz_tdiv_q" 1 1 1 1))
  (define mpz-get-ui (c-func libgmp "__gmpz_get_ui" 1 1))
  (define mpz-submul-ui (c-func libgmp "__gmpz_submul_ui" 1 1 1 1))
  (define mpz-addmul-ui (c-func libgmp "__gmpz_addmul_ui" 1 1 1 1))
  (define tmp1 (c-alloc SZ)) (define tmp2 (c-alloc SZ))
  (define acc (c-alloc SZ)) (define den (c-alloc SZ)) (define num (c-alloc SZ))
  (define t1 (c-opaque->int tmp1)) (define t2 (c-opaque->int tmp2))
  (define ap (c-opaque->int acc)) (define dp (c-opaque->int den)) (define np (c-opaque->int num))
  (mpz-init t1) (mpz-init t2)
  (mpz-init-set-ui ap 0) (mpz-init-set-ui dp 1) (mpz-init-set-ui np 1)

  (mpz-addmul-ui ap np 2) (mpz-mul-ui ap ap 3) (mpz-mul-ui dp dp 3) (mpz-mul-ui np np 1)
  (display "3")
  (mpz-submul-ui ap dp 3) (mpz-mul-ui ap ap 10) (mpz-mul-ui np np 10)
  (mpz-addmul-ui ap np 2) (mpz-mul-ui ap ap 5) (mpz-mul-ui dp dp 5) (mpz-mul-ui np np 2)
