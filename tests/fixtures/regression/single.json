    "expect_err": ""
  },
  {
    "name": "mat-identity",
    "code": "(require \"std/vector-math\" all:)(mat:ref (mat:identity 3) 1 1)",
    "expect_out": "1",
    "expect_err": ""
  },
  {
    "name": "thread-pool-enqueue-stdin",
    "code": "(display (thread_pool:enqueue (lambda () (+ 1 2))))",
    "expect_out": "3",
    "expect_err": ""
  },
  {
    "name": "letrec-poly",
    "code": "(letrec ((id (lambda (x) x)))(display (id 99))(display (id #f)))",
