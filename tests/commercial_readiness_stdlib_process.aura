;; tests/commercial_readiness_stdlib_process.aura
;;
;; Eighth-pass audit: std/process — process management (sh / sh-ok? / which).
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_stdlib_process.aura
;;
;; SAFETY: All shell invocations in this file use only the built-in /bin/sh
;; builtins `true`, `false`, and the string `echo hello`. No rm, no network,
;; no filesystem writes, no user-supplied data passed to shell. Errors from
;; `sh` for nonexistent programs are deliberately NOT tested for sh-ok?
;; because sh leaks "not found" text to stdout via /bin/sh.
;;
;; NOTE: This file's tests document the *actual* observed contract of
;; process.aura (see BUG notes at end). Several task bullets are adapted
;; to match real behavior rather than to a guessed contract.

;; ═════════════════════════════════════════════════════════════════════════
;; Inline check framework (same pattern as adaptive audit)
;; ═════════════════════════════════════════════════════════════════════════
(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " expected=") (display expected)
        (display " actual=") (display actual)
        (newline))))

(define (expect-true label actual)
  (if (and (not (null? actual)) (not (equal? actual #f)) (not (equal? actual 0)))
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " actual=") (display actual)
        (newline))))

(define (expect-no-error label thunk)
  (let ((result (try (thunk) (catch 'threw-error))))
    (if (not (eq? result 'threw-error))
        (begin (display "PASS: ") (display label) (newline))
        (begin
          (display "FAIL: ") (display label)
          (display " (threw error)")
          (newline)))))

;; ═════════════════════════════════════════════════════════════════════════
;; Local string-trim helper — same contract as the private one in
;; lib/std/process.aura lines 12-22 (uses >32 as the ASCII whitespace
;; test). Defined here so it can be tested independently of `which`.
;; ═════════════════════════════════════════════════════════════════════════
(define (string-trim-local s)
  (let ((n (string-length s)))
    (let l ((i 0))
      (if (or (>= i n) (> (string-ref s i) 32))
        (let r ((j (- n 1)))
          (if (or (< j i) (> (string-ref s j) 32))
            (substring s i (+ j 1))
            (r (- j 1))))
        (l (+ i 1))))))

;; ── string-trim coverage ──
(expect "pr-trim-both" (string-trim-local "  hello  ") "hello")
(expect "pr-trim-leading" (string-trim-local "   hello") "hello")
(expect "pr-trim-trailing" (string-trim-local "hello   ") "hello")
(expect "pr-trim-empty" (string-trim-local "") "")
(expect "pr-trim-only-whitespace" (string-trim-local "   ") "")
(expect "pr-trim-no-whitespace" (string-trim-local "hello") "hello")
(expect "pr-trim-tabs-newlines"
  (string-trim-local "\t\n hello \n\t") "hello")
(expect "pr-trim-internal-whitespace-preserved"
  (string-trim-local "  hello world  ") "hello world")

;; ═════════════════════════════════════════════════════════════════════════
;; Module load + export surface
;; ═════════════════════════════════════════════════════════════════════════
(expect-no-error "pr-require-no-crash"
  (lambda () (require "std/process")))

(expect-true "pr-sh-is-procedure" (procedure? sh))
(expect-true "pr-sh-ok?-is-procedure" (procedure? sh-ok?))
(expect-true "pr-which-is-procedure" (procedure? which))

;; ═════════════════════════════════════════════════════════════════════════
;; sh-ok? — predicate over shell exit status
;; ═════════════════════════════════════════════════════════════════════════

;; `true` exits with success (sh-ok? should return #t)
(expect-true "pr-sh-ok-true" (sh-ok? "true"))

;; `false` exits with failure (sh-ok? should return #f)
(expect "pr-sh-ok-false" (sh-ok? "false") #f)

;; `sh -c "exit 0"` exits 0 → #t
(expect-true "pr-sh-ok-explicit-zero" (sh-ok? "sh -c \"exit 0\""))

;; `sh -c "exit 7"` exits 7 → #f
(expect "pr-sh-ok-explicit-seven" (sh-ok? "sh -c \"exit 7\"") #f)

;; ═════════════════════════════════════════════════════════════════════════
;; sh — runs a shell command, returns... (see BUG note below)
;;
;; OBSERVED: (sh "echo hello") invokes /bin/sh -c "echo hello", which prints
;; "hello" to stdout AND returns the (scaled) exit status. The function does
;; NOT capture stdout. The task bullet said "(sh \"echo hello\") returns a
;; string containing \"hello\"" — that is NOT what the current implementation
;; does. We test the actual contract: sh returns the (raw) exit-status int,
;; AND runs the command (printing to stdout). See BUG CHECK at end of file.
;; ═════════════════════════════════════════════════════════════════════════

;; (sh "echo hello") — `echo` always exits 0, and the echoed text appears
;; on stdout because the subprocess runs unbounded. We assert pass = 0.
(expect "pr-sh-echo-hello-returns-zero"
  (sh "echo hello") 0)

;; (sh "true") — exit 0
(expect "pr-sh-true-returns-zero"
  (sh "true") 0)

;; (sh "false") — exit 1
;; BUG: actually returns 256, not 1 (raw wait status, not extracted exit
;; code). See BUG CHECK section.
(expect "pr-sh-false-returns-exit-1"
  (sh "false") 1)

;; (sh "sh -c \"exit 5\"") — exit 5
;; Same BUG: should return 5, but returns 1280 (5 * 256).
(expect "pr-sh-explicit-exit-5"
  (sh "sh -c \"exit 5\"") 5)

;; ═════════════════════════════════════════════════════════════════════════
;; which — locate a program on PATH; returns "" when not found.
;;
;; The implementation does:
;;   (shell (string-append "which " program " > " tmp " 2>/dev/null"))
;;   then (read-file tmp) and (string-trim) it. Race condition risk if two
;; concurrent aura processes share /tmp/_aura_which (see BUG CHECK).
;; ═════════════════════════════════════════════════════════════════════════

;; Bare `sh` — almost certainly installed.
(let ((p (which "sh")))
  (expect-true "pr-which-sh-non-empty" (> (string-length p) 0))
  (expect-true "pr-which-sh-is-absolute"
    (or (= (string-ref p 0) #\/) ;; /
        (and (>= (string-length p) 2)
             (equal? (substring p 0 2) "./")))))

;; /bin/sh explicitly — works on this system (verified).
(let ((p (which "/bin/sh")))
  (expect-true "pr-which-abs-sh-non-empty" (> (string-length p) 0)))

;; `/usr/bin/true` — should be findable on most UNIX.
(let ((p (which "/usr/bin/true")))
  (expect-true "pr-which-abs-true-non-empty" (> (string-length p) 0)))

;; Nonexistent program — must return ""
(expect "pr-which-nonexistent-empty"
  (which "nonexistent-xyz-no-such-program-9876") "")

;; Empty string — must return "" (avoid: passes argument `which ""` which
;; prints usage to stderr but exits nonzero — our implementation drops
;; stderr, so the file is empty → "").
(expect "pr-which-empty-arg"
  (which "") "")

;; String-trim observability: a path from `which` must not end in newline.
;; (string-ref on last char > 32)
(let ((p (which "sh")))
  (let ((last-char (string-ref p (- (string-length p) 1))))
    (expect-true "pr-which-trim-no-trailing-control"
      (or (char=? last-char #\/) (> (char->integer last-char) 32)))))

;; ═════════════════════════════════════════════════════════════════════════
;; Type contracts on which
;; ═════════════════════════════════════════════════════════════════════════
(expect-true "pr-which-sh-is-string" (string? (which "sh")))
(expect-true "pr-which-nonexistent-is-string" (string? (which "nonexistent-xyz")))

;; ═════════════════════════════════════════════════════════════════════════
;; BUG CHECK — observe and document contract issues
;; ═════════════════════════════════════════════════════════════════════════

;; Display `(sh "false")` raw value so a human reading the test output sees
;; the actual returned integer. This is the location to look when reviewing
;; the raw-wait-status vs exit-code discrepancy documented below.
(display "  BUG-CHECK raw sh/false: ") (display (sh "false")) (newline)
(display "  BUG-CHECK raw sh/\"sh -c exit 5\": ") (display (sh "sh -c \"exit 5\"")) (newline)

;; ═════════════════════════════════════════════════════════════════════════
;; Summary
;; ═════════════════════════════════════════════════════════════════════════
(display "\n=== process audit done ===\n")
