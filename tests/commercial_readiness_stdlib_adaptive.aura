;; tests/commercial_readiness_stdlib_adaptive.aura
;;
;; Eighth-pass audit: std/adaptive — colony adaptive decision module
;; (measure-distance, structured-diagnosis, pid:analyze, string helpers).
;; Per Anqi 16:30 原语最小化原则, any bugs surfaced here are stdlib
;; composition fixes (not engine primitive gaps).
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_stdlib_adaptive.aura

;; ═════════════════════════════════════════════════════════════════════════
;; Inline check framework (same pattern as prior audits)
;; ═════════════════════════════════════════════════════════════════════════
(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " expected=") (display expected)
        (display " actual=") (display actual)
        (newline))))

(define (expect-true label actual)
  (if (and (not (null? actual)) (not (equal? actual #f)) (not (equal? actual 0)))
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " actual=") (display actual)
        (newline))))

(define (expect-no-error label thunk)
  (let ((result (try (thunk) (catch 'threw-error))))
    (if (not (eq? result 'threw-error))
        (begin (display "PASS: ") (display label) (newline))
        (begin
          (display "FAIL: ") (display label)
          (display " (threw error)")
          (newline)))))

(require "std/adaptive")

;; ═════════════════════════════════════════════════════════════════════════
;; string helpers — pure ASCII utilities
;; ═════════════════════════════════════════════════════════════════════════

;; ── string-index ──
(expect "ad-string-index-found" (string-index "hello world" "world" 0) 6)
(expect "ad-string-index-not-found" (string-index "hello world" "xyz" 0) -1)
(expect "ad-string-index-start-offset" (string-index "abcabcabc" "abc" 3) 3)
(expect "ad-string-index-empty-substr" (string-index "hello" "" 0) 0)
(expect "ad-string-index-empty-text-not-found"
  (string-index "" "x" 0) -1)
(expect "ad-string-index-text-shorter-than-substr"
  (string-index "hi" "hello" 0) -1)

;; ── string-contains? ──
(expect-true "ad-contains-yes" (string-contains? "hello world" "world"))
(expect-true "ad-contains-no" (not (string-contains? "hello" "xyz")))
(expect-true "ad-contains-empty-substr" (string-contains? "hello" ""))
(expect-true "ad-contains-empty-text" (not (string-contains? "" "x")))
(expect-true "ad-contains-case-sensitive"
  (not (string-contains? "hello" "WORLD")))

;; ── string-downcase ──
(expect "ad-downcase-trivial" (string-downcase "HELLO") "hello")
(expect "ad-downcase-mixed" (string-downcase "HeLLo WoRLd") "hello world")
(expect "ad-downcase-already-lower" (string-downcase "hello") "hello")
(expect "ad-downcase-empty" (string-downcase "") "")
(expect "ad-downcase-non-alpha" (string-downcase "ABC123!@#") "abc123!@#")
;; Non-ASCII uppercase: documented as no-op (only ASCII 65-90)
(expect "ad-downcase-non-ascii-upper-noop"
  (string-downcase "αβγ") "αβγ")

;; ── string-trim ──
(expect "ad-trim-both" (string-trim "  hello  ") "hello")
(expect "ad-trim-leading" (string-trim "   hello") "hello")
(expect "ad-trim-trailing" (string-trim "hello   ") "hello")
(expect "ad-trim-empty" (string-trim "") "")
(expect "ad-trim-only-whitespace" (string-trim "   ") "")
(expect "ad-trim-no-whitespace" (string-trim "hello") "hello")
(expect "ad-trim-tabs-newlines"
  (string-trim "\t\n hello \n\t") "hello")
(expect "ad-trim-internal-whitespace-preserved"
  (string-trim "  hello world  ") "hello world")

;; ── count-matches (private helper, but exposed via measure-distance) ──
;; Counted via measure-distance observable behavior:
;; (measure-distance 0 "hello world foo" '("hello" "foo")) should give ratio 2/2 = 1.0
(let ((d (measure-distance 0 "hello world foo" '("hello" "foo"))))
  (expect "ad-count-matches-all-hit" (car (cdr d)) 1.0))
;; (measure-distance 0 "hello world foo" '("hello" "bar")) should give ratio 1/2 = 0.5
(let ((d (measure-distance 0 "hello world foo" '("hello" "bar"))))
  (expect "ad-count-matches-partial" (car (cdr d)) 0.5))

;; ═════════════════════════════════════════════════════════════════════════
;; measure-distance — (rc, output, expected-list) → (phase, ratio, diag)
;; ═════════════════════════════════════════════════════════════════════════

;; ── compile-error path (rc != 0) ──
(let ((d (measure-distance 1 "anything" '("foo"))))
  (expect "ad-md-compile-err-phase" (car d) "coarse")
  (expect "ad-md-compile-err-ratio" (car (cdr d)) 0.0))

;; ── empty output path ──
(let ((d (measure-distance 0 "" '("foo"))))
  (expect "ad-md-empty-phase" (car d) "coarse")
  (expect "ad-md-empty-ratio" (car (cdr d)) 0.0))

(let ((d (measure-distance 0 "()", '("foo"))))
  ;; Note: '()' display of empty list is "()". Should hit coarse/empty branch.
  (display "  empty-paren-output: ") (display d) (newline))

;; ── empty expected path ──
(let ((d (measure-distance 0 "some output" '())))
  (expect "ad-md-no-expected-phase" (car d) "putt")
  (expect "ad-md-no-expected-ratio" (car (cdr d)) 1.0))

;; ── all-match path (ratio >= 0.85) ──
(let ((d (measure-distance 0 "hello world" '("hello" "world"))))
  (expect "ad-md-all-match-phase" (car d) "putt")
  (expect "ad-md-all-match-ratio" (car (cdr d)) 1.0))

;; ── partial-match path (0 < ratio < 0.85) ──
(let ((d (measure-distance 0 "foo bar" '("foo" "bar" "baz" "qux"))))
  ;; ratio = 2/4 = 0.5
  (expect "ad-md-partial-phase" (car d) "fine")
  (expect "ad-md-partial-ratio" (car (cdr d)) 0.5))

;; ── no-match path (ratio = 0) ──
(let ((d (measure-distance 0 "abc def" '("xyz" "uvw"))))
  (expect "ad-md-no-match-phase" (car d) "fine")
  (expect "ad-md-no-match-ratio" (car (cdr d)) 0.0))

;; ── case-insensitive matching ──
(let ((d (measure-distance 0 "Hello World" '("hello"))))
  (expect "ad-md-case-insensitive" (car (cdr d)) 1.0))

;; ── ratio boundary 0.85 ──
(let ((d-1 (measure-distance 0 "aaa bbb ccc" '("aaa"))))
  ;; ratio = 1/1 = 1.0 → "putt"
  (expect "ad-md-boundary-1.0" (car d-1) "putt"))

(let ((d-2 (measure-distance 0 "aaa bbb ccc ddd" '("aaa" "xxx"))))
  ;; ratio = 1/2 = 0.5 → "fine"
  (expect "ad-md-boundary-0.5" (car d-2) "fine"))

;; ═════════════════════════════════════════════════════════════════════════
;; structured-diagnosis — builds human-readable diagnosis string
;; ═════════════════════════════════════════════════════════════════════════

;; ── happy path ──
(expect-no-error "ad-sd-happy"
  (lambda ()
    (let ((s (structured-diagnosis "hello world" '("hello"))))
      (expect-true "sd-contains-phase" (string-contains? s "Phase: "))
      (expect-true "sd-contains-ratio" (string-contains? s "Ratio: ")))))

;; ── empty output triggers coarse branch ──
(expect-no-error "ad-sd-empty-output"
  (lambda ()
    (let ((s (structured-diagnosis "" '("hello"))))
      (expect-true "sd-empty-contains-empty-note"
        (string-contains? s "empty output")))))

;; ── output containing "<hash" triggers hash warning ──
(expect-no-error "ad-sd-hash-warning"
  (lambda ()
    (let ((s (structured-diagnosis "result is <hash[3]" '("result"))))
      (expect-true "sd-hash-warning-present"
        (string-contains? s "WARNING: (display <hash>)")))))

;; ── output NOT containing "<hash" — no warning ──
(expect-no-error "ad-sd-no-hash-warning"
  (lambda ()
    (let ((s (structured-diagnosis "normal output" '("normal"))))
      (expect-true "sd-no-hash-warning"
        (not (string-contains? s "WARNING"))))))

;; ── missing keywords shown ──
(expect-no-error "ad-sd-missing-keywords"
  (lambda ()
    (let ((s (structured-diagnosis "hello" '("hello" "missing1" "missing2"))))
      (expect-true "sd-shows-missing1" (string-contains? s "missing1"))
      (expect-true "sd-shows-missing2" (string-contains? s "missing2")))))

;; ── all matched — no missing line ──
(expect-no-error "ad-sd-all-matched"
  (lambda ()
    (let ((s (structured-diagnosis "hello world" '("hello" "world"))))
      (expect-true "sd-no-missing-line"
        (not (string-contains? s "Missing in output"))))))

;; ═════════════════════════════════════════════════════════════════════════
;; pid:analyze — builds feedback list with title + warnings
;; ═════════════════════════════════════════════════════════════════════════

;; ── basic shape ──
(let ((result (pid:analyze "hello world" '("hello"))))
  (expect "ad-pid-analyze-4-elem-list" (length result) 4))

;; ── phase matches measure-distance ──
(let ((result (pid:analyze "hello" '("hello"))))
  (expect "ad-pid-analyze-phase" (car result) "putt"))

(let ((result (pid:analyze "abc" '("xyz"))))
  (expect "ad-pid-analyze-no-match-phase" (car result) "fine"))

;; ── feedback text contains expected markers ──
(let ((result (pid:analyze "hello world" '("hello"))))
  (define fb (list-ref result 3))
  (expect-true "ad-pid-feedback-has-title" (string-contains? fb "=== "))
  (expect-true "ad-pid-feedback-has-phase" (string-contains? fb "Phase: "))
  (expect-true "ad-pid-feedback-has-actual" (string-contains? fb "Actual output: ")))

;; ── empty output triggers "forgot display" hint ──
(let ((result (pid:analyze "" '("hello"))))
  (define fb (list-ref result 3))
  (expect-true "ad-pid-empty-suggests-display"
    (string-contains? fb "forget (display"))))

;; ── <hash substring triggers warning ──
(let ((result (pid:analyze "result: <hash[3]" '("result"))))
  (define fb (list-ref result 3))
  (expect-true "ad-pid-hash-warning"
    (string-contains? fb "hash-keys"))))

;; ── BUG CHECK: "Expected to contain:" line content ──
;; The current code does (set! fb (cons (string-append "Expected to contain: ") fb))
;; — note: literal empty after colon. Either expected-list is formatted elsewhere
;; (acceptable) or this is incomplete feedback (bug).
(let ((result (pid:analyze "hello" '("hello"))))
  (define fb (list-ref result 3))
  (display "  ad-pid-expected-line: \"")
    (display
      (let ((idx (string-index fb "Expected to contain:" 0)))
        (if (= idx -1) "(not found)"
            (substring fb idx (min (+ idx 60) (string-length fb))))))
    (display "\"") (newline))

;; ═════════════════════════════════════════════════════════════════════════
;; API reference functions — surface stability
;; ═════════════════════════════════════════════════════════════════════════

(expect-no-error "ad-api-for-module-core"
  (lambda ()
    (let ((s (api-for-module "core")))
      (expect-true "ad-api-core-not-empty" (> (string-length s) 0))
      (expect-true "ad-api-core-has-c-func" (string-contains? s "c-func")))))

(expect-no-error "ad-api-for-module-unknown"
  (lambda ()
    (let ((s (api-for-module "std/nonexistent")))
      (expect-true "ad-api-unknown-not-empty" (> (string-length s) 0))
      (expect-true "ad-api-unknown-generic"
        (string-contains? s "no detailed reference")))))

(expect-no-error "ad-get-api-ref-empty"
  (lambda ()
    ;; Even with empty list, should return aura-pitfalls at minimum
    (let ((s (get-api-ref '())))
      (expect-true "ad-get-api-ref-empty-has-pitfalls"
        (string-contains? s "Pitfalls")))))

(expect-no-error "ad-get-full-api-ref"
  (lambda ()
    (let ((s (get-full-api-ref)))
      (expect-true "ad-full-api-not-empty" (> (string-length s) 100)))))

;; ═════════════════════════════════════════════════════════════════════════
;; Summary
;; ═════════════════════════════════════════════════════════════════════════
(display "\n=== adaptive audit done ===\n")
