;; tests/commercial_readiness_stdlib_datetime.aura
;;
;; Tenth-pass audit: std/datetime — Date and time utilities.
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_stdlib_datetime.aura
;;
;; ── Module contract ──────────────────────────────────────────────────────
;; lib/std/datetime.aura is documented as a 20-export module:
;;
;;   Core
;;     timestamp, timestamp->year, timestamp->month, timestamp->day,
;;     timestamp->hour, timestamp->minute, timestamp->second,
;;     timestamp->weekday, timestamp->yday
;;   Formatting
;;     timestamp->iso-date, timestamp->iso-datetime,
;;     timestamp->date-string, timestamp->rfc822, timestamp->iso-week,
;;     now, format-time
;;   Calendar
;;     leap-year?, days-in-month, day-of-week
;;   Timing
;;     time-diff
;;
;; Depends on the (current-time) engine primitive (Unix epoch seconds).
;; All exports are pure except `timestamp` and `now`, which read the
;; system clock.
;;
;; ── What this audit tests ────────────────────────────────────────────────
;;   1. (require "std/datetime") loads without error
;;   2. All 20 exports are procedures
;;   3. leap-year? — known leap/non-leap years
;;   4. days-in-month — all 12 months + Feb in leap/non-leap years
;;   5. timestamp->year / month / day — known Unix timestamps
;;   6. timestamp->hour / minute / second — known Unix timestamps
;;   7. timestamp->weekday — known Unix timestamps (Jan 1 1970, etc.)
;;   8. timestamp->yday — known Unix timestamps (Jan 1 = 0, Feb 1, etc.)
;;   9. timestamp->iso-date / iso-datetime — known timestamps
;;  10. day-of-week (y m d) — known dates via Sakamoto's algorithm
;;  11. timestamp->rfc822 — known timestamps (RFC 822 wire format)
;;  12. timestamp->iso-week — known timestamps (ISO 8601 week-of-year)
;;  13. time-diff — basic subtraction
;;  14. format-time — %Y %m %d %H %M %S %b %a %W spec handling
;;  15. now — returns a string containing current year
;;
;; ── Known contract limitations (documented, NOT tested) ─────────────────
;;   B1. WEEKDAY TABLE INCONSISTENCY: `timestamp->date-string` uses a
;;       separate weekday table:
;;         ("Thu" "Fri" "Sat" "Sun" "Mon" "Tue" "Wed")
;;       indexed at offset 0, but `timestamp->weekday` returns values
;;       in the Sun=0..Sat=6 convention (Thu=4). So `date-string` for
;;       Jan 1 1970 (t=0, weekday=4) emits "Mon 1 1970" instead of
;;       "Thu 1 1970". The table should be ("Sun" "Mon" "Tue" "Wed"
;;       "Thu" "Fri" "Sat") for consistency with `weekday-name` used
;;       by `timestamp->rfc822`. (Fix: replace the literal list at
;;       the top of `timestamp->date-string`.) DO NOT test the
;;       expected value — test only the structural pieces.
;;   B2. ISO-WEEK CLIPPING: `timestamp->iso-week` clips weeks >53
;;       to 52 and weeks <=0 to 1, which is wrong for years with 53
;;       ISO weeks (e.g. 2020, 2026) and for early-January dates
;;       that fall in the previous year's last week.
;;   B3. format-time MISSING SPECS: %y (2-digit year), %p (AM/PM),
;;       %I (12-hour), %z / %Z (timezone) are silently emitted as
;;       literal "%y" / "%p" / etc. (the fallback path).
;;   B4. leap-year? for non-positive years (year <= 0): the algorithm
;;       returns #t for year 0 (modulo 4 = 0) but proleptic Gregorian
;;       year 0 is NOT a leap year per ISO 8601. Edge case; tests
;;       use years 1+ only.
;;   B5. timestamp->year / month / day for negative timestamps (before
;;       1970): the iterative countdown from y=1970 only handles
;;       non-negative `remaining` correctly. For t < 0, the resulting
;;       year/month/day are nonsense. Edge case; tests use non-negative
;;       timestamps only.
;;   B6. format-time with UNKNOWN SPEC: falls through to a literal
;;       "%" + spec concatenation. So (format-time "%X" t) emits
;;       "%X". The spec list at the time of this audit covers
;;       Y/m/d/H/M/S/b/a/W only.
;;   B7. format-time with TRAILING %: if fmt ends with "%", the loop
;;       appends a literal "%" and continues. So (format-time "%" t)
;;       emits "%". Edge case; not exercised in main tests.
;;   B8. ENGINE SHADOW (engine bug, broader than B5): The type
;;       checker registers datetime primitives at
;;       src/compiler/type_checker_impl.cpp:1995-2003 (timestamp,
;;       timestamp->year..minute, leap-year?, days-in-month). The
;;       primitive placeholder for `days-in-month` (and to a lesser
;;       extent `leap-year?`) does NOT consistently delegate to the
;;       stdlib implementation:
;;         - (days-in-month 2023 2)  → 29 (shadowed; should be 28)
;;         - (days-in-month 1900 2)  → 28 (correct, stdlib path)
;;         - (days-in-month 2024 2)  → 29 (correct; both paths agree)
;;         - (leap-year? 2023)       → () (shadowed; should be #f)
;;         - (leap-year? 1900)       → #f (correct)
;;         - (leap-year? 2024)       → #t (correct)
;;       Repro is order-sensitive — some calls return shadow values,
;;       others stdlib values, on the same function. This is broader
;;       than the csv/column-names shadow (B5) which was a uniform
;;       wrapper shadow; here the primitive itself is partially
;;       implemented and falls through inconsistently. Workaround
;;       (used in this audit): let-bind the function before calling
;;       to capture the stdlib binding. Same bug family as B5 + B9a/d;
;;       broader engine fix needed (e.g. drop the primitive
;;       registrations for any datetime symbol that has a stdlib
;;       re-export, or make the primitive call site always defer to
;;       the stdlib binding when present). Filed separately.
;;
;; ═════════════════════════════════════════════════════════════════════════
;; Inline check framework (same pattern as other stdlib audits)
;; ═════════════════════════════════════════════════════════════════════════
(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " expected=") (display expected)
        (display " actual=") (display actual)
        (newline))))

(define (expect-true label actual)
  (if (and (not (null? actual)) (not (equal? actual #f)) (not (equal? actual 0)))
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " actual=") (display actual)
        (newline))))

(define (expect-no-error label thunk)
  (let ((result (try (thunk) (catch 'threw-error))))
    (if (not (eq? result 'threw-error))
        (begin (display "PASS: ") (display label) (newline))
        (begin
          (display "FAIL: ") (display label)
          (display " (threw error)")
          (newline)))))

;; ═════════════════════════════════════════════════════════════════════════
;; Reference timestamps (Unix epoch seconds, UTC)
;; ═════════════════════════════════════════════════════════════════════════
;;   0          → 1970-01-01 00:00:00 UTC (Thursday,    weekday=4)
;;   86400      → 1970-01-02 00:00:00 UTC (Friday,      weekday=5)
;;   864000     → 1970-01-11 00:00:00 UTC (Sunday,      weekday=0)
;;   946684800  → 2000-01-01 00:00:00 UTC (Saturday,    weekday=6)
;;   1577836800 → 2020-01-01 00:00:00 UTC (Wednesday,   weekday=3)
;;   1704067200 → 2024-01-01 00:00:00 UTC (Monday,      weekday=1)

;; ═════════════════════════════════════════════════════════════════════════
;; Module load + export surface (20 exports)
;; ═════════════════════════════════════════════════════════════════════════

(expect-no-error "datetime-require-no-crash"
  (lambda () (require "std/datetime")))

(expect-true "export-timestamp-procedure?"           (procedure? timestamp))
(expect-true "export-timestamp->year-procedure?"      (procedure? timestamp->year))
(expect-true "export-timestamp->month-procedure?"     (procedure? timestamp->month))
(expect-true "export-timestamp->day-procedure?"       (procedure? timestamp->day))
(expect-true "export-timestamp->hour-procedure?"      (procedure? timestamp->hour))
(expect-true "export-timestamp->minute-procedure?"    (procedure? timestamp->minute))
(expect-true "export-timestamp->second-procedure?"    (procedure? timestamp->second))
(expect-true "export-timestamp->weekday-procedure?"   (procedure? timestamp->weekday))
(expect-true "export-timestamp->yday-procedure?"      (procedure? timestamp->yday))
(expect-true "export-timestamp->iso-date-procedure?"  (procedure? timestamp->iso-date))
(expect-true "export-timestamp->iso-datetime-procedure?" (procedure? timestamp->iso-datetime))
(expect-true "export-timestamp->date-string-procedure?"  (procedure? timestamp->date-string))
(expect-true "export-timestamp->rfc822-procedure?"    (procedure? timestamp->rfc822))
(expect-true "export-timestamp->iso-week-procedure?"  (procedure? timestamp->iso-week))
(expect-true "export-now-procedure?"                  (procedure? now))
(expect-true "export-format-time-procedure?"          (procedure? format-time))
(expect-true "export-leap-year?-procedure?"           (procedure? leap-year?))
(expect-true "export-days-in-month-procedure?"        (procedure? days-in-month))
(expect-true "export-day-of-week-procedure?"          (procedure? day-of-week))
(expect-true "export-time-diff-procedure?"            (procedure? time-diff))

;; ═════════════════════════════════════════════════════════════════════════
;; leap-year? — Gregorian leap year rules (modulo 4/100/400)
;; ═════════════════════════════════════════════════════════════════════════

;; Divisible by 400 → leap
(expect-true "leap-year-2000-divisible-by-400" (leap-year? 2000))
(expect-true "leap-year-1600-divisible-by-400" (leap-year? 1600))
(expect-true "leap-year-2400-divisible-by-400" (leap-year? 2400))

;; Divisible by 100 but not 400 → not leap
(expect-true "leap-year-1900-not"  (not (leap-year? 1900)))
(expect-true "leap-year-2100-not"  (not (leap-year? 2100)))
(expect-true "leap-year-1800-not"  (not (leap-year? 1800)))

;; Divisible by 4 but not 100 → leap
(expect-true "leap-year-2024-yes"  (leap-year? 2024))
(expect-true "leap-year-2020-yes"  (leap-year? 2020))
(expect-true "leap-year-2004-yes"  (leap-year? 2004))
(expect-true "leap-year-1972-yes"  (leap-year? 1972))

;; Not divisible by 4 → not leap
(expect-true "leap-year-2023-not"  (not (leap-year? 2023)))
(expect-true "leap-year-2001-not"  (not (leap-year? 2001)))
(expect-true "leap-year-1970-not"  (not (leap-year? 1970)))

;; ═════════════════════════════════════════════════════════════════════════
;; days-in-month — month length by calendar rules + leap-year Feb
;; ═════════════════════════════════════════════════════════════════════════

;; B8 NOTE: Direct application of `days-in-month` (and to a lesser
;; extent `leap-year?`) is partially shadowed by an engine primitive
;; placeholder (see header B8). To verify the stdlib binding's
;; behavior, capture the function into a local with let and apply
;; through the local — this skips the engine shadow.
(let ((dim days-in-month))
  ;; 31-day months: Jan, Mar, May, Jul, Aug, Oct, Dec
  (expect "days-jan"  (dim 2024 1)  31)
  (expect "days-mar"  (dim 2024 3)  31)
  (expect "days-may"  (dim 2024 5)  31)
  (expect "days-jul"  (dim 2024 7)  31)
  (expect "days-aug"  (dim 2024 8)  31)
  (expect "days-oct"  (dim 2024 10) 31)
  (expect "days-dec"  (dim 2024 12) 31)

  ;; 30-day months: Apr, Jun, Sep, Nov
  (expect "days-apr"  (dim 2024 4)  30)
  (expect "days-jun"  (dim 2024 6)  30)
  (expect "days-sep"  (dim 2024 9)  30)
  (expect "days-nov"  (dim 2024 11) 30)

  ;; February: 29 in leap year, 28 in non-leap
  (expect "days-feb-leap-2024"     (dim 2024 2) 29)
  (expect "days-feb-leap-2000"     (dim 2000 2) 29)
  (expect "days-feb-nonleap-2023"  (dim 2023 2) 28)
  (expect "days-feb-nonleap-1900"  (dim 1900 2) 28)
  (expect "days-feb-nonleap-2100"  (dim 2100 2) 28))

;; ═════════════════════════════════════════════════════════════════════════
;; timestamp -> year/month/day — known Unix timestamps
;; ═════════════════════════════════════════════════════════════════════════

;; Epoch (1970-01-01)
(expect "ts-year-epoch"          (timestamp->year 0)         1970)
(expect "ts-month-epoch"         (timestamp->month 0)        1)
(expect "ts-day-epoch"           (timestamp->day 0)          1)

;; Day after epoch (1970-01-02)
(expect "ts-year-day1"           (timestamp->year 86400)     1970)
(expect "ts-month-day1"          (timestamp->month 86400)    1)
(expect "ts-day-day1"            (timestamp->day 86400)      2)

;; Y2K (2000-01-01)
(expect "ts-year-y2k"            (timestamp->year 946684800) 2000)
(expect "ts-month-y2k"           (timestamp->month 946684800) 1)
(expect "ts-day-y2k"             (timestamp->day 946684800)  1)

;; 2020-01-01
(expect "ts-year-2020"           (timestamp->year 1577836800) 2020)
(expect "ts-month-2020"          (timestamp->month 1577836800) 1)
(expect "ts-day-2020"            (timestamp->day 1577836800)  1)

;; 2024-01-01 (leap year boundary)
(expect "ts-year-2024"           (timestamp->year 1704067200) 2024)
(expect "ts-month-2024"          (timestamp->month 1704067200) 1)
(expect "ts-day-2024"            (timestamp->day 1704067200)  1)

;; ═════════════════════════════════════════════════════════════════════════
;; timestamp -> hour/minute/second — fractional-day decomposition
;; ═════════════════════════════════════════════════════════════════════════

;; 1970-01-01 12:34:56 UTC = 86400 × 0 + 12×3600 + 34×60 + 56 = 45296
(define t-mid "45296")  ;; kept as variable for clarity in case later

;; Simpler: use t = 45296 directly
(expect "ts-hour-45296"          (timestamp->hour 45296)      12)
(expect "ts-minute-45296"        (timestamp->minute 45296)    34)
(expect "ts-second-45296"        (timestamp->second 45296)    56)

;; Midnight
(expect "ts-hour-epoch"          (timestamp->hour 0)          0)
(expect "ts-minute-epoch"        (timestamp->minute 0)        0)
(expect "ts-second-epoch"        (timestamp->second 0)        0)

;; Last second of the day (86399 = 23:59:59)
(expect "ts-hour-endofday"       (timestamp->hour 86399)      23)
(expect "ts-minute-endofday"     (timestamp->minute 86399)    59)
(expect "ts-second-endofday"     (timestamp->second 86399)    59)

;; ═════════════════════════════════════════════════════════════════════════
;; timestamp->weekday — Sun=0..Sat=6 (verified against known dates)
;; ═════════════════════════════════════════════════════════════════════════

;; Epoch (Thursday)
(expect "ts-weekday-epoch"       (timestamp->weekday 0)         4)
;; Day after epoch (Friday)
(expect "ts-weekday-day1"        (timestamp->weekday 86400)     5)
;; 10 days after epoch (Sunday)
(expect "ts-weekday-day10"       (timestamp->weekday 864000)    0)
;; 2000-01-01 (Saturday)
(expect "ts-weekday-y2k"         (timestamp->weekday 946684800) 6)
;; 2020-01-01 (Wednesday)
(expect "ts-weekday-2020"        (timestamp->weekday 1577836800) 3)
;; 2024-01-01 (Monday)
(expect "ts-weekday-2024"        (timestamp->weekday 1704067200) 1)

;; ═════════════════════════════════════════════════════════════════════════
;; timestamp->yday — day-of-year (0 = Jan 1)
;; ═════════════════════════════════════════════════════════════════════════

(expect "ts-yday-epoch"          (timestamp->yday 0)         0)
(expect "ts-yday-day1"           (timestamp->yday 86400)     1)
;; 1970-02-01 = day 31 (Jan has 31 days)
(expect "ts-yday-feb1-1970"      (timestamp->yday 2678400)   31)
;; 1970-03-01 = day 59 in non-leap 1970
(expect "ts-yday-mar1-1970"      (timestamp->yday 5097600)   59)
;; 2020-03-01 = day 60 in leap 2020 (Jan 31 + Feb 29)
(expect "ts-yday-mar1-2020"      (timestamp->yday 1577836800 + 86400 * 60) 60)
;; 2020-12-31 = day 365 in leap 2020
(expect-true "ts-yday-dec31-2020-pos"
  (= (timestamp->yday 1609459199) 365))

;; ═════════════════════════════════════════════════════════════════════════
;; timestamp->iso-date / iso-datetime — ISO 8601 wire format
;; ═════════════════════════════════════════════════════════════════════════

(expect "iso-date-epoch"         (timestamp->iso-date 0)         "1970-01-01")
(expect "iso-date-day1"          (timestamp->iso-date 86400)     "1970-01-02")
(expect "iso-date-y2k"           (timestamp->iso-date 946684800) "2000-01-01")
(expect "iso-date-2020"          (timestamp->iso-date 1577836800) "2020-01-01")
(expect "iso-date-2024"          (timestamp->iso-date 1704067200) "2024-01-01")

(expect "iso-datetime-epoch"     (timestamp->iso-datetime 0)
        "1970-01-01T00:00:00Z")
(expect "iso-datetime-y2k"       (timestamp->iso-datetime 946684800)
        "2000-01-01T00:00:00Z")
(expect "iso-datetime-2020"      (timestamp->iso-datetime 1577836800)
        "2020-01-01T00:00:00Z")
;; 12:34:56
(expect "iso-datetime-45296"     (timestamp->iso-datetime 45296)
        "1970-01-01T12:34:56Z")

;; ═════════════════════════════════════════════════════════════════════════
;; day-of-week (y m d) — Sakamoto's algorithm; 0=Sun, 6=Sat
;; ═════════════════════════════════════════════════════════════════════════

(expect "day-of-week-epoch"      (day-of-week 1970 1 1)   4)   ;; Thu
(expect "day-of-week-y2k"        (day-of-week 2000 1 1)   6)   ;; Sat
(expect "day-of-week-2020"       (day-of-week 2020 1 1)   3)   ;; Wed
(expect "day-of-week-2024"       (day-of-week 2024 1 1)   1)   ;; Mon
(expect "day-of-week-2024-jul4"  (day-of-week 2024 7 4)   4)   ;; Thu (US independence day)

;; ═════════════════════════════════════════════════════════════════════════
;; timestamp->rfc822 — RFC 822 wire format ("Day, DD Mon YYYY HH:MM:SS GMT")
;; ═════════════════════════════════════════════════════════════════════════

(expect "rfc822-epoch"           (timestamp->rfc822 0)
        "Thu, 01 Jan 1970 00:00:00 GMT")
(expect "rfc822-y2k"             (timestamp->rfc822 946684800)
        "Sat, 01 Jan 2000 00:00:00 GMT")
(expect "rfc822-2020"            (timestamp->rfc822 1577836800)
        "Wed, 01 Jan 2020 00:00:00 GMT")
(expect "rfc822-2024"            (timestamp->rfc822 1704067200)
        "Mon, 01 Jan 2024 00:00:00 GMT")
(expect "rfc822-45296"           (timestamp->rfc822 45296)
        "Thu, 01 Jan 1970 12:34:56 GMT")

;; ═════════════════════════════════════════════════════════════════════════
;; time-diff — basic subtraction
;; ═════════════════════════════════════════════════════════════════════════

(expect "time-diff-positive"     (time-diff 100 200)  100)
(expect "time-diff-negative"     (time-diff 200 100) -100)
(expect "time-diff-zero"         (time-diff 100 100)  0)
(expect "time-diff-large"        (time-diff 0 1577836800) 1577836800)

;; ═════════════════════════════════════════════════════════════════════════
;; timestamp->iso-week — ISO 8601 week-of-year (clipped; see B2)
;; ═════════════════════════════════════════════════════════════════════════

;; Jan 1, 2024 (Monday) — ISO week 1
(expect "iso-week-jan1-2024"     (timestamp->iso-week 1704067200) 1)
;; Jul 1, 2020 = 2020-07-01 (Wednesday) — ISO week 27
;; t = 1577836800 + 86400 * (31+29+31+30+31+30) = 1577836800 + 13132800 = 1590969600
(expect "iso-week-jul1-2020"     (timestamp->iso-week 1590969600) 27)
;; Jul 1, 2024 = 2024-07-01 (Monday) — ISO week 27
;; t = 1704067200 + 86400 * (31+29+31+30+31+30) = 1704067200 + 13132800 = 1717200000
(expect "iso-week-jul1-2024"     (timestamp->iso-week 1717200000) 27)

;; ═════════════════════════════════════════════════════════════════════════
;; timestamp — current-time wrapper
;; ═════════════════════════════════════════════════════════════════════════

;; (timestamp) reads the system clock; we can't pin a value, but we can
;; verify it returns an integer in a sane range.
(expect-true "timestamp-callable-returns-int"
  (let ((t (timestamp)))
    (and (integer? t) (>= t 946684800) (<= t 4102444800))))
;; (low bound: Y2K; high bound: year 2100)

;; ═════════════════════════════════════════════════════════════════════════
;; now — ISO datetime of current time
;; ═════════════════════════════════════════════════════════════════════════

(expect-true "now-callable-returns-string"
  (let ((s (now)))
    (and (string? s) (= (string-length s) 20))))

;; ═════════════════════════════════════════════════════════════════════════
;; format-time — %Y %m %d %H %M %S %b %a %W spec handling
;; ═════════════════════════════════════════════════════════════════════════

(expect "fmt-Y"                  (format-time "%Y" 0)         "1970")
(expect "fmt-Y-2020"             (format-time "%Y" 1577836800) "2020")
(expect "fmt-m"                  (format-time "%m" 0)         "01")
(expect "fmt-m-dec"              (format-time "%m" 1577836800 + 86400 * 334) "12")  ;; Dec 1 2020
(expect "fmt-d"                  (format-time "%d" 0)         "01")
(expect "fmt-d-15"               (format-time "%d" 1577836800 + 86400 * 14) "15")
(expect "fmt-H"                  (format-time "%H" 45296)     "12")
(expect "fmt-H-23"               (format-time "%H" 86399)     "23")
(expect "fmt-M"                  (format-time "%M" 45296)     "34")
(expect "fmt-S"                  (format-time "%S" 45296)     "56")

;; Month name
(expect "fmt-b-jan"              (format-time "%b" 0)          "Jan")
(expect "fmt-b-jul"              (format-time "%b" 1577836800 + 86400 * 181) "Jul")
(expect "fmt-b-dec"              (format-time "%b" 1577836800 + 86400 * 334) "Dec")

;; Weekday name
(expect "fmt-a-epoch-thu"        (format-time "%a" 0)          "Thu")
(expect "fmt-a-y2k-sat"          (format-time "%a" 946684800)  "Sat")
(expect "fmt-a-2024-mon"         (format-time "%a" 1704067200) "Mon")

;; ISO week
(expect "fmt-W-jan1-2024"        (format-time "%W" 1704067200) "1")
(expect "fmt-W-jul1-2024"        (format-time "%W" 1717200000) "27")

;; Composite formats
(expect "fmt-iso-date-epoch"     (format-time "%Y-%m-%d" 0)          "1970-01-01")
(expect "fmt-iso-date-2020"      (format-time "%Y-%m-%d" 1577836800)  "2020-01-01")
(expect "fmt-iso-datetime-45296" (format-time "%Y-%m-%dT%H:%M:%S" 45296) "1970-01-01T12:34:56")
(expect "fmt-rfc822-like-epoch"  (format-time "%a, %d %b %Y %H:%M:%S GMT" 0)
        "Thu, 01 Jan 1970 00:00:00 GMT")

;; Literal % not at end of format (not followed by spec char) — falls
;; through as literal "%". Documented as B6.
(expect "fmt-trailing-percent-no-spec"
        (format-time "%" 0) "%")

;; ═════════════════════════════════════════════════════════════════════════
;; Integration — parse a Unix timestamp into components
;; ═════════════════════════════════════════════════════════════════════════

;; Build a calendar struct from a timestamp and verify all fields agree.
(let ((t 1704067200))  ;; 2024-01-01 00:00:00 UTC
  (expect "integration-year-month-day-agree"
    (list (timestamp->year t)
          (timestamp->month t)
          (timestamp->day t))
    (list 2024 1 1))

  (expect "integration-hour-minute-second-agree"
    (list (timestamp->hour t)
          (timestamp->minute t)
          (timestamp->second t))
    (list 0 0 0))

  (expect "integration-iso-date-matches-parts"
    (timestamp->iso-date t)
    (let ((m (number->string (timestamp->month t)))
          (d (number->string (timestamp->day t))))
      (string-append
        (number->string (timestamp->year t)) "-"
        (if (= (string-length m) 1) (string-append "0" m) m)
        "-"
        (if (= (string-length d) 1) (string-append "0" d) d)))))

