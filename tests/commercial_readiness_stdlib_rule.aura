;; tests/commercial_readiness_stdlib_rule.aura
;;
;; Pass 10 audit: std/rule - rule engine. Read-only paths only.
;; Skips rule:define / rule:remove / rule:enable / rule:disable /
;; rule:apply / rule:apply-all due to (set! *rules* ...) on top-level
;; var (same pattern that hangs ant.aura). Tests pure accessors +
;; empty-state early-return paths.
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_stdlib_rule.aura

(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " expected=") (display expected)
        (display " actual=") (display actual)
        (newline))))

(define (expect-true label actual)
  (if (and (not (null? actual)) (not (equal? actual #f)) (not (equal? actual 0)))
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " actual=") (display actual)
        (newline))))

;; ── require doesn't hang ──
(expect-true "rule-require-no-crash"
  (procedure? (lambda () (require "std/rule") #t)))

(require "std/rule")

;; ── accessors on synthetic rule ──
;; Rule = (name pattern replacement condition description enabled scope)
(let ((r '(my-rule "pat" "rep" #t "desc" #t :workspace)))
  (expect "rule-accessor-name" (rule-name r) 'my-rule)
  (expect "rule-accessor-pattern" (rule-pattern r) "pat")
  (expect "rule-accessor-replace" (rule-replace r) "rep")
  (expect "rule-accessor-condition" (rule-condition r) #t)
  (expect "rule-accessor-desc" (rule-desc r) "desc")
  (expect "rule-accessor-enabled" (rule-enabled? r) #t)
  (expect "rule-accessor-scope" (rule-scope r) :workspace))

;; ── find-rule returns #f for unknown (empty *rules* default) ──
(expect "rule-find-unknown" (find-rule "nonexistent-rule-xyz") #f)

;; ── rule:list on empty *rules* returns () ──
(expect "rule-list-empty" (rule:list) '())

;; ── rule:status with unknown returns #f ──
(expect "rule-status-unknown" (rule:status "nonexistent-rule-xyz") #f)

;; ── rule:apply with unknown returns 0 (early return) ──
(expect "rule-apply-unknown" (rule:apply "nonexistent-rule-xyz") 0)

;; ── rule:apply-all on empty *rules* returns 0 ──
(expect "rule-apply-all-empty" (rule:apply-all) 0)

;; ── rule:enable with unknown returns #f (early return, no set!) ──
(expect "rule-enable-unknown" (rule:enable "nonexistent-rule-xyz") #f)

;; ── rule:disable with unknown returns #f (early return, no set!) ──
(expect "rule-disable-unknown" (rule:disable "nonexistent-rule-xyz") #f)

;; ── rule:remove with unknown — actually DOES set! *rules*, may hang ──
;; Skipped intentionally. The hang is itself a documented bug.

;; ── rule:list-violations on empty *rules* returns () ──
(expect "rule-list-violations-empty" (rule:list-violations) '())

;; ── exports are callable ──
(expect-true "rule-export-rule-define" (procedure? rule:define))
(expect-true "rule-export-rule-apply" (procedure? rule:apply))
(expect-true "rule-export-rule-apply-all" (procedure? rule:apply-all))
(expect-true "rule-export-rule-list" (procedure? rule:list))
(expect-true "rule-export-rule-list-violations" (procedure? rule:list-violations))
(expect-true "rule-export-rule-status" (procedure? rule:status))
(expect-true "rule-export-rule-save" (procedure? rule:save))
(expect-true "rule-export-rule-load" (procedure? rule:load))

(display "\n=== rule audit done (read-only paths only) ===\n")
