;; === git_integration_demo.aura ===
;; Demo of the new git-* primitives (Issue #96).

;; Current state
(define branch (git-branch-current))
(define sha (git-rev-parse))
(define status (git-status))
(define log (git-log 3))

(display "Branch: ") (display branch) (newline)
(display "HEAD:   ") (display sha) (newline)
(display "---")
(display status) (newline)
(display "---")
(display "Last 3 commits:")
(display log) (newline)

