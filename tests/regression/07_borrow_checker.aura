;; task: m4-borrow-checker
;; goal: M4 静态借用检查 — 验证 borrow/move/drop 的正确拒绝和允许
;; expect: ok

;; Helper: run a thunk and return ok or the error message
(define (expect-error fn)
  (try (fn)
    (catch (e) (if (string? e) e (string e)))))

;; Helper: run a thunk and return ok or error
(define (expect-ok fn)
  (try (fn)
    (catch (e) "ERROR: expected ok but got error")))

;; ═══════════════════════════════════════════════════
;; 测试 1: borrow 后 move → 应该错误
;; ═══════════════════════════════════════════════════
(define res1
  (expect-error
    (lambda ()
      (let ((x (make-linear 42)))
        (let ((r (borrow x)))
          (move x)
          r)))))

(display "test1 borrow-then-move: ")
(display res1)
(newline)

;; ═══════════════════════════════════════════════════
;; 测试 2: mut-borrow 后 borrow → 应该错误
;; ═══════════════════════════════════════════════════
(define res2
  (expect-error
    (lambda ()
      (let ((x (make-linear 42)))
        (let ((r (mut-borrow x)))
          (borrow x)
          r)))))

(display "test2 mut-borrow-then-borrow: ")
(display res2)
(newline)

;; ═══════════════════════════════════════════════════
;; 测试 3: 多次 imm-borrow → 应该允许
;; ═══════════════════════════════════════════════════
(define res3
  (expect-ok
    (lambda ()
      (let ((x (make-linear 42)))
        (let ((r1 (borrow x)))
          (let ((r2 (borrow x)))
            (+ (unwrap-linear r1) (unwrap-linear r2))))))))

(display "test3 multi-imm-borrow: ")
(display res3)
(newline)

;; ═══════════════════════════════════════════════════
;; 测试 4: borrow 在内部作用域，结束后可以 move → 应该允许
;; ═══════════════════════════════════════════════════
(define res4
  (expect-ok
    (lambda ()
      (let ((x (make-linear 42)))
        (begin
          (let ((r (borrow x)))
            (unwrap-linear r))
          (move x)
          42)))))

(display "test4 borrow-scope-end: ")
(display res4)
(newline)

;; ═══════════════════════════════════════════════════
;; 测试 5: mut-borrow 后 move → 应该错误
;; ═══════════════════════════════════════════════════
(define res5
  (expect-error
    (lambda ()
      (let ((x (make-linear 42)))
        (let ((r (mut-borrow x)))
          (move x)
          r)))))

(display "test5 mut-borrow-then-move: ")
(display res5)
(newline)

;; ═══════════════════════════════════════════════════
;; 结果
;; ═══════════════════════════════════════════════════
(display "ok")
(newline)
