;; Coercion benchmark — measure IR instruction count impact
;; These patterns should trigger CastOp insertion + elimination

;; 1. Direct annotation
;; expect: 42
(: x Int 42)

;; 2. Annotated arithmetic chain
;; expect: 10
(: x Int (+ 1 2 3 4))

;; 3. Nested annotations
;; expect: 30
(+ (: a Int 10) (: b Int 20))

;; 4. Lambda with annotation context
;; expect: 42
((lambda (x) x) 42)

;; 5. Let polymorphism
;; expect: 42hello
(let ((id (lambda (x) x)))
  (display (id 42))
  (display (id "hello")))
