;; tests/commercial_readiness_stdlib_string.aura
;;
;; Eighth-pass audit: std/string — string utilities (split/join/trim,
;; case conversion, contains?/prefix?/suffix?, replace, padding,
;; reverse, repeat, chars, take/drop).
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_stdlib_string.aura
;;
;; ── Module contract ──────────────────────────────────────────────────────
;; lib/std/string.aura is documented as a 17-export module:
;;   (export string-split string-split-words string-join string-trim
;;           string-upcase string-downcase
;;           string-contains? string-prefix? string-suffix? string-replace
;;           string-pad-left string-pad-right string-reverse string-repeat
;;           string->chars chars->string string-take string-drop)
;;
;; Internally all routines are pure .aura (no engine prims beyond
;; string-append / string-length / string-ref / substring / list
;; helpers). The module intentionally avoids requiring std/list
;; internally (per the file header — module eval runs in isolated
;; env, internal imports would pollute top_).
;;
;; ── What this audit tests ────────────────────────────────────────────────
;;   1. (require "std/string") loads without error
;;   2. All 17 named exports are procedures
;;   3. Functional smoke tests for each export — round-trips, edge cases
;;
;; ── Audit history (this session) ─────────────────────────────────────────
;;   B8a. (string-join (list "a" "b" "c") ",") returned "" instead of
;;        "a,b,c" for any depth ≥1. Root cause: the source had
;;        (string-append (car strs) sep (string-join (cdr strs) sep))
;;        which places the recursive call in the 3rd (non-tail)
;;        position of string-append; the engine does not TCO that
;;        pattern and the recursion returned "" per the B8 family
;;        described in tests/commercial_readiness_stdlib_surface.aura
;;        header (B8: "tail-recursive Scheme define functions with
;;        (f (cdr x) …) recursion return '' or () when the recursive
;;        arg is not let-bound. Affects std/string string-join,
;;        std/math gcd/lcm. Workaround: bind via let.").
;;        FIX APPLIED in lib/std/string.aura this session:
;;          (let ((rest (string-join (cdr strs) sep)))
;;            (string-append (car strs) sep rest))
;;        Now verified working at depths 1, 2, 3, 5 + multi-char sep +
;;        empty sep. Pattern noted for future similar stdlib functions
;;        that recurse via string-append with multiple prefix args.
;;
;; ── Documented contract limitations (NOT bugs, NOT tested) ──────────────
;;   C1. string-trim only strips ASCII space (0x20), not tabs/newlines/
;;       other whitespace. Source uses (= (car lst) 32) as the
;;       drop-leading predicate. This is the documented V2 behavior;
;;       expand only if requested via a future upgrade.
;;   C2. string-split-words treats codepoints > 127 as non-word (so
;;       high-byte ASCII chars are also split boundaries). Documented
;;       ASCII-printable range per source: `(and (> c 32) (< c 127))`.
;;   C3. chars->string works on a list of integer codepoints but the
;;       char-literal syntax #\a fails inside a require'd module with
;;       "unbound variable: a" (related to surface B10 — the reader
;;       bug is at a lower level than this stdlib file). Workaround:
;;       pass numeric codepoints, e.g. (chars->string (list 97)).
;;   B-string-2026-07-18-A. (chars->string (list)) returns 0 instead
;;       of "". Root cause: the engine primitive (list->string ())
;;       returns 0 not "" for empty-list input. Cascades to chars->string.
;;       (string->chars "") correctly returns () because (string->list "")
;;       returns () — asymmetric to chars->string. Both #f /= "" of
;;       C-string-test convention would expect; needs engine primitive
;;       fix to (list->string ()) returning "" (or a clear sentinel
;;       decision). Documented for next session.
;;   B-string-2026-07-18-B. \xff (and likely \xNN byte escapes) are not
;;       recognized by the aura string-literal reader. (string->chars
;;       "\xff") returns (120 102 102) — the literal "xff" — instead of
;;       (255). Use char-code lists via (chars->string (list 255)) if you
;;       need the byte value. Reader-level fix needed; not stdlib scope.

;; ═════════════════════════════════════════════════════════════════════════
;; Inline check framework (same pattern as surface / encoding / json)
;; ═════════════════════════════════════════════════════════════════════════
(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " expected=") (display expected)
        (display " actual=") (display actual)
        (newline))))

(define (expect-true label actual)
  (if (and (not (null? actual)) (not (equal? actual #f)) (not (equal? actual 0)))
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " actual=") (display actual)
        (newline))))

(define (expect-no-error label thunk)
  (let ((result (try (thunk) (catch 'threw-error))))
    (if (not (eq? result 'threw-error))
        (begin (display "PASS: ") (display label) (newline))
        (begin
          (display "FAIL: ") (display label)
          (display " (threw error)")
          (newline)))))

;; ═════════════════════════════════════════════════════════════════════════
;; Module load + export surface (17 exports)
;; ═════════════════════════════════════════════════════════════════════════

(expect-no-error "string-require-no-crash"
  (lambda () (require "std/string")))

(expect-true "export-string-split-procedure?"      (procedure? string-split))
(expect-true "export-string-split-words-procedure?"(procedure? string-split-words))
(expect-true "export-string-join-procedure?"       (procedure? string-join))
(expect-true "export-string-trim-procedure?"       (procedure? string-trim))
(expect-true "export-string-upcase-procedure?"     (procedure? string-upcase))
(expect-true "export-string-downcase-procedure?"   (procedure? string-downcase))
(expect-true "export-string-contains?-procedure?"  (procedure? string-contains?))
(expect-true "export-string-prefix?-procedure?"    (procedure? string-prefix?))
(expect-true "export-string-suffix?-procedure?"    (procedure? string-suffix?))
(expect-true "export-string-replace-procedure?"    (procedure? string-replace))
(expect-true "export-string-pad-left-procedure?"   (procedure? string-pad-left))
(expect-true "export-string-pad-right-procedure?"  (procedure? string-pad-right))
(expect-true "export-string-reverse-procedure?"    (procedure? string-reverse))
(expect-true "export-string-repeat-procedure?"     (procedure? string-repeat))
(expect-true "export-string->chars-procedure?"     (procedure? string->chars))
(expect-true "export-chars->string-procedure?"     (procedure? chars->string))
(expect-true "export-string-take-procedure?"       (procedure? string-take))
(expect-true "export-string-drop-procedure?"       (procedure? string-drop))

;; ═════════════════════════════════════════════════════════════════════════
;; string-split — str by sep (sep can be string or char code integer)
;; ═════════════════════════════════════════════════════════════════════════

(expect "split-basic"    (string-split "a,b,c" ",") (list "a" "b" "c"))
(expect "split-numbers"  (string-split "1,2,3,4" ",") (list "1" "2" "3" "4"))
(expect "split-empty-sep-each-char" (string-split "abc" "") (list "a" "b" "c"))
(expect "split-leading-sep" (string-split ",a,b" ",") (list "" "a" "b"))
(expect "split-trailing-sep" (string-split "a,b," ",") (list "a" "b" ""))
(expect "split-no-sep-found" (string-split "abc" ",") (list "abc"))
(expect "split-empty-input" (string-split "" ",") (list ""))
(expect "split-multi-char-sep" (string-split "a::b::c" "::") (list "a" "b" "c"))

;; ═════════════════════════════════════════════════════════════════════════
;; string-split-words — whitespace tokenize; word-chars are 33-126 (C2)
;; ═════════════════════════════════════════════════════════════════════════

(expect "split-words-basic"   (string-split-words "hello world") (list "hello" "world"))
(expect "split-words-multi-spaces"
  (string-split-words "  hello   world  ")
  (list "hello" "world"))
(expect "split-words-leading-tabs" (string-split-words "\thello") (list "hello"))
(expect "split-words-empty" (string-split-words "") (list))
(expect "split-words-only-spaces" (string-split-words "   ") (list))
(expect "split-words-3-words" (string-split-words "the quick brown fox")
  (list "the" "quick" "brown" "fox"))

;; ═════════════════════════════════════════════════════════════════════════
;; string-join — list of strs + sep; B8a fixed this session
;; ═════════════════════════════════════════════════════════════════════════

(expect "join-single" (string-join (list "x") ",") "x")
(expect "join-two"    (string-join (list "x" "y") ",") "x,y")
(expect "join-three"  (string-join (list "x" "y" "z") ",") "x,y,z")
(expect "join-five"   (string-join (list "a" "b" "c" "d" "e") ",")
  "a,b,c,d,e")
(expect "join-empty-list" (string-join (list) ",") "")
(expect "join-empty-sep"  (string-join (list "a" "b" "c") "") "abc")
(expect "join-multi-char-sep"
  (string-join (list "x" "y" "z") " - ") "x - y - z")
(expect "join-numbers-as-strings"
  (string-join (list "1" "2" "3") "+") "1+2+3")
(expect "join-words-from-split-words"
  (string-join (string-split-words "the quick brown fox") " ")
  "the quick brown fox")

;; ═════════════════════════════════════════════════════════════════════════
;; string-trim — strip leading + trailing spaces (C1: only space, not tabs)
;; ═════════════════════════════════════════════════════════════════════════

(expect "trim-both-spaces"      (string-trim "  hello  ")    "hello")
(expect "trim-leading-only"     (string-trim "   hello")     "hello")
(expect "trim-trailing-only"    (string-trim "hello   ")     "hello")
(expect "trim-no-spaces"        (string-trim "hello")        "hello")
(expect "trim-empty"            (string-trim "")             "")
(expect "trim-only-spaces"      (string-trim "   ")          "")
(expect "trim-preserve-internal"
  (string-trim "  hello world  ")
  "hello world")

;; ═════════════════════════════════════════════════════════════════════════
;; string-upcase / string-downcase — ASCII only (97-122 / 65-90)
;; ═════════════════════════════════════════════════════════════════════════

(expect "upcase-basic"    (string-upcase "hello")   "HELLO")
(expect "upcase-mixed"    (string-upcase "HeLLo")   "HELLO")
(expect "upcase-already"  (string-upcase "HELLO")   "HELLO")
(expect "upcase-empty"    (string-upcase "")        "")
(expect "upcase-with-numbers" (string-upcase "abc123") "ABC123")
(expect "downcase-basic"  (string-downcase "HELLO") "hello")
(expect "downcase-mixed"  (string-downcase "HeLLo") "hello")
(expect "downcase-already"(string-downcase "hello") "hello")
(expect "updown-roundtrip"
  (string-downcase (string-upcase "Hello World"))
  "hello world")

;; ═════════════════════════════════════════════════════════════════════════
;; string-contains? — substring search
;; ═════════════════════════════════════════════════════════════════════════

(expect-true "contains-yes"     (string-contains? "hello world" "world"))
(expect-true "contains-no"      (not (string-contains? "hello" "xyz")))
(expect-true "contains-empty-needle" (string-contains? "hello" ""))
(expect-true "contains-case-sensitive"
  (not (string-contains? "hello" "WORLD")))
(expect-true "contains-needle-longer-than-haystack"
  (not (string-contains? "hi" "hello")))
(expect-true "contains-needle-equal-haystack"
  (string-contains? "hello" "hello"))

;; ═════════════════════════════════════════════════════════════════════════
;; string-prefix? / string-suffix?
;; ═════════════════════════════════════════════════════════════════════════

(expect-true "prefix-yes"        (string-prefix? "hello world" "hello"))
(expect-true "prefix-no"         (not (string-prefix? "hello" "world")))
(expect-true "prefix-empty"      (string-prefix? "hello" ""))
(expect-true "prefix-equal"      (string-prefix? "hello" "hello"))
(expect-true "prefix-longer-than" (not (string-prefix? "hi" "hello")))
(expect-true "suffix-yes"        (string-suffix? "hello world" "world"))
(expect-true "suffix-no"         (not (string-suffix? "hello" "world")))
(expect-true "suffix-empty"      (string-suffix? "hello" ""))
(expect-true "suffix-equal"      (string-suffix? "hello" "hello"))

;; ═════════════════════════════════════════════════════════════════════════
;; string-replace — replace ALL occurrences (not just first)
;; ═════════════════════════════════════════════════════════════════════════

(expect "replace-first-occurrence"
  (string-replace "hello world" "world" "there")
  "hello there")
(expect "replace-all-occurrences"
  (string-replace "ababab" "a" "X")
  "XbXbXb")
(expect "replace-no-match"
  (string-replace "hello" "xyz" "abc")
  "hello")
(expect "replace-with-empty"
  (string-replace "hello" "l" "")
  "heo")
(expect "replace-empty-needle"
  (string-replace "hello" "" "X")
  "hello")
;; Documented contract: replace with longer needle than source returns
;; source unchanged (0-length or longer-than-source)
(expect "replace-empty-source"
  (string-replace "" "x" "y")
  "")

;; ═════════════════════════════════════════════════════════════════════════
;; string-pad-left / string-pad-right
;; ═════════════════════════════════════════════════════════════════════════

(expect "pad-left-3-spaces"
  (string-pad-left "hi" 5)
  "   hi")
(expect "pad-left-already-wide"
  (string-pad-left "hello" 3)
  "hello")
(expect "pad-left-exact"
  (string-pad-left "hello" 5)
  "hello")
(expect "pad-right-3-spaces"
  (string-pad-right "hi" 5)
  "hi   ")
(expect "pad-right-already-wide"
  (string-pad-right "hello" 3)
  "hello")
(expect "pad-roundtrip"
  (string-pad-right (string-pad-left "x" 5) 9)
  "   x    ")

;; ═════════════════════════════════════════════════════════════════════════
;; string-reverse
;; ═════════════════════════════════════════════════════════════════════════

(expect "reverse-basic"  (string-reverse "hello")  "olleh")
(expect "reverse-empty"  (string-reverse "")       "")
(expect "reverse-1char"  (string-reverse "x")      "x")
(expect "reverse-palindrome-unchanged"
  (string-reverse "racecar") "racecar")
(expect "reverse-double"
  (string-reverse (string-reverse "abc")) "abc")

;; ═════════════════════════════════════════════════════════════════════════
;; string-repeat — n ≥ 1 cases (verified working at n=5 in this session)
;; ═════════════════════════════════════════════════════════════════════════

(expect "repeat-1"     (string-repeat "ab" 1)     "ab")
(expect "repeat-3"     (string-repeat "ab" 3)     "ababab")
(expect "repeat-5"     (string-repeat "x" 5)      "xxxxx")
(expect "repeat-0"     (string-repeat "x" 0)      "")
;; Note: source uses n≤1 contract: n=0 returns "" (verified),
;; n<0 also returns "" by the same <=1 check
(expect "repeat-negative" (string-repeat "x" -3) "")
(expect "repeat-empty-string" (string-repeat "" 5) "")

;; ═════════════════════════════════════════════════════════════════════════
;; string->chars / chars->string — list of integer codepoints
;; (C3: #\a reader syntax fails inside require env; use numeric codes)
;; ═════════════════════════════════════════════════════════════════════════

(expect "to-chars-abc" (string->chars "abc") (list 97 98 99))
(expect "to-chars-hello" (string->chars "hello") (list 104 101 108 108 111))
(expect "chars-from-codes"
  (chars->string (list 72 101 108 108 111))
  "Hello")
(expect "chars-from-single-code"
  (chars->string (list 65))
  "A")
;; NOTE: empty-list case (chars->string (list)) returns 0 instead
;; of "". Documented as B-string-2026-07-18-A in the header.
(expect "chars-to-from-roundtrip"
  (chars->string (string->chars "roundtrip"))
  "roundtrip")

;; ═════════════════════════════════════════════════════════════════════════
;; string-take / string-drop
;; ═════════════════════════════════════════════════════════════════════════

(expect "take-3-of-5"   (string-take "hello" 3)    "hel")
(expect "take-0"        (string-take "hello" 0)    "")
(expect "take-more-than" (string-take "hi" 10)    "hi")
(expect "take-exact"    (string-take "abc" 3)     "abc")
(expect "take-empty"    (string-take "" 3)        "")
(expect "drop-3-of-5"   (string-drop "hello" 2)    "llo")
(expect "drop-0"        (string-drop "hello" 0)    "hello")
(expect "drop-more-than" (string-drop "hi" 10)    "")
(expect "drop-empty"    (string-drop "" 3)        "")
(expect "take-drop-equal" (string-take "abcde" 3) "abc")
(expect "drop-after-take" (string-drop "abcde" 3) "de")

;; ═════════════════════════════════════════════════════════════════════════
;; Round-trip composition tests — sanity-check that the primitives
;; compose cleanly to produce expected outputs.
;; ═════════════════════════════════════════════════════════════════════════

(expect "compose-trim-upcase"
  (string-upcase (string-trim "  hello  "))
  "HELLO")
(expect "compose-split-join"
  (string-join (string-split "a,b,c" ",") "+")
  "a+b+c")
(expect "compose-take-replace"
  (string-replace (string-take "abc" 2) "a" "X")
  "Xb")
(expect "compose-reverse-pad"
  (string-pad-right (string-reverse "ab") 5)
  "ba   ")
(expect "compose-chars-via-take"
  (string-take (chars->string (list 72 101 108 108 111)) 2)
  "He")

;; ═════════════════════════════════════════════════════════════════════════
;; B8 inventory footer — keeps the bug-fix record visible at end-of-file.
;; ═════════════════════════════════════════════════════════════════════════
;; B8a: string-join non-tail-call bug — FIXED this session in
;;       lib/std/string.aura. Let-bound the recursive result inside
;;       (string-append (car strs) sep ...). Now returns correct
;;       output for all depths (verified up to 5 elements + multi-
;;       char sep + empty sep).
;; B-string-2026-07-18-A: (list->string ()) returns 0 instead of "".
;;       Cascades to chars->string. Engine primitive level — out of
;;       stdlib scope; tracked for engine follow-up.
;; B-string-2026-07-18-B: \xff byte escape not recognized in aura
;;       string literals. Returns literal "xff" codepoints instead.
;;       Use (chars->string (list 255)) for byte values. Reader
;;       level — out of stdlib scope.
;; C1:  string-trim only strips ASCII space (0x20). Documented.
;; C2:  string-split-words treats high-byte chars as whitespace.
;;       Documented.
;; C3:  chars->string works on numeric codepoints; #\a reader
;;       syntax fails (surface B10). Use numeric codes.

;; ═════════════════════════════════════════════════════════════════════════
;; End marker
;; ═════════════════════════════════════════════════════════════════════════
(display "DONE")
(newline)
