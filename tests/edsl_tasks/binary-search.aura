;; goal: Write (binary-search target sorted-lst) that returns #t if target exists using std/list take/drop
;; expect: #t
;; depend: std/list
;; hint: --- WORKING Aura binary search ---
;; hint: (require std/list all:)
;; hint: (define (binary-search target lst)
;; hint:   (if (null? lst) #f
