; ── Capability + Functor 集成 最终测试 (P4) ──

(display "=== P0: Capability Type System ===")(newline)

(display "P0.1: with-capability env binding")
(newline)
(define p0_1 "no")
(with-capability "FileRead" (set! p0_1 "yes"))
(display (if (string=? p0_1 "yes") "  PASS" "  FAIL"))
(newline)

(display "P0.2: check-capability inside scope")
(newline)
(define p0_2a #f)
(with-capability "FileRead" (set! p0_2a (check-capability "FileRead")))
(display "  inside: ")
(display (if p0_2a "PASS" "FAIL"))
(newline)
(display "  outside: ")
(display (if (not (check-capability "FileRead")) "PASS" "FAIL"))
(newline)

(display "P0.3: nested scope isolation")
(newline)
(define p0_3 #f)
(with-capability "A"
  (with-capability "B" (set! p0_3 (check-capability "A")))
  (display (if (check-capability "A") "  inner sees outer: PASS" "  inner sees outer: FAIL"))
  (newline)
  (display (if (not (check-capability "B")) "  outer does NOT see inner: PASS" "  outer does NOT see inner: FAIL"))
  (newline))

(display "=== P1: Capability Stack ===")(newline)

(display "P1.1: stack inside nested scopes")
(newline)
(with-capability "FileRead"
  (with-capability "Network"
    (display "  ")
    (display (capability-stack))
    (newline)))
(display "  expected: (FileRead Network)")
(newline)

(display "P1.2: empty stack outside")
(newline)
(display "  empty: ")
(display (if (not (pair? (capability-stack))) "PASS" "FAIL"))
(newline)

(display "=== P2: Functor + Capability ===")(newline)

(display "P2.1: (cap :Capability) param syntax")
(newline)
(define-module (Mod path (cap :Capability))
  (export get-path)
  (define (get-path) path))
(display "  parse OK: PASS")
(newline)

(display "P2.2: (:require ...) directive")
(newline)
(define-module (FileMod (cap :Capability))
  (:require FileRead FileWrite)
  (export touch)
  (define (touch p) p))
(display "  parse OK: PASS")
(newline)

(display "=== All P4 Tests PASS ===")(newline)
