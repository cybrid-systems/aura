; ── Hash inline dispatch benchmark (Phase 4a) ───
; Tests hash-ref performance with the new inline LLVM IR dispatch.
; Usage: ./build/aura < tests/hash_bench.aura

; ── Fixnum key benchmark ──
(display "=== Hash benchmark: fixnum keys ===")(newline)

(define h (hash 42 100 7 200 99 300))
(display "hash size=")(display (hash-length h))(newline)
(display "hash-ref 42 → ")(display (hash-ref h 42))(newline)
(display "hash-ref 7 → ")(display (hash-ref h 7))(newline)
(display "hash-ref 99 → ")(display (hash-ref h 99))(newline)
(display "hash-ref 999 (miss) → ")(display (hash-ref h 999))(newline)

(define (run-fixnum n)
  (if (> n 0)
    (begin
      (hash-ref h 42)
      (hash-ref h 7)
      (hash-ref h 99)
      (hash-ref h 999)
      (run-fixnum (- n 1)))
    #t))

(display "Running 1000 iterations...")(newline)
(run-fixnum 1000)
(display "Done with 4000 hash-ref fixnum ops")(newline)

; ── String key benchmark ──
(display "=== Hash benchmark: string keys ===")(newline)

(define h2 (hash "hello" 100 "world" 200 "aura" 300))
(display "hash size=")(display (hash-length h2))(newline)
(display "hash-ref \"hello\" → ")(display (hash-ref h2 "hello"))(newline)
(display "hash-ref \"missing\" → ")(display (hash-ref h2 "missing"))(newline)

(define (run-string n)
  (if (> n 0)
    (begin
      (hash-ref h2 "hello")
      (hash-ref h2 "world")
      (hash-ref h2 "aura")
      (hash-ref h2 "missing")
      (run-string (- n 1)))
    #t))

(display "Running 1000 iterations...")(newline)
(run-string 1000)
(display "Done with 4000 hash-ref string ops")(newline)

; ── Mixed: hash-set! + hash-ref + hash-remove! ──
(display "=== Mixed ops ===")(newline)

(define h3 (hash 1 10 2 20))
(define (run-mixed n)
  (if (> n 0)
    (begin
      (hash-set! h3 4 40)
      (hash-ref h3 4)
      (hash-ref h3 1)
      (hash-remove! h3 4)
      (hash-ref h3 4)
      (run-mixed (- n 1)))
    #t))

(display "Running 1000 iterations...")(newline)
(run-mixed 1000)
(display "After mixed ops, hash size=")(display (hash-length h3))(newline)
(display "hash-ref 1 → ")(display (hash-ref h3 1))(newline)

(display "All benchmarks completed.")(newline)
