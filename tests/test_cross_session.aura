; ── Cross-session agent test for --serve-async mode ──
; Each line is a JSON command for the serve-async protocol.
;
; Usage: cat tests/test_cross_session.aura | ./build/aura --serve-async

; ── Test 1: Spawn agents via agent:spawn ──
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(agent:spawn \"planner\" (lambda (t) (string-append \"plan:\" t)))(agent:spawn \"coder\" (lambda (p) (string-append \"code:\" p)))(display \"t1:agents-spawned\")"}

; ── Test 2: Agent ask in same session ──
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(display (string-append \"t2:ask-planner:\" (agent:ask \"planner\" \"fib\")))"}

; ── Test 3: Full pipeline ──
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(define plan (agent:ask \"planner\" \"fib\"))(define code (agent:ask \"coder\" plan))(display (string-append \"t3:pipeline:\" code))"}

; ── Test 4: Create cross-session agents via session:create + agent:spawn ──
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(session:create \"session-a\")(session:create \"session-b\")(display \"t4:sessions-created\")"}

; ── Test 5: Agent list across sessions ──
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(agent:spawn \"worker-a\" (lambda (x) (string-append \"wa:\" x)))(display (string-append \"t5:list:\" (string-join (agent:list) \",\")))"}

; ── Test 6: Cross-session send/recv ──
{"cmd":"exec","code":"(display \"t6:cross-session-ready\")","session":"session-a"}
{"cmd":"exec","code":"(display \"t6:listening\")","session":"session-b"}
{"cmd":"exec","code":"(send \"session-b\" \"hello from session-a\")(display \"t6:sent\")","session":"session-a"}
{"cmd":"exec","code":"(define msg (recv))(display (string-append \"t6:recv:\" msg))","session":"session-b"}

; ── Test 7: Cross-session agent:ask (using send/recv protocol) ──
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(agent:spawn \"sa-helper\" (lambda (x) (string-append \"helper:\" x)))(display \"t7:helper-ready\")","session":"session-a"}
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(define result (agent:ask \"sa-helper\" \"task\"))(display (string-append \"t7:cross-ask:\" result))","session":"session-b"}

; ── Test 8: Agent lifecycle in separate sessions ──
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(display (agent:status \"sa-helper\"))","session":"session-a"}
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(agent:stop \"sa-helper\")(display (agent:status \"sa-helper\"))","session":"session-a"}
{"cmd":"exec","code":"(require \"std/orchestrator\" all:)(agent:restart \"sa-helper\" (lambda (x) (string-append \"v2:\" x)))(display (agent:ask \"sa-helper\" \"test\"))","session":"session-a"}

; ── Done ──
{"cmd":"exec","code":"(display \"t8:all-tests-complete\")"}
