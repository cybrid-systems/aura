;; compiler bug: timeout in task 'memoize'
(require "std/llm" all:)
(define __sp__ "Return ONLY Aura code.")
(define __gen__ (lambda (g)
  (json-get-string (aura-llm-call (json-encode (hash
    "model" "deepseek-v4-flash"
    "messages" (list
      (hash "role" "system" "content" __sp__)
      (hash "role" "user" "content" g))
    "temperature" 0.3
    "max_tokens" 4096))) "content")))
(define __fix__ (lambda (code err goal) ""))
(display (intend "Write (memoize fn) that wraps a function with a cache using hash, test with fibonacci" __gen__ aura-verify __fix__ 3))
