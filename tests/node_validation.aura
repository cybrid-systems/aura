; ── Node Validation Test Suite ─────────────────────────────
;
; Tests FlatAST::validate_node / validate_all_nodes (Issue #38):
;   - NodeMeta invariant checking
;   - ast:validate-nodes primitive
;   - Structural validation after mutations
;
; Run: ./aura < tests/node_validation.aura

(require std/test all:)

(display "═══ Node Validation Test Suite ═══\n")
(newline)

(define total-pass 0)
(define total-fail 0)

(define (report name ok)
  (display "  ")
  (display name)
  (display ": ")
  (if ok
    (begin (display "✅\n") (set! total-pass (+ total-pass 1)))
    (begin (display "❌\n") (set! total-fail (+ total-fail 1))))
  ok)

; Helper: extract :pass from ast:validate-nodes result
(define (nodes-pass?)
  (let* ((result (ast:validate-nodes))
         (pass-entry (car result)))
    (if (pair? pass-entry) (cdr pass-entry) #f)))

; Helper: check count is zero (count is embedded as string in alist)
; We just check :pass which already reflects validation status
(define (nodes-zero-errors?)
  (nodes-pass?))

; ── 1. Empty workspace ──
(newline)
(display "── 1. Clean workspace ──\n")

(set-code "(define (f x) (+ x 1))")
(report "clean-ast-passes" (nodes-pass?))
(report "clean-ast-zero-errors" (nodes-zero-errors?))

; ── 2. Simple valid nodes ──
(newline)
(display "── 2. Various valid constructs ──\n")

(set-code "
(define (fact n)
  (if (<= n 1)
    1
    (* n (fact (- n 1)))))

(define (map f lst)
  (if (null? lst)
    '()
    (cons (f (car lst)) (map f (cdr lst)))))

(define (greet name)
  (string-append \"Hello, \" name))
")
(report "complex-valid-ast" (nodes-pass?))

; ── 3. Ownership nodes ──
(newline)
(display "── 3. Ownership constructs ──\n")

(set-code "
(define (test-linear)
  (let ((x 42))
    (move x)))
")
(report "ownership-nodes-valid" (nodes-pass?))

; ── 4. Let/LetRec/Define ──
(newline)
(display "── 4. Binding forms ──\n")

(set-code "
(define x 42)
(define (add a b) (+ a b))
(let ((y 10) (z 20)) (+ y z))
(letrec ((even? (lambda (n) (if (= n 0) #t (odd? (- n 1)))))
         (odd? (lambda (n) (if (= n 0) #f (even? (- n 1))))))
  (even? 5))
")
(report "binding-forms-valid" (nodes-pass?))

; ── 5. Type annotations ──
(newline)
(display "── 5. Type annotations ──\n")

(set-code "
(define (add [x : Int] [y : Int]) : Int
  (+ x y))
")
(report "type-annotations-valid" (nodes-pass?))

; ── 6. Literals ──
(newline)
(display "── 6. Literals ──\n")

(set-code "
(define values
  (begin
    42
    3.14
    \"hello\"
    #t
    #f
    '()))
")
(report "literals-valid" (nodes-pass?))

; ── 7. After mutation ──
(newline)
(display "── 7. Post-mutation validity ──\n")

(set-code "
(define (add [x : Int] [y : Int]) : Int (+ x y))
")
(report "rebind-keeps-valid"
  (begin
    (mutate:rebind "add" "(lambda (a b) (+ a b))")
    (nodes-pass?)))

(set-code "
(define (greet name)
  (string-append \"Hi, \" name))
")
(report "set-body-keeps-valid"
  (begin
    (mutate:set-body "greet" "(lambda (n) (string-append \"Hello, \" n))")
    (nodes-pass?)))

; ── 8. Multiple mutations ──
(newline)
(display "── 8. Mutation chain ──\n")

(set-code "
(define (f x) (* x 2))
(define (g x) (+ x 1))
(define (h x) (- x 1))
")
(report "chain-rebind-1"
  (begin
    (mutate:rebind "f" "(lambda (y) (* y 3))")
    (nodes-pass?)))
(report "chain-rebind-2"
  (begin
    (mutate:rebind "g" "(lambda (z) (+ z 10))")
    (nodes-pass?)))
(report "chain-rebind-3"
  (begin
    (mutate:rebind "h" "(lambda (w) (- w 5))")
    (nodes-pass?)))

; ── Results ──
(newline)
(display "═══ Results ═══\n")
(display total-pass)(display " passed, ")(display total-fail)(display " failed\n")

(if (= total-fail 0)
  (display "✅ All node validation tests passed!\n")
  (begin (display "❌ ")(display total-fail)(display " test(s) failed\n")))
