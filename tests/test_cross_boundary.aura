;; === test_cross_boundary.aura — tree-walker/IR 边界测试 ===
;; 
;; 举一反三：修复 set! 的根因是 IR 和 tree-walker 有各自的
;; cell heap。哪些其他操作也可能掉进同一个坑？
;;
;; 风险矩阵：
;;   state type   | tree-walker | IR          | 共享? | 风险
;;   -------------+-------------+-------------+-------+------
;;   cells_       | vector      | unordered_map | NO  | set!已修
;;   pairs_       | vector      | 通过primitive  | YES | 安全
;;   string_heap_ | vector      | 独立vector    | NO  | ???
;;   vector_heap_ | vector      | 通过primitive  | YES | 安全
;;
;; 测试策略：创建→在边界两侧读写→验证结果

(define passed 0) (define failed 0)
(define (chk a e m)
  (if (equal? a e)
      (begin (set! passed (+ passed 1))
             (display "[PASS] ") (display m) (newline))
      (begin (set! failed (+ failed 1))
             (display "[FAIL] ") (display m)
             (display " exp=") (display e)
             (display " got=") (display a) (newline))))

(display "=== 1. set! top-level variable (regression) ===\n")
(define n 3)
(set! n 5)
(chk n 5 "set! literal to top-level variable")

(define s "hello")
(set! s "world")
(chk s "world" "set! string literal to top-level variable")

(define b #t)
(set! b #f)
(chk b #f "set! bool literal to top-level variable")

(display "=== 2. set! in letrec (internal cells) ===\n")
;; letrec uses internal cells — should NOT be affected
(letrec ((x 1) (y 2))
  (set! x 10)
  (chk x 10 "set! in letrec")
  (chk y 2 "letrec y unchanged"))

(display "=== 3. set! in while loop ===\n")
(define wc 0)
(while (< wc 5)
  (set! wc (+ wc 1)))
(chk wc 5 "while loop with expression-based set!")

(display "=== 4. set! in function (expression-based) ===\n")
(define myval 0)
(set! myval (+ myval 1))
(set! myval (+ myval 1))
(display myval) (display " . ")
(chk myval 2 "set! on top-level from expression")

(display "=== 5. set-car! / set-cdr! (pairs — should work) ===\n")
(define p (cons 1 2))
(set-car! p 10)
(set-cdr! p 20)
(chk (car p) 10 "set-car! on pair")
(chk (cdr p) 20 "set-cdr! on pair")

(display "=== 6. vector-set! (vectors — should work) ===\n")
(define v (vector 1 2 3))
(vector-set! v 0 99)
(chk (vector-ref v 0) 99 "vector-set! element 0")
(chk (vector-ref v 1) 2 "vector element 1 unchanged")

(display "=== 7. set! across multiple expressions ===\n")
(define counter 0)
(set! counter 100)
(set! counter 200)
(set! counter 300)
(chk counter 300 "successive set! expressions")

(display "=== 8. equal? on shared strings ===\n")
(define s1 "abc")
(define s2 "abc")
(define s3 "xyz")
(chk (equal? s1 s2) #t "equal? strings created by define")
(chk (equal? s1 s3) #f "equal? different strings")
(chk (equal? (car (cons "hello" "world")) "hello") #t "equal? string from cons with literal")

(display "=== 9. nested set! in function scope ===\n")
(define outer 1)
(define (test-scope)
  (define inner 2)
  (set! inner 20)
  (set! outer 10)
  (chk inner 20 "set! inner in function")
  (chk outer 10 "set! outer from function"))
(test-scope)
(chk outer 10 "outer modified by function")

(display "=== Results: ") (display passed) (display " passed, ")
(display failed) (display " failed") (newline)
