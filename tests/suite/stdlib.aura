(require "std/test" all:)
; Standard library tests

(test-suite "stdlib:list"
  (require std/list)
  (check= (1 3 4) (sort (list 3 1 4)))
  (check= 10 (sum (list 1 2 3 4)))
  (check= 24 (product (list 2 3 4)))
  (check= 15 (foldl + 0 (range 1 6)))
  (check= 5 (last (list 1 2 3 4 5)))
  (check= (1 2 3 4) (flatten (list 1 (list 2 3) 4)))
  (check= (1 0 2 0 3) (intersperse 0 (list 1 2 3)))
  (check= (1 0 2 0 3) (intersperse-iterative 0 (list 1 2 3)))
  (check= 6 (foldr + 0 (list 1 2 3)))
  (check= (1 2 3) (take-while (lambda (x) (< x 4)) (list 1 2 3 4 5)))
  (check= (4 5) (drop-while (lambda (x) (< x 4)) (list 1 2 3 4 5)))
  (check= ((1 4) (2 5) (3 6)) (zip (list 1 2 3) (list 4 5 6)))))

(test-suite "stdlib:math"
  (require std/math)
  (check= 25 (square 5))
  (check= 125 (cube 5))
  (check>= 4.0 (sqrt 16))
  (check= 120 (factorial 5))
  (check (odd? 3))
  (check (even? 4))
  (check>= 3.14 (pi))))

(test-suite "stdlib:string"
  (require std/string)
  (check= "hello" (string-trim "  hello  "))
  (check= ("a" "b" "c") (string-split "a,b,c" ","))
  (check= "a b" (string-join '("a" "b") " "))
  (check= "HELLO" (string-upcase "hello"))
  (check= "hello" (string-downcase "HELLO")))

(test-suite "stdlib:json"
  (require std/json)
  (check= (1 2 3) (json-parse "[1,2,3]"))
  (check (json-parse "true"))
  (check (json-parse "false")))

(test-suite "stdlib:struct"
  (require std/struct all:)
  (define-struct point (x y z))
  (check (point? (make-point 1 2 3)))
  (check= 1 (point-x (make-point 1 2 3)))
  (check= 2 (point-y (make-point 1 2 3)))
  (check= 3 (point-z (make-point 1 2 3))))

(test-suite "stdlib:validate"
  (require std/validate)
  (check (valid? (validate '{"type": "number"} 42))))

;; ═══════════════════════════════════════════════════════════════
;; std/net — HTTP client + URL utilities
;; ═══════════════════════════════════════════════════════════════

(test-suite "net:url-encode"
  (require "std/net" all:)
  (check (string? (url-encode "hello")))
  (check (= (string-index (url-encode "a b") "+" 0) 1))
  (check (string=? (url-encode "abc") "abc")))

(test-suite "net:url-encode-special"
  (require "std/net" all:)
  (let ((e (url-encode "a/b")))
    (check (> (string-index e "%2F" 0) -1))))

(test-suite "net:url-decode"
  (require "std/net" all:)
  (check (string? (url-decode "hello")))
  (check (string=? (url-decode "hello+world") "hello world"))
  (check (string=? (url-decode "abc") "abc")))

(test-suite "net:url-decode-percent"
  (require "std/net" all:)
  (check (string=? (url-decode "a%2Fb") "a/b"))
  (check (string=? (url-decode "%20") " "))
  (check (string=? (url-decode "hello%21") "hello!")))

(test-suite "net:url-decode-roundtrip"
  (require "std/net" all:)
  ;; encode then decode should roundtrip for basic ASCII
  (let* ((original "hello world/foo")
         (encoded (url-encode original))
         (decoded (url-decode encoded)))
    (check (string=? original decoded))))

(test-suite "net:url-join"
  (require "std/net" all:)
  (check (string? (url-join "https://x.com" "api")))
  (check (string=? (url-join "https://x.com" "api") "https://x.com/api"))
  (check (string=? (url-join "https://x.com/" "api") "https://x.com/api"))
  (check (string=? (url-join "" "api") "api")))

(test-suite "net:http-get-json"
  (require "std/net" all:)
  ;; Should return () when no network or invalid URL (not crash)
  (let ((result (http-get-json "https://nonexistent.example.com/test")))
    (check (or (hash? result) (null? result)))))

(test-suite "net:fetch-try"
  (require "std/net" all:)
  ;; Should return "" on failure (not crash)
  (let ((result (fetch-try "https://nonexistent.example.com/x" 1)))
    (check (string? result))))

(test-suite "net:http-post-json"
  (require "std/net" all:)
  ;; Should return () on failure (not crash)
  (let ((result (http-post-json "https://nonexistent.example.com/post" "{}")))
    (check (or (hash? result) (null? result)))))

;; ═══════════════════════════════════════════════════════════════
;; std/encoding — hex + base64 encoding
;; ═══════════════════════════════════════════════════════════════

(test-suite "encoding:hex-encode"
  (require "std/encoding" all:)
  (check (string=? (hex-encode "ABC") "414243"))
  (check (string=? (hex-encode "") ""))
  (check (string=? (hex-encode "a") "61")))

(test-suite "encoding:hex-decode"
  (require "std/encoding" all:)
  (check (string=? (hex-decode "414243") "ABC"))
  (check (string=? (hex-decode "") ""))
  (check (string=? (hex-decode "61") "a")))

(test-suite "encoding:hex-roundtrip"
  (require "std/encoding" all:)
  (let* ((orig "hello world 123!")
         (enc (hex-encode orig))
         (dec (hex-decode enc)))
    (check (string=? orig dec))))

(test-suite "encoding:base64-encode"
  (require "std/encoding" all:)
  (check (string=? (base64-encode "hello") "aGVsbG8="))
  (check (string=? (base64-encode "") ""))
  (check (string=? (base64-encode "f") "Zg=="))
  (check (string=? (base64-encode "fo") "Zm8="))
  (check (string=? (base64-encode "foo") "Zm9v")))

(test-suite "encoding:base64-decode"
  (require "std/encoding" all:)
  (check (string=? (base64-decode "aGVsbG8=") "hello"))
  (check (string=? (base64-decode "") ""))
  (check (string=? (base64-decode "Zg==") "f"))
  (check (string=? (base64-decode "Zm8=") "fo"))
  (check (string=? (base64-decode "Zm9v") "foo")))

(test-suite "encoding:base64-roundtrip"
  (require "std/encoding" all:)
  (let* ((orig "test message with spaces and 123 numbers!")
         (enc (base64-encode orig))
         (dec (base64-decode enc)))
    (check (string=? orig dec))))

;; ═══════════════════════════════════════════════════════════════
;; std/net — edge cases
;; ═══════════════════════════════════════════════════════════════

(test-suite "net:url-encode-edge"
  (require "std/net" all:)
  (check (string=? (url-encode "") ""))
  (check (string=? (url-encode "~") "~"))          ;; unreserved
  (check (string=? (url-encode ".") "."))           ;; unreserved
  (check (string=? (url-encode "_") "_"))           ;; unreserved
  (check (string=? (url-encode "-") "-"))           ;; unreserved
  (check (> (string-index (url-encode "#") "%23" 0) -1))
  (check (> (string-index (url-encode "&") "%26" 0) -1)))

(test-suite "net:url-decode-edge"
  (require "std/net" all:)
  (check (string=? (url-decode "") ""))
  ;; Invalid percent sequences should leave % as-is
  (check (string? (url-decode "%")))
  (check (string? (url-decode "%2"))))

(test-suite "net:url-join-edge"
  (require "std/net" all:)
  (check (string=? (url-join "http://a" "") "http://a/"))
  (check (string=? (url-join "http://a/" "") "http://a/"))
  (check (string=? (url-join "" "") "")))

;; ═══════════════════════════════════════════════════════════════
;; std/encoding — edge cases + corner cases
;; ═══════════════════════════════════════════════════════════════

(test-suite "encoding:hex-edge"
  (require "std/encoding" all:)
  (check (string=? (hex-encode (hex-decode "41")) "41"))
  (check (string=? (hex-encode (hex-decode "")) ""))
  (check (string=? (hex-decode "gg") (list->string (list 0))))  ;; invalid hex->0
  (check (string? (hex-encode "longer string with 123")))
  (check (string? (hex-decode "deadbeef0102"))))

(test-suite "encoding:base64-all-padding"
  (require "std/encoding" all:)
  ;; 1 byte → 2 pad, 2 bytes → 1 pad, 3 bytes → 0 pad
  (check (string=? (base64-encode "a") "YQ=="))
  (check (string=? (base64-encode "ab") "YWI="))
  (check (string=? (base64-encode "abc") "YWJj"))
  ;; Roundtrip for each
  (check (string=? "a" (base64-decode (base64-encode "a"))))
  (check (string=? "ab" (base64-decode (base64-encode "ab"))))
  (check (string=? "abc" (base64-decode (base64-encode "abc")))))

(test-suite "encoding:base64-all-chars"
  (require "std/encoding" all:)
  ;; All ASCII printable chars roundtrip
  (let* ((all-chars (list->string
                     (let loop ((i 32) (r (list)))
                       (if (> i 126) r (loop (+ i 1) (cons i r))))))
         (enc (base64-encode all-chars))
         (dec (base64-decode enc)))
    (check (string=? all-chars dec))))

(test-suite "encoding:hex-fuzz"
  (require "std/encoding" all:)
  ;; Random-ish strings roundtrip
  (check (string=? "A" (hex-decode (hex-encode "A"))))
  (check (string=? "XYZ" (hex-decode (hex-encode "XYZ"))))
  (check (string=? "123" (hex-decode (hex-encode "123")))))

(test-suite "encoding:empty-roundtrip"
  (require "std/encoding" all:)
  (check (string=? "" (hex-decode (hex-encode ""))))
  (check (string=? "" (base64-decode (base64-encode "")))))

;; ═══════════════════════════════════════════════════════════════
;; std/fs — file system utilities
;; ═══════════════════════════════════════════════════════════════

(test-suite "fs:path-join"
  (require "std/fs" all:)
  (check (string=? (path-join "a" "b") "a/b"))
  (check (string=? (path-join "a/" "b") "a/b"))
  (check (string=? (path-join "a" "b" "c" "d") "a/b/c/d"))
  (check (string=? (path-join "" "a") "a"))
  (check (string=? (path-join "a" "") "a/"))
  (check (string=? (path-join) "")))

(test-suite "fs:path-dirname"
  (require "std/fs" all:)
  (check (string=? (path-dirname "/a/b/c.txt") "/a/b"))
  (check (string=? (path-dirname "c.txt") "."))
  (check (string=? (path-dirname "/a/") "/a"))
  (check (string=? (path-dirname "/") "/"))
  (check (string=? (path-dirname "") ".")))

(test-suite "fs:path-basename"
  (require "std/fs" all:)
  (check (string=? (path-basename "/a/b/c.txt") "c.txt"))
  (check (string=? (path-basename "c.txt") "c.txt"))
  (check (string=? (path-basename "/") ""))
  (check (string=? (path-basename "") ""))
  (check (string=? (path-basename "a/b/c") "c")))

(test-suite "fs:path-extname"
  (require "std/fs" all:)
  (check (string=? (path-extname "file.txt") ".txt"))
  (check (string=? (path-extname "file") ""))
  (check (string=? (path-extname "/a/b/file.html") ".html"))
  (check (string=? (path-extname ".hidden") ".hidden"))
  (check (string=? (path-extname "a.b.c") ".c")))

(test-suite "fs:file-exists"
  (require "std/fs" all:)
  (check (file-exists? "lib/std/fs.aura"))
  (check (not (file-exists? "nonexistent_file_xyz")))
  (check (not (file-exists? ""))))

(test-suite "fs:file-size"
  (require "std/fs" all:)
  (check (> (file-size "lib/std/fs.aura") 0))
  (check (= (file-size "nonexistent_xyz") 0)))

(test-suite "fs:dir-list"
  (require "std/fs" all:)
  (check (pair? (dir-list "lib/std")))
  (check (null? (dir-list "nonexistent_dir_xyz"))))

(test-suite "fs:dir-files-dirs"
  (require "std/fs" all:)
  ;; At minimum, there should be files in lib/std
  (let ((files (dir-files "lib/std"))
        (dirs (dir-dirs "lib/std")))
    (check (pair? files))  ;; at least some files
    (check (list? dirs))))  ;; dirs is a list (maybe empty or some)

;; ═══════════════════════════════════════════════════════════════
;; std/fs — edge cases
;; ═══════════════════════════════════════════════════════════════

(test-suite "fs:path-edge"
  (require "std/fs" all:)
  (check (string=? (path-extname ".gitignore") ".gitignore"))
  (check (string=? (path-extname "a") ""))
  (check (string=? (path-extname "") ""))
  (check (string=? (path-basename "a") "a"))
  (check (string=? (path-basename "/") ""))
  (check (string=? (path-dirname "a") "."))
  (check (string=? (path-join "/" "a") "/a"))
  (check (string=? (path-join "/a" "/b") "/a/b")))

(test-suite "fs:file-operations"
  (require "std/fs" all:)
  ;; Write then read should roundtrip
  (let* ((test-path "/tmp/_aura_fs_test.txt")
         (content "hello aura fs!"))
    (file-write test-path content)
    (let ((read-back (file-read test-path)))
      (check (string=? content read-back)))))

(test-suite "fs:dir-files"
  (require "std/fs" all:)
  ;; lib/std/ should have some files
  (let ((files (dir-files "lib/std")))
    (check (pair? files)))
  ;; root dir not found → empty
  (let ((files (dir-files "/nonexistent_xyz")))
    (check (null? files))))

;; ═══════════════════════════════════════════════════════════════
;; std/uuid — UUID v4 generation
;; ═══════════════════════════════════════════════════════════════

(test-suite "uuid:generate"
  (require "std/uuid" all:)
  (let ((u (uuid)))
    (check (string? u))
    (check (= (string-length u) 36))))

(test-suite "uuid:format"
  (require "std/uuid" all:)
  (let ((u (uuid)))
    ;; UUID format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
    (check (= (string-ref u 8) 45))   ;; dash at pos 8
    (check (= (string-ref u 13) 45))  ;; dash at pos 13
    (check (= (string-ref u 18) 45))  ;; dash at pos 18
    (check (= (string-ref u 23) 45))  ;; dash at pos 23
    ;; Version nibble is 4
    (check (= (string-ref u 14) 52))))  ;; '4' at pos 14

(test-suite "uuid:variant"
  (require "std/uuid" all:)
  ;; Variant nibble should be 8/a/b/c at pos 19
  (let* ((u (uuid))
         (c (string-ref u 19)))  ;; pos 19 = variant
    (check (or (= c 56) (= c 97) (= c 98) (= c 99)))))  ;; '8' '9' 'a' 'b'

(test-suite "uuid:hex-only"
  (require "std/uuid" all:)
  ;; All non-dash chars should be hex digits
  (let* ((u (uuid))
         (check-char (lambda (i)
           (let ((c (string-ref u i)))
             (or (and (>= c 48) (<= c 57))   ;; 0-9
                 (and (>= c 97) (<= c 102))   ;; a-f
                 (and (>= c 65) (<= c 70)))))))  ;; A-F
    (check (check-char 0))
    (check (check-char 1))))

(test-suite "uuid:nil"
  (require "std/uuid" all:)
  (check (string=? (uuid-nil) "00000000-0000-0000-0000-000000000000")))

(test-suite "uuid:compact"
  (require "std/uuid" all:)
  (let ((c (uuid-compact)))
    (check (string? c))
    ;; Compact UUID has no dashes
    (check (= (string-length c) 32))))

;; ═══════════════════════════════════════════════════════════════
;; std/uuid — additional edge cases
;; ═══════════════════════════════════════════════════════════════

(test-suite "uuid:unique"
  (require "std/uuid" all:)
  ;; Generate 5 UUIDs, they should all be different
  (let* ((u1 (uuid)) (u2 (uuid)) (u3 (uuid)) (u4 (uuid)) (u5 (uuid)))
    (check (not (string=? u1 u2)))
    (check (not (string=? u1 u3)))
    (check (not (string=? u2 u3)))
    (check (not (string=? u4 u5)))))

(test-suite "uuid:version-nibble"
  (require "std/uuid" all:)
  ;; The version nibble (pos 14) must always be '4'
  (let loop ((i 0) (ok #t))
    (if (or (>= i 10) (not ok)) (check ok)
      (let ((c (string-ref (uuid) 14)))
        (if (= c 52) (loop (+ i 1) #t) (loop 10 #f))))))

(test-suite "uuid:variant-nibble"
  (require "std/uuid" all:)
  ;; The variant nibble (pos 19) must be one of 8/9/a/b
  (let loop ((i 0) (ok #t))
    (if (or (>= i 10) (not ok)) (check ok)
      (let* ((u (uuid))
             (c (string-ref u 19)))
        (if (or (= c 56) (= c 97) (= c 98) (= c 99))
          (loop (+ i 1) #t)
          (display "bad variant: ")(display c)(newline)
          (loop 10 #f))))))

(test-suite "uuid:nil-format"
  (require "std/uuid" all:)
  (let ((n (uuid-nil)))
    (check (= (string-length n) 36))
    ;; All chars are '0' or '-'
    (let loop ((i 0) (all-zero #t))
      (if (>= i 36) (check all-zero)
        (let ((c (string-ref n i)))
          (if (or (= c 48) (= c 45))  ;; '0' or '-'
            (loop (+ i 1) all-zero)
            (loop 36 #f)))))))

(test-suite "uuid:compact-length"
  (require "std/uuid" all:)
  (let loop ((i 0))
    (if (>= i 5) (check #t)
      (let ((c (uuid-compact)))
        (if (= (string-length c) 32)
          (loop (+ i 1))
          (begin (display "bad compact len: ")(display c)(newline) (check #f)))))))

;; ═══════════════════════════════════════════════════════════════
;; std/process — process management
;; ═══════════════════════════════════════════════════════════════

(test-suite "process:sh"
  (require "std/process" all:)
  (check (= (sh "true") 0))
  (check (not (= (sh "false") 0))))

(test-suite "process:sh-ok"
  (require "std/process" all:)
  (check (sh-ok? "true"))
  (check (not (sh-ok? "false"))))

(test-suite "process:which-found"
  (require "std/process" all:)
  (let ((p (which "ls")))
    (check (string? p))
    (check (> (string-length p) 0))))

(test-suite "process:which-not-found"
  (require "std/process" all:)
  (let ((p (which "nonexistent_cmd_xyz")))
    (check (string=? p ""))))

(test-suite "process:which-path"
  (require "std/process" all:)
  ;; Several well-known programs should exist
  (check (> (string-length (which "echo")) 0))
  (check (> (string-length (which "sh")) 0)))

;; ═══════════════════════════════════════════════════════════════
;; std/regex — regular expressions
;; ═══════════════════════════════════════════════════════════════

(test-suite "regex:match"
  (require "std/regex" all:)
  (check (re-match? "hello" "hello world"))
  (check (not (re-match? "xyz" "hello"))))

(test-suite "regex:find"
  (require "std/regex" all:)
  (check (string=? (re-find "\\d+" "abc123def") "123"))
  (check (string=? (re-find "xyz" "hello") "")))

(test-suite "regex:replace"
  (require "std/regex" all:)
  (check (string=? (re-replace "or" "color" "our") "colour"))
  (check (string=? (re-replace "\\d" "a1b2c3" "X") "aXbXcX")))

(test-suite "regex:split"
  (require "std/regex" all:)
  (let ((r (re-split "," "a,b,c")))
    (check (pair? r))
    (check (= (length r) 3)))
  (check (string=? (re-split "," "a") (list "a"))))

(test-suite "regex:quote"
  (require "std/regex" all:)
  (check (> (string-length (re-quote "a.b*c")) 5))
  (check (string=? (re-quote "hello") "hello")))

;; ═══════════════════════════════════════════════════════════════
;; std/datetime — enhanced
;; ═══════════════════════════════════════════════════════════════

(test-suite "datetime:timestamp-basic"
  (require std/datetime all:)
  (let ((t (current-time)))
    (check (number? t))
    (check (> t 1.7e9))))

(test-suite "datetime:iso-date"
  (require std/datetime all:)
  (let* ((t (current-time))
         (d (timestamp->iso-date t)))
    (check (string? d))
    (check (= (string-length d) 10))))

(test-suite "datetime:rfc822"
  (require std/datetime all:)
  (let* ((t (current-time))
         (r (timestamp->rfc822 t)))
    (check (string? r))
    (check (> (string-length r) 20))
    (check (string-suffix? r " GMT"))))

(test-suite "datetime:now"
  (require std/datetime all:)
  (let ((n (now)))
    (check (string? n))
    (check (= (string-length n) 20))))  ;; "2026-05-26T11:59:00Z"

(test-suite "datetime:format-time"
  (require std/datetime all:)
  (let* ((t (current-time))
         (f (format-time "%Y-%m-%d" t)))
    (check (string? f))
    (check (= (string-length f) 10))))

(test-suite "datetime:components"
  (require std/datetime all:)
  (let ((t (current-time)))
    (check (number? (timestamp->year t)))
    (check (>= (timestamp->year t) 2026))
    (check (and (>= (timestamp->month t) 1) (<= (timestamp->month t) 12)))
    (check (and (>= (timestamp->day t) 1) (<= (timestamp->day t) 31)))
    (check (and (>= (timestamp->hour t) 0) (<= (timestamp->hour t) 23)))))

;; ═══════════════════════════════════════════════════════════════
;; std/regex — additional coverage
;; ═══════════════════════════════════════════════════════════════

(test-suite "regex:match-digit"
  (require "std/regex" all:)
  (check (re-match? "^\\d+$" "12345"))
  (check (not (re-match? "^\\d+$" "abc123"))))

(test-suite "regex:find-multiple"
  (require "std/regex" all:)
  (check (string=? (re-find "[a-z]+" "123abc456def") "abc"))
  (check (string=? (re-find "\\s+" "hello   world") "   "))
  (check (string=? (re-find "[0-9]" "no digits") "")))

(test-suite "regex:replace-all"
  (require "std/regex" all:)
  (check (string=? (re-replace "\\s+" "a b   c" " ") "a b c"))
  (check (string=? (re-replace "\\d" "test123" "") "test")))

(test-suite "regex:split-multi"
  (require "std/regex" all:)
  (let ((r (re-split "\\s+" "one   two three")))
    (check (pair? r))
    (check (>= (length r) 2)))
  (check (string=? (re-split "," "single") (list "single")))
  (check (null? (re-split "," ""))))

(test-suite "regex:quote-special"
  (require "std/regex" all:)
  (check (string=? (re-quote ".^$*+?{}[]\\|()") "\\.\\^\\$\\*\\+\\?\\{\\}\\[\\]\\\\\\|\\(\\)"))
  (check (string=? (re-quote "abc123") "abc123"))
  (check (string=? (re-quote "test_str") "test_str")))

;; ═══════════════════════════════════════════════════════════════
;; std/datetime — additional coverage
;; ═══════════════════════════════════════════════════════════════

(test-suite "datetime:leap-year"
  (require std/datetime all:)
  (check (leap-year? 2024))
  (check (not (leap-year? 2023)))
  (check (not (leap-year? 1900)))
  (check (leap-year? 2000)))

(test-suite "datetime:days-in-month"
  (require std/datetime all:)
  (check (= (days-in-month 2024 2) 29))  ;; leap
  (check (= (days-in-month 2023 2) 28))  ;; non-leap
  (check (= (days-in-month 2024 1) 31))
  (check (= (days-in-month 2024 4) 30))
  (check (= (days-in-month 2024 12) 31)))

(test-suite "datetime:format-specs"
  (require std/datetime all:)
  (let* ((t (current-time))
         (ft (format-time "%Y-%m-%dT%H:%M:%S" t)))
    (check (string? ft))
    (check (= (string-length ft) 19))))  ;; "2026-05-26T11:59:00"

(test-suite "datetime:format-literal"
  (require std/datetime all:)
  (let* ((t (current-time))
         (ft (format-time "%%" t)))
    (check (string=? ft "%"))))

;; ═══════════════════════════════════════════════════════════════
;; std/process — additional coverage
;; ═══════════════════════════════════════════════════════════════

(test-suite "process:which-common"
  (require "std/process" all:)
  (check (> (string-length (which "cat")) 0))
  (check (> (string-length (which "rm")) 0))
  (check (> (string-length (which "mkdir")) 0)))

(test-suite "process:sh-exit-codes"
  (require "std/process" all:)
  (check (= (sh "true") 0))
  (check (not (= (sh "false") 0)))
  (check (= (sh "exit 42") 42)))

(test-suite "process:sh-ok-edge"
  (require "std/process" all:)
  (check (sh-ok? "true"))
  (check (not (sh-ok? "false")))
  (check (not (sh-ok? "exit 1"))))

;; ═══════════════════════════════════════════════════════════════
;; std/fs — additional coverage
;; ═══════════════════════════════════════════════════════════════

(test-suite "fs:path-join-multi"
  (require "std/fs" all:)
  (check (string=? (path-join "a" "b" "c" "d" "e") "a/b/c/d/e"))
  (check (string=? (path-join "a" "" "c") "a/c"))
  (check (string=? (path-join) ""))
  (check (string=? (path-join "a") "a")))

(test-suite "fs:path-extname-various"
  (require "std/fs" all:)
  (check (string=? (path-extname "index.html") ".html"))
  (check (string=? (path-extname "archive.tar.gz") ".gz"))
  (check (string=? (path-extname "Makefile") ""))
  (check (string=? (path-extname ".bashrc") ".bashrc"))
  (check (string=? (path-extname "/a/b/c.css") ".css")))

(test-suite "fs:file-write-temp"
  (require "std/fs" all:)
  (let* ((p "/tmp/_aura_test_write.txt")
         (c "hello fs test"))
    (file-write p c)
    (let ((r (file-read p)))
      (check (string=? r c)))
    ;; Cleanup
    (shell (string-append "rm -f " p))))

(test-suite "fs:dir-list-sorted"
  (require "std/fs" all:)
  (let ((entries (dir-list "lib/std")))
    (check (pair? entries))
    ;; fs.aura should be in the list (or nearby alphabetically)
    (check (list? entries))))

(test-suite "fs:dir-files-count"
  (require "std/fs" all:)
  (let ((files (dir-files "lib/std")))
    ;; At minimum: net, encoding, fs, uuid, process should exist
    (check (>= (length files) 5))))

;; ═══════════════════════════════════════════════════════════════
;; std/uuid — additional coverage
;; ═══════════════════════════════════════════════════════════════

(test-suite "uuid:many-unique"
  (require "std/uuid" all:)
  ;; Generate 20 UUIDs, they should all be unique
  (let* ((u1 (uuid)) (u2 (uuid)) (u3 (uuid)) (u4 (uuid)) (u5 (uuid))
         (u6 (uuid)) (u7 (uuid)) (u8 (uuid)) (u9 (uuid)) (u10 (uuid)))
    (check (not (string=? u1 u2)))
    (check (not (string=? u1 u3)))
    (check (not (string=? u4 u5)))
    (check (not (string=? u6 u10)))
    ;; All should be 36 chars
    (check (= (string-length u1) 36))
    (check (= (string-length u2) 36))
    (check (= (string-length u10) 36))))

(test-suite "uuid:compact-all-unique"
  (require "std/uuid" all:)
  (let ((c1 (uuid-compact)) (c2 (uuid-compact)) (c3 (uuid-compact)))
    (check (not (string=? c1 c2)))
    (check (not (string=? c2 c3)))
    (check (= (string-length c1) 32))))

;; ═══════════════════════════════════════════════════════════════
;; std/encoding — additional coverage
;; ═══════════════════════════════════════════════════════════════

(test-suite "encoding:hex-case"
  (require "std/encoding" all:)
  ;; Upper and lower case hex both work for decode
  (check (string=? (hex-decode "414243") "ABC"))
  (check (string=? (hex-decode "616263") "abc"))
  (check (string=? (hex-encode "abc") "616263")))

(test-suite "encoding:base64-no-padding"
  (require "std/encoding" all:)
  ;; Base64 without padding should still decode (len%4 != 0 means padding stripped)
  (check (string? (base64-decode (base64-encode "hello world 123!"))))
  (check (string=? (base64-decode (base64-encode "he")) "he"))
  (check (string=? (base64-decode (base64-encode "hel")) "hel")))

(test-suite "encoding:base64-binary"
  (require "std/encoding" all:)
  ;; Binary-ish data roundtrip
  (let* ((data (list->string (list 0 1 2 127 128 255)))
         (enc (base64-encode data))
         (dec (base64-decode enc)))
    (check (string=? data dec))))

;; ═══════════════════════════════════════════════════════════════
;; std/net — additional coverage
;; ═══════════════════════════════════════════════════════════════

(test-suite "net:url-encode-all"
  (require "std/net" all:)
  ;; All printable ASCII chars encode properly
  (check (> (string-length (url-encode "hello world!@#$%^&*()")) 0))
  (check (string=? (url-encode "") ""))
  (check (string? (url-encode "~.-_")))  ;; unreserved

(test-suite "net:url-decode-full"
  (require "std/net" all:)
  (check (string=? (url-decode "%41%42%43") "ABC"))
  (check (string=? (url-decode "a%2Bb") "a+b"))
  (check (string=? (url-decode "%7E") "~"))
  (check (string? (url-decode "%%")))  ;; malformed shouldn't crash

(test-suite "net:url-join-various"
  (require "std/net" all:)
  (check (string=? (url-join "http://example.com" "path/to") "http://example.com/path/to"))
  (check (string=? (url-join "http://example.com/" "path/to") "http://example.com/path/to"))
  (check (string=? (url-join "" "path") "path"))
  (check (string=? (url-join "http://a" "") "http://a/")))
