(require "std/test" all:)
; Standard library tests

(test-suite "stdlib:list"
  (require std/list)
  (check= (1 3 4) (sort (list 3 1 4)))
  (check= 10 (sum (list 1 2 3 4)))
  (check= 24 (product (list 2 3 4)))
  (check= 15 (foldl + 0 (range 1 6)))
  (check= 5 (last (list 1 2 3 4 5)))
  (check= (1 2 3 4) (flatten (list 1 (list 2 3) 4)))
  (check= (1 2 3) (take-while (lambda (x) (< x 4)) (list 1 2 3 4 5)))
  (check= (4 5) (drop-while (lambda (x) (< x 4)) (list 1 2 3 4 5)))
  (check= ((1 4) (2 5) (3 6)) (zip (list 1 2 3) (list 4 5 6)))))

(test-suite "stdlib:math"
  (require std/math)
  (check= 25 (square 5))
  (check= 125 (cube 5))
  (check>= 4.0 (sqrt 16))
  (check= 120 (factorial 5))
  (check (odd? 3))
  (check (even? 4))
  (check>= 3.14 (pi))))

(test-suite "stdlib:string"
  (require std/string)
  (check= "hello" (string-trim "  hello  "))
  (check= ("a" "b" "c") (string-split "a,b,c" ","))
  (check= "a b" (string-join '("a" "b") " "))
  (check= "HELLO" (string-upcase "hello"))
  (check= "hello" (string-downcase "HELLO")))

(test-suite "stdlib:json"
  (require std/json)
  (check= (1 2 3) (json-parse "[1,2,3]"))
  (check (json-parse "true"))
  (check (json-parse "false")))

(test-suite "stdlib:struct"
  (require std/struct all:)
  (define-struct point (x y z))
  (check (point? (make-point 1 2 3)))
  (check= 1 (point-x (make-point 1 2 3)))
  (check= 2 (point-y (make-point 1 2 3)))
  (check= 3 (point-z (make-point 1 2 3))))

(test-suite "stdlib:validate"
  (require std/validate)
  (check (valid? (validate '{"type": "number"} 42))))

;; ═══════════════════════════════════════════════════════════════
;; std/net — HTTP client + URL utilities
;; ═══════════════════════════════════════════════════════════════

(test-suite "net:url-encode"
  (require "std/net" all:)
  (check (string? (url-encode "hello")))
  (check (= (string-index (url-encode "a b") "+" 0) 1))
  (check (string=? (url-encode "abc") "abc")))

(test-suite "net:url-encode-special"
  (require "std/net" all:)
  (let ((e (url-encode "a/b")))
    (check (> (string-index e "%2F" 0) -1))))

(test-suite "net:url-decode"
  (require "std/net" all:)
  (check (string? (url-decode "hello")))
  (check (string=? (url-decode "hello+world") "hello world"))
  (check (string=? (url-decode "abc") "abc")))

(test-suite "net:url-decode-percent"
  (require "std/net" all:)
  (check (string=? (url-decode "a%2Fb") "a/b"))
  (check (string=? (url-decode "%20") " "))
  (check (string=? (url-decode "hello%21") "hello!")))

(test-suite "net:url-decode-roundtrip"
  (require "std/net" all:)
  ;; encode then decode should roundtrip for basic ASCII
  (let* ((original "hello world/foo")
         (encoded (url-encode original))
         (decoded (url-decode encoded)))
    (check (string=? original decoded))))

(test-suite "net:url-join"
  (require "std/net" all:)
  (check (string? (url-join "https://x.com" "api")))
  (check (string=? (url-join "https://x.com" "api") "https://x.com/api"))
  (check (string=? (url-join "https://x.com/" "api") "https://x.com/api"))
  (check (string=? (url-join "" "api") "api")))

(test-suite "net:http-get-json"
  (require "std/net" all:)
  ;; Should return () when no network or invalid URL (not crash)
  (let ((result (http-get-json "https://nonexistent.example.com/test")))
    (check (or (hash? result) (null? result)))))

(test-suite "net:fetch-try"
  (require "std/net" all:)
  ;; Should return "" on failure (not crash)
  (let ((result (fetch-try "https://nonexistent.example.com/x" 1)))
    (check (string? result))))

(test-suite "net:http-post-json"
  (require "std/net" all:)
  ;; Should return () on failure (not crash)
  (let ((result (http-post-json "https://nonexistent.example.com/post" "{}")))
    (check (or (hash? result) (null? result)))))

;; ═══════════════════════════════════════════════════════════════
;; std/encoding — hex + base64 encoding
;; ═══════════════════════════════════════════════════════════════

(test-suite "encoding:hex-encode"
  (require "std/encoding" all:)
  (check (string=? (hex-encode "ABC") "414243"))
  (check (string=? (hex-encode "") ""))
  (check (string=? (hex-encode "a") "61")))

(test-suite "encoding:hex-decode"
  (require "std/encoding" all:)
  (check (string=? (hex-decode "414243") "ABC"))
  (check (string=? (hex-decode "") ""))
  (check (string=? (hex-decode "61") "a")))

(test-suite "encoding:hex-roundtrip"
  (require "std/encoding" all:)
  (let* ((orig "hello world 123!")
         (enc (hex-encode orig))
         (dec (hex-decode enc)))
    (check (string=? orig dec))))

(test-suite "encoding:base64-encode"
  (require "std/encoding" all:)
  (check (string=? (base64-encode "hello") "aGVsbG8="))
  (check (string=? (base64-encode "") ""))
  (check (string=? (base64-encode "f") "Zg=="))
  (check (string=? (base64-encode "fo") "Zm8="))
  (check (string=? (base64-encode "foo") "Zm9v")))

(test-suite "encoding:base64-decode"
  (require "std/encoding" all:)
  (check (string=? (base64-decode "aGVsbG8=") "hello"))
  (check (string=? (base64-decode "") ""))
  (check (string=? (base64-decode "Zg==") "f"))
  (check (string=? (base64-decode "Zm8=") "fo"))
  (check (string=? (base64-decode "Zm9v") "foo")))

(test-suite "encoding:base64-roundtrip"
  (require "std/encoding" all:)
  (let* ((orig "test message with spaces and 123 numbers!")
         (enc (base64-encode orig))
         (dec (base64-decode enc)))
    (check (string=? orig dec))))
