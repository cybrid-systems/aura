; Aura intend E2 — Strategy 系统测试
(display "╔════════════════════════════════════════╗")
(display "║  intend E2 Tests                      ║")
(display "╚════════════════════════════════════════╝")

; ── 1. define-strategy ──────────────────────────
(display "")
(display "=== 1. define-strategy ===")

(display (define-strategy "test-strategy" "(phase generate (llm-generate goal))"))
(display (define-strategy "second-strategy" "(phase check (typecheck-current))"))

; ── 2. register-strategy! (更新已有) ────────────
(display "")
(display "=== 2. register-strategy! (update) ===")
(display (register-strategy! "test-strategy" "(phase generate (llm-generate goal) :max-attempts 5)"))

; ── 3. define-strategy 缺参数 ───────────────────
(display "")
(display "=== 3. define-strategy bad args ===")
(display (define-strategy "only-name"))
(display (define-strategy))
(display (define-strategy 42 "body"))

; ── 4. intend-history（空 → 应有输出）────────────
(display "")
(display "=== 4. intend-history ===")
(display (intend-history))

; ── 5. intend with strategy name ────────────────
(display "")
(display "=== 5. intend (no api key) ===")
(display (intend "test" "test-strategy" 1))

; ── 6. intend-history after intend ──────────────
(display "")
(display "=== 6. intend-history after intend ===")
(display (intend-history))

; ── 7. 原始用法兼容（intend goal max-attempts）───
(display "")
(display "=== 7. backward compat ===")
(display (intend "hello" 1))

(display "")
(display "╔════════════════════════════════════════╗")
(display "║  E2 tests complete                    ║")
(display "╚════════════════════════════════════════╝")
