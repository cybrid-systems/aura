; tests/suite/incremental_mutation_test.aura — Issue #238 stress test
(set-code "
(define (shared x) (+ x 1))
(define (f0 x) (shared (+ x 0)))
(define (f1 x) (shared (+ x 1)))
(define (f2 x) (shared (+ x 2)))
(define (f3 x) (shared (+ x 3)))
(define (f4 x) (shared (+ x 4)))
(define (f5 x) (shared (+ x 5)))
(define (f6 x) (shared (+ x 6)))
(define (f7 x) (shared (+ x 7)))
")
(eval-current)
(display "baseline-cache-size: ") (display (compile:cache-size)) (newline)
(display "baseline-dirty-count: ") (display (compile:dirty-count)) (newline)
(let ((total-cycles 100)
      (cycle-target
        (lambda (i)
          (if (= 0 (mod i 9))
              "shared"
              (string-append "f" (number->string (- (mod i 9) 1))))))
      (run-all
        (lambda (i mismatches)
          (if (>= i total-cycles)
              (begin
                (display "mutations-completed: ") (display total-cycles) (newline)
                (display "mismatches: ") (display mismatches) (newline)
                mismatches)
              (let ((target (cycle-target i)) (new-val (+ i 100)))
                (let ((body (string-append "(lambda (x) (+ x " (number->string new-val) "))")))
                  (mutate:rebind target body "summary")
                  (run-all (+ i 1) mismatches)))))))
  (let ((pre-dirty (compile:dirty-count)))
    (eval-current)
    (let ((post-dirty (compile:dirty-count)))
      (display "warmup-no-mut-preserves-dirty: ")
      (display (if (= pre-dirty post-dirty) #t #f))
      (newline)))
  (display "starting-cycles...") (newline)
  (run-all 0 0)
  (newline)
  (eval-current)
  (display "final-cache-size: ") (display (compile:cache-size)) (newline)
  (display "final-dirty-count: ") (display (compile:dirty-count)) (newline)
  (display "dep-edges: ") (display (compile:dep-edges)) (newline)
  (let ((pre-dirty (compile:dirty-count)))
    (eval-current)
    (let ((post-dirty (compile:dirty-count)))
      (display "no-mut-preserves-dirty: ")
      (display (if (= pre-dirty post-dirty) #t #f))
      (newline)))
  (display "test-complete") (newline))
