(require "std/test" all:)
; Type System tests
; Tests: type inference, gradual typing, occurrence typing,
;        value restriction, let-polymorphism, ADT, coercion

(test-suite "typesystem:inference"
  (check= Int (type-of 42))
  (check= Int (type-of (+ 1 2)))
  (check= String (type-of "hello"))
  (check= Bool (type-of #t))
  (check= Int (type-of (* 3 4)))
  (check= Int (type-of (- 10 3)))
  (check= Int (type-of (quotient 10 3))))

(test-suite "typesystem:annotation"
  (check= Int (type-of (: x Int 42)))
  (check= 42 (: x Int 42))
  (check= 3 (: x Int (+ 1 2)))
  (check= Int (type-of (: y Int 99)))
  (check= 99 (: y Int 99)))

(test-suite "typesystem:occurrence"
  (check= "hello"
    (let ((x "hello")) (if (string? x) x "fallback")))
  (check= 42
    (let ((x 42)) (if (number? x) (+ x 0) 0)))
  (check= #t
    (let ((x (cons 1 2))) (if (pair? x) #t "no")))
  (check= "hi"
    (let ((x "hi")) (if (string? x) x "no")))
  (check= 0
    (let ((x "str")) (if (number? x) x 0))))
  (check= 42
    (let ((x 42))
      (cond ((number? x) (+ x 0)) (else 0))))
  (check= "hello"
    (let ((x "hi"))
      (cond ((string? x) x) (else "hello"))))
  (check= 0
    (let ((x "not-a-number"))
      (cond ((number? x) (+ x 0)) (else 0))))
  (check= 0
    (let ((x (list 1 2 3)))
      (match x
        ((a b c) 0)
        (else 1))))
  (check= "a"
    (let ((x (list "a" 2)))
      (match x
        ((a b) a)
        (else "z"))))


(test-suite "typesystem:let-poly"
  (check= 42hello
    (let ((id (lambda (x) x)))
      (display (id 42))
      (display (id "hello")))))

(test-suite "typesystem:let-poly-extended"
  ;; 1. Multiple polymorphic uses
  (check= 42t
    (let ((id (lambda (x) x)))
      (display (id 42))
      (display (id #t))))
  ;; 2. Nested let-poly
  (check= 42t
    (let ((f (lambda (x) x)))
      (let ((g (lambda (y) (f y))))
        (display (g 42))
        (display (g #t)))))
  ;; 3. Higher-order compose
  (check= 42
    (let ((compose (lambda (f g) (lambda (x) (f (g x))))))
      (let ((add1 (lambda (x) (+ x 1)))
            (mul2 (lambda (x) (* x 2))))
        (let ((h (compose mul2 add1)))
          (display (h 20))))))
  ;; 4. Curry
  (check= 42
    (let ((const (lambda (x) (lambda (y) x))))
      (display ((const 42) "ignored"))))
  ;; 5. Multiple poly bindings
  (check= 12
    (let ((f (lambda (x) x))(g (lambda (x) x)))
      (display (f 1))(display (g 2))))
  ;; 6. Pair construction
  (check= 2
    (let ((pair (lambda (x y) (cons y x))))
      (display (car (pair 1 2)))))
  ;; 7. Let-poly inside lambda
  (check= 42t
    ((lambda (z)
       (let ((f (lambda (x) x)))
         (display (f z))
         (display (f #t)))) 42))
  ;; 8. Let-poly with fst
  (check= 4
    (let ((fst (lambda (p) (car p))))
      (display (+ (fst (cons 1 2)) (fst (cons 3 4))))))
  ;; 9. letrec poly
  (check= 99f
    (letrec ((id (lambda (x) x)))
      (display (id 99))
      (display (id #f)))))

(test-suite "typesystem:adt-exhaustive"
  ;; 1. Option: all covered
  (check= 42
    (begin (define-type (Option a) (Some a) (None))
      (let ((x (Some 42))) (match x ((Some v) v) ((None) 0)))))
  ;; 2. Option: missing None — type warning expected
  (check= 42
    (begin (define-type (Option a) (Some a) (None))
      (let ((x (Some 42))) (match x ((Some v) v)))))
  ;; 3. Multi-ctor: all covered
  (check= 1
    (begin (define-type (Color) (Red) (Green) (Blue))
      (let ((x Red)) (match x ((Red) 1) ((Green) 2) ((Blue) 3)))))
  ;; 4. Multi-ctor: wildcard
  (check= 1
    (begin (define-type (Color) (Red) (Green) (Blue))
      (let ((x Red)) (match x ((Red) 1) (_ 0)))))
  ;; 5. Either (multi-param)
  (check= 1
    (begin (define-type (Either a b) (Left a) (Right b))
      (let ((x (Left 1))) (match x ((Left v) v) ((Right v) 0)))))
  ;; 6. Nested ADTs (separate match expressions)
  (check= 42
    (begin (define-type (Option a) (Some a) (None))
      (define-type (Result e v) (Ok v) (Err e))
      (let ((x (Ok (Some 42))))
        (match x ((Ok y) (match y ((Some v) v) ((None) 0))) ((Err _) 0)))))
  ;; 7. Recursive ADT (List)
  (check= 6
    (begin (define-type (List a) (Nil) (Cons a (List a)))
      (let ((xs (Cons 1 (Cons 2 (Cons 3 Nil)))))
        (match xs ((Cons h t) (display h) (display (+ h 1))) (Nil 0)))))
  ;; 8. Pattern with field binding
  (check= hello
    (begin (define-type (Pair a b) (MkPair a b))
      (let ((p (MkPair "hello" 42)))
        (match p ((MkPair s n) (display s) (display n))))))
  ;; 9. Multi-ctor covered with wildcard for rest
  (check= 1
    (begin (define-type (Season) (Spring) (Summer) (Fall) (Winter))
      (let ((x Spring)) (match x ((Spring) 1) (_ 0))))))

(test-suite "typesystem:value-restriction"
  (check= 42
    (let ((x (+ 40 2))) (+ x 0)))
  (check= 10
    (let ((x (+ 1 2 3 4))) x))
  (check= 30
    (let ((x (+ 10 20))) x))
  (check= 12
    (let ((x (* 3 4))) x)))

(test-suite "typesystem:effects"
  ;; 效果类型不破坏现有类型检查
  (check= 42
    (begin (define (f x) (+ x 1)) (display (f 41))))
  ;; mutate 原语在 REPL 中可正常调用
  (check (begin (set-code "(define (f x) (+ x 1))") (mutate:rebind "f" "(lambda (x) (* x 2))") #t)))

(test-suite "typesystem:coercion"
  (check= 2
    (+ 1 #t))
  (check= 3
    (+ 1 2))
  (check= 3
    (+ 1 2)))

(test-suite "typesystem:gradual"
  (check= 42
    (: x Int 42))
  (check= 3
    (: x Int (+ 1 2))))

(test-suite "typesystem:adt"
  (define-type (Option a) (Some a) (None))
  (check= 42
    (match (Some 42) ((Some x) x) (None 0)))
  (check= 0
    (match None ((Some x) x) (None 0)))
  (check= #t
    (match (Some 99) ((Some _) #t) (None #f))))

(test-suite "typesystem:blame"
  ;; Blame is primarily a runtime concept. These tests verify
  ;; that the type system correctly identifies annotation boundaries.
  (check= 42
    (: x Int 42))
  (check= "type safe"
    (if (string? "hello") "type safe" "type error")))

(test-suite "typesystem:declare-type"
  (check (begin (declare-type "mytest" "Int" "Int") #t))
  (check (begin (declare-type "myadd" "Int Int" "Int") #t))
  (check (begin (declare-type "myecho" "String" "String") #t))
  (check (begin (declare-type "mypred" "Int" "Bool") #t))
  (check (begin (declare-type "myvoid" "String" "Void") #t)))

(test-suite "typesystem:query"
  (display "typesystem:query — manual check via typecheck pipeline"))
