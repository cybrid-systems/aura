(require "std/test" "std/heal" all:)
; Error handling tests
; Tests: error, raise, try/catch, check, check=

(test-suite "errors:error"
  (check (is_error (error "msg"))))

(test-suite "errors:raise"
  (check (is_error (raise "cause"))))

(test-suite "errors:try-success"
  (check= 42 (try 42 (catch (e) 0))))

(test-suite "errors:try-catch"
  (check= "caught" (try (error "fail") (catch (e) "caught"))))

(test-suite "errors:try-catch-value"
  (check (try (error "fail") (catch (e) e))))

(test-suite "errors:try-catch-raise"
  (check (try (raise "hello") (catch (e) e))))

(test-suite "errors:assert-pass"
  (check (assert (= 1 1))))

(test-suite "errors:assert-fail"
  (check (is_error (assert (= 1 2)))))

(test-suite "errors:check-pass"
  (check (check 42)))

(test-suite "errors:check-fail"
  (check (is_error (check #f))))

(test-suite "errors:check=-pass"
  (check (check= 5 (+ 2 3))))

(test-suite "errors:check=-fail"
  (check (is_error (check= 5 3))))

(test-suite "errors:car-on-nonpair"
  (check (try (car 42) (catch (e) #t))))

(test-suite "errors:modulo-by-zero"
  (check (try (modulo 5 0) (catch (e) #t))))

(test-suite "errors:string-ref-oob"
  (check (try (string-ref "abc" 100) (catch (e) #t))))

;; ── check-success tests ────────────────────────────────

(test-suite "check-success:basic-match"
  (check (check-success "42" (list "42"))))

(test-suite "check-success:basic-no-match"
  (check (= (check-success "hello" (list "42")) #f)))

(test-suite "check-success:substring-match"
  (check (check-success "result: 42" (list "42"))))

(test-suite "check-success:multi-keyword"
  (check (check-success "expected Int" (list "error" "Int" "String"))))

(test-suite "check-success:error-output-rejects-error"
  (check (= (check-success "parse error: expected expression" (list "error")) #f)))

(test-suite "check-success:error-output-rejects-parse"
  (check (= (check-success "parse error: expected expression" (list "parse")) #f)))

(test-suite "check-success:error-output-allows-define"
  (check (check-success "expected Define, got Int" (list "Define"))))

(test-suite "check-success:structured-error-rejects"
  (check (= (check-success "(\"type error\" \"type mismatch\")" (list "error")) #f)))

(test-suite "check-success:void-is-false"
  (check (= (check-success (void) (list "42")) #f)))

(test-suite "check-success:empty-list"
  (check (= (check-success "anything" (list)) #f)))

(test-suite "check-success:word-boundary"
  (check (check-success "found 42" (list "42"))))

(test-suite "check-success:word-boundary-no-false"
  (check (= (check-success "type mismatch: expected Int, got 142" (list "42")) #f)))

(test-suite "check-success:keyword-long"
  (check (check-success "1:1: expected expression, got ')'" (list "expression"))))

;; ── diagnose tests ───────────────────────────────────────

(test-suite "diagnose:unbound-for-each"
  (check (check-success "missing-require"
    (list (car (diagnose "unbound variable: for-each"))))))

(test-suite "diagnose:unbound-make-hash"
  (check (check-success "missing-require"
    (list (car (diagnose "unbound variable: make-hash"))))))

(test-suite "diagnose:unbound-define-type"
  (check (check-success "missing-require"
    (list (car (diagnose "unbound variable: define-type"))))))

(test-suite "diagnose:type-error-ffi"
  (check (check-success "type-error-unbound"
    (list (car (diagnose "type error: cannot call: ffi-sqrt"))))))

(test-suite "diagnose:parse-error"
  (check (check-success "parse-error"
    (list (car (diagnose "parse error: expected expression at line 1"))))))

(test-suite "diagnose:closure-no-display"
  (check (check-success "closure-no-display"
    (list (car (diagnose "program returned an uncalled function (closure)"))))))

(test-suite "diagnose:unknown-no-match"
  (check (= (diagnose "random message") #f)))

(test-suite "diagnose:fix-type-add-require"
  (check (check-success "add-require"
    (list (car (cdr (cdr (diagnose "unbound variable: for-each"))))))))

(test-suite "diagnose:fix-data-std-list"
  (check (check-success "std/list"
    (list (car (cdr (cdr (cdr (diagnose "unbound variable: for-each")))))))))

(test-suite "diagnose:generic-unbound"
  (check (check-success "unbound-variable"
    (list (car (diagnose "unbound variable: my-unknown-fn"))))))

;; ── apply-fix tests ──────────────────────────────────────

(test-suite "apply-fix:add-require-std-list"
  (check (check-success "std/list"
    (list (apply-fix "(define (f x) (for-each display x))"
                     (diagnose "unbound variable: for-each"))))))

(test-suite "apply-fix:add-require-std-hash"
  (check (check-success "std/hash"
    (list (apply-fix "(define (f) (make-hash))"
                     (diagnose "unbound variable: make-hash"))))))

(test-suite "apply-fix:preserves-original-code"
  (check (check-success "original-fn"
    (list (apply-fix "(define (original-fn x) x)\n(for-each display (list 1 2))"
                     (diagnose "unbound variable: for-each"))))))

(test-suite "apply-fix:no-double-require"
  (let* ((code "(require \"std/list\" all:)\n(define (f x) (for-each display x))")
         (fixed (apply-fix code (diagnose "unbound variable: for-each"))))
    ;; fixed should still contain std/list (original require preserved)
    (check (check-success fixed (list "std/list")))
    ;; fixed should NOT have TWO std/list references
    (check (check-success fixed (list "std/list")))
    (check (= (string-contains fixed "for-each") #t))))

(test-suite "apply-fix:define-function-stub"
  (let ((fixed (apply-fix "(display (ffi-sqrt 42))"
                          (diagnose "type error: cannot call: ffi-sqrt"))))
    (check (check-success fixed (list "ffi-sqrt")))
    (check (check-success fixed (list "define")))))

(test-suite "apply-fix:no-diagnosis"
  (check (= (apply-fix "(display 42)" (diagnose "random")) #f)))

(test-suite "apply-fix:closure-unchanged"
  (let ((code "(define (f x) (* x 2))"))
    (check (check-success
      (apply-fix code (diagnose "program returned closure")) (list "define"))))))

;; ── apply-fix: comprehensive require patterns ─────────────

(test-suite "apply-fix:add-require-std-rule"
  (check (check-success "std/rule"
    (list (apply-fix "(rule:define 'test :pattern \"x\" :replace \"y\")"
                     (diagnose "unbound variable: rule:define"))))))

(test-suite "apply-fix:add-require-std-pipeline"
  (check (check-success "std/pipeline"
    (list (apply-fix "(synthesize:pipeline \"test\" (synthesize:fill \"t\" \"a\"))"
                     (diagnose "unbound variable: synthesize:pipeline"))))))

(test-suite "apply-fix:add-require-std-data"
  (check (check-success "std/data"
    (list (apply-fix "(define-type Tree (leaf val) (node left right))"
                     (diagnose "unbound variable: define-type"))))))

(test-suite "apply-fix:add-require-ffi"
  (check (check-success "std/ffi"
    (list (apply-fix "(c-func \"m\" \"sqrt\" (list \"double\") \"double\")"
                     (diagnose "unbound variable: c-func"))))))

(test-suite "apply-fix:add-require-std-hash-ref"
  (check (check-success "std/hash"
    (list (apply-fix "(hash-ref h 'key)"
                     (diagnose "unbound variable: hash-ref"))))))

;; ── apply-fix: multiple missing requires ──────────────────

(test-suite "apply-fix:multiple-requires"
  (let* ((code "(map (lambda (x) (hash-ref h x)) (list 1 2 3))")
         (fixed (apply-fix (apply-fix code (diagnose "unbound variable: map"))
                          (diagnose "unbound variable: hash-ref"))))
    (check (check-success fixed (list "std/list")))
    (check (check-success fixed (list "std/hash"))))))

;; ── apply-fix: already correct code ──────────────────────

(test-suite "apply-fix:already-requires-std-list"
  (let* ((code "(require \"std/list\" all:)\n(for-each display (list 1 2))")
         (fixed (apply-fix code (diagnose "unbound variable: for-each"))))
    ;; Should still have exactly one std/list
    (check (check-success fixed (list "std/list")))
    (check (check-success fixed (list "for-each"))))))

(test-suite "apply-fix:already-requires-std-hash"
  (let* ((code "(require \"std/hash\" all:)\n(define (f) (hash-ref h 'key))")
         (fixed (apply-fix code (diagnose "unbound variable: hash-ref"))))
    (check (check-success fixed (list "std/hash")))
    (check (check-success fixed (list "hash-ref"))))))

;; ── apply-fix: define-function with various names ─────────

(test-suite "apply-fix:define-stub-for-custom-fn"
  (let ((fixed (apply-fix "(display (my-custom-func 42 7))"
                          (diagnose "unbound variable: my-custom-func"))))
    (check (check-success fixed (list "my-custom-func")))
    (check (check-success fixed (list "define"))))))

(test-suite "apply-fix:define-stub-for-unknown"
  (let ((fixed (apply-fix "(display (some-func))"
                          (diagnose "unbound variable: some-func"))))
    (check (check-success fixed (list "some-func"))))))

;; ── apply-fix: edge cases ────────────────────────────────

(test-suite "apply-fix:no-args-to-fix"
  (check (= (apply-fix "(display 42)" (diagnose "random")) #f)))

(test-suite "apply-fix:empty-code-string"
  (let ((fixed (apply-fix "" (diagnose "unbound variable: for-each"))))
    (check (check-success fixed (list "std/list")))
    (check (check-success fixed (list "require"))))))

(test-suite "apply-fix:failure-returns-bool-false"
  (check (= (apply-fix "code" #f) #f)))

(test-suite "apply-fix:diagnose-fix-cycle"
  ;; Full cycle: diagnose → apply-fix → verify
  (let* ((code "(for-each display (list 1 2 3))")
         (diag (diagnose "unbound variable: for-each"))
         (fixed (apply-fix code diag))
         (re-diag (diagnose "unbound variable: for-each")))
    (check (check-success fixed (list "std/list")))
    (check (check-success fixed (list "for-each"))))))

;; ── self-healing integration tests (鸿渐于陆) ────────────────
;; These test the full heal cycle: code → error → diagnose → apply-fix → verify

(test-suite "heal:missing-require-for-each"
  (let* ((code "(for-each display (list 1 2))")
         (err "unbound variable: for-each")
         (diag (diagnose err))
         (fixed (apply-fix code diag)))
    ;; fixed should contain the require
    (check (check-success fixed (list "std/list")))
    ;; fixed should NOT equal original code
    (check (check= (string=? code fixed) #f))))

(test-suite "heal:missing-require-make-hash"
  (let* ((code "(hash-ref (make-hash) 'key)")
         (err "unbound variable: make-hash")
         (diag (diagnose err))
         (fixed (apply-fix code diag)))
    (check (check-success fixed (list "std/hash")))
    (check (check= (string=? code fixed) #f))))

(test-suite "heal:missing-require-rule"
  (let* ((code "(rule:define 'test :pattern \"x\" :replace \"y\")")
         (err "unbound variable: rule:define")
         (diag (diagnose err))
         (fixed (apply-fix code diag)))
    (check (check-success fixed (list "std/rule")))
    (check (check= (string=? code fixed) #f))))

(test-suite "heal:missing-require-synthesize"
  (let* ((code "(synthesize:fill \"t\" \"a\")")
         (err "unbound variable: synthesize:fill")
         (diag (diagnose err))
         (fixed (apply-fix code diag)))
    (check (check-success fixed (list "std/pipeline")))
    (check (check= (string=? code fixed) #f))))

(test-suite "heal:missing-require-define-type"
  (let* ((code "(define-type Tree (leaf val) (node left right))")
         (err "unbound variable: define-type")
         (diag (diagnose err))
         (fixed (apply-fix code diag)))
    (check (check-success fixed (list "std/data")))
    (check (check= (string=? code fixed) #f))))

(test-suite "heal:apply-fix-on-parse-error"
  ;; Parse errors can't be auto-fixed — code should remain unchanged
  (let* ((code "(display (+ 1 2")
         (err "parse error: expected expression")
         (diag (diagnose err))
         (fixed (apply-fix code diag)))
    ;; fix-syntax returns code unchanged
    (check (check= fixed code))    ; unchanged
    (check (check-success (car (cdr (cdr diag))) (list "fix-syntax")))))

(test-suite "heal:apply-fix-on-closure"
  ;; Closure already handled by eval-current auto-fix, code unchanged
  (let* ((code "(define (f x) (* x 2))")
         (err "program returned an uncalled function")
         (diag (diagnose err))
         (fixed (apply-fix code diag)))
    (check (check-success (car diag) (list "closure-no-display")))
    (check (check= fixed code))))    ; unchanged

(test-suite "heal:no-error-no-heal"
  ;; No error → no diagnosis → apply-fix returns #f
  (let* ((code "(display 42)")
         (diag (diagnose "no error here")))
    (check (= diag #f))
    (check (= (apply-fix code diag) #f))))

(test-suite "heal:chain-apply-fix-twice"
  ;; Two missing requires in one code
  (let* ((code "(for-each display (hash-keys (make-hash)))")
         (diag1 (diagnose "unbound variable: for-each"))
         (diag2 (diagnose "unbound variable: make-hash"))
         (fixed1 (apply-fix code diag1))
         (fixed2 (try (apply-fix fixed1 diag2) (catch (e) fixed1))))
    (check (check-success fixed2 (list "std/list")))
    (check (check-success fixed2 (list "std/hash"))))))

(test-suite "heal:idempotent-no-change-needed"
  ;; Code that already has the right require — apply-fix no-ops
  (let* ((code "(require \"std/list\" all:)\n(for-each display (list 1 2))")
         (err "unbound variable: for-each")
         (diag (diagnose err))
         (fixed (apply-fix code diag)))
    (check (check-success fixed (list "std/list")))
    (check (check= fixed code))))    ; unchanged

(test-suite "heal:fixer-fallback-chain"
  ;; Simulate the fixer's step 0: diagnose → apply-fix
  ;; This mimics what bench.aura's fixer does
  (let* ((code "(hash-ref h 'key)")
         (err "unbound variable: hash-ref")
         (diag (try (diagnose err) (catch (e) #f)))
         (fixed (if (and diag (pair? diag))
                  (apply-fix code diag)
                  #f))
         (healed (and (string? fixed) (not (string=? fixed code)))))
    (check healed)
    (check (check-success fixed (list "std/hash")))
    (check (check-success fixed (list "hash-ref"))))))

(test-suite "heal:diagnose-execute-roundtrip"
  ;; End-to-end: error → diagnose → apply-fix → execute fixed code → check output
  (let* ((original-code "(for-each display (list 1 2 3))")
         (err "unbound variable: for-each")
         (diag (diagnose err))
         (fixed-code (apply-fix original-code diag))
         (full-code (string-append "(require \"std/test\" all:)" fixed-code))
         (has-require (check-success fixed-code (list "require" "std/list")))
         (has-original (check-success fixed-code (list "for-each" "display"))))
    (check has-require)
    (check has-original))))

;; ── heal primitive tests (std/heal.aura) ───────────────────

(test-suite "heal:working-code"
  (let ((r (heal "(display (+ 1 2))" (list "3") 3)))
    (check (check-success (car r) (list "healed")))))

(test-suite "heal:missing-require-for-each"
  (let ((r (heal "(for-each display (list 1 2))" (list "1" "2") 3)))
    (check (check-success (car r) (list "healed")))
    (check (check-success (car (cdr r)) (list "std/list")))))

(test-suite "heal:missing-require-hash"
  (let ((r (heal "(hash-ref (make-hash) 'x)" (list "hash-ref") 3)))
    (check (check-success (car r) (list "healed")))
    (check (check-success (car (cdr r)) (list "std/hash")))))

(test-suite "heal:parse-error-fails"
  (let ((r (heal "(display (+ 1" (list "3") 3)))
    (check (check-success (car r) (list "failed")))))

(test-suite "heal:exact-output-match"
  (let ((r (heal "(display 42)" (list "42") 1)))
    (check (check-success (car r) (list "healed")))))

(test-suite "heal:output-has-result"
  (let ((r (heal "(display 42)" (list "42") 1)))
    (check (check-success (car (cdr (cdr r))) (list "42")))))

(test-suite "heal:max-attempts-returns-failed"
  (let ((r (heal "(error \"always fails\")" (list "success") 2)))
    (check (check-success (car r) (list "failed")))))

(test-suite "heal:fixed-code-preserved"
  (let ((r (heal "(for-each display (list 1 2))" (list "1" "2") 3)))
    (check (check-success (car r) (list "healed")))
    ;; Fixed code should contain the require that was added
    (check (check-success (car (cdr r)) (list "std/list")))))

(test-suite "heal:multiple-attempts-recorded"
  ;; Code that needs healing should show attempt >= 1 (heal outputs debug line)
  (let ((r (heal "(for-each display (list 1 2))" (list "1" "2") 5)))
    (check (check-success (car r) (list "healed")))
    (check (check-success (car (cdr r)) (list "std/list" "for-each")))))

(test-suite "heal:zero-attempts"
  (let ((r (heal "(display 42)" (list "42") 0)))
    (check (check-success (car r) (list "failed")))))

(test-suite "heal:no-expected-keywords-mismatch"
  (let ((r (heal "(display 42)" (list "99") 1)))
    (check (check-success (car r) (list "failed")))))

(test-suite "heal:check-success-on-healed-output"
  (let ((r (heal "(display 42)" (list "42") 1)))
    (check (check-success (car (cdr (cdr r))) (list "42")))
    (check (check-success (car r) (list "healed")))))

(test-suite "heal:require-std-rule"
  (let ((r (heal "(rule:define 't :pattern \"x\" :replace \"y\")" (list "rule") 3)))
    (check (check-success (car r) (list "healed")))
    (check (check-success (car (cdr r)) (list "std/rule")))))

(test-suite "heal:require-std-pipeline"
  (let ((r (heal "(synthesize:pipeline \"t\" (synthesize:fill \"tmpl\" \"a\"))"
                 (list "synthesize") 3)))
    (check (check-success (car r) (list "healed")))
    (check (check-success (car (cdr r)) (list "std/pipeline")))))

(test-suite "heal:heal-twice-idempotent"
  ;; Heal the same already-healed code — should still pass
  (let* ((r1 (heal "(for-each display (list 1 2))" (list "1" "2") 3))
         (fixed-code (car (cdr r1)))
         (r2 (heal fixed-code (list "1" "2") 3)))
    (check (check-success (car r1) (list "healed")))
    (check (check-success (car r2) (list "healed")))))

(test-suite "heal:edsl-heal-chain"
  ;; EDSL code with set-code — should work with heal
  (let* ((edsl-code "(set-code \"(define (f x) (* x 2))\")")
         (r (heal edsl-code (list "set-code") 3)))
    ;; EDSL code should at least run without error
    (check (or (check-success (car r) (list "healed"))
               (check-success (car r) (list "failed"))))))
