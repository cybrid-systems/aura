(require "std/test" all:)
(require "std/orchestrator" all:)

; ── orch:define-role ──
(test-suite "orch:define-role-basic"
  (check (orch:define-role "generator" (cons (lambda (x) x) "direct"))))

(test-suite "orch:define-role-overwrite"
  (orch:define-role "test-role" (cons (lambda (x) (+ x 1)) "direct"))
  (check (orch:define-role "test-role" (cons (lambda (x) (* x 2)) "direct"))))

; ── orch:step ──
(test-suite "orch:step-direct"
  (orch:define-role "double" (cons (lambda (x) (* x 2)) "direct"))
  (check (= (orch:step "double" 5) 10)))

(test-suite "orch:step-unknown-role"
  (check (= (orch:step "nonexistent" 42) 42)))

(test-suite "orch:pipeline-basic"
  (orch:define-role "add1" (cons (lambda (x) (+ x 1)) "direct"))
  (orch:define-role "add2" (cons (lambda (x) (+ x 2)) "direct"))
  (check (= (orch:pipeline (list "add1" "add2") 0) 3)))

(test-suite "orch:pipeline-empty"
  (check (= (orch:pipeline (quote ()) 42) 42)))

(test-suite "orch:pipeline-chaining"
  (orch:define-role "double" (cons (lambda (x) (* x 2)) "direct"))
  (orch:define-role "square" (cons (lambda (x) (* x x)) "direct"))
  (check (= (orch:pipeline (list "double" "square") 5) 100)))

(test-suite "orch:run-basic"
  (orch:define-role "inc" (cons (lambda (x) (+ x 1)) "direct"))
  (check (= (orch:run "test-pipeline" (list "inc" "inc") 0) 2)))

; ── agent:spawn (in stdin mode: should return structured error) ──
(test-suite "orch:agent-spawn-stdin"
  (check (pair? (agent:spawn "test-agent"))))

(test-suite "orch:agent-list-stdin"
  (check (null? (agent:list))))

; ── orch:parallel ──
(test-suite "orch:parallel-basic"
  (orch:define-role "double" (cons (lambda (x) (* x 2)) "direct"))
  (orch:define-role "triple" (cons (lambda (x) (* x 3)) "direct"))
  (let ((r (orch:parallel (list double triple) 5)))
    (and (pair? r) (= (car r) 10) (= (car (cdr r)) 15))))

(test-suite "orch:parallel-empty"
  (check (null? (orch:parallel (quote ()) 42))))

(test-suite "orch:parallel-single"
  (orch:define-role "inc" (cons (lambda (x) (+ x 1)) "direct"))
  (let ((r (orch:parallel (list inc) 0)))
    (and (pair? r) (= (car r) 1)))))

;; ═══════════════════════════════════════════════════════════════
;; P1: Agent lifecycle — spawn, ask, status, stop, restart
;; ═══════════════════════════════════════════════════════════════

(test-suite "orch:agent-spawn-with-handler"
  (check (string=? (agent:spawn "adder" (lambda (x) (+ x 1))) "adder")
    "agent:spawn returns agent name"))

(test-suite "orch:agent-ask-local"
  (agent:spawn "double" (lambda (x) (* x 2)))
  (check (= (agent:ask "double" 21) 42)
    "agent:ask invokes handler and returns result"))

(test-suite "orch:agent-ask-multiple"
  (agent:spawn "triple" (lambda (x) (* x 3)))
  (check (and (= (agent:ask "triple" 5) 15) (= (agent:ask "triple" 10) 30))
    "agent:ask can be called multiple times"))

(test-suite "orch:agent-status-basic"
  (agent:spawn "status-test" (lambda (x) x))
  (check (string=? (agent:status "status-test") "running")
    "agent:status returns 'running' for active agent"))

(test-suite "orch:agent-stop-and-status"
  (agent:spawn "stopper" (lambda (x) x))
  (agent:stop "stopper")
  (check (string=? (agent:status "stopper") "stopped")
    "agent:stop changes status to 'stopped'"))

(test-suite "orch:agent-restart-replaces-handler"
  (agent:spawn "replacer" (lambda (x) (+ x 1)))
  (agent:restart "replacer" (lambda (x) (* x 2)))
  (check (= (agent:ask "replacer" 5) 10)
    "agent:restart replaces handler"))

(test-suite "orch:agent-list-after-spawn"
  (agent:spawn "agent-a" (lambda (x) x))
  (agent:spawn "agent-b" (lambda (x) x))
  (define names (agent:list))
  (check (and (pair? names) (member "agent-a" names) (member "agent-b" names))
    "agent:list includes all spawned agents"))

(test-suite "orch:agent-ask-unknown-agent"
  ;; agent:ask on non-existent agent falls through to send (returns error pair)
  (check (pair? (agent:ask "ghost" 42))
    "agent:ask on unknown agent returns error pair"))

(test-suite "orch:agent-stop-unknown"
  (check (eq? (agent:stop "nonexistent") #f)
    "agent:stop on unknown returns #f"))

(test-suite "orch:agent-restart-creates-if-missing"
  ;; restart on non-existent agent creates it
  (agent:restart "newbie" (lambda (x) (* x x)))
  (check (= (agent:ask "newbie" 6) 36)
    "agent:restart creates new agent if name not found"))

;; ═══════════════════════════════════════════════════════════════
;; P1: orch:conduct — full pipeline conductor
;; ═══════════════════════════════════════════════════════════════

(test-suite "orch:conduct-basic"
  (orch:define-role "inc" (cons (lambda (x) (+ x 1)) "direct"))
  (check (= (orch:conduct (list "inc" "inc" "inc") 0) 3)
    "orch:conduct executes sequential pipeline"))

(test-suite "orch:conduct-empty"
  (check (= (orch:conduct (quote ()) 42) 42)
    "orch:conduct with empty steps returns input"))

(test-suite "orch:conduct-mixed-roles"
  (orch:define-role "add2" (cons (lambda (x) (+ x 2)) "direct"))
  (orch:define-role "mul3" (cons (lambda (x) (* x 3)) "direct"))
  (check (= (orch:conduct (list "add2" "mul3") 5) 21)  ; (5+2)*3 = 21
    "orch:conduct chains different roles"))

;; ═══════════════════════════════════════════════════════════════
;; P1: orch:conduct with orch:if (conditional branches)
;; ═══════════════════════════════════════════════════════════════

(test-suite "orch:if-true-branch"
  (orch:define-role "upper" (cons (lambda (x) (+ x 100)) "direct"))
  (orch:define-role "lower" (cons (lambda (x) (+ x 1)) "direct"))
  ;; If positive → upper, else → lower. Input 5 is positive.
  (check (= (orch:conduct (list (orch:if (lambda (x) (> x 0)) "upper" "lower")) 5) 105)
    "orch:if takes true branch when predicate is truthy"))

(test-suite "orch:if-false-branch"
  (orch:define-role "upper" (cons (lambda (x) (+ x 100)) "direct"))
  (orch:define-role "lower" (cons (lambda (x) (+ x 1)) "direct"))
  ;; Input -5 is not positive → else branch
  (check (= (orch:conduct (list (orch:if (lambda (x) (> x 0)) "upper" "lower")) -5) -4)
    "orch:if takes false branch when predicate is falsy"))

;; ═══════════════════════════════════════════════════════════════
;; P1: orch:conduct with orch:retry (retry on failure)
;; ═══════════════════════════════════════════════════════════════

(test-suite "orch:retry-basic"
  (let ((attempts 0))
    (orch:define-role "unstable" (cons
      (lambda (x)
        (set! attempts (+ attempts 1))
        (if (< attempts 3) (error "not yet") (+ x 1)))
      "direct"))
    (check (= (orch:conduct (list (orch:retry "unstable" 5)) 10) 11)
      "orch:retry succeeds after multiple attempts")))

(test-suite "orch:retry-failure-on-empty"
  ;; Empty pipeline + retry should just return input
  (check (= (orch:conduct (list (orch:retry (quote ()) 3)) 42) 42)
    "orch:retry on empty step returns input"))

;; ═══════════════════════════════════════════════════════════════
;; P1: orch:conduct with lambda steps (inline functions)
;; ═══════════════════════════════════════════════════════════════

(test-suite "orch:conduct-lambda-step"
  (check (= (orch:conduct (list (lambda (x) (+ x 5))) 10) 15)
    "orch:conduct accepts lambda as step"))

(test-suite "orch:conduct-lambda-chain"
  (check (= (orch:conduct (list (lambda (x) (* x 2)) (lambda (x) (+ x 1))) 3) 7)
    "orch:conduct chains lambda steps"))

;; ═══════════════════════════════════════════════════════════════
;; P1: orch:role and orch:step* constructors
;; ═══════════════════════════════════════════════════════════════

(test-suite "orch:role-basic"
  (define r (orch:role (lambda (x) (+ x 1))))
  (check (pair? r)
    "orch:role returns a pair"))

(test-suite "orch:step*-named"
  ;; Step* with hash arguments — uses the action from config
  (check (pair? (orch:step* :role "test" :strategy "direct"))
    "orch:step* returns a pair"))

;; ═══════════════════════════════════════════════════════════════
;; P1: orch:parallel — timeout and error handling
;; ═══════════════════════════════════════════════════════════════

(test-suite "orch:parallel-with-timeout"
  (orch:define-role "slow" (cons (lambda (x) (sleep 5) (* x 2)) "direct"))
  ;; Timeout at 0.1s — slow fn won't complete, should return (#f)
  (let ((r (orch:parallel (list slow) 42 0.1)))
    (check (and (pair? r) (not (car r)))
      "orch:parallel with timeout returns #f for timed-out fibers")))

(test-suite "orch:parallel-error-isolation"
  ;; One fiber failing should not prevent others
  (let ((r (orch:parallel (list (lambda (x) (error "boom"))
                                (lambda (x) (+ x 1)))
                          5)))
    (check (and (pair? r) (= (car (cdr r)) 6))
      "orch:parallel error isolation — good fiber still returns result")))

;; ═══════════════════════════════════════════════════════════════
;; P1: orch:pipeline — edge cases
;; ═══════════════════════════════════════════════════════════════

(test-suite "orch:pipeline-single-step"
  (orch:define-role "identity" (cons (lambda (x) x) "direct"))
  (check (= (orch:pipeline (list "identity") 99) 99)
    "orch:pipeline with single step works"))
