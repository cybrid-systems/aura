(require "std/test" all:)
(require "std/orchestrator" all:)

; ── orch:define-role ──
(test-suite "orch:define-role-basic"
  (check (orch:define-role "generator" (cons (lambda (x) x) "direct"))))

(test-suite "orch:define-role-overwrite"
  (orch:define-role "test-role" (cons (lambda (x) (+ x 1)) "direct"))
  (check (orch:define-role "test-role" (cons (lambda (x) (* x 2)) "direct"))))

; ── orch:step ──
(test-suite "orch:step-direct"
  (orch:define-role "double" (cons (lambda (x) (* x 2)) "direct"))
  (check (= (orch:step "double" 5) 10)))

(test-suite "orch:step-unknown-role"
  (check (= (orch:step "nonexistent" 42) 42)))

(test-suite "orch:pipeline-basic"
  (orch:define-role "add1" (cons (lambda (x) (+ x 1)) "direct"))
  (orch:define-role "add2" (cons (lambda (x) (+ x 2)) "direct"))
  (check (= (orch:pipeline (list "add1" "add2") 0) 3)))

(test-suite "orch:pipeline-empty"
  (check (= (orch:pipeline (quote ()) 42) 42)))

(test-suite "orch:pipeline-chaining"
  (orch:define-role "double" (cons (lambda (x) (* x 2)) "direct"))
  (orch:define-role "square" (cons (lambda (x) (* x x)) "direct"))
  (check (= (orch:pipeline (list "double" "square") 5) 100)))

(test-suite "orch:run-basic"
  (orch:define-role "inc" (cons (lambda (x) (+ x 1)) "direct"))
  (check (= (orch:run "test-pipeline" (list "inc" "inc") 0) 2)))

; ── agent:spawn (in stdin mode: should return structured error) ──
(test-suite "orch:agent-spawn-stdin"
  (check (pair? (agent:spawn "test-agent"))))

(test-suite "orch:agent-list-stdin"
  (check (null? (agent:list))))

; ── orch:parallel ──
(test-suite "orch:parallel-basic"
  (orch:define-role "double" (cons (lambda (x) (* x 2)) "direct"))
  (orch:define-role "triple" (cons (lambda (x) (* x 3)) "direct"))
  (let ((r (orch:parallel (list double triple) 5)))
    (and (pair? r) (= (car r) 10) (= (car (cdr r)) 15))))

(test-suite "orch:parallel-empty"
  (check (null? (orch:parallel (quote ()) 42))))

(test-suite "orch:parallel-single"
  (orch:define-role "inc" (cons (lambda (x) (+ x 1)) "direct"))
  (let ((r (orch:parallel (list inc) 0)))
    (and (pair? r) (= (car r) 1))))
