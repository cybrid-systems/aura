; suite/engine_metrics.aura — P1a/P2b (engine:metrics) facade
; Works under AURA_PRIMITIVES=full and s0 (facade-only).

(require "std/test" all:)

(test-suite "engine:metrics-summary"
  (check (hash? (engine:metrics)))
  (check (= 1 (hash-ref (engine:metrics) "schema")))
  (check (> (hash-ref (engine:metrics) "stats-count") 0))
  (check (pair? (hash-ref (engine:metrics) "stats-names"))))

(test-suite "engine:metrics-by-name"
  ; Lookup routes to underlying stats prim when registered (full mode).
  ; Under s0, individual query:*-stats are absent → void (still OK).
  (define one (engine:metrics "query:macro-hygiene-stats"))
  (check (or (hash? one) (eq? one (void))))
  (check (eq? (engine:metrics "query:no-such-stats-zzz") (void))))

(test-suite "engine:metrics-all"
  (define all (engine:metrics :all))
  (check (hash? all))
  (check (= (hash-ref (engine:metrics) "stats-count")
            (hash-ref all "stats-count"))))

; Full-mode parity: direct stats prim matches facade by-name.
(test-suite "engine:metrics-parity"
  (define via (engine:metrics "query:macro-hygiene-stats"))
  (if (eq? via (void))
      (check #t) ; s0: no bulk stats registered
    (begin
      (define direct (query:macro-hygiene-stats))
      (check (hash? direct))
      (check (hash? via))
      (check (number? (hash-ref via "schema"))))))
