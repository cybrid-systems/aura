(require "std/test" all:)
; EDSL (query/mutate/workspace) tests
; Tests: set-code, query:*, mutate:*, eval-current, typecheck-current

(test-suite "edsl:workspace"
  (check (set-code "(define (add x y) (+ x y))"))
  (check (module? (use "std/list"))))

(test-suite "edsl:query-find"
  (set-code "(define (fib n) (if (< n 2) n (+ (fib (- n 1)) (fib (- n 2)))))")
  (check (> (length (query:find "fib")) 0)))

(test-suite "edsl:query-children"
  (set-code "(define (f x) (+ x 1))")
  (let ((root (query:root)))
    (check (> (length (query:children root)) 0))))

(test-suite "edsl:query-node"
  (let ((root (query:root)))
    (check (pair? (query:node root)))))

(test-suite "edsl:query-calls"
  (check (pair? (query:calls "fib"))))

(test-suite "edsl:query-parent"
  (check (pair? (query:parent 0))))

(test-suite "edsl:query-siblings"
  (check (pair? (query:siblings 0))))

(test-suite "edsl:query-pattern"
  (set-code "(define (f x) (+ x 1))")
  (check (pair? (query:pattern "(+ ... ...)"))))

(test-suite "edsl:node-type"
  (set-code "(define (f x) (+ x 1))")
  (check (pair? (query:node-type "Call"))))

(test-suite "edsl:mutate-set-body"
  (set-code "(define (fib n) (if (< n 2) n (+ (fib (- n 1)) (fib (- n 2)))))")
  (check (mutate:set-body "fib" "(iter 0 1 n)")))

(test-suite "edsl:mutate-rebind"
  (set-code "(define (add x y) (+ x y))")
  (check (mutate:rebind "add" "(define (add x y) (* x y))")))

(test-suite "edsl:mutate-remove-node"
  (set-code "(define (f x) (+ x 1))")
  (check (mutate:remove-node 0)))

(test-suite "edsl:mutate-replace-value"
  (set-code "(define (f x) (+ x 1))")
  (check (mutate:replace-value 2 100 "change value")))

(test-suite "edsl:mutate-insert-child"
  (set-code "(define (f x) (+ x 1))")
  (check (mutate:insert-child 0 1 "(* x x)" "insert")))

(test-suite "edsl:eval-current"
  (set-code "(define (add x y) (+ x y))")
  (check (eval-current)))

(test-suite "edsl:typecheck"
  (check (string? (typecheck-current))))

;; ── Transaction rollback tests ─────────────────────────────

(test-suite "edsl:mutation-transaction"
  (set-code "(define (f x) (+ x 1))")
  ;; Apply a valid mutation
  (check (mutate:replace-value 2 42 "change to 42"))
  ;; Mutations are committed individually
  (check (query:node-type "LiteralInt")))

(test-suite "edsl:rollback-after-failure"
  (set-code "(define (f x) (+ x 1))")
  (check (mutate:replace-value 2 42 "change to 42"))
  (check (query:node-type "LiteralInt")))

;; ═══════════════════════════════════════════════════════════════
;; P1/P2: Def-Use Analysis tests
;; ═══════════════════════════════════════════════════════════════

(test-suite "defuse:define"
  (set-code "(define x 42)")
  (let* ((result (query:def-use "x"))
         (defs (car result))
         (uses (cdr result)))
    (check (= (length defs) 1))
    (check (= (length uses) 0)))
  ;; Clean up
  (set-code "(define (f x) (+ x 1))"))

(test-suite "defuse:define-function"
  (set-code "(define (fib n) (if (< n 2) n (+ (fib (- n 1)) (fib (- n 2)))))")
  (let* ((result (query:def-use "fib"))
         (defs (car result))
         (uses (cdr result)))
    ;; fib is defined once and used in recursive calls + possibly display
    (check (= (length defs) 1))
    (check (> (length uses) 0))))

(test-suite "defuse:lambda-param"
  (set-code "(define (f x) (+ x 1))")
  (let* ((result (query:def-use "x"))
         (defs (car result))
         (uses (cdr result)))
    (check (= (length defs) 1))  ;; lambda param
    (check (> (length uses) 0))))  ;; used in body

(test-suite "defuse:let-binding"
  (set-code "(let ((y 42)) y)")
  (let* ((result (query:def-use "y"))
         (defs (car result))
         (uses (cdr result)))
    (check (= (length defs) 1))
    (check (= (length uses) 1))))

(test-suite "defuse:letrec-recur"
  (set-code "(letrec ((fact (lambda (n) (if (= n 0) 1 (* n (fact (- n 1))))))) (fact 5))")
  (let* ((result (query:def-use "fact"))
         (defs (car result))
         (uses (cdr result)))
    (check (= (length defs) 1))
    ;; fact used in recursive body + the call (fact 5)
    (check (> (length uses) 0))))

(test-suite "defuse:unused-symbol"
  (set-code "(define x 42)")
  (let* ((result (query:def-use "nonexistent"))
         (defs (car result))
         (uses (cdr result)))
    (check (= (length defs) 0))
    (check (= (length uses) 0))))

(test-suite "defuse:undefined-builtin"
  (set-code "(define (f x) (+ x 1))")
  (let* ((result (query:def-use "display"))
         (defs (car result))
         (uses (cdr result)))
    (check (= (length defs) 0))  ;; display is not defined
    ;; display may or may not be used depending on code
    (check (list? defs))))

(test-suite "defuse:cross-scope"
  (set-code "
    (define outer 42)
    (define (f n)
      (let ((inner 10))
        (+ outer inner n)))
  ")
  ;; outer: defined at module scope, used inside f
  (let* ((outer-result (query:def-use "outer"))
         (outer-defs (car outer-result))
         (outer-uses (cdr outer-result)))
    (check (= (length outer-defs) 1))
    (check (> (length outer-uses) 0)))
  ;; inner: defined in let, used in body
  (let* ((inner-result (query:def-use "inner"))
         (inner-defs (car inner-result))
         (inner-uses (cdr inner-result)))
    (check (= (length inner-defs) 1))
    (check (= (length inner-uses) 1)))
  ;; n: defined in lambda, used in body
  (let* ((n-result (query:def-use "n"))
         (n-defs (car n-result))
         (n-uses (cdr n-result)))
    (check (= (length n-defs) 1))
    (check (> (length n-uses) 0))))

(test-suite "defuse:reaches"
  (set-code "(define (f x) (+ x 1))")
  ;; query:reaches on define node (node 0 if root, or found by query:node-type)
  (let ((defines (query:node-type "Define")))
    (if (pair? defines)
      (let ((define-node (car defines))
            (result (query:reaches (car defines)))
            (defs (car result))
            (uses (cdr result)))
        ;; The define reaches the variable x
        (check (= (length defs) 1))
        (check (> (length uses) 0)))
      ;; If no Define node (shouldn't happen), pass placeholder
      (check #t))))

(test-suite "defuse:reaches-on-variable"
  (set-code "(define (f x) (+ x 1))")
  ;; query:reaches on a Variable node (should be void, since Variables don't define)
  (let ((variables (query:node-type "Variable")))
    (if (pair? variables)
      ;; reaches on a variable should return empty, not crash
      (check (pair? (query:reaches (car variables))))
      (check #t))))

(test-suite "defuse:effects"
  (set-code "(define (f x) (+ x 1))")
  (let ((result (query:effects "f")))
    (check (pair? result))  ;; result is a pair
    ;; effects returns (defs uses callers) as three-element list
    ;; At minimum, f is defined once; callers may vary
    (check (> (length (car result)) 0))))

(test-suite "defuse:effects-nonexistent"
  (set-code "(define (f x) (+ x 1))")
  (let ((result (query:effects "nonexistent")))
    ;; All three lists should be empty but not crash
    (check (pair? result))))

(test-suite "defuse:cache-rebuild-after-mutate"
  (set-code "(define (f x) (+ x 1))")
  ;; Cache builds on first query
  (let* ((before (query:def-use "f"))
         (before-defs (car before)))
    (check (= (length before-defs) 1)))
  ;; Rebind changes the definition — cache should rebuild
  (check (mutate:rebind "f" "(lambda (y) (* y 2))" "test rebind"))
  ;; Now query:def-use should show updated results
  (let* ((after (query:def-use "f"))
         (after-defs (car after)))
    (check (= (length after-defs) 1))))

(test-suite "defuse:multiple-set-code"
  ;; First workspace
  (set-code "(define (f x) (+ x 1))")
  (let* ((r1 (query:def-use "f"))
         (d1 (car r1)))
    (check (= (length d1) 1)))
  ;; Second workspace — should completely rebuild cache
  (set-code "(define (g x) (* x 2))")
  (let* ((r2 (query:def-use "g"))
         (d2 (car r2)))
    (check (= (length d2) 1)))
  ;; f should no longer exist
  (let* ((r3 (query:def-use "f"))
         (d3 (car r3)))
    (check (= (length d3) 0))))

(test-suite "defuse:empty-workspace"
  (set-code "(define x 1)")
  (display (query:def-use "x"))
  (set-code "")
  (check (pair? (query:def-use "x")))
  (check (pair? (query:effects "x"))))

;; ═══════════════════════════════════════════════════════════════
;; P10: AST Snapshot / Restore / Diff
;; ═══════════════════════════════════════════════════════════════

(test-suite "snapshot:basic"
  (set-code "(define (f x) (+ x 1))")
  (let ((sid (ast:snapshot "f")))
    (check (>= sid 0))
    ;; List snapshots should include our snapshot
    (check (pair? (ast:list-snapshots)))))

(test-suite "snapshot:restore"
  (set-code "(define (f x) (+ x 1))")
  (define sid (ast:snapshot "before"))
  ;; Mutate
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  ;; Restore
  (check (ast:restore sid))
  ;; Should be back to original
  (let ((defs (car (query:def-use "f"))))
    (check (= (length defs) 1))))

(test-suite "snapshot:diff-after-mutate"
  (set-code "(define (f x) (+ x 1))")
  (define sid (ast:snapshot "f"))
  ;; Mutate
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  ;; Diff should show changes
  (let ((changes (ast:diff sid)))
    ;; There should be at least some diff entries
    (check (> (length changes) 0))
    ;; At least one entry should be :removed or :added
    (check (pair? changes))))

(test-suite "snapshot:empty-id-uses-most-recent"
  (set-code "(define (f x) (+ x 1))")
  (ast:snapshot "v1")
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  ;; Without args, ast:diff should use most recent snapshot
  (check (pair? (ast:diff))))

(test-suite "snapshot:mutliple-snapshots"
  (set-code "(define (f x) (+ x 1))")
  (ast:snapshot "v1")
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  (ast:snapshot "v2")
  (check (pair? (ast:list-snapshots))))

(test-suite "snapshot:diff-empty-after-restore"
  (set-code "(define (f x) (+ x 1))")
  (define sid (ast:snapshot "v1"))
  ;; Mutate then restore
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  (ast:restore sid)
  ;; Diff vs snapshot should now be minimal (only formatting changes)
  ;; or empty for same single-expression inputs
  (check (list? (ast:diff sid))))

(test-suite "snapshot:diff-empty-no-changes"
  (set-code "(define (f x) (+ x 1))")
  (define sid (ast:snapshot "v1"))
  ;; No mutations — diff should be empty (or just formatting diffs)
  (let ((changes (ast:diff sid)))
    (check (list? changes))))

(test-suite "snapshot:restore-invalid-id"
  (set-code "(define (f x) (+ x 1))")
  ;; Restore with invalid (too large) ID should return #f, not crash
  (check (not (ast:restore 9999))))

(test-suite "snapshot:diff-no-snapshots"
  (set-code "(define (f x) (+ x 1))")
  ;; Diff without any snapshots should return empty list, not crash
  (check (list? (ast:diff))))

(test-suite "snapshot:consecutive-diffs"
  (set-code "(define (f x) (+ x 1))")
  (define s1 (ast:snapshot "v1"))
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  (define s2 (ast:snapshot "v2"))
  ;; Diff s1 (before mutate) vs s2 (after mutate)
  (define diff1 (ast:diff s1))
  (define diff2 (ast:diff s2))
  ;; Both should be valid lists
  (check (list? diff1))
  (check (list? diff2))))

(test-suite "snapshot:list-after-multiple"
  (set-code "(define (f x) (+ x 1))")
  (ast:snapshot "a")
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  (ast:snapshot "b")
  ;; List should contain at least 2 snapshots
  (let ((lst (ast:list-snapshots)))
    (check (>= (length lst) 2)))))



;; ═══════════════════════════════════════════════════════════════
;; P11: AST Summary & Compile Status
;; ═══════════════════════════════════════════════════════════════

(test-suite "summary:basic"
  (set-code "(define (f x) (+ x 1))")
  (let ((s (ast:summary)))
    (check (pair? s))
    (check (>= (length s) 1))))

(test-suite "summary:node-counts"
  (set-code "(define (f x) (+ x 1))")
  (query:def-use "f")
  (let ((s (ast:summary)))
    (check (> (length s) 0))))

(test-suite "summary:after-mutation"
  (set-code "(define (f x) (+ x 1))")
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  (let ((s (ast:summary)))
    (check (pair? s))
    (check (> (length s) 0))))

(test-suite "compile:status-basic"
  (set-code "(define (f x) (+ x 1))")
  (let ((st (compile:status)))
    (check (pair? st))
    (check (>= (length st) 3))))

(test-suite "compile:status-after-mutation"
  (set-code "(define (f x) (+ x 1))")
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  (let ((st (compile:status)))
    (check (pair? st))))


;; ═══════════════════════════════════════════════════════════════
;; P12: Higher-Order AST Transformations
  (test-suite "mutate:splice-basic"
  (set-code "(begin (display 1) (display 3))")
  (let ((root (query:root)))
    ;; Splice (display 2) between 1 and 3 at position 1
    (let ((result (mutate:splice root 1 "(display 2)" "splice")))
      (check (> (length result) 0))
      ;; Should have 1 inserted node
      (check (= (length result) 1))
      ;; Children should include the new node
      (let ((children (query:children root)))
        (check (>= (length children) 2))))))

(test-suite "mutate:splice-multiple"
  (set-code "(begin (display 1) (display 4))")
  (let ((root (query:root)))
    ;; Splice two expressions at position 1
    (let ((result (mutate:splice root 1 "(display 2)" "(display 3)" "splice multiple")))
      (check (= (length result) 2))
      ;; Children should now have 4 entries
      (let ((children (query:children root)))
        (check (>= (length children) 3))))))

(test-suite "mutate:wrap-basic"
  (set-code "(define (f x) (+ x 1))")
  ;; Find the (+ x 1) call and wrap in display
  (let ((calls (query:node-type "Call")))
    (if (pair? calls)
      (let ((result (mutate:wrap (car calls) "(display _)" "wrap test")))
        (check (>= result 0)))
      ;; If no calls (shouldnt happen), pass placeholder
      (check #t))))

(test-suite "mutate:wrap-after-splice"
  (set-code "(begin (display 1) (display 3))")
  (let ((root (query:root)))
    ;; Splice then wrap — verify both mutate and wrap work together
    (mutate:splice root 1 "(display 2)" "splice")
    ;; Now wrap the last child (display 3) in begin
    (let ((children (query:children root)))
      (if (pair? children)
        (let ((last-child (car (reverse children))))
          (check (>= (mutate:wrap last-child "(begin _)" "wrap") 0)))
        (check #t)))))

(test-suite "mutate:splice-empty"
  (set-code "(define x 42)")
  (let ((root (query:root)))
    (check (not (mutate:splice root 0 "splice")))))
  ;; splice with no code args should return #f
  (check (not (mutate:splice 0 0 "splice"))))


;; ═══════════════════════════════════════════════════════════════
;; P13: Workspace Layering (P0)
;; ═══════════════════════════════════════════════════════════════

(test-suite "ws:create-and-current"
  (set-code "(define (f x) (+ x 1))")
  ;; Create a child workspace
  (let ((id (workspace:create "test")))
    (check (>= id 0))
    ;; Should still be on root
    (check (= (workspace:current) 0))))

(test-suite "ws:switch-and-mutate"
  (set-code "(define (f x) (+ x 1))")
  (let ((id (workspace:create "child")))
    (check (workspace:switch id))
    ;; Mutate in child
    (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
    ;; Switch back to root
    (workspace:switch 0)
    ;; Root should be unchanged
    (let ((result (query:def-use "f")))
      (check (> (length (car result)) 0)))))

(test-suite "ws:list"
  (set-code "(define (f x) (+ x 1))")
  (workspace:create "a")
  (workspace:create "b")
  (let ((lst (workspace:list)))
    ;; List should contain root + at least one child
    (check (>= (length lst) 2))))

(test-suite "ws:delete"
  (set-code "(define (f x) (+ x 1))")
  (let ((id (workspace:create "temp")))
    (workspace:switch id)
    (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
    (workspace:switch 0)
    ;; Delete the child
    (check (workspace:delete id))
    ;; Root should still be intact
    (let ((result (query:def-use "f")))
      (check (> (length (car result)) 0)))))

(test-suite "ws:isolation"
  (set-code "(define (f x) (+ x 1))")
  (let ((id (workspace:create "isolated")))
    ;; Create a second workspace from root
    (workspace:switch id)
    ;; Mutate in child — should not affect root
    (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
    (workspace:switch 0)
    ;; Root def-use should show the ORIGINAL code being in effect
    (check #t)))


(test-suite "ws:multiple-workspaces"
  (set-code "(define (f x) (+ x 1))")
  (define w1 (workspace:create "a"))
  (define w2 (workspace:create "b"))
  (define w3 (workspace:create "c"))
  ;; All should have different IDs
  (check (not (= w1 w2)))
  (check (not (= w1 w3)))
  (check (not (= w2 w3)))
  ;; List should show all
  (let ((lst (workspace:list)))
    (check (= (length lst) 4)))  ;; root + 3 children)

(test-suite "ws:deep-isolation"
  (set-code "(define x 1)")
  (define w1 (workspace:create "mutator"))
  (workspace:switch w1)
  ;; Mutate heavily
  (set-code "(define x 999)")
  (set-code "(define y 42)")
  (mutate:rebind "y" "(lambda () 100)" "test")
  ;; Switch back to root
  (workspace:switch 0)
  ;; Root should have ONLY the original
  (let* ((r (query:def-use "x"))
         (defs (car r)))
    (check (= (length defs) 1)))
  ;; y should not exist in root
  (let* ((r (query:def-use "y"))
         (defs (car r)))
    (check (= (length defs) 0))))

(test-suite "ws:switch-defuse-rebuild"
  (set-code "(define (f x) (+ x 1))")
  ;; Build def-use cache in root
  (query:def-use "f")
  (define w1 (workspace:create "child"))
  (workspace:switch w1)
  ;; Child should have its own def-use (rebuilt on switch)
  (let* ((r (query:def-use "f"))
         (defs (car r))
         (uses (cdr r)))
    (check (= (length defs) 1))
    (check (> (length uses) 0)))
  ;; Switch back — cache rebuilds again
  (workspace:switch 0)
  (let* ((r (query:def-use "f"))
         (defs (car r)))
    (check (= (length defs) 1))))

(test-suite "ws:create-from-child"
  (set-code "(define (f x) (+ x 1))")
  (define w1 (workspace:create "inner"))
  (workspace:switch w1)
  ;; Mutate inner
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  ;; Create grandchild FROM inner (clones inner's state)
  (define w2 (workspace:create "grandchild"))
  (workspace:switch w2)
  ;; Grandchild should have inner's version of f
  (let* ((r (query:def-use "f"))
         (defs (car r)))
    (check (= (length defs) 1))))

(test-suite "ws:delete-nonroot"
  (set-code "(define (f x) (+ x 1))")
  (workspace:create "a")
  (workspace:create "b")
  (workspace:create "c")
  ;; Delete non-root and non-active
  (check (workspace:delete 1))
  ;; List should have fewer entries
  (let ((lst (workspace:list)))
    (check (>= (length lst) 2))))

(test-suite "ws:delete-active-switches-to-root"
  (set-code "(define (f x) (+ x 1))")
  (define wid (workspace:create "temp"))
  (workspace:switch wid)
  ;; Delete the active workspace
  (workspace:delete wid)
  ;; Should auto-switch to root
  (check (= (workspace:current) 0))))

(test-suite "ws:list-after-delete"
  (set-code "(define (f x) (+ x 1))")
  (workspace:create "delete-me")
  (workspace:delete 1)
  ;; List should only have root
  (let ((lst (workspace:list)))
    (check (= (length lst) 1))))


;; ═══════════════════════════════════════════════════════════════
;; P13 P1: COW + Read-only Lock
;; ═══════════════════════════════════════════════════════════════

(test-suite "ws:cow-isolation"
  (set-code "(define (f x) (+ x 1))")
  (define w1 (workspace:create "cow-test"))
  ;; Switch triggers COW — child gets own flat
  (workspace:switch w1)
  (mutate:rebind "f" "(lambda (x) (* x 2))" "mutate after cow")
  (display (current-source))
  ;; Root should be unchanged
  (workspace:switch 0)
  (let* ((r (query:def-use "f"))
         (uses (cdr r)))
    ;; f still used as before
    (check (pair? uses))))

(test-suite "ws:lock-prevents-mutate"
  (set-code "(define (f x) (+ x 1))")
  (define w1 (workspace:create "lock-test"))
  (workspace:lock w1 #t)
  (workspace:switch w1)
  ;; Mutate should be rejected
  (check (not (mutate:rebind "f" "(lambda (x) (* x 2))" "test")))
  ;; Source should be unchanged
  (let* ((r (query:def-use "f"))
         (defs (car r)))
    (check (= (length defs) 1))))

(test-suite "ws:lock-unlock-allows-mutate"
  (set-code "(define (f x) (+ x 1))")
  (define w1 (workspace:create "unlock-test"))
  (workspace:lock w1 #t)
  (workspace:switch w1)
  ;; Should be rejected while locked
  (check (not (mutate:rebind "f" "(lambda (x) (* x 2))" "test")))
  ;; Unlock
  (workspace:lock w1 #f)
  ;; Now should succeed
  (check (mutate:rebind "f" "(lambda (x) (* x 2))" "test")))

(test-suite "ws:lock-on-main-workspace"
  (set-code "(define (f x) (+ x 1))")
  ;; Lock root workspace — all mutations should fail
  (workspace:lock 0 #t)
  (check (not (mutate:rebind "f" "(lambda (x) (* x 2))" "test")))
  (workspace:lock 0 #f)
  (check (mutate:rebind "f" "(lambda (x) (* x 2))" "test")))

(test-suite "ws:can-write-query"
  (set-code "(define (f x) (+ x 1))")
  (define w1 (workspace:create "perm-test"))
  ;; Initially writable
  (check (workspace:can-write? w1))
  ;; Lock → not writable
  (workspace:lock w1 #t)
  (check (not (workspace:can-write? w1)))
  ;; Unlock → writable again
  (workspace:lock w1 #f)
  (check (workspace:can-write? w1)))

(test-suite "ws:cow-multiple-workspaces"
  (set-code "(define x 42)")
  (define wa (workspace:create "a"))
  (define wb (workspace:create "b"))
  ;; Mutate a
  (workspace:switch wa)
  (set-code "(define x 1)")
  ;; Mutate b
  (workspace:switch wb)
  (set-code "(define x 99)")
  ;; Root should still be 42
  (workspace:switch 0)
  (let* ((r (query:def-use "x"))
         (defs (car r)))
    (check (= (length defs) 1))))

(test-suite "ws:lock-set-code"
  (set-code "(define x 1)")
  (define w1 (workspace:create "lock-sc"))
  (workspace:lock w1 #t)
  (workspace:switch w1)
  ;; set-code should also be rejected
  (check (not (set-code "(define y 2)")))))


;; ═══════════════════════════════════════════════════════════════
;; P14: Inter-Agent Messaging
;; ═══════════════════════════════════════════════════════════════

(test-suite "msg:my-id-returns-string"
  (check (string? (my-id))))

(test-suite "msg:recv-timeout-returns-void"
  ;; recv with 0ms timeout should return void (no messages)
  (check (not (recv 0))))

(test-suite "msg:send-no-target"
  ;; send to nonexistent target returns #f
  (check (not (send "nonexistent" "test"))))

(test-suite "msg:send-self-no-mailbox"
  ;; send to self (same session) should work in --serve mode only
  ;; outside serve: no mailbox available, returns #f
  (check (not (send "self" "test"))))


;; ═══════════════════════════════════════════════════════════════
;; P14P1: Messaging — reply, session-active?, mailbox-count
;; ═══════════════════════════════════════════════════════════════

(test-suite "msg:mailbox-count-zero"
  ;; In standalone mode (no serve), mailbox count should be 0
  (check (= (mailbox-count) 0)))

(test-suite "msg:session-active-nonexistent"
  (check (not (session-active? "nonexistent-agent"))))

(test-suite "msg:session-active-string"
  (check (string? (my-id))))

(test-suite "msg:reply-no-last-sender"
  ;; reply with no prior recv should return #f
  (check (not (reply "hello"))))


;; ═══════════════════════════════════════════════════════════════
;; P13 P2: Workspace sync-from, discard, merge
;; ═══════════════════════════════════════════════════════════════

(test-suite "ws:discard-child"
  (set-code "(define (f x) (+ x 1))")
  (define cid (workspace:create "child"))
  (workspace:switch cid)
  (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
  ;; Discard should reset to parent
  (check (workspace:discard cid))))

(test-suite "ws:discard-no-own-flat"
  (set-code "(define (f x) (+ x 1))")
  (define cid (workspace:create "child"))
  ;; Child has no own flat (COW) — discard should be a no-op
  (check (workspace:discard cid))))

(test-suite "ws:discard-invalid-id"
  (set-code "(define x 1)")
  ;; discard on root (id 0) should return #f
  (check (not (workspace:discard 0))))


;; ═══════════════════════════════════════════════════════════════
;; P15: Synthesize Template Strategy (P0)
;; ═══════════════════════════════════════════════════════════════

(test-suite "synth:register-template"
  (check (synthesize:register-template "test-fn"
    "(define ({name} x) (* 2 x))" "name")))

(test-suite "synth:fill-template"
  (set-code "(begin)")
  (synthesize:register-template "double"
    "(define (double-{name} x) (* 2 x))" "name")
  (check (synthesize:fill "double" "val")))

(test-suite "synth:fill-multi-param"
  (set-code "(begin)")
  (synthesize:register-template "handler"
    "(define (handle-{r} req) (query "{q}"))" "r" "q")
  (check (synthesize:fill "handler" "users" "select *")))

(test-suite "synth:list-templates"
  (check (pair? (synthesize:list-templates))))

(test-suite "synth:fill-nonexistent"
  ;; Filling a non-existent template should return void
  (check (not (synthesize:fill "no-such-template" "x"))))


;; ═══════════════════════════════════════════════════════════════
;; P16: Synthesize LLM Strategy — synthesize:define
;; ═══════════════════════════════════════════════════════════════

(test-suite "synth:define-no-api-key"
  ;; Without LLM_API_KEY, returns empty string
  (check (string? (synthesize:define "f" "Int -> Int"))))

(test-suite "synth:define-keywords"
  (check (string? (synthesize:define "g" "Int -> Int"
                     :prompt "test" :model "test" :max-attempts 3))))


;; ═══════════════════════════════════════════════════════════════
;; Pipeline — synthesize:pipeline
;; ═══════════════════════════════════════════════════════════════

(test-suite "pipeline:basic"
  (require "std/pipeline" all:)
  (set-code "(define x 1)")
  (check (synthesize:pipeline "test"
    (set-code "(define x 2)"))))

(test-suite "pipeline:verify-workspace"
  (require "std/pipeline" all:)
  (set-code "(define x 1)")
  (synthesize:pipeline "verify"
    (set-code "(define x 42)"))
  (let* ((r (query:def-use "x"))
         (defs (car r)))
    (check (= (length defs) 1))))

(test-suite "pipeline:template-step"
  (require "std/pipeline" all:)
  (set-code "(begin)")
  (synthesize:register-template "double"
    "(define (double-{name} x) (* 2 x))" "name")
  (check (synthesize:pipeline "double-gen"
    (synthesize:fill "double" "myval"))))

(test-suite "pipeline:multiple-steps"
  (require "std/pipeline" all:)
  (set-code "(begin)")
  (synthesize:register-template "add"
    "(define (add-{name} x y) (+ x y))" "name")
  (check (synthesize:pipeline "multi"
    (synthesize:fill "add" "nums")
    (set-code "(define z 3)"))))

(test-suite "pipeline:step-order"
  (require "std/pipeline" all:)
  (set-code "(define (f x) x)")
  (check (synthesize:pipeline "order"
    (mutate:rebind "f" "(lambda (x) (+ x 1))" "step1")
    (mutate:rebind "f" "(lambda (x) (* x 2))" "step2"))))

(test-suite "pipeline:rollback-on-failure"
  (require "std/pipeline" all:)
  (set-code "(define x 42)")
  (define sid (ast:snapshot "before"))
  ;; First success then failure - pipeline should rollback
  (synthesize:pipeline "fail-test"
    (set-code "(define x 1)")
    (mutate:rebind "x" "(lambda () (+ 1 2))" "step2"))  ;; rebind on define variable should fail
  ;; Verify we're back to snapshot
  (check (pair? (ast:diff sid))))  ;; diff should exist (might show changes)


;; ═══════════════════════════════════════════════════════════════
;; P17: Synthesize Genetic Strategy — synthesize:optimize
;; ═══════════════════════════════════════════════════════════════

(test-suite "synth:optimize-basic"
  (set-code "(define (f x) (+ x 100))")
  (let ((result (synthesize:optimize "f" :population 3 :generations 1)))
    (check (pair? result))))  ;; returns (gen . fitness)

(test-suite "synth:optimize-code-valid"
  (set-code "(define (f x) (+ x 1))")
  (synthesize:optimize "f" :population 3 :generations 1)
  ;; After optimize, workspace should still have valid code
  (let ((src (current-source)))
    (check (string? src))))

(test-suite "synth:optimize-keywords"
  (set-code "(define (f x) 42)")
  (check (pair? (synthesize:optimize "f"
    :population 5 :generations 2 :mutation-rate 0.5))))

(test-suite "synth:optimize-fitness-high"
  ;; A correct function should score ~1000 (4/4 probes pass) + length bonus
  (set-code "(define (inc x) (+ x 1))")
  (let ((result (synthesize:optimize "inc" :population 3 :generations 1)))
    (check (pair? result))
    (let ((fitness (cdr result)))
      (check (> fitness 900.0)))))

(test-suite "synth:optimize-benchmark-kw"
  ;; :benchmark is an alias for :fitness — user-provided expression
  (set-code "(define (f x) (+ x 1))")
  (check (pair? (synthesize:optimize "f"
    :population 3 :generations 1 :benchmark "10.0"))))

(test-suite "synth:optimize-multiarg"
  ;; Multi-arg functions should optimize and return valid code
  (set-code "(define (add x y) (+ x y))")
  (let ((result (synthesize:optimize "add" :population 3 :generations 1)))
    (check (pair? result))
    ;; After optimize, workspace should have valid code for multi-arg function
    (let ((src (current-source)))
      (check (string? src))
      (check (> (length src) 0)))))

(test-suite "synth:optimize-workspace-preserved"
  ;; After optimize, the workspace should still work
  (set-code "(define (sq x) (* x x))")
  (synthesize:optimize "sq" :population 3 :generations 1)
  (let ((src (current-source)))
    (check (string? src))
    (check (> (length src) 0)))
  ;; The function should still be callable after optimization
  ;; (the workspace is restored with best variant)
  (let ((call-result (eval "(sq 5)")))
    (check (number? call-result))))


;; ═══════════════════════════════════════════════════════════════
;; Rule Normalize — rule:define / apply / list
;; ═══════════════════════════════════════════════════════════════

(test-suite "rule:define-and-list"
  (require "std/rule" all:)
  (rule:define 'test-rule :pattern "(+ 1 2)" :replace "3")
  (let ((rules (rule:list)))
    (check (pair? rules))
    (check (> (length rules) 0))))

(test-suite "rule:apply-non-existent"
  (require "std/rule" all:)
  ;; Applying a non-existent rule returns 0
  (check (= (rule:apply 'no-such-rule) 0)))

(test-suite "rule:remove"
  (require "std/rule" all:)
  (rule:define 'temp-rule :pattern "(+ 1 1)" :replace "2")
  (rule:remove 'temp-rule)
  (let ((rules (rule:list)))
    (check (= (rule:apply 'temp-rule) 0))))

(test-suite "rule:list-violations-empty"
  (require "std/rule" all:)
  ;; With no matching code, violations should be empty
  (set-code "(define x 1)")
  (let ((v (rule:list-violations)))
    (check (list? v))))

(test-suite "rule:apply-all"
  (require "std/rule" all:)
  (rule:define 'r1 :pattern "(+ 1 1)" :replace "2")
  (let ((total (rule:apply-all)))
    (check (>= total 0))))


;; ═══════════════════════════════════════════════════════════════
;; Rule P1 — condition, enable/disable, status
;; ═══════════════════════════════════════════════════════════════

(test-suite "rule-p1:condition-basic"
  (require "std/rule" all:)
  (rule:define 'cond-rule
    :pattern "(+ 1 1)" :replace "2"
    :condition "#t")  ;; always true
  (check (>= (rule:apply 'cond-rule) 0)))

(test-suite "rule-p1:enable-disable"
  (require "std/rule" all:)
  (rule:define 'toggle-rule
    :pattern "(+ 1 1)" :replace "2")
  (check (rule:disable 'toggle-rule))
  ;; Disabled rule should not apply
  (check (= (rule:apply 'toggle-rule) 0))
  (check (rule:enable 'toggle-rule)))

(test-suite "rule-p1:status"
  (require "std/rule" all:)
  (rule:define 'status-rule
    :pattern "(+ x 1)" :replace "(+ x 2)"
    :description "test rule")
  (let ((s (rule:status 'status-rule)))
    (check (pair? s))))

(test-suite "rule-p1:description-in-list"
  (require "std/rule" all:)
  (rule:define 'desc-rule
    :pattern "(+ 1 1)" :replace "2"
    :description "simplify addition")
  ;; List should include description info
  (let ((lst (rule:list)))
    (check (pair? lst))))

(test-suite "rule-p1:violations-with-condition"
  (require "std/rule" all:)
  (set-code "(define x 1)")
  (rule:define 'viol-rule
    :pattern "(define x 1)" :replace "(define y 1)"
    :condition "#t")
  (let ((v (rule:list-violations)))
    (check (list? v))))


;; ═══════════════════════════════════════════════════════════════
;; Rule P2 — scope, save/load, comprehensive coverage
;; ═══════════════════════════════════════════════════════════════

(test-suite "rule-p2:scope-workspace"
  (require "std/rule" all:)
  (rule:define 'scope-rule
    :pattern "(+ 1 1)" :replace "2"
    :scope :workspace)
  (check (>= (rule:apply 'scope-rule) 0)))

(test-suite "rule-p2:redefine-overwrites"
  (require "std/rule" all:)
  (rule:define 'overwrite-test
    :pattern "(+ 1 1)" :replace "2"
    :description "v1")
  (rule:define 'overwrite-test
    :pattern "(+ 1 2)" :replace "3"
    :description "v2")
  (let ((s (rule:status 'overwrite-test)))
    (check (pair? s))))

(test-suite "rule-p2:list-includes-scope"
  (require "std/rule" all:)
  (rule:define 'scope-list-rule
    :pattern "(+ 1 1)" :replace "2"
    :scope :workspace)
  (let ((lst (rule:list)))
    (check (pair? lst))))

(test-suite "rule-p2:apply-all-disabled"
  (require "std/rule" all:)
  (rule:define 'disabled-test
    :pattern "(+ 1 1)" :replace "2")
  (rule:disable 'disabled-test)
  ;; apply-all should skip disabled
  (check (= (rule:apply-all) 0)))

(test-suite "rule-p2:condition-false-skips"
  (require "std/rule" all:)
  (set-code "(define (f x) (+ x 1))")
  (rule:define 'cond-skip
    :pattern "(+ ?x 1)" :replace "(* ?x 2)"
    :condition "#f")  ;; Always false = never applies
  (check (= (rule:apply 'cond-skip) 0)))

(test-suite "rule-p2:save-load"
  (require "std/rule" all:)
  (rule:define 'save-test-rule
    :pattern "(+ 1 1)" :replace "2"
    :description "save/load test"
    :scope :workspace)
  (rule:save "/tmp/aura-test-rules.json")
  ;; Clear and reload
  (rule:remove 'save-test-rule)
  (let ((count (rule:load "/tmp/aura-test-rules.json")))
    (check (> count 0))
    (check (pair? (rule:status 'save-test-rule))))))

(test-suite "rule-p2:violations-empty-workspace"
  (require "std/rule" all:)
  (set-code "(begin)")
  (rule:define 'empty-viol-test
    :pattern "(+ 1 1)" :replace "2")
  (let ((v (rule:list-violations)))
    (check (list? v))
    (check (= (length v) 0))))

(test-suite "rule-p2:multiple-rules"
  (require "std/rule" all:)
  (rule:define 'rule-a :pattern "(+ 1 1)" :replace "2")
  (rule:define 'rule-b :pattern "(* 2 2)" :replace "4")
  (let ((lst (rule:list)))
    (check (= (length lst) 2))))


(test-suite "type:annot-bind"
  ;; (: name Type val) should bind the variable
  (: x Int 42)
  (check (= x 42))
  (check (string? (current-source)))
  ;; Multiple annotations
  (: a Int 10)
  (: b Int 5)
  (check (= (+ a b) 15))
  ;; Annotation with coercion
  (: s String "hello")
  (check (string? s))
  ;; Annotation should return the value
  (check (= (: x Int 42) 42)))

;; ═══════════════════════════════════════════════════════════════
;; Synthesize v2 — test-driven code synthesis
;; ═══════════════════════════════════════════════════════════════

(test-suite "synth-v2:eval-test-pass"
  (require "std/synthesize-v2" all:)
  (let* ((code "(define (add x y) (+ x y))")
         (test-code "(display (add 2 3))")
         (expected "5")
         (result (synthesize:eval-test code test-code expected)))
    (check (car result))))  ;; #t means pass

(test-suite "synth-v2:eval-test-fail"
  (require "std/synthesize-v2" all:)
  (let* ((code "(define (add x y) (* x y))")  ;; WRONG: product not sum
         (test-code "(display (add 2 3))")
         (expected "5")
         (result (synthesize:eval-test code test-code expected)))
    (check (not (car result)))))  ;; #f means fail

(test-suite "synth-v2:run-tests-all-pass"
  (require "std/synthesize-v2" all:)
  (let* ((code "(define (add x y) (+ x y))")
         (tests (list (list "(display (add 2 3))" "5")
                     (list "(display (add 0 0))" "0")))
         (result (synthesize:run-tests code tests))
         (passed (list-ref result 0))
         (total (list-ref result 1)))
    (check (= passed total))))

(test-suite "synth-v2:run-tests-some-fail"
  (require "std/synthesize-v2" all:)
  (let* ((code "(define (add x y) (+ x y))")
         (tests (list (list "(display (add 2 3))" "5")
                     (list "(display (add 2 3))" "WRONG")))  ;; second fails
         (result (synthesize:run-tests code tests))
         (passed (list-ref result 0))
         (total (list-ref result 1))
         (failures (list-ref result 2)))
    (check (< passed total))
    (check (> (length failures) 0))))

(test-suite "synth-v2:test-driven-correct"
  (require "std/synthesize-v2" all:)
  (let* ((code "(define (add x y) (+ x y))")
         (tests (list (list "(display (add 2 3))" "5")))
         (result (synthesize:test-driven "add"
                  :goal "add two numbers"
                  :code code :tests tests :max-attempts 1))
         (success (car result))
         (details (caddr result)))
    (check success)
    (check (= (list-ref details 0) 1))  ;; passed
    (check (= (list-ref details 1) 1))))  ;; total

(test-suite "synth-v2:test-driven-bad-tests"
  (require "std/synthesize-v2" all:)
  (let* ((result (synthesize:test-driven "f"
                  :goal "test" :tests 42))  ;; invalid tests
         (success (car result)))
    (check (not success))))

(test-suite "synth-v2:test-driven-empty-tests"
  (require "std/synthesize-v2" all:)
  (let* ((result (synthesize:test-driven "f"
                  :goal "test" :tests (list)))
         (success (car result)))
    (check (not success))))

(test-suite "synth-v2:test-driven-wrong-code"
  (require "std/synthesize-v2" all:)
  (let* ((code "(define (add x y) (* x y))")  ;; wrong: product
         (tests (list (list "(display (add 2 3))" "5")))
         (result (synthesize:test-driven "add"
                  :goal "sum" :code code :tests tests :max-attempts 1))
         (success (car result)))
    ;; With max-attempts=1, should not pass
    (check (not success))))

(test-suite "synth-v2:run-tests-empty"
  (require "std/synthesize-v2" all:)
  ;; run-tests with empty test list should return 0/0
  (let* ((result (synthesize:run-tests "code" (list)))
         (passed (list-ref result 0))
         (total (list-ref result 1)))
    (check (= passed 0))
    (check (= total 0))))

(test-suite "synth-v2:eval-test-empty-code"
  (require "std/synthesize-v2" all:)
  ; eval-test with empty code should not crash
  (let* ((result (synthesize:eval-test "" "(display 42)" "42"))
         (success (car result)))
    ;; empty code might not produce output, but shouldn't crash
    (check (boolean? success))))

(test-suite "synth-v2:build-diagnostic"
  (require "std/synthesize-v2" all:)
  (let* ((failures (list (list "(display (add 2 3))" "5" "expected 5, got 6")))
         (diag (build-diagnostic "add" "(define (add x y) (* x y))"
                                0 1 failures)))
    (check (string? diag))
    (check (> (string-length diag) 0))))

(test-suite "synth-v2:extract-code-lisp-block"
  (require "std/synthesize-v2" all:)
  ;; Typical LLM response with ```lisp block
  (let* ((response "Here is the code:\n```lisp\n(define (add x y) (+ x y))\n```")
         (code (extract-code response)))
    (check (string? code))
    (check (> (string-length code) 0))
    (check (string-contains? code "define"))))

(test-suite "synth-v2:extract-code-plain-block"
  (require "std/synthesize-v2" all:)
  ;; LLM response with plain ``` block
  (let* ((response "```\n(define (f x) (* x 2))\n```")
         (code (extract-code response)))
    (check (string? code))
    (check (> (string-length code) 0))))

(test-suite "synth-v2:extract-code-define-only"
  (require "std/synthesize-v2" all:)
  ;; LLM response with raw (define ...) without code fences
  (let* ((response "Here is the function: (define (f x) (* x 2))")
         (code (extract-code response)))
    (check (string? code))))

(test-suite "synth-v2:extract-code-empty"
  (require "std/synthesize-v2" all:)
  ;; Empty response should not crash
  (let* ((code (extract-code "")))
    (check (string? code))))

(test-suite "synth-v2:debug-empty-code"
  (require "std/synthesize-v2" all:)
  ;; synthesize:debug with empty code should return failure
  (let* ((result (synthesize:debug :code "" :tests (list (list "(display 1)" "1"))))
         (success (car result)))
    (check (not success))))

(test-suite "synth-v2:string-trim"
  (require "std/synthesize-v2" all:)
  (check (string? (string-trim "  hello  ")))
  (check (string=? (string-trim "  hello  ") "hello"))
  (check (string=? (string-trim "") ""))
  (check (string=? (string-trim "a") "a"))
  (check (string=? (string-trim "  a  ") "a")))

(test-suite "synth-v2:call-llm-no-key"
  (require "std/synthesize-v2" all:)
  ;; Without API key, call-llm should return empty string
  (let* ((content (call-llm "test" "" "" "deepseek-chat")))
    (check (string? content))))
