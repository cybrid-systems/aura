(require "std/test" all:)
(require "std/string" all:)
(require "std/json" all:)
(require "std/math" all:)
(require "std/list" all:)

; ── 1. gc-stats returns a string ──
(assert (string? (gc-stats)))

; ── 2. gc-heap cleanly runs ──
(assert (gc-heap))

; ── 3. Function bindings survive gc-heap ──
(define (my-fn x) (+ x 1))
(check= 6 (my-fn 5))
(gc-heap)
(check= 7 (my-fn 6))
(gc-heap)
(gc-heap)
(check= 8 (my-fn 7))

; ── 4. Module functions survive gc-heap ──
(define hello "hello world")
(check= 11 (string-length hello))
(gc-heap)
(check= 11 (string-length hello))

; ── 5. Closures (lambdas) survive gc-heap ──
(define square (lambda (x) (* x x)))
(check= 25 (square 5))
(gc-heap)
(check= 36 (square 6))
(gc-heap)
(gc-heap)
(check= 49 (square 7))

; ── 6. set! variables survive gc-heap ──
(define counter 0)
(set! counter 1)
(check= 1 counter)
(gc-heap)
(check= 1 counter)
(set! counter 2)
(check= 2 counter)

; ── 7. gc-heap in while loop ──
(define total 0)
(define i 0)
(while (lambda () (< i 5))
  (lambda ()
    (gc-heap)
    (set! total (+ total 1))
    (set! i (+ i 1))))
(check= 5 i)
(check= 5 total)

; ── 8. gc-freeze is safe ──
(gc-freeze)
(gc-freeze)
(gc-freeze)

; ── 9. gc-freeze + gc-heap sequence ──
(gc-freeze)
(gc-heap)
(gc-freeze)
(gc-heap)
(gc-heap)

; ── 10. Simulate benchmark workload ──
(define (sim-task n)
  (json-parse (string-append "{\"name\":\"t" (number->string n) "\"}"))
  (set-code "(+ 1 2)")
  (eval-current))
(sim-task 1)
(gc-heap)
(sim-task 2)
(gc-heap)
(sim-task 3)
(gc-heap)
(check= 42 (+ 40 2))

; ── 11. gc-stats called many times ──
(gc-stats) (gc-stats) (gc-stats)
(gc-heap) (gc-stats) (gc-stats)
(assert (string? (gc-stats)))

; ── 12. require still works after gc-heap ──
(gc-heap)
(check= 3 (length '(1 2 3)))
(gc-heap)
(check= 4 (length '(a b c d)))

; ── 13. Huge string survives gc-heap ──
(define long-str "abcdefghijklmnopqrstuvwxyz0123456789abcdefghijklmnopqrstuvwxyz")
(check= 62 (string-length long-str))
(gc-heap)
(check= 62 (string-length long-str))

; ── 14. Closure + string combination ──
(define (combine a b) (string-append a (number->string b)))
(check= "x42" (combine "x" 42))
(gc-heap)
(gc-heap)
(check= "y99" (combine "y" 99))

; ── 15. eval-current after gc-heap ──
(set-code "(+ 100 200)")
(gc-heap)
(check= 300 (eval-current))

; ── 16. gc-heap is idempotent ──
(gc-heap) (gc-heap) (gc-heap)
(gc-heap) (gc-heap)
(assert (string? (gc-stats)))

; ── 17. Many gc-heap calls ──
(define j 0)
(while (lambda () (< j 20))
  (lambda ()
    (gc-heap)
    (check= (+ 1 1) 2)
    (set! j (+ j 1))))

; ── 18. gc-temp basic ──
(assert (gc-temp))

; ── 19. gc-temp idempotent ──
(gc-temp) (gc-temp) (gc-temp)

; ── 20. Function bindings survive gc-temp ──
(define (add1 x) (+ x 1))
(check= 6 (add1 5))
(gc-temp)
(check= 7 (add1 6))
(gc-temp)
(gc-temp)
(check= 8 (add1 7))

; ── 21. gc-temp after intend ──
(define (my-gen g) "(+ 1 2)")
(define (my-ver c) "#t")
(intend "gc-test" my-gen my-ver 1)
(gc-temp)
(assert (string? (gc-stats)))
(check= 3 (+ 1 2))

; ── 22. gc-heap still works after gc-temp ──
(gc-temp)
(gc-heap)
(gc-stats)
(check= 3 (+ 1 2))

; ════════════════════════════════════════════════════════
; ── Double Arena ── gc-temp clears temp closures
; ════════════════════════════════════════════════════════

; ── 23. gc-temp does not break module functions under stress ──
(define (mod-fn x) (* x 3))
(gc-temp) (gc-temp) (gc-temp)
(gc-temp) (gc-temp)
(check= 15 (mod-fn 5))
(define (mod-fn2 x) (+ x 10))
(gc-temp)
(check= 20 (mod-fn2 10))

; ── 24. gc-temp in loop (20x) ──
(define k 0)
(while (lambda () (< k 20))
  (lambda ()
    (gc-temp)
    (check= (+ 2 2) 4)
    (set! k (+ k 1))))
(check= 20 k)

; ── 25. gc-temp after intend that creates closures inside ──
; Verifier creates a closure (define inside intend) which should
; be allocated in temp_arena_ and cleaned by gc-temp.
(define (ver-creates-closure code)
  (define (inner-check) (+ 1 1))
  (if (= (inner-check) 2) "#t" "#f"))
(define (gen-returns-code g) "(display 42)")
(intend "inner-closure" gen-returns-code ver-creates-closure 1)
(gc-temp)
(assert (string? (gc-stats)))

; ── 26. Multiple intends with gc-temp between (no closures growth) ──
(define (gen-simple g) "(display 1)")
(define (ver-simple c) "#t")
(intend "a" gen-simple ver-simple 1) (gc-temp)
(intend "b" gen-simple ver-simple 1) (gc-temp)
(intend "c" gen-simple ver-simple 1) (gc-temp)
(check= 3 (+ 1 2))

; ── 27. gc-temp with intend that uses fixer ──
(define (gen-fail g) "(display bad)")  ; will fail
(define (ver-fail c) (if (check-success c "(1)") "#t" "#f"))
(define (fix-c c e g) "(display 1)")
(intend "fix-me" gen-fail ver-fail fix-c 2)
(gc-temp)
(check= 5 (+ 2 3))

; ── 28. gc-temp preserves closures created before gc-freeze ──
(gc-freeze)
(define (persistent-closure x) (* x x))
(define gen-freeze "(display 1)")
(define ver-freeze "#t")
(intend "freeze" (lambda (g) "(display 1)") (lambda (c) "#t") 1)
(gc-temp)
; persistent-closure must still work
(check= 25 (persistent-closure 5))
(gc-temp)
(check= 36 (persistent-closure 6))

; ── 29. gc-heap → gc-temp → gc-heap sequence ──
(gc-heap)
(gc-temp)
(gc-heap)
(gc-temp)
(json-parse "{\"x\":1}")
(set-code "(display 99)")
(eval-current)
(gc-temp)
(check= 99 99)

; ── 30. gc-temp after module re-require ──
(gc-temp)
(require "std/math" all:)
(check= 20 (+ 10 10))
(gc-temp)
(check= 30 (+ 15 15))

; ── 31. gc-temp doesn't break gc-stats ──
(gc-temp) (gc-stats) (gc-temp) (gc-stats) (gc-temp)
(assert (string? (gc-stats)))

; ── 32. Stress: 10 intends with gc-temp each, closures stable ──
(define n 0)
(while (lambda () (< n 10))
  (lambda ()
    (intend (string-append "s" (number->string n))
      gen-simple ver-simple 1)
    (gc-temp)
    (set! n (+ n 1))))
(check= 10 n)

; ── 33. Module closures from require survive many gc-temp ──
(require "std/list" all:)
(check= 3 (length '(a b c)))
(gc-temp) (gc-temp) (gc-temp)
(gc-temp) (gc-temp) (gc-temp)
(gc-temp) (gc-temp) (gc-temp)
(gc-temp) (gc-temp)
(check= 4 (length '(w x y z)))

; ── 34. Mutating cell survives gc-temp ──
(define mutable 0)
(set! mutable 42)
(check= 42 mutable)
(gc-temp)
(check= 42 mutable)
(set! mutable 99)
(gc-temp)
(check= 99 mutable)
