; ── tests/bench.aura — EDSL Benchmark ───
(require "std/bench" all:)

; Define print-report locally instead of from module
(define (print-report tasks results)
  (define agg (aggregate tasks results))
  (define total (list-ref agg 0))
  (define pass (list-ref agg 1))
  (define fail (list-ref agg 2))
  (define stats (list-ref agg 3))
  (define rounds (length results))
  (newline)
  (display "=== Benchmark Results ===")(newline)
  (display "Tasks: ")(display total)(display "  Rounds: ")(display rounds)(newline)
  (display "Passed: ")(display pass)(display "  Failed: ")(display fail)(newline)
  (if (> (+ pass fail) 0)
    (begin
      (display "Rate: ")
      (display (number->string (quotient (* pass 100) (+ pass fail))))
      (display "%")(newline)))
  (newline)
  (display "Task                  Pass/Fail  Rate")(newline)
  (display "----------------------------------------")(newline)
  (let iter ((si 0))
    (if (< si (length stats))
      (let* ((s (list-ref stats si))
             (name (list-ref s 0))
             (p (list-ref s 1))
             (f (list-ref s 2))
             (r (list-ref s 3))
             (rate-str (if (> r 0) (number->string (quotient (* p 100) r)) "0")))
        (display name)(display "  ")
        (display p)(display "/")(display f)(display "  ")
        (display rate-str)(display "%")(newline)
        (iter (+ si 1)))
      '()))
  agg)

(define model (try (getenv "LLM_MODEL") (catch "deepseek-v4-flash")))
(define rounds 1)
(define max-attempts 2)

(display "=== Aura EDSL Benchmark ===")(newline)
(display "Model: ")(display model)(newline)
(display "Tasks: ")(display (task-count))(newline)(newline)

(define results (run-rounds all-tasks model max-attempts rounds))
(print-report all-tasks results)
