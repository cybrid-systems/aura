; ── tests/bench.aura — Aura Native EDSL Benchmark ───
; Usage: LLM_API_KEY="***" ./build/aura < tests/bench.aura
;
; Options (via env vars):
;   LLM_MODEL         Model name (default: deepseek-v4-flash)
;   BENCH_ROUNDS      Number of rounds (default: 1)
;   BENCH_ATTEMPTS    Max LLM attempts per task (default: 3)
;   BENCH_LIMIT       Max tasks to run (default: all 135)

(require "std/bench" all:)

; Wrap everything in a single begin block so that fiber:spawn triggers
; tree-walker fallback (via needs_tree_walker_fallback) for the entire code,
; including module-level calls like run-parallel that use fiber:spawn.
(begin
  (fiber:spawn (lambda () #t))

  ; ── Config from env ──
  (define model (try (getenv "LLM_MODEL") (catch "deepseek-v4-flash")))
  (define (get-env-num name default)
    (let ((v (getenv name)))
      (if (string? v) (string->number v) default)))
  (define rounds (get-env-num "BENCH_ROUNDS" 1))
  (define max-a (get-env-num "BENCH_ATTEMPTS" 3))
  (define workers (get-env-num "BENCH_WORKERS" 4))
  (define limit (get-env-num "BENCH_LIMIT" 0))

  ; ── Select tasks (with offset for parallel slicing) ──
  (define offset (get-env-num "BENCH_OFFSET" 0))
  (define tasks
    (if (> limit 0)
      (take limit (if (> offset 0)
        ; Skip via manual loop (stdlib 'skip' not used to keep deps light)
        (let loop ((i 0) (tl all-tasks))
          (if (or (>= i offset) (null? tl)) tl
            (loop (+ i 1) (cdr tl))))
        all-tasks))
      (if (> offset 0)
        (let loop ((i 0) (tl all-tasks))
          (if (or (>= i offset) (null? tl)) tl
            (loop (+ i 1) (cdr tl))))
        all-tasks)))
  (define task-count (length tasks))

  ; ── Run ──
  (display "=== Aura EDSL Benchmark ===")(newline)
  (display "Model: ")(display model)(newline)
  (display "Tasks: ")(display task-count)(newline)
  (display "Rounds: ")(display rounds)(newline)
  (display "Max attempts: ")(display max-a)(newline)
  (newline)

  ; Use parallel runner — tree-walker fallback covers fiber:spawn inside module
  (run-parallel tasks model max-a rounds workers)

  ; ── Done ──
  ; OK/FAIL lines are printed per-task by run-rounds.
  ; Count via grep on the output side.
  (display "=== All tasks completed ===")(newline))
