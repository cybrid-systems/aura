;; === multi_session_leak_test.aura ===
;; Issue #67 acceptance test: 1000+ module loads in serve-like pattern,
;; assert no arena growth.
;;
;; Run:
;;   ./build/aura < tests/multi_session_leak_test.aura
;;   ASAN_OPTIONS=detect_leaks=1 ./build_asan/aura < tests/multi_session_leak_test.aura

(require std/json all:)

(display "=== Multi-Session Module Load Test ===\n")

(define initial-stats (stats:get "gc-stats"))
(display "Initial: ")
(display initial-stats)
(newline)

;; Simulate 50 module loads with gc between each
;; (1000 is too slow for a smoke test, but the leak rate should be similar)
(define (load-iter n)
  (if (= n 0)
      'done
      (begin
        (require "std/json" all:)
        (eval '(json-parse "{\"x\":1}"))
        (eval '(json-parse "{\"y\":2}"))
        ;; Force GC to free module state
        (gc-module "std/json.aura")
        (load-iter (- n 1)))))

(load-iter 50)

(define final-stats (stats:get "gc-stats"))
(display "Final:   ")
(display final-stats)
(newline)

;; Check that we didn't grow unboundedly
(define growth (- (cdr final-stats) (cdr initial-stats)))
(display "Growth:  ")
(display growth)
(newline)

(if (< growth 1048576)  ;; 1 MB threshold for 50 iterations
    (display "✅ PASS: memory growth under threshold\n")
    (display "❌ FAIL: memory growth exceeded 1MB threshold\n"))
