;; === test-closure-capture.aura — 闭包捕获回归测试 ===
;; 覆盖 EVAL_CACHE_RETURN_VAL 删除后闭包捕获正确的所有场景

(define passed 0)
(define failed 0)

(define (chk a e m)
  (if (equal? a e)
      (begin (set! passed (+ passed 1))
             (display "[PASS] ") (display m) (newline))
      (begin (set! failed (+ failed 1))
             (display "[FAIL] ") (display m)
             (display " exp=") (display e)
             (display " got=") (display a) (newline))))

(define (msg v) (display v) v)

;; ── 1. 基本闭包捕获（核心 bug） ──
(display "--- 1. basic closure capture ---\n")
(define (make-adder n) (lambda (x) (+ x n)))
(define add10 (make-adder 10))
(define add20 (make-adder 20))
(chk (add10 1) 11 "make-adder 10: (+ 10 1) = 11")
(chk (add20 1) 21 "make-adder 20: (+ 20 1) = 21")
(chk (add10 5) 15 "make-adder 10: (+ 10 5) = 15")

;; ── 2. 多次调用同一个工厂 ──
(display "--- 2. multiple calls to same factory ---\n")
(define (factory prefix) (lambda (suffix) (string-append prefix suffix)))
(define greet (factory "hello "))
(define farewell (factory "goodbye "))
(chk (greet "world") "hello world" "factory: hello world")
(chk (farewell "world") "goodbye world" "factory: goodbye world")
(chk (greet "there") "hello there" "factory: hello there (second call)")

;; ── 3. 闭包捕获 #t/#f ──
(display "--- 3. closure capture bools ---\n")
(define (make-cond pick?) (lambda (a b) (if pick? a b)))
(define pick-first (make-cond #t))
(define pick-second (make-cond #f))
(chk (pick-first 1 2) 1 "cond #t: returns first")
(chk (pick-second 1 2) 2 "cond #f: returns second")

;; ── 4. 闭包嵌套 ──
(display "--- 4. nested closures ---\n")
(define (make-complex a)
  (lambda (b)
    (lambda (c)
      (+ a b c))))
(define add-1-2 (make-complex 1))
(define add-10-20 (make-complex 10))
(chk ((add-1-2 3) 4) 8 "nested: 1+3+4=8")
(chk ((add-10-20 30) 40) 80 "nested: 10+30+40=80")

;; ── 5. 同一个 Lambda 节点多次求值（同一个函数体创建不同闭包） ──
;; 注意: set! 对 function param 的修改在当前调用后即丢弃（捕获是值而非引用）
(display "--- 5. same lambda node, different captures ---\n")
(define (capture-n n)
  (lambda (x) (+ x n)))
(define add5 (capture-n 5))
(define add3 (capture-n 3))
(chk (add5 1) 6 "add5: 5+1=6")
(chk (add3 1) 4 "add3: 3+1=4")
(chk (add5 10) 15 "add5: 5+10=15")

;; ── 6. 映射函数到列表 ──
(display "--- 6. map with closures ---\n")
(define (make-mult n) (lambda (x) (* x n)))
(chk ((make-mult 3) 5) 15 "mult 3: 3*5=15")
(chk ((make-mult 0) 5) 0 "mult 0: 0*5=0")
(chk ((make-mult -2) 5) -10 "mult -2: -2*5=-10")

;; ── 7. 多个参数捕获 ──
(display "--- 7. multi-param capture ---\n")
(define (make-fn a b)
  (lambda (c d) (+ a b c d)))
(define fn1 (make-fn 1 2))
(define fn2 (make-fn 10 20))
(chk (fn1 3 4) 10 "multi-param: 1+2+3+4=10")
(chk (fn2 30 40) 100 "multi-param: 10+20+30+40=100")

;; ── 8. 捕获空列表 / void ──
(display "--- 8. edge cases ---\n")
(define (make-pred n)
  (lambda (x) (if (> x n) "greater" "less-or-equal")))
(define pred10 (make-pred 10))
(define pred100 (make-pred 100))
(chk (pred10 5) "less-or-equal" "pred10: 5 <= 10")
(chk (pred10 15) "greater" "pred10: 15 > 10")
(chk (pred100 50) "less-or-equal" "pred100: 50 <= 100")
(chk (pred100 150) "greater" "pred100: 150 > 100")

;; ── 9. 递归闭包生产 ──
(display "--- 9. recursive closure factory ---\n")
(define (make-pow exp)
  (if (= exp 0)
      (lambda (x) 1)
      (let ((sub (make-pow (- exp 1))))
        (lambda (x) (* x (sub x))))))
(define square (make-pow 2))
(define cube (make-pow 3))
(chk (square 3) 9 "pow 2: 3^2=9")
(chk (cube 3) 27 "pow 3: 3^3=27")
(chk (square 5) 25 "pow 2: 5^2=25")

;; ── 10. 回归：既有功能未受影响 ──
(display "--- 10. regression tests ---\n")
(define n 0)
(set! n 42)
(chk n 42 "set! literal")
(chk (equal? "hello" "hello") #t "equal? string")
(chk (and #f 99) #f "and short-circuit")
(chk (or #t (display "x")) #t "or short-circuit")
(define i 0)
(while (< i 5) (set! i (+ i 1)))
(chk i 5 "while loop")

;; ── 11. define + lambda + 4-arg if 组合（parser fix 不冲突） ──
(display "--- 11. define with if 4arg + closure ---\n")
;; 4-arg if: then=(str-append), else=(newline), extra=(str-append)(newline)
;; else-begin = (begin (newline)(str-append "else:" b)(newline))
;; else-begin 返回值是 (newline)=void；所以测试检查副作用不是返回值
(define (if-in-closure? pick?)
  (lambda (a b)
    (if pick?
        (string-append "then:" a) (newline)
        (string-append "else:" b) (newline))
    ;; 最后一个表达式是闭包的返回值
    "done"))
(define pick-a (if-in-closure? #t))
(define pick-b (if-in-closure? #f))
(chk (pick-a "X" "Y") "done" "if4arg in closure #t + body after")
(chk (pick-b "X" "Y") "done" "if4arg in closure #f + body after")

;; ── 结果 ──
(newline)
(display "=== Results: ") (display passed) (display " passed, ")
(display failed) (display " failed") (newline)
