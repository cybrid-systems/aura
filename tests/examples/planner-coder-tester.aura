; ── Planner-Coder-Tester — 多 Agent 协作示例 ──
; Issue #15: 验证 agent:spawn + agent:ask 三角色管线
;
; 这个示例演示交响乐指挥模式：
;   指挥（main 流程）→ planner（规划）→ coder（编码）→ tester（测试）
;
; 运行: ./build/aura < tests/examples/planner-coder-tester.aura

(require "std/test" all:)
(require "std/orchestrator" all:)
(require "std/string" all:)

(test-suite "pct:spawn-agents"
  (check (agent:spawn "planner"
    (lambda (task) (string-append "PLAN: " task))))
  (check (agent:spawn "coder"
    (lambda (plan) (string-append "CODE: (" plan ")"))))
  (check (agent:spawn "tester"
    (lambda (code) (string-append "TEST: " code " => PASS"))))
  (check (pair? (agent:list))))

(test-suite "pct:ask-planner"
  (check (string=? (agent:ask "planner" "fib(5)") "PLAN: fib(5)")))

(test-suite "pct:ask-coder"
  (check (string=? (agent:ask "coder" "PLAN: fib(5)") "CODE: (PLAN: fib(5))")))

(test-suite "pct:ask-tester"
  (check (string=? (agent:ask "tester" "(define (fib n) ...)") "TEST: (define (fib n) ...) => PASS")))

(test-suite "pct:pipeline"
  (check (string=? (orch:pipeline
    (list "planner" "coder" "tester") "fib(5)")
    "TEST: CODE: (PLAN: fib(5)) => PASS")))

(test-suite "pct:conduct"
  (check (string=? (orch:conduct
    (list
      (lambda (x) (string-append "PRE: " x))
      (lambda (x) (string-append "POST: " x)))
    "data")
    "POST: PRE: data")))

(test-suite "pct:parallel"
  (define fns (list
    (lambda (x) (string-append "A:" x))
    (lambda (x) (string-append "B:" x))))
  (define results (try (orch:parallel fns "x") (catch (e) (quote ()))))
  (check (= (length results) 2)))

(test-suite "pct:agent-list"
  (check (pair? (agent:list))))

(define result (run-tests))
(display result)
(newline)
