; ── Gradual Typing Test Suite (Issue #40) ─────────────────
;
; Tests Sound Gradual Typing coercion:
;   - CoercionNode insertion by type checker
;   - Dynamic → Static type boundary handling
;   - AST validation after coercion insertion
;
; Run: ./aura < tests/gradual_typing.aura

(require std/test all:)

(display "═══ Gradual Typing Test Suite ═══\n")
(newline)

(define total-pass 0)
(define total-fail 0)

(define (report name ok)
  (display "  ")
  (display name)
  (display ": ")
  (if ok
    (begin (display "✅\n") (set! total-pass (+ total-pass 1)))
    (begin (display "❌\n") (set! total-fail (+ total-fail 1))))
  ok)

; Helper: typecheck, return #t if successful (no type errors)
(define (safe-typecheck)
  (let ((result (typecheck-current)))
    (and (string? result)
         (> (string-length result) 0))))

; ── 1. No coercion in trivial code ──
(newline)
(display "── 1. No coercion in trivial code ──\n")

(set-code "(define (f x) (+ x 1))")
(report "clean-typecheck" (safe-typecheck))

; ── 2. Annotated function ──
(newline)
(display "── 2. Annotated function ──\n")

(set-code "
(define (test-fn [x : Int])
  (+ x 1))
")
(report "annotated-typecheck" (safe-typecheck))

; ── 3. Dynamic → Static coercion via call ──
(newline)
(display "── 3. Dynamic → Static coercion ──\n")

(set-code "
(define (identity [x : Int]) x)
(define (g y) (identity y))
")
(report "dynamic-to-static-typecheck" (safe-typecheck))

; ── 4. Multi-arg coercion ──
(newline)
(display "── 4. Multi-arg coercion ──\n")

(set-code "
(define (sum [a : Int] [b : Int]) (+ a b))
(define (call-sum x y) (sum x y))
")
(report "multi-arg-typecheck" (safe-typecheck))
(report "multi-arg-ast-valid"
  (let* ((result (ast:validate-nodes))
         (pass-entry (car result)))
    (if (pair? pass-entry) (cdr pass-entry) #f)))

; ── 5. Return type coercion ──
(newline)
(display "── 5. Return type coercion ──\n")

(set-code "
(define (make-val) \"42\")
(define (use-val [x : Int])
  (+ x 1))
(define (test) (use-val (make-val)))
")
(report "return-coercion-typecheck" (safe-typecheck))

; ── 6. Mixed coercion types ──
(newline)
(display "── 6. Mixed coercion types ──\n")

(set-code "
(define (identity [x : Int]) x)
(define (greet [n : String]) (string-append \"Hi, \" n))
(define (test-coercions a b)
  (greet (identity a)))
")
(report "mixed-coercion-typecheck" (safe-typecheck))

; ── 7. Float arguments ──
(newline)
(display "── 7. Float coercion ──\n")

(set-code "
(define (add [a : Float] [b : Float]) (+ a b))
(define (test-float x y) (add x y))
")
(report "float-coercion-typecheck" (safe-typecheck))

; ── 8. Nested dynamic chain ──
(newline)
(display "── 8. Nested dynamic chain ──\n")

(set-code "
(define (a [x : Int]) x)
(define (b y) (a y))
(define (c z) (b z))
")
(report "nested-chain-typecheck" (safe-typecheck))

; ── Results ──
(newline)
(display "═══ Results ═══\n")
(display total-pass)(display " passed, ")(display total-fail)(display " failed\n")

(if (= total-fail 0)
  (display "✅ All gradual typing tests passed!\n")
  (begin (display "❌ ")(display total-fail)(display " test(s) failed\n")))
