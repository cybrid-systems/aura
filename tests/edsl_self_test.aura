; ── Aura EDSL Self-Test Suite (#1452 declarative harness) ────
;
; Pure Aura test of EDSL + governance facade. No Python, no LLM.
; Run: ./aura < tests/edsl_self_test.aura
; Also: tests/suite/edsl_self_test.aura (suite runner copy)
;
; Uses std/edsl-test-harness (immediate it/report — not quoted
; test-suite bodies, which hit data_to_flat edge cases).

(require "std/edsl-test-harness" all:)
; Issue #561: synthesize:list-templates demoted to stdlib.
(require "std/synthesize")

(display "═══ EDSL Self-Test Suite (#1452) ═══\n")
(reset-totals)

; ── 1. Workspace boot ──
(describe "1. Workspace boot"
  (lambda ()
    (it "set-code" (set-code "(define (f x) (+ x 1))"))
    (it "current-source" (string? (current-source)))
    (it "eval-current" (eval-current))
    (it "typecheck-current" (string? (typecheck-current)))))

; ── 2. Query ──
(describe "2. Query"
  (lambda ()
    (set-code "(define x 42)")
    (it "def-use-simple" (= (length (car (query:def-use "x"))) 1))

    (set-code "(define (fib n) (if (< n 2) n (+ (fib (- n 1)) (fib (- n 2)))))")
    (it "def-use-function"
      (let* ((r (query:def-use "fib")) (d (car r)) (u (cdr r)))
        (and (= (length d) 1) (> (length u) 0))))

    (set-code "(define (f x) (+ x 1))")
    (it "def-use-param" (= (length (car (query:def-use "x"))) 1))

    (set-code "(define x 1)")
    (it "def-use-nonexistent"
      (let* ((r (query:def-use "nonexistent")) (d (car r)) (u (cdr r)))
        (and (= (length d) 0) (= (length u) 0))))

    (set-code "(define (f x) (+ x 1))")
    (it "query-reaches"
      (let ((defs (query:node-type "Define")))
        (if (pair? defs) (pair? (query:reaches (car defs))) #t)))
    (it "query-effects" (pair? (query:effects "f")))
    (it "query-node-type" (pair? (query:node-type "Define")))))

; ── 3. Mutation ──
(describe "3. Mutation"
  (lambda ()
    (set-code "(define (f x) (+ x 1))")
    (it "mutate-rebind" (mutate:rebind "f" "(lambda (x) (* x 2))" "test"))
    (it "mutate-set-body" (mutate:set-body "f" "(* x 3)"))
    (set-code "(define (f x) (+ x 1))")
    (it "mutate-replace-value" (mutate:replace-value 2 100 "change"))

    (set-code "(begin (display 1) (display 3))")
    (it "mutate-splice"
      (let ((root (query:root)))
        (> (length (mutate:splice root 1 "(display 2)" "splice")) 0)))

    (set-code "(define (f x) (+ x 1))")
    (it "mutate-wrap"
      (let ((calls (query:node-type "Call")))
        (if (pair? calls) (>= (mutate:wrap (car calls) "(display _)" "wrap") 0) #t)))

    (set-code "(define (f x) (+ x 1))")
    (it "mutate-cache-rebuild"
      (begin (query:def-use "f")
             (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
             (pair? (query:def-use "f"))))))

; ── 4. Snapshot ──
(describe "4. Snapshot"
  (lambda ()
    (set-code "(define (f x) (+ x 1))")
    (it "snapshot-basic" (>= (ast:snapshot "test") 0))

    (it "snapshot-restore"
      (let ((sid (ast:snapshot "before")))
        (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
        (ast:restore sid)
        (pair? (query:def-use "f"))))

    (it "snapshot-diff"
      (let ((sid (ast:snapshot "v1")))
        (mutate:rebind "f" "(lambda (x) (* x 2))" "test")
        (pair? (ast:diff sid))))

    (set-code "(define x 1)")
    (ast:snapshot "v1")
    (it "snapshot-list" (pair? (stats:get "ast:list-snapshots")))))

; ── 5. Summary / compile ──
(describe "5. Summary"
  (lambda ()
    (set-code "(define (f x) (+ x 1))")
    (it "summary-basic" (pair? (stats:get "ast:summary")))
    (it "compile-status" (not (void? (stats:get "compile:status")))))

; ── 6. Workspace ──
(describe "6. Workspace"
  (lambda ()
    (set-code "(define x 1)")
    (workspace:create "a")
    (workspace:create "b")
    (it "ws-create-list" (>= (length (workspace:list)) 2))

    (set-code "(define (f x) (+ x 1))")
    (it "ws-isolation"
      (let ((ws (workspace:create "iso")))
        (workspace:switch ws)
        (mutate:rebind "f" "(lambda (x) (* x 2))" "mut")
        (workspace:switch 0)
        (pair? (query:def-use "f"))))

    (set-code "(define x 1)")
    (it "ws-lock" (let ((ws (workspace:create "lt")))
      (workspace:lock ws #t) (not (workspace:can-write? ws))))
    (it "ws-unlock" (let ((ws (workspace:create "ut")))
      (workspace:lock ws #t) (workspace:lock ws #f) (workspace:can-write? ws)))

    (set-code "(define (f x) (+ x 1))")
    (it "ws-discard" (let ((ws (workspace:create "dt")))
      (workspace:switch ws) (mutate:rebind "f" "(lambda (x) (* x 2))" "t")
      (workspace:switch 0) (workspace:discard ws)))
    (it "ws-current" (= (workspace:current) 0))))

; ── 7. Messaging ──
(describe "7. Messaging"
  (lambda ()
    (it "msg-my-id" (string? (my-id)))
    (it "msg-recv-timeout" (not (recv 0)))
    (it "msg-send-no-target" (not (send "nonexistent" "test")))
    (it "msg-mailbox-count" (or (void? (stats:get "mailbox-count")) (= (stats:get "mailbox-count") 0)))
    (it "msg-session-active" (not (session-active? "nonexistent")))
    (it "msg-reply-no-sender" (not (reply "test")))))

; ── 8. Template ──
(describe "8. Template"
  (lambda ()
    (set-code "(begin)")
    (synthesize:register-template "double" "(define (double-{n} x) (* 2 x))" "n")
    (it "synth-fill" (synthesize:fill "double" "val"))
    (it "synth-list" (pair? (synthesize:list-templates)))

    (set-code "(begin)")
    (synthesize:register-template "h" "(define (handle-{r} req) (display req))" "r")
    (it "synth-multi" (synthesize:fill "h" "users"))
    (it "synth-nonexistent" (not (synthesize:fill "no-such" "x")))))

; ── 9. Optimize ──
(describe "9. Optimize"
  (lambda ()
    (set-code "(define (f x) (+ x 100))")
    (it "opt-basic" (pair? (synthesize:optimize "f" ":population" 3 ":generations" 1)))

    (set-code "(define (f x) (+ x 1))")
    (synthesize:optimize "f" ":population" 3 ":generations" 1)
    (it "opt-preserves" (string? (current-source)))))

; ── 10. Encoding collision regression ──
(describe "10. Encoding collision"
  (lambda ()
    (set-code "(define (f x) (+ x 1))")
    (it "encoding-defuse-prep" (set-code "(define (f x) (+ x 1))"))

    (display "CollisionGuard-aaa")
    (display "CollisionGuard-bbb")
    (display "CollisionGuard-ccc")
    (display "CollisionGuard-ddd")
    (display "CollisionGuard-eee")
    (display "CollisionGuard-fff")
    (display "CollisionGuard-ggg")
    (display "CollisionGuard-hhh")
    (display "CollisionGuard-iii")
    (display "CollisionGuard-jjj")
    (display "CollisionGuard-kkk")
    (display "CollisionGuard-lll")
    (display "CollisionGuard-mmm")
    (display "CollisionGuard-nnn")
    (display "CollisionGuard-ooo")
    (display "CollisionGuard-ppp")
    (display "CollisionGuard-qqq")
    (display "CollisionGuard-rrr")
    (display "CollisionGuard-sss")
    (display "CollisionGuard-ttt")
    (display "CollisionGuard-uuu")
    (display "CollisionGuard-vvv")
    (display "CollisionGuard-www")
    (display "CollisionGuard-xxx")
    (display "CollisionGuard-yyy")
    (display "CollisionGuard-zzz")
    (newline)

    (set-code "(define (fib n) (if (< n 2) n (+ (fib (- n 1)) (fib (- n 2)))))")
    (let* ((r (query:def-use "fib")) (d (car r)) (u (cdr r)))
      (it "encoding-defuse-fib-after-guard" (and (= (length d) 1) (> (length u) 0))))

    (it "encoding-string-pred" (string? "any-string"))
    (it "encoding-error-pred" (not (error? "safe-string")))
    (it "encoding-keyword-pred" (not (keyword? "safe-string")))

    (set-code "(define (g x) (+ x 2))
(define (h x) (* x 3))
(define (j x) (- x 1))
(define (k x) (/ x 2))
(define (m x) (* x x))")
    (it "encoding-defuse-g" (let* ((r (query:def-use "g")) (d (car r))) (= (length d) 1)))
    (it "encoding-defuse-h" (let* ((r (query:def-use "h")) (d (car r))) (= (length d) 1)))
    (it "encoding-defuse-j" (let* ((r (query:def-use "j")) (d (car r))) (= (length d) 1)))
    (it "encoding-defuse-k" (let* ((r (query:def-use "k")) (d (car r))) (= (length d) 1)))
    (it "encoding-defuse-m" (let* ((r (query:def-use "m")) (d (car r))) (= (length d) 1)))

    (set-code "(define (helper x) (* x 2))
(define (caller y) (helper (helper y)))")
    (let* ((r (query:def-use "helper")) (d (car r)) (u (cdr r)))
      (it "encoding-defuse-uses-count" (> (length u) 0)))

    (set-code "(define (adder x) (+ x 1))
(define (user a) (adder (adder a)))")
    (let* ((r (query:effects "adder")) (callers (cdr (cdr r))))
      (it "encoding-effects-callers" (> (length callers) 0)))))

; ── 11. Governance / SlimSurface facade (#1448–#1451) ──
(describe "11. Governance facade"
  (lambda ()
    ; #1451 Agent-Proof proposal check
    (it "validate-new-blocks-stats"
      (let ((h (primitive:validate-new "query:agent-hallucinated-stats")))
        (and (hash? h) (not (hash-ref h "ok")) (hash-ref h "blocked"))))
    (it "validate-new-blocks-string"
      (let ((h (primitive:validate-new "string-fake-1452")))
        (and (hash? h) (not (hash-ref h "ok")))))
    (it "validate-new-already-registered"
      (let ((h (primitive:validate-new "+")))
        (and (hash? h) (hash-ref h "already-registered") (not (hash-ref h "ok")))))
    (it "validate-new-free-name-requires-red-line"
      (let ((h (primitive:validate-new "agent-proof-free-name-1452")))
        (and (hash? h) (hash-ref h "ok") (hash-ref h "requires-red-line"))))

    ; #1450 facade
    (it "stats-count-int" (integer? (stats:count)))
    (it "stats-count-budget" (<= (stats:count) 420))
    (it "stats-get-gc" (not (void? (stats:get "gc-stats"))))
    (it "engine-surface-hash" (hash? (engine:surface)))
    (it "engine-surface-budget"
      (let ((h (engine:surface)))
        (= (hash-ref h "target-budget") 420)))
    (it "engine-surface-zero-public-stats"
      (let ((h (engine:surface)))
        (= (hash-ref h "public-stats-remaining") 0)))
    (it "engine-metrics-hash" (hash? (engine:metrics)))))

; ── Results ──
(summary)
