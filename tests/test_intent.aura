; Aura intend — E1 测试套件
; 测试 intend 原语的生命周期和边界条件

(display "╔════════════════════════════════════════╗")
(display "║  intend E1 Tests                      ║")
(display "╚════════════════════════════════════════╝")

; ── 1. 无 API key → 优雅失败 ──────────────────────────
(display "")
(display "=== 1. Graceful failure (no API key) ===")

(let ((r (intend "test" 1)))
  (display r))

; ── 2. 缺参数（空调用）─────────────────────────────
(display "")
(display "=== 2. No arguments ===")
(display (intend))  

; ── 3. 空字符串 goal ──────────────────────────────
(display "")
(display "=== 3. Empty goal ===")
(display (intend "" 1))

; ── 4. max-attempts = 0 ──────────────────────────
(display "")
(display "=== 4. max-attempts = 0 ===")
(display (intend "test" 0))

; ── 5. max-attempts = 5（也能跑）─────────────────
(display "")
(display "=== 5. max-attempts = 5 ===")
(display (intend "test" 5))

; ── 6. 作为 EDSL 管线的一部分 ─────────────────────
(display "")
(display "=== 6. With set-code pipeline ===")
(set-code "(intend \"test\" 1)")
(display (eval-current))

; ── 7. 返回格式验证 ──────────────────────────────
(display "")
(display "=== 7. Result format inspection ===")
(let ((r (intend "hello" 1)))
  (display "result type: ")
  (display (type-of r))
  (display "result: ")
  (display r))

(display "")
(display "╔════════════════════════════════════════╗")
(display "║  E1 tests complete                    ║")
(display "╚════════════════════════════════════════╝")
