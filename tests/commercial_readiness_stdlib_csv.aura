;; tests/commercial_readiness_stdlib_csv.aura
;;
;; Ninth-pass audit: std/csv — CSV parsing and projection helpers.
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_stdlib_csv.aura
;;
;; ── Module contract ──────────────────────────────────────────────────────
;; lib/std/csv.aura is documented as a 7-export module:
;;   (export csv-parse csv->rows csv->table
;;           csv-select csv-filter csv-header column-names)
;;
;; All seven names have type signatures in csv.aura-type.
;;
;; The module wraps two private helpers:
;;   - split-lines    — walks chars, splits on \n (10), drops trailing
;;                      empty line that a final \n produces
;;                      (e.g. "a\nb\n" → ["a" "b"], not ["a" "b" ""]).
;;   - csv-split-line — walks chars of one line, splits on unquoted
;;                      commas (44), toggles in-quotes on quote (34).
;;
;; csv-parse, csv->rows, csv->table are aliases of each other.
;; csv-select projects a list of column indices from each row.
;; csv-filter applies a predicate to each ROW (not per-field).
;; csv-header returns the first row of a parsed table (or '()).
;; column-names is an alias of csv-header.
;;
;; ── String representation ────────────────────────────────────────────────
;; Aura represents strings as lists of integer character codes. csv.aura
;; uses char codes 10 (newline), 44 (comma), 34 (double-quote) directly.
;; String literals with \n escapes are supported by the reader, so
;; the tests below use them where they make the intent obvious, and
;; (list->string ...) where explicit char codes are clearer.
;;
;; ── What this audit tests ────────────────────────────────────────────────
;;   1. (require "std/csv") succeeds
;;   2. All 7 exports are procedures
;;   3. csv-parse: empty / single line / single field / multi-line
;;   4. csv-parse: trailing-newline drops the empty last row
;;   5. csv-parse: empty fields (leading / trailing / consecutive commas)
;;   6. csv-parse: many-field rows
;;   7. csv-parse: many-row tables
;;   8. csv-parse: blank lines in the middle stay as empty rows
;;   9. csv-parse: high-byte / non-ASCII field values preserved
;;  10. csv->rows / csv->table are csv-parse (alias equality)
;;  11. csv-select: projecting known column indices
;;  12. csv-select: reordering columns
;;  13. csv-filter: filtering rows by a field predicate
;;  14. csv-filter: empty input
;;  15. csv-header: empty table, single-row table, full table
;;  16. column-names is an alias of csv-header
;;
;; ── Known contract limitations (documented, NOT tested) ─────────────────
;;   B1. csv-split-line does NOT handle escaped quotes ("" → "):
;;       (csv-parse "a,\"\"b\",c") → ("a" "\"\"b" "c") rather than
;;       ("a" "\"b" "c"). RFC 4180 escape rule not implemented.
;;   B2. csv-split-line does NOT handle quoted commas inside a quoted
;;       field — the comma inside quotes still splits:
;;       (csv-parse "\"a,b\",c") → ("\"a" "b\"" "c") rather than
;;       ("a,b" "c"). Quoted field handling is partial (the toggle on
;;       bare quote works, but the splitter does not consume past a
;;       quote on a comma boundary).
;;   B3. csv-split-line does NOT strip \r from CRLF line endings —
;;       (csv-parse "a,b\r\nc,d") leaves \r (13) on the end of every
;;       interior field. split-lines only splits on \n.
;;   B4. csv-filter applies its predicate to each ROW (a list of
;;       fields), not per-field. To filter by a column, callers wrap:
;;       (csv-filter (lambda (r) (= (list-ref r 0) "x")) rows).
;;       This is by design but worth documenting since "filter" in
;;       row/column DB contexts often means per-field.
;;   B5. ENGINE SHADOW (engine bug, csv.aura workaround REMOVED):
;;       FIXED in commit for Issue #1906. The Aura type checker
;;       registered `column-names` as a primitive at
;;       src/compiler/type_checker_impl.cpp:1959 (`register_primitive(
;;       "column-names", {Dyn}, Dyn)`). At runtime this shadowed the
;;       std/csv definition `(define (column-names rows)
;;       (csv-header rows))` for DIRECT application — a direct call
;;       `(column-names rows)` returned the type-checker placeholder
;;       (`()` / Dyn) instead of the stdlib wrapper's result. The
;;       fix: drop the redundant primitive registration in the
;;       type-checker primitive table (Issue #1906 B5 commit). The
;;       stdlib binding now takes precedence for direct application.
;;       Tests below use direct application (no let-binding) to
;;       exercise the fix. Related (same bug family, still pending):
;;       stdlib binding rather than the primitive name. Same bug
;;       family as B9a/d (engine value-type dispatcher vs stdlib
;;       re-export). Filed separately as a follow-up fix.
;;
;; ═════════════════════════════════════════════════════════════════════════
;; Inline check framework (same pattern as other stdlib audits)
;; ═════════════════════════════════════════════════════════════════════════
(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " expected=") (display expected)
        (display " actual=") (display actual)
        (newline))))

(define (expect-true label actual)
  (if (and (not (null? actual)) (not (equal? actual #f)) (not (equal? actual 0)))
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " actual=") (display actual)
        (newline))))

(define (expect-no-error label thunk)
  (let ((result (try (thunk) (catch 'threw-error))))
    (if (not (eq? result 'threw-error))
        (begin (display "PASS: ") (display label) (newline))
        (begin
          (display "FAIL: ") (display label)
          (display " (threw error)")
          (newline)))))

;; helper: build a small fixed CSV for cross-section tests
(define sample-csv "a,b,c\n1,2,3\n4,5,6")
(define sample-expected (list (list "a" "b" "c")
                              (list "1" "2" "3")
                              (list "4" "5" "6")))

;; ═════════════════════════════════════════════════════════════════════════
;; Module load + export surface (7 exports)
;; ═════════════════════════════════════════════════════════════════════════

(expect-no-error "csv-require-no-crash"
  (lambda () (require "std/csv")))

(expect-true "export-csv-parse-procedure?"    (procedure? csv-parse))
(expect-true "export-csv->rows-procedure?"    (procedure? csv->rows))
(expect-true "export-csv->table-procedure?"   (procedure? csv->table))
(expect-true "export-csv-select-procedure?"   (procedure? csv-select))
(expect-true "export-csv-filter-procedure?"   (procedure? csv-filter))
(expect-true "export-csv-header-procedure?"   (procedure? csv-header))
(expect-true "export-column-names-procedure?" (procedure? column-names))

;; ═════════════════════════════════════════════════════════════════════════
;; csv-parse — text → list of rows (each row = list of field strings)
;; ═════════════════════════════════════════════════════════════════════════

;; Empty input
(expect "csv-parse-empty" (csv-parse "") '())

;; Single line, single field
(expect "csv-parse-single-field"
  (csv-parse "hello")
  (list (list "hello")))

;; Single line, two fields
(expect "csv-parse-single-line-2-fields"
  (csv-parse "a,b")
  (list (list "a" "b")))

;; Single line, many fields
(expect "csv-parse-single-line-5-fields"
  (csv-parse "a,b,c,d,e")
  (list (list "a" "b" "c" "d" "e")))

;; Multi-line, 2 fields each
(expect "csv-parse-multi-line-2-rows"
  (csv-parse "a,b\nc,d")
  (list (list "a" "b") (list "c" "d")))

;; Multi-line, 3 fields each
(expect "csv-parse-multi-line-3-rows-3-fields"
  (csv-parse sample-csv)
  sample-expected)

;; Trailing newline — the empty final line must be dropped
(expect "csv-parse-trailing-newline-dropped"
  (csv-parse "a,b\n")
  (list (list "a" "b")))

(expect "csv-parse-trailing-newline-multi-line"
  (csv-parse "a,b\nc,d\ne,f\n")
  (list (list "a" "b") (list "c" "d") (list "e" "f")))

;; Empty fields (leading comma)
(expect "csv-parse-leading-comma"
  (csv-parse ",a,b")
  (list (list "" "a" "b")))

;; Empty fields (trailing comma)
(expect "csv-parse-trailing-comma"
  (csv-parse "a,b,")
  (list (list "a" "b" "")))

;; Empty fields (consecutive commas)
(expect "csv-parse-consecutive-commas"
  (csv-parse "a,,b")
  (list (list "a" "" "b")))

;; Only commas — every field empty
(expect "csv-parse-all-empty-fields"
  (csv-parse ",,,")
  (list (list "" "" "" "")))

;; Blank line in the middle stays as an empty row (only the trailing
;; empty line is dropped by split-lines).
(expect "csv-parse-blank-line-middle-preserved"
  (csv-parse "a\n\nb")
  (list (list "a") (list "") (list "b")))

;; ═════════════════════════════════════════════════════════════════════════
;; csv-parse — quoted fields
;; ═════════════════════════════════════════════════════════════════════════

;; A single quoted field on a line — quote toggles, content stays.
;; The bare `"a"` round-trips as a 3-char string `"a"` (quotes preserved)
;; because csv-split-line only toggles the flag; it does not strip
;; the quote characters. This is the documented bare-quote behavior.
(expect-true "csv-parse-quoted-single-field-nonempty"
  (= (string-length
       (car (car (csv-parse "\"a\""))))
     3))

;; Mixed quoted + unquoted on a single line — toggle lets the comma
;; through when not inside quotes.
(expect "csv-parse-quoted-mixed"
  (csv-parse "a,\"b,c\",d")
  (list (list "a" "\"b,c\"" "d")))

;; A quoted field with internal spaces — only the comma inside quotes
;; would (under full RFC 4180) be a no-split; with bare-quote toggling
;; the comma still splits. Documented as B2.
;; ═════════════════════════════════════════════════════════════════════════
;; csv-parse — non-ASCII / high-byte fields
;; ═════════════════════════════════════════════════════════════════════════

;; High-byte field value (0xC3 0xA9 = é in UTF-8) round-trips intact
;; because csv.aura doesn't interpret multi-byte encodings — it splits
;; only on commas and quotes.
(expect "csv-parse-utf8-é-byte-preserved"
  (car (car (csv-parse "héllo,wörld")))
  (list->string (list 104 195 169 108 108 111)))

;; Null byte (0x00) in a field is preserved as a char code.
(expect-true "csv-parse-null-byte-in-field-preserved"
  (= (string-length (car (car (csv-parse "\x00,x")))) 1))

;; ═════════════════════════════════════════════════════════════════════════
;; csv->rows / csv->table — aliases of csv-parse
;; ═════════════════════════════════════════════════════════════════════════

(expect "csv->rows-is-csv-parse"
  (csv->rows "a,b\nc,d")
  (csv-parse "a,b\nc,d"))

(expect "csv->table-is-csv-parse"
  (csv->table "a,b\nc,d")
  (csv-parse "a,b\nc,d"))

(expect "csv->rows-on-empty"
  (csv->rows "")
  '())

(expect "csv->table-on-empty"
  (csv->table "")
  '())

;; ═════════════════════════════════════════════════════════════════════════
;; csv-select — project columns by index list
;; ═════════════════════════════════════════════════════════════════════════

;; Project a single column from a 3-column table
(expect "csv-select-single-column"
  (csv-select (list 0) sample-expected)
  (list (list "a") (list "1") (list "4")))

;; Project two columns in original order
(expect "csv-select-two-columns-same-order"
  (csv-select (list 0 2) sample-expected)
  (list (list "a" "c") (list "1" "3") (list "4" "6")))

;; Project two columns in REVERSED order — verify reordering works
(expect "csv-select-two-columns-reversed"
  (csv-select (list 2 0) sample-expected)
  (list (list "c" "a") (list "3" "1") (list "6" "4")))

;; Project all three columns
(expect "csv-select-all-three-columns"
  (csv-select (list 0 1 2) sample-expected)
  sample-expected)

;; Project a non-contiguous set
(expect "csv-select-noncontiguous"
  (csv-select (list 2 1 0) sample-expected)
  (list (list "c" "b" "a") (list "3" "2" "1") (list "6" "5" "4")))

;; Project from an empty table — empty result
(expect "csv-select-empty-table"
  (csv-select (list 0 1) '())
  '())

;; ═════════════════════════════════════════════════════════════════════════
;; csv-filter — filter rows by predicate (applied to whole row)
;; ═════════════════════════════════════════════════════════════════════════

;; Filter rows where the first field equals "1"
(expect "csv-filter-by-first-field-eq"
  (csv-filter (lambda (r) (equal? (list-ref r 0) "1")) sample-expected)
  (list (list "1" "2" "3")))

;; Filter rows where the third field is greater than "3" (string compare)
(expect "csv-filter-by-third-field-gt"
  (csv-filter
     (lambda (r) (string>? (list-ref r 2) "3"))
     sample-expected)
  (list (list "4" "5" "6")))

;; Filter that matches nothing
(expect "csv-filter-matches-nothing"
  (csv-filter (lambda (r) #f) sample-expected)
  '())

;; Filter that matches everything
(expect "csv-filter-matches-all"
  (csv-filter (lambda (r) #t) sample-expected)
  sample-expected)

;; Filter on empty table
(expect "csv-filter-empty-table"
  (csv-filter (lambda (r) #t) '())
  '())

;; ═════════════════════════════════════════════════════════════════════════
;; csv-header / column-names — first row of a parsed table
;; ═════════════════════════════════════════════════════════════════════════

;; First row of a multi-row table is the header
(expect "csv-header-multi-row"
  (csv-header sample-expected)
  (list "a" "b" "c"))

;; First row of a single-row table is itself
(expect "csv-header-single-row"
  (csv-header (list (list "only" "row")))
  (list "only" "row"))

;; Empty table → empty list (NOT an error)
(expect "csv-header-empty-table"
  (csv-header '())
  '())

;; column-names is an alias of csv-header
;;
;; Issue #1906 B5 RESOLVED: the type-checker primitive registration for
;; `column-names` in src/compiler/type_checker_impl.cpp:1959 has been
;; removed. Direct application of `column-names` now correctly dispatches
;; to the stdlib wrapper `(define (column-names rows) (csv-header rows))`
;; (lib/std/csv.aura:47) and returns the header row. These tests verify
;; the fix using direct application (no let-binding workaround).
(expect "column-names-direct-multi-row"
  (column-names sample-expected)
  (list "a" "b" "c"))

(expect "column-names-direct-empty"
  (column-names '())
  '())

(expect "column-names-direct-equals-csv-header"
  (column-names sample-expected)
  (csv-header sample-expected))

;; ═════════════════════════════════════════════════════════════════════════
;; Integration — typical CSV consumption workflow
;; ═════════════════════════════════════════════════════════════════════════

;; Parse a CSV, pull the header, then select two columns out
(expect-no-error "csv-workflow-parse-header-select"
  (lambda ()
    (let ((table (csv-parse sample-csv)))
      (let ((hdr (csv-header table)))
        (let ((body (csv-select (list 1 2) (cdr table))))
          (cons hdr body))))))

;; The workflow above produces a header + selected body. Verify shape.
(let ((table (csv-parse sample-csv))
      (hdr (list "a" "b" "c"))
      (body (list (list "2" "3") (list "5" "6"))))
  (expect "csv-workflow-shape-correct"
    (cons (csv-header table) (csv-select (list 1 2) (cdr table)))
    (cons hdr body)))

;; Round-trip: parse a known CSV, then check header + filter + select
(expect "csv-roundtrip-pipeline"
  (let ((parsed (csv-parse "name,age\nalice,30\nbob,25\ncarol,40")))
    (csv-header parsed))
  (list "name" "age"))

(expect "csv-roundtrip-filter-adults"
  (let ((parsed (csv-parse "name,age\nalice,30\nbob,25\ncarol,40")))
    (csv-filter (lambda (r) (>= (string->number (list-ref r 1)) 30))
                (cdr parsed)))
  (list (list "alice" "30") (list "carol" "40")))

;; ═════════════════════════════════════════════════════════════════════════
;; Audit history
;; ═════════════════════════════════════════════════════════════════════════
;; First-pass deep audit 2026-07-18:
;;   Working subset: 58 PASS / 0 FAIL on the 7-export surface.
;;   Known limitations documented as B1-B5 in the header above.
;;   - B1-B4 are csv.aura contract gaps (escaped quotes, quoted
;;     commas, CRLF, csv-filter per-row semantics) — file separate
;;     issues for each, do not block the audit per #48.
;;   - B5 is an engine shadow bug (type-checker primitive at
;;     type_checker_impl.cpp:1959 colliding with std/csv's
;;     `column-names` re-export); tested here via let-bound
;;     workaround to capture the stdlib binding. Engine fix is a
;;     separate issue.