;; === safe_refactor_test.aura ===
;; Tests for std/safe-refactor (Issue #96 Action 2)

(require std/safe-refactor all:)

;; Test 1: with-snapshot success case (thunk returns int)
(define r1 (safe-refactor:with-snapshot "test-1" (lambda () 42)))
;; expect r1: 42

;; Test 2: with-snapshot rollback case (thunk raises)
(define r2 (safe-refactor:with-snapshot "test-2" (lambda () (error "boom"))))
;; expect r2: (rolled-back "error-raised")

;; Test 3: with-snapshot explicit fail
(define r3 (safe-refactor:with-snapshot "test-3" (lambda () 'fail)))
;; expect r3: (rolled-back "explicit-fail")

;; Test 4: with-snapshot returns list (thunk returns list)
(define r4 (safe-refactor:with-snapshot "test-4" (lambda () (list 1 2 3))))
;; expect r4: (1 2 3)

;; Test 5: check-and-apply — pre-verify fails
(define r5
  (safe-refactor:check-and-apply
    (lambda () #f)
    (lambda () #t)
    (lambda () 'never)))
;; expect r5: (rejected "pre-verify-failed")

;; Test 6: check-and-apply — post-verify fails
(define r6
  (safe-refactor:check-and-apply
    (lambda () #t)
    (lambda () #f)
    (lambda () 'applied)))
;; expect r6: (rolled-back "post-verify-failed")

;; Test 7: check-and-apply — all pass
(define r7
  (safe-refactor:check-and-apply
    (lambda () #t)
    (lambda () #t)
    (lambda () 'success)))
;; expect r7: (applied success)

;; Test 8: with-snapshot returns string
(define r8 (safe-refactor:with-snapshot "test-8" (lambda () "hello")))
;; expect r8: hello

;; Output
(display r1) (newline)
(display r2) (newline)
(display r3) (newline)
(display r4) (newline)
(display r5) (newline)
(display r6) (newline)
(display r7) (newline)
(display r8) (newline)
;; expect:
;; 42
;; (rolled-back error-raised)
;; (rolled-back explicit-fail)
;; (1 2 3)
;; (rejected pre-verify-failed)
;; (rolled-back post-verify-failed)
;; (applied success)
;; hello
