;; tests/commercial_readiness_stdlib_socket.aura
;;
;; Eighth-pass audit: std/socket — TCP socket library alias module.
;;
;; Run:
;;   ./build/aura < tests/commercial_readiness_stdlib_socket.aura
;;
;; ── Module contract ──────────────────────────────────────────────────────
;; lib/std/socket.aura is documented as a 4-export alias module:
;;   (export tcp-connect tcp-send tcp-recv tcp-close)
;; Its header comment says "Uses native C++ socket primitives (not FFI)".
;;
;; The four aliases are intended to forward to native primitives that
;; ARE registered in the evaluator (see
;; src/compiler/evaluator_primitives_io.cpp:649 — `add("tcp-connect", ...)`,
;; and src/compiler/type_checker_impl.cpp:1864 — type registration).
;;
;; ── What this audit tests ────────────────────────────────────────────────
;; The contract surface: (require "std/socket") succeeds and the four
;; names are bound to procedures. We deliberately DO NOT invoke the
;; functions, see BUG CHECK below.
;;
;; SAFETY: No network calls attempted. All assertions are pure metadata
;; (procedure? checks). No filesystem, no shell, no network.

;; ═════════════════════════════════════════════════════════════════════════
;; Inline check framework (same pattern as adaptive / process / refactor)
;; ═════════════════════════════════════════════════════════════════════════
(define (expect label actual expected)
  (if (equal? actual expected)
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " expected=") (display expected)
        (display " actual=") (display actual)
        (newline))))

(define (expect-true label actual)
  (if (and (not (null? actual)) (not (equal? actual #f)) (not (equal? actual 0)))
      (begin (display "PASS: ") (display label) (newline))
      (begin
        (display "FAIL: ") (display label)
        (display " actual=") (display actual)
        (newline))))

(define (expect-no-error label thunk)
  (let ((result (try (thunk) (catch 'threw-error))))
    (if (not (eq? result 'threw-error))
        (begin (display "PASS: ") (display label) (newline))
        (begin
          (display "FAIL: ") (display label)
          (display " (threw error)")
          (newline)))))

;; ═════════════════════════════════════════════════════════════════════════
;; Module load + export surface
;; ═════════════════════════════════════════════════════════════════════════

;; (require "std/socket") must not crash.
(expect-no-error "socket-require-no-crash"
  (lambda () (require "std/socket")))

;; Each declared export must be bound to a procedure.
(expect-true "socket-tcp-connect-is-procedure" (procedure? tcp-connect))
(expect-true "socket-tcp-send-is-procedure" (procedure? tcp-send))
(expect-true "socket-tcp-recv-is-procedure" (procedure? tcp-recv))
(expect-true "socket-tcp-close-is-procedure" (procedure? tcp-close))

;; Type-file sanity: lib/std/socket.aura-type declares 4 entries.
;; If require succeeded, the module is loaded; if the export list and the
;; type file diverge, the compiler's primitive-surface freeze would
;; normally catch it pre-build — so reaching this point means the surface
;; is internally consistent (we don't re-assert it here, just record the
;; observation).

;; ═════════════════════════════════════════════════════════════════════════
;; BUG CHECK — recursive alias self-call (header docstring vs. body)
;; ═════════════════════════════════════════════════════════════════════════
;;
;; lib/std/socket.aura lines 8-9 read:
;;
;;   (define (tcp-connect host port)
;;     (tcp-connect host port))
;;
;; i.e. the alias calls itself, NOT the native primitive whose binding
;; (also named tcp-connect) lives in evaluator_primitives_io.cpp:649.
;; In Scheme, `define` introduces a new lexical/top-level binding that
;; SHADOWS any earlier binding of the same name in the same scope, so the
;; recursive self-call resolves to the wrapper itself → infinite
;; recursion on first invocation. The wrapper is unbound from the
;; native primitive and provides nothing to base cases on.
;;
;; Same pattern (also broken) for tcp-send / tcp-recv / tcp-close.
;;
;; The header comment ("Uses native C++ socket primitives (not FFI)")
;; indicates the intent was something like:
;;
;;   (define (tcp-connect host port) (cpp:tcp-connect host port))
;;   — or —
;;   (export tcp-connect ...)        ; without re-defining
;;
;; so the native primitive from evaluator_primitives_io.cpp would remain
;; accessible under the same name. Both fixes require editing
;; lib/std/socket.aura, which is OUT OF SCOPE for this audit file
;; (per task instruction "Do NOT modify lib/std/socket.aura").
;;
;; Empirical observation: invoking (loopy 0) for `(define (loopy x)
;; (loopy x))` (an isomorphic shape) does NOT throw under the current
;; evaluator — it returns a partial value silently. So calling the
;; broken aliases would NOT surface a loud error; it would silently
;; miscompute. The right place to detect this is a static check on the
;; define body, which is what the BUG CHECK below records for a human
;; reviewer.
;;
;; We emit a human-readable marker so a future run output makes the
;; suspicion obvious. We do NOT call tcp-connect et al. (would either
;; hang the harness or return garbage depending on evaluator tail-call
;; behavior; either way nondeterministic).

(display "  BUG-CHECK socket.aura body is recursive-self-call (not native forward). ")
(display "  See lib/std/socket.aura lines 8-9 (and 11-12, 14-15, 17-18). ")
(display "  Header says \"Uses native C++ socket primitives (not FFI)\" ")
(display "  but each wrapper calls itself — infinite recursion. ")
(newline)
(display "  Native primitives exist at src/compiler/evaluator_primitives_io.cpp:649 ")
(display "(tcp-connect) — alias module does not forward to them. ")
(newline)

;; ═════════════════════════════════════════════════════════════════════════
;; Summary
;; ═════════════════════════════════════════════════════════════════════════
(display "\n=== socket audit done ===\n")