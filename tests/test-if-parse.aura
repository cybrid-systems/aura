;; === test-if-parse.aura — if 解析器边缘情况测试 ===
;; 覆盖 parse_if 修复：多余参数自动包装为 begin 作为 else 分支

(define passed 0)
(define failed 0)

(define (chk a e m)
  (if (equal? a e)
      (begin (set! passed (+ passed 1))
             (display "[PASS] ") (display m) (newline))
      (begin (set! failed (+ failed 1))
             (display "[FAIL] ") (display m)
             (display " exp=") (display e)
             (display " got=") (display a) (newline))))

(define (msg v) (display v) v)

;; ── 1. if 标准 3 参数（基线） ──
(display "--- 1. standard if (3 args) ---\n")
(chk (if #t 1 2) 1 "if #t then else")
(chk (if #f 1 2) 2 "if #f then else")
(chk (if (< 3 5) "yes" "no") "yes" "if (< 3 5) → yes")
(chk (if (> 3 5) "yes" "no") "no" "if (> 3 5) → no")

;; ── 2. if without else ──
(display "--- 2. if without else ---\n")
(chk (if #t 42) 42 "if #t without else")
(define if-true (if #t "executed"))
(chk if-true "executed" "if #t executed (top-level)")
(define if-false (if #f "skipped"))
(chk (void? if-false) #t "if #f returns void")

;; ── 3. if with 4 args (fix core scenario) ──
(display "--- 3. if with 4+ args ---\n")
(chk (if #f 1 2 3) 3 "if #f 4arg: else-begin returns last")
(chk (if #t 1 2 3) 1 "if #t 4arg: then=1, extra ignored")
(define x 0)
(if #t (set! x 10) (set! x 20) (set! x 30))
(chk x 10 "if #t 4arg: executes then")
(if #f (set! x 0) (set! x 1) (set! x 2))
(chk x 2 "if #f 4arg: else-begin(1 2) returns last(2)")
(chk (if #f 1 (+ 2 3) (+ 4 5)) 9 "if 4arg #f: else-begin sums")
(chk (if #t 1 (+ 2 3) (+ 4 5)) 1 "if 4arg #t: then=1")
(chk (if #f 1 2 3 4 5) 5 "if 6arg: else-begin returns last")
(chk (if #t 1 2 3 4 5) 1 "if 6arg #t: then=1")

;; ── 4. if in define function body (pre-fix core bug) ──
(display "--- 4. if in define function body ---\n")
(define (f1) (if #t 10 20 30) 40)
(chk (f1) 40 "f1: body continues after if 4arg")
(define (f2) (if #f "a" "b" "c") "after")
(chk (f2) "after" "f2: body after if #f multi-else")
(define (f3)
  (msg "A")
  (if #t (msg "B") (msg "C") (msg "D") (msg "E"))
  (msg "F"))
(chk (f3) "F" "f3: if 6arg, body after works")

;; ── 5. if embedded in let ──
(display "--- 5. if in let ---\n")
(chk (let ((x 10)) (if #f x (+ x 1) (+ x 2))) 12 "if #f 4arg in let: else-begin(+1 +2)=12")
(chk (let ((x 10)) (if #t x (+ x 1) (+ x 2))) 10 "if #t 4arg in let: then=x=10")

;; ── 6. if in closure (lambda) ──
(display "--- 6. if in closure ---\n")
(chk (((lambda (pick?) (lambda (a b) (if pick? a b (string-append a b)))) #t) "x" "y") "x" "inline closure #t")
(chk (((lambda (pick?) (lambda (a b) (if pick? a b (string-append a b)))) #f) "x" "y") "xy" "inline closure #f")

;; ── 7. nested if ──
(display "--- 7. nested if ---\n")
(chk (if #t (if #f 1 2 3) 4) 3 "nested: outer#t inner#f 4arg → else-begin(2 3)=3")
(chk (if #f 1 (if #t 2 3 4) 5) 5 "nested: outer#f inner#t 4arg → else-begin(3 4 5)")

;; ── 8. if with complex conditions ──
(display "--- 8. if with complex conditions ---\n")
(chk (if (equal? "a" "a") (+ 1 2) (+ 3 4) (+ 5 6)) 3 "complex cond #t: then=3")
(chk (if (equal? "a" "b") (+ 1 2) (+ 3 4) (+ 5 6)) 11 "complex cond #f: else-begin 3+4+5+6=11")

;; ── 9. if + side effects (the fix should not break existing if) ──
(display "--- 9. if with side effects ---\n")
(define acc '())
(define (push! v) (set! acc (cons v acc)) v)
;; if #t: then=(push! "b") executes; else-begin=(push! "c")(push! "d")(push! "e") does NOT
(if #t (push! "b") (push! "c") (push! "d") (push! "e"))
(chk (reverse acc) '("b") "if #t 6arg: only then executed")
;; if #f: then does NOT; else-begin=(push! "x")(push! "y") executes both
(if #f (push! "skip") (push! "x") (push! "y"))
(chk (reverse acc) '("b" "x" "y") "if #f 6arg: else-begin executes both")

;; ── 10. if in while / letrec (regression) ──
(display "--- 10. regression: while + letrec + equal? ---\n")
(define i 0)
(while (< i 3)
  (set! i (+ i 1)))
(chk i 3 "while loop regression")
(chk (equal? "hello" "hello") #t "equal? string regression")
(chk (equal? (list 1 2) (list 1 2)) #t "equal? pair regression")
(define n 0)
(set! n 42)
(chk n 42 "set! literal regression")
(chk (and #f 99) #f "and short-circuit regression")

;; ── 结果 ──
(newline)
(display "=== Results: ") (display passed) (display " passed, ")
(display failed) (display " failed") (newline)
