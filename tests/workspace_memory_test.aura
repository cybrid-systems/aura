;; === workspace_memory_test.aura ===
;; Tests for Issue #97 Action 3: per-workspace memory isolation

;; Setup: create a workspace tree
(workspace:create "ws1")

;; Test 1: primitives exist
(display (procedure? workspace:memory-used)) (newline)
(display (procedure? workspace:memory-limit)) (newline)
(display (procedure? workspace:set-memory-limit)) (newline)
(display (procedure? workspace:cow-refused-count)) (newline)

;; Test 2: default limit is -1 (unlimited)
(display (workspace:memory-limit)) (newline)

;; Test 3: default used is 0
(display (workspace:memory-used)) (newline)

;; Test 4: set-memory-limit accepts a value
(display (workspace:set-memory-limit 1048576)) (newline)

;; Test 5: after setting, limit returns the value
(display (workspace:memory-limit)) (newline)

;; Test 6: set-memory-limit 0 means unlimited
(display (workspace:set-memory-limit 0)) (newline)
(display (workspace:memory-limit)) (newline)

;; Test 7: set-memory-limit with negative value fails
(display (workspace:set-memory-limit -1)) (newline)

;; Test 8: create child workspace, budget is also 0 by default
(workspace:create "ws2")
(display (workspace:memory-limit)) (newline)

;; Test 9: set budget on ws2
(display (workspace:set-memory-limit 1024)) (newline)
(display (workspace:memory-limit)) (newline)

;; Test 10: switching back to ws1 keeps its budget
(workspace:switch 0)
(display (workspace:memory-limit)) (newline)
