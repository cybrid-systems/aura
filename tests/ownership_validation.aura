; ── Ownership Validation Test Suite ──────────────────────────
;
; Tests the ownership validation pass (Issue #37):
;   - ast:validate-ownership primitive
;   - Post-mutation ownership re-validation
;   - Ownership dirty tracking
;
; Run: ./aura < tests/ownership_validation.aura

(require std/test all:)

(display "═══ Ownership Validation Test Suite ═══\n")
(newline)

(define total-pass 0)
(define total-fail 0)

(define (report name ok)
  (display "  ")
  (display name)
  (display ": ")
  (if ok
    (begin (display "✅\n") (set! total-pass (+ total-pass 1)))
    (begin (display "❌\n") (set! total-fail (+ total-fail 1))))
  ok)

; Helper: run ast:validate-ownership, return #t if :pass is true
; result is alist: ((:pass . bool) (:notes . (...)))
(define (validate-pass?)
  (let* ((result (ast:validate-ownership))
         (pass-entry (car result)))
    (if (pair? pass-entry)
      (cdr pass-entry)
      #f)))

; Helper: extract notes from ast:validate-ownership result
(define (validate-notes)
  (let* ((result (ast:validate-ownership))
         (rest (cdr result))
         (notes-entry (if (pair? rest) (car rest) '())))
    (if (pair? notes-entry) (cdr notes-entry) '())))

; ── 1. Empty / trivial workspace ──
(newline)
(display "── 1. No ownership ops ──\n")

(set-code "(define (f x) (+ x 1))")
(report "no-ownership-ops-pass" (validate-pass?))

; ── 2. Single move ──
(newline)
(display "── 2. Single move ──\n")

(set-code "
(define (make-resource) 42)
(define (test-move)
  (let ((x (make-resource)))
    (move x)))
")
(report "single-move-pass" (validate-pass?))

; ── 3. Single borrow ──
(newline)
(display "── 3. Single borrow ──\n")

(set-code "
(define (make-resource) 42)
(define (test-borrow)
  (let ((x (make-resource)))
    (borrow x)))
")
(report "single-borrow-pass" (validate-pass?))

; ── 4. Single mut-borrow ──
(newline)
(display "── 4. Single mutable borrow ──\n")

(set-code "
(define (make-resource) 42)
(define (test-mut-borrow)
  (let ((x (make-resource)))
    (&mut x)))
")
(report "single-mut-borrow-pass" (validate-pass?))

; ── 5. Single drop ──
(newline)
(display "── 5. Single drop ──\n")

(set-code "
(define (make-resource) 42)
(define (test-drop)
  (let ((x (make-resource)))
    (drop x)))
")
(report "single-drop-pass" (validate-pass?))

; ── 6. Mutate:rebind triggers ownership validation ──
(newline)
(display "── 6. Post-mutation re-validation ──\n")

(set-code "
(define (make-resource) 42)
(define (test-own)
  (let ((x (make-resource)))
    (move x)))
")
(report "mutate-rebind-preserves-ownership"
  (begin
    (mutate:rebind "test-own"
      "(lambda (x) (move x))")
    ; After rebind, validate should still pass
    (validate-pass?)))

; ── 7. Mutate:set-body triggers ownership validation ──
(newline)
(display "── 7. Post-set-body validation ──\n")

(set-code "
(define (make-resource) 42)
(define (test-own y)
  (+ y 1))
")
(report "mutate-set-body-ownership"
  (begin
    (mutate:set-body "test-own"
      "(let ((x (make-resource))) (move x))")
    (validate-pass?)))

; ── 8. Ownership dirty tracking ──
(newline)
(display "── 8. Ownership env after mutation ops ──\n")

(set-code "
(define (make-resource) 42)
(define (use-resource r) (+ r 1))
")
(report "clean-after-mutation"
  (begin
    ; Apply a mutation via query-and-fix
    ; This validates that the dirty-tracking functions don't crash
    (mutate:rebind "use-resource"
      "(lambda (r) (let ((x (make-resource))) (move x) (+ r 1)))")
    (validate-pass?)))

; ── 9. Empty flat AST ──
(newline)
(display "── 9. Edge cases ──\n")

(set-code "(define (empty-fn) 42)")
(report "empty-flat-ast" (validate-pass?))

; ── 10. Nested ownership ops ──
(newline)
(display "── 10. Nested scopes ──\n")

(set-code "
(define (make-resource) 42)
(define (test-nested)
  (let ((x (make-resource)))
    (let ((y (make-resource)))
      (move x)
      (move y))))
")
(report "nested-scope-pass" (validate-pass?))

; ── 11. Ownership ops in define body only ──
(newline)
(display "── 11. Define body with move ──\n")

(set-code "
(define x
  (let ((r 42))
    (move r)))
")
(report "define-body-move" (validate-pass?))

; ── Results ──
(newline)
(display "═══ Results ═══\n")
(display total-pass)(display " passed, ")(display total-fail)(display " failed\n")

(if (= total-fail 0)
  (display "✅ All ownership validation tests passed!\n")
  (begin (display "❌ ")(display total-fail)(display " test(s) failed\n")))
