;; === auto_evolve_test.aura ===
;; Tests for Issue #97 Action 2: auto-evolve primitives

;; === LIMITATION ===
;; (auto-evolve-once ...) works correctly — calls the closures inline.
;; (auto-evolve-loop ...) + (auto-evolve-tick ...) have a limitation: the
;; closure IDs stored at loop-start time may not remain valid for tick
;; (the runtime's closure map is per-evaluation). This is a known
;; limitation; the primitive plumbing is correct but the tree-walker's
;; closure lifecycle needs work to support multi-cycle loops.
;;
;; For now, the tests verify primitive existence, the once-mode cycle
;; (which works inline), and the state-management primitives
;; (running?, stop, cycle-count, total-fixed).

;; Define helpers (work with string=?, not eq?, because eq? on symbols
;; is currently broken — see #95 if you want to fix that).
(define (my-detect)
  (list (list "hot-key" "k1" 100) (list "slow" "k2")))

(define (my-fix gap)
  (cond
    ((string=? (car gap) "hot-key")
     #t)
    (#t #f)))

;; Test 1: auto-evolve-once with valid closures (works inline)
(define r1 (auto-evolve-once my-detect my-fix))
(display "r1=") (display r1) (newline)  ; 1

;; Test 2: cycle count starts at 0
(display "cycles=") (display (auto-evolve-cycle-count)) (newline)  ; 0
(display "fixed=") (display (auto-evolve-total-fixed)) (newline)  ; 0

;; Test 3: primitives exist
(display (procedure? auto-evolve-loop)) (newline)  ; #t
(display (procedure? auto-evolve-tick)) (newline)  ; #t
(display (procedure? auto-evolve-stop)) (newline)  ; #t
(display (procedure? auto-evolve-running?)) (newline)  ; #t

;; Test 4: stop when not running is #f
(display (auto-evolve-stop)) (newline)  ; #f

;; Test 5: running? when not running is #f
(display (auto-evolve-running?)) (newline)  ; #f
