;; === contracts_test.aura ===
;; Issue #83: verify C++26 native `contract_assert` works.
;;
;; Aura uses the C++26 standard `contract_assert()` statement (in
;; <contracts>) for runtime contract enforcement, hooked to a custom
;; `handle_contract_violation` in src/core/contract_handler.cpp that
;; prints "contract violation" and aborts.
;;
;; GCC 16.1 supports `contract_assert` but does NOT yet parse the
;; `[[pre: expr]]` / `[[post: expr]]` attribute syntax. We express
;; pre/post intent via `// pre:` / `// post:` comments above the
;; assertion. Migrate to attribute form when GCC 17+ / clang 20+ lands.
;;
;; Note: the contracts being tested here are C++-level contracts on
;; Aura's evaluator (e.g. copy_env in evaluator_impl.cpp), not
;; Aura-level contracts. This test verifies the C++ machinery
;; doesn't break normal Aura code execution.

;; Test 1: function call exercises copy_env (which has a pre-condition
;; that the target arena or main arena_ is non-null). If we got here,
;; the pre-condition passed.
(define (divide x y)
  (if (= y 0) 0
      (/ x y)))

(display (divide 10 2))  ; → 5
(newline)

;; Test 2: nested function calls — each call goes through copy_env
(define total 0)
(define (accumulate n)
  (if (<= n 0) total
      (begin
        (set! total (+ total n))
        (accumulate (- n 1)))))

(accumulate 10)  ; → 55
(display total)
(newline)

;; Test 3: closure creation also exercises copy_env
(define (make-adder base)
  (lambda (x) (+ x base)))
(define add10 (make-adder 10))
(display (add10 5))  ; → 15
(newline)

(display "✅ PASS: contract_assert on C++ hot path doesn't break normal usage\n")
