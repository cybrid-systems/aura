                if (slot >= primitives_.slot_count()) return make_void();
                auto prim = primitives_.lookup(primitives_.name_for_slot(slot));
                if (!prim) return make_void();
                return (*prim)({arg});
            }
            if (is_closure(fn)) {
                auto cid = as_closure_id(fn);
                auto result = apply_closure(cid, {arg});
