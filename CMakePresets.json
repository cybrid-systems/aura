{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Debug (Ninja, GCC 16)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release (Ninja, GCC 16)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "macos",
            "displayName": "macOS Debug (Ninja, Homebrew GCC 16)",
            "description": "Builds the core evaluator + REPL on macOS. serve-async (fiber scheduler) is disabled because macOS lacks eventfd/epoll. Requires: brew install gcc@16 cmake ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-mac",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "gcc-16",
                "CMAKE_CXX_COMPILER": "g++-16"
            }
        },
        {
            "name": "macos-release",
            "displayName": "macOS Release (Ninja, Homebrew GCC 16)",
            "description": "Builds the core evaluator + REPL on macOS. serve-async (fiber scheduler) is disabled because macOS lacks eventfd/epoll. Requires: brew install gcc@16 cmake ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-mac",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "gcc-16",
                "CMAKE_CXX_COMPILER": "g++-16"
            }
        },
        {
            "name": "asan",
            "displayName": "AddressSanitizer (Debug, Ninja, GCC 16) — Issue #299",
            "description": "AddressSanitizer-instrumented build. Use for memory safety: UAF, double-free, OOB, leaks. Pairs with: cmake --build --preset asan",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_asan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "CMAKE_CXX_FLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address",
                "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address"
            }
        },
        {
            "name": "ubsan",
            "displayName": "UndefinedBehaviorSanitizer (Debug, Ninja, GCC 16) — Issue #299",
            "description": "UBSan-instrumented build. Use for UB detection: signed overflow, shift OOB, null deref, type confusion, vptr. Pairs with: cmake --build --preset ubsan",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_ubsan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-fsanitize=undefined -fno-omit-frame-pointer",
                "CMAKE_CXX_FLAGS": "-fsanitize=undefined -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=undefined",
                "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=undefined"
            }
        },
        {
            "name": "repro",
            "displayName": "Reproducible Release (Ninja, GCC 16) — Issue #675",
            "description": "Hermetic Release build with SOURCE_DATE_EPOCH, prefix maps, fixed random seed, and --build-id=none. Pairs with: ./build.py repro",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_repro",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_FLAGS": "-ffile-prefix-map=${sourceDir}=. -fdebug-prefix-map=${sourceDir}=. -frandom-seed=aura-repro-675 -g0",
                "CMAKE_CXX_FLAGS": "-ffile-prefix-map=${sourceDir}=. -fdebug-prefix-map=${sourceDir}=. -frandom-seed=aura-repro-675 -g0",
                "CMAKE_EXE_LINKER_FLAGS": "-Wl,--build-id=none",
                "CMAKE_SHARED_LINKER_FLAGS": "-Wl,--build-id=none"
            },
            "environment": {
                "SOURCE_DATE_EPOCH": "1704067200",
                "CCACHE_DISABLE": "1"
            }
        },
        {
            "name": "tsan",
            "displayName": "ThreadSanitizer (Debug, Ninja, GCC 16) — Issue #299",
            "description": "ThreadSanitizer-instrumented build. Use for data race detection in fibers and concurrent mutate/query. -O0 forced (TSan produces false positives at -O2/-O3). Incompatible with ASan. Pairs with: cmake --build --preset tsan",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_tsan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
                "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
                "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=thread"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "macos",
            "configurePreset": "macos"
        },
        {
            "name": "macos-release",
            "configurePreset": "macos-release"
        },
        {
            "name": "asan",
            "configurePreset": "asan"
        },
        {
            "name": "ubsan",
            "configurePreset": "ubsan"
        },
        {
            "name": "tsan",
            "configurePreset": "tsan"
        },
        {
            "name": "repro",
            "configurePreset": "repro"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "macos",
            "configurePreset": "macos"
        }
    ]
}
