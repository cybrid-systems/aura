# Build context exclusions (reduces image build time + attack surface).
# Matches the patterns in .gitignore that shouldn't leak into Docker.
.git/
.gitignore
.github/
.githooks/

# Build outputs — never needed inside the container.
build/
build_repro/
build_asan/
build_ubsan/
build_tsan/
build_dbg/
build_gdb/
build_o0/
build_rel/
compiled/
gcm.cache/

# Editor / OS junk
*.swp
*.swo
.DS_Store
.vscode/
.idea/

# Local env / secrets (never bake into images)
.env
.env.*
*.pem
*.key

# Test artifacts + logs (not runtime needs)
*.log
*.tmp
test-results/
.cache/
__pycache__/
*.pyc

# Docker meta (recursive prevention)
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Docs / design notes (not runtime needs)
docs/
*.md
LICENSE